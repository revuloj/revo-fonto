<?xml version="1.0"?>
<!DOCTYPE vortaro SYSTEM "../dtd/vokoxml.dtd">
<vortaro>
<art mrk="$Id: arakid.xml,v 1.40 2026/06/22 18:19:36 revo Exp $">
<kap>
  <rad>arakid</rad>/o <fnt><bib>PV</bib></fnt>,
  <var><kap><rad var="&hcirc;">ara&hcirc;id</rad>/o</kap></var>
</kap>

<drv mrk="arakid.0o">
  <kap><tld/>o, <var><kap><tld var="&hcirc;"/>o</kap></var></kap>
  <snc mrk="arakid.0o.BOT">
    <uzo tip="fak">BOT</uzo>
    <dif>
      <ref tip="lst" cel="genr.0o.BIO" lst="voko:botanikaj_genroj">Genro</ref> el familio <ref
      tip="malprt" cel="fabac.0oj">fabacoj</ref>
      (<trd lng="la">Arachis</trd>);
      <ref tip="lst" cel="herb.0o" lst="voko:faboparencoj">herbo</ref>,
      kies oleri&ccirc;aj <ref tip="prt" cel="gusx.0o">gu&scirc;oj</ref> maturi&gcirc;as
      en la tero:
      <ekz>
        <klr>[en]</klr> la rakonto pri diablo kaj terkulturisto <klr>[&#8230;]</klr> ili
        dividas rikolton je supra&jcirc;oj kaj malsupra&jcirc;oj, kaj komence la diablo ricevas
        supra&jcirc;ojn de <tld/>oj kaj poste malsupra&jcirc;ojn de maizo
        <fnt>
          <bib>Monato</bib>
          <aut>Nikolao Gudskov</aut>
          <vrk><url ref="&Monato;/2007/009009.php">Ruza leporo kaj &ccirc;iuj aliaj</url></vrk>
        </fnt>.
      </ekz>
    </dif>
    <bld lok="&WCU;/thumb/b/be/Arachis_pintoi.jpg/330px-Arachis_pintoi.jpg" prm="PD">floroj kaj
    folioj de <tld/>o (Arachis pintoi), Insulo Borneo
        <fnt>
          <aut>Lordtct, propra verko</aut>
          <lok><url ref="&WCW;/File:Arachis_pintoi.jpg">&WCW;/File:Arachis_pintoi.jpg</url></lok>
        </fnt>
    </bld>
    <trd lng="zh">&#33457;&#29983; <pr>hu&amacron;sh&emacron;ng</pr></trd>
  </snc>
  <snc mrk="arakid.0o.mangxo">
    <uzo tip="fak">KUI</uzo>
    <dif>
      La man&gcirc;ebla grajno de la specio
      <ref tip="malprt" cel="ter.0nukso.BOT">ternukso<sncref ref="ter.0nukso.BOT"/></ref>:
      <ekz>
        helpe de la pluvo, la kamparanoj produktas maizon, <tld/>on, maniokon a&ubreve; rizon
        <fnt>
          <bib>Monato</bib>
          <aut>Sagbadjelou Kokou/pg</aut>
          <vrk><url ref="&Monato;/2005/008658.php">Pro pluvo plu</url></vrk>
        </fnt>;
      </ekz>
      <ekz>
        tiom genia aparato ne estas produktebla kaj a&ccirc;etebla kontra&ubreve; kelkaj <tld/>oj
        <fnt>
          <aut>Stefan Maul</aut>
            <vrk><url ref="&Monato;/2000/007154.php">Finfine oni povas dibo&ccirc;i sen pento</url></vrk>
            <bib>Monato</bib>
            <lok>2000/12, p. 30</lok>
          </fnt>;
      </ekz>
      <ekz>
        <tld var="&hcirc;"/>a oleo
        <fnt>
          <bib>Viki</bib>
          <lok><url ref="https://eo.wikipedia.org/?curid=598553">Arakida oleo</url></lok>
        </fnt>;
      </ekz>
      <ekz>
        <tld var="&hcirc;"/>o-kapa cikado
        <fnt>
          <aut>Wouter F. Pilger</aut>
          <vrk><url ref="&hcirc;araido">PPL Insektoj</url></vrk>
        </fnt>.
      </ekz>
    </dif>
    <bld lok="&WCU;/thumb/5/52/Arachis_hypogaea_004.JPG/330px-Arachis_hypogaea_004.JPG" prm="CC
    BY-SA 3.0">sekigitaj <tld/>ogu&scirc;oj, (Arachis hypogaea)
        <fnt>
          <aut>H. Zell, propra verko</aut>
          <lok><url
          ref="&WCW;/File:Arachis_hypogaea_004.JPG">&WCW;/File:Arachis_hypogaea_004.JPG</url></lok>
        </fnt>
    </bld>
    <trdgrp lng="it">
      <trd>nocciolina</trd>,
      <trd>nocciolina americana</trd>,
      <trd>bagigi</trd>,
      <trd>seme di arachide</trd>,
      <trd>spagnoletta</trd>
    </trdgrp>
    <trdgrp lng="zh">
      <trd>&#33457;&#29983;&#31958; <pr>hu&amacron;sh&emacron;ngt&aacute;ng</pr></trd>,
      <trd>&#22320;&#35910; <pr>d&igrave;d&ograve;u</pr></trd>,
      <trd>&#33853;&#33457;&#29983; <pr>lu&ograve;hu&amacron;sh&emacron;ng</pr></trd>,
      <trd>&#22303;&#35910; <pr>t&#468;d&ograve;u</pr></trd>,
      <trd>&#38271;&#29983;&#26524; <pr>ch&aacute;ngsh&emacron;nggu&#466;</pr></trd>,
      <trd>&#24102;&#22771;&#33457;&#29983; <pr>d&agrave;ik&eacute;hu&amacron;sh&emacron;ng</pr></trd>,
      <trd>&#24118;&#27580;&#33457;&#29983; <pr>d&agrave;ik&eacute;hu&amacron;sh&emacron;ng</pr></trd>
    </trdgrp>
  </snc>
  <rim>
    La&ubreve; <fnt><bib>BL</bib></fnt>: Prefere diru <ke>ternukso</ke>.
  </rim>
  <trd lng="be">&c_a;&c_r;&c_a;&c_h;&c_ib;&c_s;</trd>
  <trd lng="bg">&c_f;&c_malmol;&c_s;&c_t;&c_malmol;&c_k;</trd>
  <trd lng="bo">&t_sa;&t_bata;&t_tsheg;&t_ta;&t_ma;&t_tsheg;</trd>
  <trd lng="ca">cacauet</trd>
  <trdgrp lng="cs">
    <trd>ara&scaron;&iacute;d</trd>,
    <trd>bursk&yacute; o&rcaron;&iacute;&scaron;ek</trd>,
    <trd>podzemnice olejn&aacute;</trd>
  </trdgrp>
  <trd lng="de">Erdnuss</trd>
  <trd lng="en">peanut</trd>
  <trdgrp lng="es">
    <trd>cacahuate</trd>,
    <trd>cacahuete</trd>,
    <trd>man&iacute;</trd>
  </trdgrp>
  <trdgrp lng="fr">
    <trd>arachide</trd>,
    <trd>cacahu&egrave;te</trd>,
    <trd>cacahou&egrave;te</trd>
  </trdgrp>
  <trd lng="gl">cacahuete</trd>
  <trd lng="he">&bet;&#1468;&#1465;&tet;&#1462;&fnun;</trd>
  <trdgrp lng="hu">
    <trd>amerikai mogyor&oacute;</trd>,
    <trd>b&uacute;rmogyor&oacute;</trd>,
    <trd>f&ouml;ldimogyor&oacute;</trd>
  </trdgrp>
  <trd lng="id">kacang tanah</trd>
  <trd lng="it">arachide</trd>
  <trdgrp lng="ja">
    <trd>&#12500;&#12540;&#12490;&#12483;&#12484;</trd>,
    <trd>&#12521;&#12483;&#12459;&#12475;&#12452;</trd>,
    <trd>&#12490;&#12531;&#12461;&#12531;&#12510;&#12513;</trd>
  </trdgrp>
  <trd lng="nl">pinda</trd>
  <trdgrp lng="pl">
    <trd>orzeszki ziemne</trd>,
    <trd>arachidy</trd>,
    <trd>fistaszki</trd>
  </trdgrp>
  <trd lng="ro">alune de p&abreve;m&acirc;nt</trd>
  <trdgrp lng="ru">
    <trd>&c_a;&c_r;&c_a;&c_h;&c_i;&c_s;</trd>,
    <trd>&c_z;&c_je;&c_m;&c_l;&c_ja;&c_n;&c_o;&c_j; &c_o;&c_r;&c_je;&c_h;</trd>
  </trdgrp>
  <trdgrp lng="sk">
    <trd>ara&scaron;id</trd>,
    <trd>b&uacute;rsky orech</trd>,
    <trd>podzemnica olejn&aacute;</trd>
  </trdgrp>
  <trd lng="tr">yer f&inodot;st&inodot;&gbreve;&inodot;</trd>
  <trdgrp lng="uk">
    <trd>&c_a;&c_r;&c_a;&c_h;&c_ib;&c_s; &c_p;&c_ib;&c_d;&c_z;&c_je;&c_m;&c_n;&c_i;&c_j;</trd>,
    <trd>&c_z;&c_je;&c_m;&c_l;&c_ja;&c_n;&c_i;&c_j; &c_g;&c_o;&c_r;&c_ib;&c_h;</trd>
  </trdgrp>
</drv>
</art>
