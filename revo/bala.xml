<drv mrk="bala.0i">
  <kap><ofc>*</ofc><tld/>i</kap>
  <gra><vspec>tr</vspec></gra>
  <snc mrk="bala.0i.malpurajxon">
    <dif>
      Forpu&scirc;i la polvon a&ubreve; malpura&jcirc;on per speciala
      ilo, konsistanta el fasko da vergetoj a&ubreve; haregoj:
      <ekz>
        <tld/>i la kuirejon
        <fnt>
          <bib>IdO</bib>
          <lok>Tria Parto</lok>
        </fnt>;
      </ekz>
      <ekz>
        <tld/>i la straton
        <fnt>
          <bib>Voja&gcirc;Imp</bib>
          <lok>En Peterburgo</lok>
        </fnt>;
      </ekz>
      <ekz>
        <uzo tip="stl">FIG</uzo>
        ventego <tld/>is la fundon
        <fnt>
          <bib>FdO</bib>
        </fnt>;
      </ekz>
      <ekz>
        vi devus du jarojn <tld/>i &ccirc;e mi la &ccirc;evalejon
        <fnt>
          <bib>Far1</bib>
          <lok>&Ccirc;apitro XXV</lok>
        </fnt>;
      </ekz>
      <ekz>
        <klr>[la paseroj]</klr> <tld/>is la teron per siaj vostoj
        <fnt>
          <bib>Fab2</bib>
          <lok>Najbaraj familioj</lok>
        </fnt>;
      </ekz>
      <ekz>
        se &ccirc;iu <tld/>os anta&ubreve; sia pordo, tiam en la tuta
        urbo estos ordo
        <fnt><bib>PrV</bib></fnt>.
      </ekz>
    </dif>
    <ref tip="vid" cel="tapisx.balai_sub_0on">balai sub la tapi&scirc;on</ref>
    <trdgrp lng="ca">
      <trd>escombrar</trd>,
      <trd>agranar</trd>
    </trdgrp>
    <trd lng="hu">seper</trd>
    <trdgrp lng="id">
      <trd><baz>sapu</baz>menyapu</trd>,
      <trd><baz>seka</baz>menyeka</trd>
    </trdgrp>
    <trdgrp lng="pl">
      <trd>zamiata&cacute;</trd>,
      <trd>zmiata&cacute;</trd>
    </trdgrp>
    <trdgrp lng="zh">
      <trd>&#25481;&#21521; <pr>di&agrave;oxi&agrave;ng</pr></trd>,
      <trd>&#25171;&#x626B; <pr>d&#x1CE;s&#x1CE;o</pr></trd>
    </trdgrp>
  </snc>
  <snc mrk="bala.0i.FIG">
     <uzo tip="stl">FIG</uzo>
     <dif>
       <ref tip="dif" cel="bala.for0i.FIG">For<tld/>i</ref>:
       <ekz>
        Dum semajno prusa&ccirc;ojn levi&gcirc;o popola &#11005; <tld lit="B"/>is, ke ne restis e&ccirc; nur unu
        sola
        <fnt>
          <bib>SrT</bib>
          <lok>Libro VII.</lok>
        </fnt>!
      </ekz>
      <ekz>
        &gcirc;is kiam oni ne <tld/>is la tutan junan <nom>PEA</nom>-stabon anta&ubreve; la Jubilea UK
        <klr>[&#8230;]</klr>
        <fnt>
          <bib>LOdE</bib>
          <lok>2000, No 5 (67)</lok>
        </fnt>.
      </ekz>
     </dif>
     <trdgrp lng="ca">
       <trd>bandejar</trd>,
       <trd>treure del mig</trd>,
       <trd>eliminar</trd>
     </trdgrp>
     <trdgrp lng="id">
       <trd><baz>sapu</baz>menyapu bersih</trd>,
       <trd><baz>sapu</baz>menyapu habis</trd>
     </trdgrp>
     <trd lng="pl">zamiata&cacute;</trd>
    <trdgrp lng="zh">
    <trd>&#25171;&#x626B; <pr>d&#x1CE;s&#x1CE;o</pr></trd>,
    <trd>&#25481;&#21521; <pr>di&agrave;oxi&agrave;ng</pr></trd>
  </trdgrp>
</snc>
  <trdgrp lng="be">
    <trd>&c_m;&c_je;&c_s;&c_mol;&c_c;&c_ib;</trd>,
    <trd>&c_p;&c_a;&c_d;&c_m;&c_ja;&c_t;&c_a;&c_c;&c_mol;</trd>
  </trdgrp>
  <trdgrp lng="bg">
    <trd>&c_m;&c_je;&c_t;&c_a;</trd>,
    <trd>&c_p;&c_o;&c_m;&c_i;&c_t;&c_a;&c_m;</trd>
  </trdgrp>
  <trd lng="bo">&t_ga;&t_da;&t_tsheg;&t_da;&t_ra;&t_tsheg;&t_ba;&t_yata;&t_drengbu;&t_da;&t_tsheg;</trd>
  <trd lng="br">skuba&ntilde;</trd>
  <trdgrp lng="cs">
    <trd>m&eacute;st</trd>,
    <trd>sm&eacute;st</trd>,
    <trd>zametat</trd>
  </trdgrp>
  <trdgrp lng="de">
    <trd>kehren</trd>,
    <trd>fegen</trd>
  </trdgrp>
  <trd lng="en">sweep</trd>
  <trd lng="es">barrer</trd>
  <trdgrp lng="fa">
    <trd>&a_r;&a_w;&a_b;&f_y;&a_d;&a_n;</trd>,
    <trd>&a_j;&a_A;&a_r;&a_w; &f_k;&a_r;&a_d;&a_n;</trd>
  </trdgrp>
  <trd lng="fr">balayer</trd>
  <trd lng="he">&lamed;&tet;&#x5B7;&alef;&tet;&#x5B5;&alef;</trd>
  <trdgrp lng="ja">
    <trd>&#25475;&#x304F;  <pr>&#x306F;&#x304F;</pr></trd>,
    <trd>&#x8D70;&#x67FB;&#12377;&#x308B;  <pr>&#x305D;&#12358;&#12373;&#12377;&#x308B;</pr></trd>
  </trdgrp>
  <trd lng="nl">vegen</trd>
  <trd lng="pt">varrer</trd>
  <trdgrp lng="ru">
    <trd>&c_m;&c_je;&c_s;&c_t;&c_i;</trd>,
    <trd>&c_p;&c_o;&c_d;&c_m;&c_je;&c_t;&c_a;&c_t;&c_mol;</trd>
  </trdgrp>
  <trdgrp lng="sk">
    <trd>zameta&tcaron;</trd>,
    <trd>zmies&tcaron;</trd>
  </trdgrp>
  <trd lng="sv">sopa</trd>
  <trd lng="tr">s&uuml;p&uuml;rmek</trd>
  <trdgrp lng="uk">
    <trd>&c_m;&c_je;&c_s;&c_t;&c_i;</trd>,
    <trd>&c_z;&c_a;&c_m;&c_ib;&c_t;&c_a;&c_t;&c_i;</trd>,
    <trd>&c_p;&c_ib;&c_d;&c_m;&c_ib;&c_t;&c_a;&c_t;&c_i;</trd>
  </trdgrp>
</drv>

<drv mrk="bala.0ajxo">
  <kap><tld/>a&jcirc;o</kap>
  <snc mrk="bala.0ajxo.balaitajxo">
    <dif>
      <tld/>ita&jcirc;o:
      <ekz>
        barelo de <tld/>a&jcirc;o
        <fnt>
          <bib>Fab2</bib>
          <lok>Gefian&ccirc;oj</lok>
        </fnt>;
      </ekz>
      <ekz>
        for en la <tld/>a&jcirc;on
        <fnt>
          <bib>Fab3</bib>
        </fnt>!
      </ekz>
      <ekz>
        <klr>[li]</klr> montris sub tiu <tld/>a&jcirc;o kelke da potpecoj de florpoto
        <fnt>
          <bib>Fab2</bib>
          <lok>An&gcirc;elo</lok>
        </fnt>;
      </ekz>
      <ekz>
        ili estas plenplenaj de <tld/>a&jcirc;oj, &ccirc;ifonoj
        <fnt>
          <bib>Fab4</bib>
          <lok>Turgardisto Ole</lok>
        </fnt>;
      </ekz>
      <ekz>
        <uzo tip="stl">FIG</uzo>
        <tld/>a&jcirc;on el korto eksteren ne elportu
        <klr>(ne publike kverelu pri privataj misoj)</klr>
        <fnt>
          <bib>PrV</bib>
        </fnt>.
      </ekz>
    </dif>
    <trdgrp lng="br">
      <trd>skubadur</trd>,
      <trd>skubien</trd>
    </trdgrp>
    <trdgrp lng="ca">
      <trd>escombraries</trd>,
      <trd>fems</trd>
    </trdgrp>
    <trdgrp lng="fr">
      <trd>balayure</trd>,
      <trd>ordure</trd>
    </trdgrp>
    <trd lng="nl">veegsel</trd>
    <trd lng="en">sweepings</trd>
    <trd lng="pl">&sacute;mieci</trd>
    <trd lng="zh">&#22403;&#x573E; <pr>l&amacron;j&imacron;</pr></trd>
  </snc>
  <snc mrk="bala.0ajxo.senvalorajxo">
    <uzo tip="stl">FIG</uzo>
    <dif>
      Senvalora&jcirc;o,
      <ref tip="vid" cel="bagate.0o">bagatelo</ref>,
      <ref tip="vid" cel="jxet.el0ajxo">el&jcirc;eta&jcirc;o</ref>,
      <ref tip="vid" cel="rub.0o">rubo</ref>:
      <ekz>
        ni fari&gcirc;as kiel la <tld/>a&jcirc;o de la mondo, la for&jcirc;eta&jcirc;o de &ccirc;io
        <fnt>
          <bib>NT</bib>
          <lok>I. Korintanoj 4:13</lok>
        </fnt>;
      </ekz>
      <ekz>
        vi povis a&ccirc;eti la tutan <tld/>a&jcirc;on por unu krono
        <fnt>
          <bib>KKr</bib>
          <lok>I</lok>
        </fnt>;
      </ekz>
      <ekz>
        la agonianto jam estas rigardata nur <tld/>a&jcirc;o, kiun oni devas forigi
        <fnt>
          <bib>VaK</bib>
          <lok>Sesa &Ccirc;apitro</lok>
        </fnt>;
      </ekz>
      <ekz>
        tiam ekkaptis ilin la uragano fortege
        kaj Ni faris ilin <tld/>a&jcirc;o
        <fnt>
          <aut>trad. I. Chiussi</aut>,
          <vrk>La Nobla Korano</vrk>,
          <lok>1970</lok>
        </fnt>.
      </ekz>
    </dif>
    <trd lng="bg">&c_b;&c_o;&c_k;&c_l;&c_u;&c_k;</trd>
    <trdgrp lng="ca">
      <trd>brolleria</trd>,
      <trd>fotesa</trd>,
      <trd>bagatel&middot;la</trd>
    </trdgrp>
    <trd lng="fr">rebut</trd>
    <trdgrp lng="nl">
      <trd>afval</trd>,
      <trd>vuilnis</trd>
    </trdgrp>
    <trd lng="pl">&sacute;mieci</trd>
  </snc>
  <trd lng="be">&c_s;&c_mol;&c_m;&c_je;&c_c;&c_mol;&c_c;&c_je;</trd>
  <trd lng="ca">deixalles</trd>
  <trd lng="de">Kehricht</trd>
  <trdgrp lng="fa">
    <trd>&a_kh;&a_A;&f_k;&a_r;&a_w;&a_b;&a_h;</trd>,
    <trd>&a_A_madda;&a_sh;&a_gh;&a_A;&a_l;</trd>
  </trdgrp>
  <trd lng="he">&mem;&he; &shin;&tet;&vav;&alef;&tet;&alef;</trd>
  <trd lng="hu">szem&eacute;t</trd>
  <trd lng="id">sampah</trd>
  <trdgrp lng="ja">
    <trd>&#12385;&#x308A;</trd>,
    <trd>&#12372;&#x307F;</trd>
  </trdgrp>
  <trdgrp lng="ru">
    <trd>&c_s;&c_o;&c_r;</trd>,
    <trd>&c_m;&c_u;&c_s;&c_o;&c_r;</trd>
  </trdgrp>
  <trd lng="uk">&c_s;&c_m;&c_ib;&c_t;&c_t;&c_ja;</trd>
</drv>

<drv mrk="bala.0ilo">
  <kap><tld/>ilo</kap>
  <snc mrk="bala.0ilo.HEJM">
    <dif>
      Ilo por <tld/>i:
      <ekz>
        la knabinoj alportis la <tld/>ilon kaj purigis la pelton
        <fnt>
          <bib>ElektFab</bib>
          <lok>Ne&gcirc;ulino kaj Rozulino</lok>
        </fnt>;
      </ekz>
      <ekz>
        <ind>ligisto de la <tld/>iloj</ind>
        <fnt>
          <bib>ElektFab</bib>
          <lok>Du fratoj</lok>
        </fnt>;
        <trd lng="de">Besenbinder</trd>
      </ekz>
      <ekz>
        en la kuirejo &scirc;i refoje purigis <klr>[&#8230;]</klr> per siteloj da akvo, vi&scirc;ilo kaj
        <tld/>ilo
        <fnt>
          <bib>IdO</bib>
          <lok>Tria Parto</lok>
        </fnt>;
      </ekz>
      <ekz>
        tiu eltran&ccirc;as la komikajn amuzajn bildojn: <klr>[&#8230;]</klr> jen maljunan
        sor&ccirc;istinon, kiu rajdas sur <tld/>ilo kaj tenas sian viron sur la nazo
        <fnt>
          <bib>Fab1</bib>
          <lok>Floroj de la malgranda Ida</lok>
        </fnt>;
      </ekz>
      <ekz>
        nova <tld/>ilo bone <tld/>as
        <klr>(oni montras fervoron transprenante novan taskon)</klr>
        <fnt>
          <bib>PrV</bib>
        </fnt>;
      </ekz>
      <ekz>
        sidi kiel muso sub <tld/>ilo
        <klr>(silenti, senmovi pro timo a&ubreve; singardo)</klr>
        <fnt><bib>PrV</bib></fnt>.
      </ekz>
    </dif>
    <trdgrp lng="zh">
    <trd>&#x7BF2; <pr>hu&igrave;</pr></trd>,
    <trd>&#x57FD; <pr>s&agrave;o</pr></trd>,
    <trd>&#x626B; <pr>s&agrave;o</pr></trd>,
    <trd>&#x7B24;&#x5E1A; <pr>ti&aacute;ozhou</pr></trd>,
    <trd>&#x5E1A; <pr>zh&#x1D2;u</pr></trd>,
    <trd>&#x626B;&#x628A; <pr>s&agrave;ob&#x1CE;</pr></trd>,
    <trd>&#x626B;&#x5E1A; <pr>s&agrave;ozhou</pr></trd>
  </trdgrp>
</snc>
  <trdgrp lng="be">
    <trd>&c_m;&c_ja;&c_t;&c_l;&c_a;</trd>,
    <trd>&c_v;&c_je;&c_n;&c_ib;&c_k;</trd>
  </trdgrp>
  <trd lng="bg">&c_m;&c_je;&c_t;&c_l;&c_a;</trd>
  <trd lng="bo">&t_pha;&t_yata;&t_ga;&t_sa;&t_tsheg;&t_ma;&t_tsheg;</trd>
  <trdgrp lng="br">
    <trd>balaenn</trd>,
    <trd>skubellenn</trd>
  </trdgrp>
  <trdgrp lng="ca">
    <trd>escombra</trd>,
    <trd>granera</trd>
  </trdgrp>
  <trd lng="cs">ko&scaron;t&ecaron;</trd>
  <trd lng="de">Besen</trd>
  <trdgrp lng="en">
    <trd>broom</trd>,
    <trd>sweeper</trd>
  </trdgrp>
  <trd lng="es">escoba</trd>
  <trd lng="fa">&a_j;&a_A;&a_r;&a_w;</trd>
  <trd lng="fr">balai</trd>
  <trd lng="he">&mem;&#x5B0;&tet;&#x5B7;&alef;&tet;&#x5B5;&alef;</trd>
  <trd lng="hu">sepr&udblac;</trd>
  <trd lng="id">sapu</trd>
  <trdgrp lng="it">
    <trd>scopa</trd>,
    <trd>ramazza</trd>
  </trdgrp>
  <trd lng="ja">&#x307B;&#12358;&#x304D;</trd>
  <trdgrp lng="nl">
    <trd>bezem</trd>,
    <trd>veger</trd>,
    <trd>borstel<klr tip="ind"> (bezem)</klr></trd>
  </trdgrp>
  <trdgrp lng="pl">
    <trd>miot&lstroke;a</trd>,
    <trd>zmiotka</trd>
  </trdgrp>
  <trd lng="pt">vassoura</trd>
  <trd lng="ro">m&abreve;tur&abreve;</trd>
  <trdgrp lng="ru">
    <trd>&c_m;&c_je;&c_t;&c_l;&c_a;</trd>,
    <trd>&c_v;&c_je;&c_n;&c_i;&c_k;</trd>
  </trdgrp>
  <trd lng="sk">zmet&aacute;k</trd>
  <trd lng="tr">s&uuml;p&uuml;rge</trd>
  <trdgrp lng="uk">
    <trd>&c_m;&c_ib;&c_t;&c_l;&c_a;</trd>,
    <trd>&c_p;&c_o;&c_m;&c_je;&c_l;&c_o;</trd>,
    <trd>&c_v;&c_ib;&c_n;&c_i;&c_k;</trd>
  </trdgrp>
</drv>

<drv mrk="bala.0ileto">
  <kap>
    <tld/>ileto
  </kap>
  <snc>
    <dif>
      <tld lit="B"/>ilo kun mallonga tenilo por unumana uzo:
      <ekz>
        unu el la atributoj de &jcirc;iloj estas simpla <tld/>ileto el salika&jcirc;oj, kunligitaj
        per rotanga&jcirc;oj
        <fnt>
          <bib>Monato</bib>
          <vrk>Belgio: Fama karnavalo en Binche</vrk>
        </fnt>;
      </ekz>
      <ekz>
        se la virino menciis hundorimenon, <nom>Betsy</nom> poste venis kun &gcirc;i &ndash; sammaniere okazis
        je la <tld/>ilo, kiun la hundino klare distingas de <tld/>ileto
        <fnt>
          <bib>Monato</bib>
          <aut>Evgeni Georgiev</aut>
          <vrk><url ref="&Monato;/2010/010209.php"
              >&Scirc;afhundo senlima</url></vrk>
          <lok>2010</lok>
        </fnt>.
      </ekz>
    </dif>
  </snc>
  <trd lng="de">Handfeger</trd>
  <trd lng="en">hand broom</trd>
  <trd lng="fr">balayette</trd>
</drv>

<drv mrk="bala.el0i">
  <kap>el<tld/>i</kap>
  <gra><vspec>tr</vspec></gra>
  <snc mrk="bala.el0i.FIG">
    <dif>
      <ref tip="dif" cel="bala.for0i.FIG">For<tld/>i</ref>:
      <ekz>
        mi el<tld/>os la domon de <nom>Jerobeam</nom>, kiel oni el<tld/>as
        malpura&jcirc;on
        <fnt><bib>MT</bib>, <lok>&Re1; 14:10</lok></fnt>.
      </ekz>
    </dif>
    <trd lng="zh">&#x626B; <pr>s&#x1CE;o</pr></trd>
</snc>
  <trdgrp lng="be">
    <trd>&c_v;&c_y;&c_m;&c_ja;&c_t;&c_a;&c_c;&c_mol;</trd>,
    <trd>&c_a;&c_d;&c_m;&c_ja;&c_t;&c_a;&c_c;&c_mol;</trd>
  </trdgrp>
  <trd lng="bg">&c_i;&c_z;&c_m;&c_i;&c_t;&c_a;&c_m;</trd>
  <trd lng="br">skuba&ntilde; kuit</trd>
  <trdgrp lng="ca">
    <trd>eliminar</trd>,
    <trd>treure del mig</trd>
  </trdgrp>
  <trd lng="cs">vym&eacute;st</trd>
  <trd lng="de">ausfegen</trd>
  <trd lng="fr">balayer<klr> (&eacute;liminer)</klr></trd>
  <trd lng="hu">els&ouml;p&ouml;r</trd>
  <trdgrp lng="id">
    <trd><baz>sapu</baz>menyapu bersih</trd>,
    <trd><baz>sapu</baz>menyapu habis</trd>,
    <trd><baz>sapu</baz>menyapu keluar</trd>
  </trdgrp>
  <trd lng="it"><ind>spazzare</ind> via</trd>
  <trd lng="nl">leegvegen</trd>
  <trdgrp lng="pl">
    <trd>wymiata&cacute;</trd>,
    <trd>zamiata&cacute;</trd>
  </trdgrp>
  <trd lng="sk">vymies&tcaron;</trd>
  <trd lng="uk">&c_v;&c_i;&c_m;&c_ib;&c_t;&c_a;&c_t;&c_i;</trd>
</drv>

<drv mrk="bala.for0i">
  <kap>for<tld/>i</kap>
  <gra><vspec>tr</vspec></gra>
  <snc mrk="bala.for0i.FIG">
    <uzo tip="stl">FIG</uzo>
    <dif>
      Dispu&scirc;i, perforte <ref tip="super" cel="for.0igi">forigi</ref>:
      <ekz>
        mi for<tld/>os de &gcirc;i &gcirc;ian polvon, kaj mi faros
        &gcirc;in nuda roko
        <fnt>
          <bib>MT</bib>
          <lok>Je&hcirc;ezkel 26:4</lok>
        </fnt>;
      </ekz>
      <ekz>
        mi <klr>[...]</klr> for<tld/>os la postesignojn post vi
        <fnt>
          <bib>MT</bib>
          <lok>I. Re&gcirc;oj 21:21</lok>
        </fnt>;
      </ekz>
      <ekz>
        unu el la lastaj diktatoroj
de I&#8217; civilizita mondo estas for<tld/>ita de sia trono
        <fnt>

          <vrk><url>Estimataj gelegantoj</url></vrk>
          <bib>Monato</bib>
          <lok>2000/11, p. 3</lok>
        </fnt>;
      </ekz>
      <ekz>
        la vento for<tld/>as la nubojn, la foliojn;
      </ekz>
      <ekz>
