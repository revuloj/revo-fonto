<?xml version="1.0"?>
<!DOCTYPE vortaro SYSTEM "../dtd/vokoxml.dtd">
<vortaro>
<art mrk="$Id: sekvenc.xml,v 1.13 2026/03/16 07:46:47 revo Exp $">
<kap>
    <rad>sekvenc</rad>/o <fnt><bib>PVEF</bib></fnt>
</kap>
<drv mrk="sekvenc.0o">
  <kap><tld/>o</kap>
  <snc mrk="sekvenc.0o.vico">
    <dif>
       <ref tip="super" cel="vic.0o">Vico</ref> de interligitaj objektoj
       a&ubreve; aperoj:
       <ekz>
         <tld/>o de sonfiguroj;
      </ekz>
      <ekz>
         <uzo tip="fak">MUZ</uzo>
           kvintfala <tld/>o
         <fnt>
           <bib>Viki</bib>,
           <lok>Sekvenco</lok>
         </fnt>;
      </ekz>
      <ekz>
         <uzo tip="fak">FOT</uzo>
         <tld/>o de sinsekvaj fotoj de la sama sceno;
      </ekz>
      <ekz>
        <uzo tip="fak">KOMP</uzo>
        proceduro estas nomhava <tld/>o de instrukcioj;
      </ekz>
      <ekz>
        <uzo tip="fak">BIO</uzo>
        ili kreis grand-egan datumbazon pri DNA-<tld/>oj de diversaj organismoj
        <fnt>
          <aut>R. Pigro</aut>
          <vrk>Mammuthusin, la surpriza kontra&ubreve;batalanto de superbakterioj</vrk>
          <lok>Monato, 2026/2, p. 22a</lok>
        </fnt>.
      </ekz>
    </dif>
    <refgrp tip="vid">
      <ref cel="cxen.0o.FIG">&ccirc;eno</ref>,
      <ref cel="seri.0o">serio</ref>
    </refgrp>
  </snc>
  <trdgrp lng="be">
    <trd>&c_s;&c_e;&c_k;&c_v;&c_e;&c_n;&c_c;&c_y;&c_ja;</trd>,
    <trd>&c_p;&c_a;&c_s;&c_mol;&c_l;&c_ja;&c_d;&c_o;&c_w;&c_n;&c_a;&c_s;&c_mol;&c_c;&c_mol;</trd>
  </trdgrp>
  <trdgrp lng="cs">
    <trd>posloupnost</trd>,
    <trd>po&rcaron;ad&iacute;</trd>,
    <trd>sekvence</trd>,
    <trd>sled</trd>
  </trdgrp>
  <trdgrp lng="de">
    <trd>Folge</trd>,
    <trd>Sequenz</trd>
  </trdgrp>
  <trdgrp lng="fr">
    <trd>s&eacute;quence</trd>,
    <trd>suite</trd>
  </trdgrp>
  <trdgrp lng="pl">
    <trd>sekwencja</trd>,
    <trd>ci&aogonek;g</trd>
  </trdgrp>
  <trdgrp lng="sk">
    <trd>poradie</trd>,
    <trd>postupnos&tcaron;</trd>,
    <trd>sekvencia</trd>,
    <trd>sled</trd>
  </trdgrp>
  <trdgrp lng="uk">
    <trd>&c_s;&c_je;&c_k;&c_v;&c_je;&c_n;&c_c;&c_ib;&c_ja;</trd>,
    <trd>&c_k;&c_ib;&c_l;&c_mol;&c_k;&c_a; &c_k;&c_a;&c_r;&c_t; &c_o;&c_d;&c_n;&c_ib;&c_jeu;&c_ji; &c_m;&c_a;&c_s;&c_t;&c_ib;</trd>,
    <trd>&c_p;&c_o;&c_s;&c_l;&c_ib;&c_d;&c_o;&c_v;&c_n;&c_ib;&c_s;&c_t;&c_mol;</trd>
  </trdgrp>
  <trdgrp lng="zh">
    <trd>&#x6B21;&#x5E8F; <pr>c&igrave;x&ugrave;</pr></trd>,
    <trd>&#x5E8F;&#x5217; <pr>x&ugrave;li&egrave;</pr></trd>
  </trdgrp>
</drv>

<drv mrk="sekvenc.0i">
  <kap>
    <tld/>i
  </kap>
  <snc>
    <dif>
      Ordigi la&ubreve; <tld/>o, determini la vicordon de io:
      <ekz>
        <uzo tip="fak">BIO</uzo>
        oni <tld/>is la plej antikvan homan DNA-on
        <fnt>
          <bib>Monato</bib>
          <aut>Roberto Pigro</aut>
          <vrk><url ref="&Monato;/2014/011214.php"
              >2013: dek donacoj al la posteuloj</url></vrk>
          <lok>2014</lok>
        </fnt>.
      </ekz>
    </dif>
  </snc>
  <trd lng="de">sequenzieren</trd>
  <trd lng="en">sequence <klr>(vt)</klr></trd>
  <trd lng="fr">s&eacute;quencer </trd>
</drv>

</art>

