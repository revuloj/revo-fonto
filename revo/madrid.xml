<!DOCTYPE vortaro SYSTEM "../dtd/vokoxml.dtd">
<vortaro>
  <art mrk="$Id: madrid.xml,v 1.11 2026/06/12 08:00:22 revo Exp $">
    <kap><ofc>10</ofc>
      <rad>Madrid</rad>/o
        <fnt>
          <bib>FK</bib>
        </fnt>
    </kap>

<drv mrk="madrid.0o">
  <kap><tld/>o</kap>
  <uzo tip="fak">POL</uzo><uzo tip="fak">GEOG</uzo>
  <snc>
    <dif>
      <ref tip="lst" lst="voko:&ccirc;efurboj" cel="urb.cxef0o.POL">&Ccirc;efurbo</ref>
      de <ref tip="malprt" cel="hispan.H0ujo">Hispanujo</ref>;
      situo: (<frm>40&#730;25&minute;N  3&#730;41&minute;W</frm>):
      <ekz>
        se vi deziras skribi, ekzemple, al iu hispano <tld/>on, sed nek
        vi scias lian
        lingvon, nek li vian
        <fnt>
          <bib>FK</bib>
        </fnt>;
      </ekz>
      <ekz>
        la familio komercis en <tld/>o kaj importis per &scirc;ipo el diversaj
        sud-amerikaj
        landoj plurajn varojn
        <fnt>
          <bib>Monato</bib>
          <aut>David Curtis</aut>
          <vrk><url ref="&Monato;/2004/008282.html">Volontuli en Tyntesfield</url></vrk>
        </fnt>;
      </ekz>
      <ekz>
        per politika pu&scirc;o de la minoritataj lingvoj la registaro en
        <tld/>o provas trovi
        subtenantojn por la EU-konstitucio &ccirc;e la anoj de la iberiaj
        malplimultoj
        <fnt>
          <bib>Monato</bib>
          <aut>Marko Naoki Lins</aut>
          <vrk><url ref="&Monato;/2004/008449.html">Hispanio volas la katalunan, e&ubreve;skan kaj galegan
          kiel
              EU-lingvojn</url></vrk>
        </fnt>;
      </ekz>
      <ekz>
        la sciencistoj e&ccirc; konsultis la episkopon de <tld/>o por
        konfirmi, ke iliaj
        interpretadoj de la bibliaj vortoj estis &gcirc;ustaj
        <fnt>
          <bib>Monato</bib>
          <aut>Vil&ccirc;jo Simcock</aut>
          <vrk><url ref="&Monato;/2005/008514.php">Kiom varmega estas la infero?</url></vrk>
        </fnt>.
      </ekz>
    </dif>
    <trd lng="be">&c_M;&c_a;&c_d;&c_r;&c_y;&c_d;</trd>
    <trd lng="de">Madrid</trd>
    <trd lng="en">Madrid</trd>
    <trd lng="pl">Madryt</trd>
    <trd lng="ro">Madrid</trd>
  </snc>
  <trd lng="ca">Madrid</trd>
  <trd lng="es">Madrid</trd>
  <trd lng="fr">Madrid</trd>
  <trd lng="ja">&#12510;&#12489;&#12522;&#12540;&#12489;</trd>
  <trd lng="uk">&c_M;&c_a;&c_d;&c_r;&c_i;&c_d;</trd>
  <trdgrp lng="zh">
    <trd>&#39340;&#24503;&#35041; <pr>m&#462;d&eacute;l&#464;</pr></trd>,
    <trd>&#39532;&#24503;&#37324; <pr>m&#462;d&eacute;l&#464;</pr></trd>
  </trdgrp>
</drv>
</art>

