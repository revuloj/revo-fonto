<?xml version="1.0"?>
<!DOCTYPE vortaro SYSTEM "../dtd/vokoxml.dtd">
<vortaro>
<art mrk="$Id: donjxu.xml,v 1.15 2026/05/14 14:38:09 revo Exp $">
<kap>
  <rad>don&jcirc;uan</rad>/o <fnt><bib>SPV</bib></fnt>
</kap>
<drv mrk="donjxu.0o">
  <kap><tld/>o</kap>
  <snc mrk="donjxu.0o.BELE">
    <uzo tip="fak">BELE</uzo>
    <uzo tip="fak">PERS</uzo>
    <dif>
      Beletra tipo de nobela, eleganta, fiera kaj malpia virindelogisto,
      el hispanaj teatra&jcirc;oj fare de Tirso de Molina
      (&ccirc;irka&ubreve; 1625) kaj
      multaj postaj verkoj:
      <ekz>
        <ind><tld/>a</ind> lerteco;
        <trd lng="fr">donjuanesque</trd>
      </ekz>
      <ekz>
        ni protektos unu la alian kontra&ubreve; la salonaj <tld/>oj
        <fnt>
          <bib>KrM</bib>
          <lok>5. Petro Kornojn Tenas, Pa&ubreve;lo Lakton Prenas.</lok>
        </fnt>;
      </ekz>
      <ekz>
        &scirc;paru la <tld/>ajn aventurojn a&ubreve; &ccirc;iuokaze ne spicu la verkon tro forte per ili
        <fnt>
          <bib>KrM</bib>
          <lok>1. Kiu Sin Enjungis, Devas Tiri.</lok>
        </fnt>.
      </ekz>
    </dif>
  </snc>
  <trd lng="be">&c_d;&c_o;&c_n;&c_zh;&c_u;&c_a;&c_n;</trd>
  <trdgrp lng="de">
    <trd>Don Juan</trd>,
    <trd>Frauenverf&uuml;hrer</trd>
  </trdgrp>
  <trd lng="fr">don Juan</trd>
  <trd lng="it">Don Giovanni</trd>
  <trdgrp lng="pl">
    <trd>Don Juan</trd>,
    <trd>don&zdot;uan</trd>,
    <trd>kobieciarz</trd>,
    <trd>lowelas</trd>
  </trdgrp>
  <trdgrp lng="pt">
    <trd>don-ju&aacute;n</trd>,
    <trd>dom-jo&atilde;o</trd>
  </trdgrp>
  <trd lng="ru">&c_d;&c_o;&c_n;&c_zh;&c_u;&c_a;&c_n;</trd>
  <trd lng="zh">&#x5510;&#x749C; <pr>t&aacute;nghu&aacute;ng</pr></trd>
</drv>

<drv mrk="donjxu.0ismo">
  <kap><tld/>ismo</kap>
  <snc mrk="donjxu.0ismo.PSI">
    <uzo tip="fak">PSI</uzo>
    <dif>
      Konstanta ser&ccirc;ado de novaj ama&jcirc;oj &ccirc;e novaj inoj.
    </dif>
  </snc>
  <trd lng="be">&c_d;&c_o;&c_n;&c_zh;&c_u;&c_a;&c_n;&c_s;&c_t;&c_v;&c_a;</trd>
  <trdgrp lng="de">
    <trd>Satyriasis</trd>,
    <trd>Donjuanismus</trd>
  </trdgrp>
  <trd lng="fr">donjuanisme</trd>
  <trd lng="he">&dalet;&vav;&fnun; &het;&vav;&alef;&nun;&yod;&zayin;&fmem;</trd>
  <trd lng="it">dongiovannismo</trd>
  <trdgrp lng="ja">
    <trd>&#x731F;&#x8272;  <pr>&#x308A;&#x3087;&#x3046;&#x3057;&#x3087;&#x304F;</pr></trd>,
    <trd>&#x30C9;&#x30F3;&#x30D5;&#x30A1;&#x30F3;&#x75C7;  <pr>&#x30C9;&#x30F3;&#x30D5;&#x30A1;&#x30F3;&#x3057;&#x3087;&#x3046;</pr></trd>
  </trdgrp>
  <trd lng="ru">&c_d;&c_o;&c_n;&c_zh;&c_u;&c_a;&c_n;&c_s;&c_t;&c_v;&c_o;</trd>
</drv>
</art>
