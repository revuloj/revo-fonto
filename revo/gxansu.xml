<?xml version="1.0"?>
<!DOCTYPE vortaro SYSTEM "../dtd/vokoxml.dtd">
<vortaro>
<art mrk="$Id: gxansu.xml,v 1.2 2026/07/15 14:06:12 afido Exp $">
<kap>
    <rad>&Gcirc;ansu</rad>/o <fnt><bib>LanLin</bib></fnt>,
    <var><kap><rad var="&gcirc;j">&Gcirc;jangsu</rad>/o <fnt><bib>PIV2</bib></fnt></kap></var>
</kap>
<drv mrk="gxansu.0o">
  <kap><tld/>o,
  <var><kap><tld var="&gcirc;j"/>o</kap></var></kap>
  <snc mrk="gxansu.0o.GEOG">
    <uzo tip="fak">GEOG</uzo>
    <uzo tip="fak">POL</uzo>
    <dif>
      Provinco en la oriento de <ref tip="malprt" cel="cxin.CX0ujo">&Ccirc;inujo</ref>, kun la &ccirc;efurbo
      Nankino::
      <ekz>
        nova&jcirc;oj pri la &ccirc;ina <klr>[&#x2026;]</klr> provinco <tld/>o
        <fnt>
          <aut>-</aut>
          <vrk><url ref="https://eo.wikinews.org/wiki/Kategorio:%C4%9Cansuo">
          Kategorio: &Gcirc;ansuo</url></vrk>
          <lok>Vikinova&jcirc;oj, 2015-01-04</lok>
        </fnt>;
      </ekz>
      <ekz>
        la grupeto, kun kiu ni kunvenis en tiu urbo de la provinco <klr>[&#x2026;]</klr> <tld var="&gcirc;j"/>o,
        aran&gcirc;is rendevuon
        <fnt>
          <aut>R. Lambert, trad. J. Gonz&aacute;lez</aut>
          <vrk><url ref="https://eo.mondediplo.com/2026/04/article3385">
          Surstrataj scenoj en &Ccirc;inujo</url></vrk>
          <lok>Le Monde diplomatique, 2026-04</lok>
        </fnt>.
      </ekz>
    </dif>
  </snc>
  <trd lng="de">Jiangsu</trd>
  <trd lng="fr">Jiangsu</trd>
  <trdgrp lng="zh">
    <trd>&#x6C5F;&#x8607; <pr>Ji&amacron;ngs&umacron;</pr></trd>,
    <trd>&#x6C5F;&#x82CF; <pr>Ji&amacron;ngs&umacron;</pr></trd>
  </trdgrp>
</drv>
</art>

