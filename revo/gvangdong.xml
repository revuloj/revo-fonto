<?xml version="1.0"?>
<!DOCTYPE vortaro SYSTEM "../dtd/vokoxml.dtd">
<vortaro>
<art mrk="$Id: gvangdong.xml,v 1.1 2026/07/14 17:34:56 afido Exp $">
<kap>
    <rad>Gvangdong</rad>/o,
    <var><kap><rad var="g&ubreve;">G&ubreve;angdong</rad>/o <fnt><bib>PIV2</bib></fnt></kap></var>,
    <var><kap><rad var="kantoni">Kantoni</rad>/o <fnt><bib>Viki</bib></fnt></kap></var>
</kap>
<drv mrk="gvangdong.0o">
  <kap><tld/>o,
  <var><kap><tld var="g&ubreve;"/>o</kap></var>,
  <var><kap><tld var="kantoni"/>o</kap></var></kap>
  <snc mrk="gvangdong.0o.SNC">
    <uzo tip="fak">GEOG</uzo>
    <uzo tip="fak">POL</uzo>
    <dif>
      Provinco en la sud-orienta parto de <ref tip="malprt" cel="cxin.CX0ujo">&Ccirc;inujo</ref> kun la
      &ccirc;efurbo Kantono:
      <ekz>
        en februaro 2003 informagentejoj maltrankvilige sciigis, ke en la suda provinco de &Ccirc;inio
        <tld/>o <klr>[&#8230;]</klr>
        aperis amasaj okazoj de malsano, kiu similis gripon kaj ofte kompliki&gcirc;is en pne&ubreve;monion
        <fnt>
          <aut>V. Lemelev</aut>
          <vrk><url ref="https://www.monato.be/2005/008721.php">
          De kie venis kaj kial &ccirc;esis netipa pne&ubreve;monio?</url></vrk>
          <lok>Monato, 2005/12, p. 17a</lok>
        </fnt>;
      </ekz>
      <ekz>
        tiuj koreaj prononcoj similas al la nuntempaj prononcoj de la kantonlingva provinco <tld
        var="g&ubreve;"/>o en &Ccirc;inio
        <fnt>
          <aut>Bak Giwan</aut>
          <vrk>Influo de la &ccirc;ina ideografio</vrk>
          <lok>Monato, 2026/03, p. 16a-17a</lok>
        </fnt>;
      </ekz>
      <ekz>
        Makao <klr>[&#8230;]</klr> situas  &ccirc;e la delto de la Perlorivero, limante kun <tld
        var="kantoni"/>o norde kaj kun la Sud&ccirc;ina Maro sude
        <fnt>
          <aut>-</aut>
          <vrk><url ref="https://eo.wikipedia.org/wiki/Makao">Makao</url></vrk>
          <lok>Vikipedio, 2025-09-16</lok>
        </fnt>.
      </ekz>
    </dif>
  </snc>
  <trd lng="fr">Guangdong</trd>
</drv>
</art>


