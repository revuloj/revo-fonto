<?xml version="1.0"?>
<!DOCTYPE vortaro SYSTEM "../dtd/vokoxml.dtd">
<vortaro>
<art mrk="$Id: fenacetin.xml,v 1.1 2026/05/15 12:07:42 afido Exp $">
<kap>
    <rad>fenacetin</rad>/o <fnt><bib>PIV1</bib></fnt>
</kap>
<drv mrk="fenacetin.0o">
  <kap><tld/>o</kap>
  <snc mrk="fenacetin.0o.SNC">
    <uzo tip="fak">MED</uzo>
    <dif>
      Kontra&ubreve;febra kaj kontra&ubreve;dolora <ref tip="super" cel="medika1.0o.MED">medikamento</ref>,
      rezignita en la fino de la 20a jarcento pro rendifekta kaj probabla kanceriga kromefiko:
      <ekz>
        <tld/>o havas trioblan pli malaltan koncentritecon en la sango de fumantoj pro la pli
        intensa metabolo en la hepato
        <fnt>
          <aut>G&aacute;bor L&aacute;z&aacute;r</aut>
          <vrk>Fumado kaj la metabolo de kelkaj medikamentoj</vrk>
          <lok><url ref="https://www.eventoj.hu/arkivo/eve-207.htm">Eventoj, aprilo 2001
          (207)</url></lok>
        </fnt>;
      </ekz>
      <ekz>
        mi <klr>[&#8230;]</klr> pansis lian kapon kaj donis al li <tld/>on
        <fnt>
          <aut>F. Moln&aacute;r, trad. J. Horvath</aut>
          <vrk><url ref="https://verkoj.com/tradukistoj/jozefo-horvath/jocxjo_kpl.pdf">
          Jo&ccirc;jo kaj aliaj komedietoj</url></vrk>
          <lok>2025</lok>
        </fnt>.
      </ekz>
    </dif>
  </snc>
  <trd lng="de">Phenacetin</trd>
  <trd lng="en">phenacetin</trd>
  <trd lng="fr">ph&eacute;nac&eacute;tine</trd>
  <trd lng="it">fenacetina</trd>
</drv>
</art>

