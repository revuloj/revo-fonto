<?xml version="1.0"?>
<!DOCTYPE vortaro SYSTEM "../dtd/vokoxml.dtd">
<vortaro>
<art mrk="$Id: sel.xml,v 1.33 2026/06/04 18:00:21 revo Exp $">
<kap>
  <ofc>*</ofc>
  <rad>sel</rad>/o <fnt><bib>UV</bib></fnt>
</kap>
<drv mrk="sel.0o">
  <kap><ofc>*</ofc><tld/>o</kap>
  <snc mrk="sel.0o.RAJ">
    <dif>
      <ref tip="super" cel="segx.0o.meblo">Se&gcirc;o</ref>, kiun oni ligas
      sur la dorso de rajdbesto a&ubreve; fiksas sur biciklo, motorciklo a&ubreve;
      simila:
      <ekz>
        li saltis sur la <tld/>on;
      </ekz>
      <ekz>
        &ccirc;evalo blanka, pompe ornamita, kun gravurita <tld/>o kaj kolora
        brido
        <fnt><bib>RugxDom</bib>, <lok>&ccirc;apitro 52a, volumo 2a, p.
        174a</lok></fnt>.
      </ekz>
    </dif>
  </snc>
  <trd lng="be">&c_s;&c_ja;&c_d;&c_l;&c_o;</trd>
  <trdgrp lng="ca">
    <trd>sella<klr tip="amb"> (de muntar)</klr></trd>,
    <trd>sell&oacute;<klr tip="amb"> (de bicicleta, moto, etc.)</klr></trd>
    <trd>sell&iacute;</trd>
  </trdgrp>
  <trd lng="cs">sedlo</trd>
  <trd lng="de">Sattel</trd>
  <trd lng="en">saddle</trd>
  <trdgrp lng="es">
    <trd>sill&iacute;n<klr> (bicicleta, moto)</klr></trd>,
    <trd>silla<klr> (de montar)</klr></trd>
  </trdgrp>
  <trd lng="fr">selle<klr> (&eacute;quitation etc.)</klr></trd>
  <trd lng="hu">nyereg</trd>
  <trd lng="it">sella</trd>
  <trdgrp lng="ja">
    <trd>&#38797;  <pr>&#12367;&#12425;</pr></trd>,
    <trd>&#12469;&#12489;&#12523;</trd>,
    <trd>&#38797;&#24418;&#12398;&#12418;&#12398;  <pr>&#12367;&#12425;&#12363;&#12383;&#12398;&#12418;&#12398;</pr></trd>,
    <trd>&#38797;&#37096;  <pr>&#12354;&#12435;&#12406;</pr></trd>,
    <trd>&#38797;&#19979;&#32905;  <pr>&#12367;&#12425;&#12363;&#12395;&#12367;</pr></trd>,
    <trd>&#39378;  <pr>&#12371;&#12414;</pr></trd>
  </trdgrp>
  <trd lng="nl">zadel</trd>
  <trd lng="pl">siod&lstroke;o</trd>
  <trd lng="ru">&c_s;&c_je;&c_d;&c_l;&c_o;</trd>
  <trdgrp lng="sk">
    <trd>sedadlo</trd>,
    <trd>sedlo</trd>
  </trdgrp>
  <trd lng="uk">&c_s;&c_ib;&c_d;&c_l;&c_o;</trd>
  <trdgrp lng="zh">
    <trd>&#38797; <pr>&#257;n</pr></trd>,
    <trd>&#39340;&#38797; <pr>m&#462;&#257;n</pr></trd>,
    <trd>&#39532;&#38797; <pr>m&#462;&#257;n</pr></trd>,
    <trd>&#38796; <pr>&#257;n</pr></trd>,
    <trd>&#25302;&#20855; <pr>tu&#333;j&ugrave;</pr></trd>,
    <trd>&#38797;&#29366;&#29289; <pr>&#257;nzhu&agrave;ngw&ugrave;</pr></trd>,
    <trd>&#38797;&#29376;&#29289; <pr>&#257;nzhu&agrave;ngw&ugrave;</pr></trd>,
    <trd>&#38797;&#29366;&#37096; <pr>&#257;nzhu&agrave;ngb&ugrave;</pr></trd>,
    <trd>&#38797;&#29376;&#37096; <pr>&#257;nzhu&agrave;ngb&ugrave;</pr></trd>
  </trdgrp>
</drv>

<drv mrk="sel.0i">
  <kap><ofc>*</ofc><tld/>i <fnt><bib>F</bib>, <lok>Universala Vortaro,
  <url ref="&AdE;/fundamento/universala_vortaro.html#av-5192">sel'i</url></lok></fnt></kap>
  <gra><vspec>tr</vspec></gra>
  <snc mrk="sel.0i.RAJ">
    <dif>
      Meti <tld/>on sur:
      <ekz>
        post kiam li man&gcirc;is panon kaj trinkis, oni <tld/>is por li la
        azenon
        <fnt><bib>MT</bib>, <lok>&Re1; 13:23</lok></fnt>.
      </ekz>
    </dif>
  </snc>
  <trdgrp lng="be">
    <trd>&c_a;&c_s;&c_ja;&c_d;&c_l;&c_a;&c_c;&c_mol;</trd>,
    <trd>&c_s;&c_ja;&c_d;&c_l;&c_a;&c_c;&c_mol;</trd>
  </trdgrp>
  <trd lng="ca">ensellar</trd>
  <trdgrp lng="cs">
    <trd>osedlat</trd>,
    <trd>sedlat</trd>
  </trdgrp>
  <trd lng="de">satteln</trd>
  <trd lng="en">saddle</trd>
  <trd lng="es">ensillar</trd>
  <trd lng="fr">seller</trd>
  <trd lng="hu">megnyergel</trd>
  <trd lng="it">sellare</trd>
  <trd lng="ja">&#38797;&#12434;&#32622;&#12367;  <pr>&#12367;&#12425;&#12434;&#12362;&#12367;</pr></trd>
  <trd lng="nl">zadelen</trd>
  <trdgrp lng="pl">
    <trd>osiod&lstroke;a&cacute;</trd>,
    <trd>kulbaczy&cacute;</trd>
  </trdgrp>
  <trdgrp lng="ru">
    <trd>&c_s;&c_je;&c_d;&c_l;&c_a;&c_t;&c_mol;</trd>,
    <trd>&c_o;&c_s;&c_je;&c_d;&c_l;&c_a;&c_t;&c_mol;</trd>
  </trdgrp>
  <trd lng="sk">osedla&tcaron;</trd>
  <trd lng="uk">&c_s;&c_ib;&c_d;&c_l;&c_a;&c_t;&c_i;</trd>
  <trd lng="zh">&#38836; <pr>b&egrave;i</pr></trd>
</drv>

<drv mrk="sel.de0igxi">
  <kap>de<tld/>i&gcirc;i</kap>
  <gra><vspec>ntr</vspec></gra>
  <snc mrk="sel.de0igxi.RAJ">
    <dif>
      Dei&gcirc;i de <tld/>o, finante la rajdon:
      <ekz>
        ili <klr>...</klr> alvenis al vila&gcirc;o, haltis tie kaj
        de<tld/>i&gcirc;is &ccirc;e gastejo
        <fnt><bib>DonKihxoto</bib>, <lok>parto 2a, &ccirc;apitro 71a, p.
        797a</lok></fnt>.
      </ekz>
    </dif>
  </snc>
  <trdgrp lng="be">
    <trd>&c_z;&c_mol;&c_l;&c_je;&c_z;&c_mol;&c_c;&c_ib; &c_z;&c_mol;
    <ind>&c_s;&c_ja;&c_d;&c_l;&c_a;</ind></trd>,
    <trd>&c_s;&c_a;&c_s;&c_k;&c_o;&c_ch;&c_y;&c_c;&c_mol; &c_z;&c_mol;
    <ind>&c_s;&c_ja;&c_d;&c_l;&c_a;</ind></trd>
  </trdgrp>
  <trd lng="ca">descavalcar</trd>
  <trd lng="es">desmontar</trd>
  <trdgrp lng="fr">
    <trd>d&eacute;monter<klr> (&eacute;quitation)</klr></trd>,
    <trd>descendre de <ind>selle</ind></trd>
  </trdgrp>
  <trd lng="hu">lesz&aacute;ll a <ind>nyeregb&odblac;l</ind></trd>
  <trd lng="it">smontare dalla <ind>sella</ind></trd>
  <trd lng="ja">&#19979;&#39340;&#12377;&#12427;  <pr>&#12375;&#12383;&#12358;&#12414;&#12377;&#12427;</pr></trd>
  <trd lng="pl">zej&sacute;&cacute; z  <ind>siod&lstroke;a</ind></trd>
  <trd lng="ru">&c_s;&c_l;&c_je;&c_z;&c_t;&c_mol; &c_s; &c_s;&c_je;&c_d;&c_l;&c_a;</trd>
  <trdgrp lng="zh">
    <trd>&#19979;&#39340; <pr>xi&agrave;m&#462;</pr></trd>,
    <trd>&#19979;&#39532; <pr>xi&agrave;m&#462;</pr></trd>
  </trdgrp>
</drv>

<drv mrk="sel.sur0igxi">
  <kap>sur<tld/>i&gcirc;i,
  <var><kap>en<tld/>i&gcirc;i</kap></var></kap>
  <gra><vspec>ntr</vspec></gra>
  <snc mrk="sel.sur0igxi.RAJ">
    <dif>
      Eksidi rajde sur <tld/>o:
      <ekz>
        <nom>Sleipnir</nom>, la &ccirc;evalo de Odino,
        estis prenita kaj alkondukita, kaj <nom>Hermod</nom>
        sur<tld/>i&gcirc;is kaj galopis for
        <fnt>
          <aut>Snorri Sturluson, trad. B. Ragnarsson</aut>
          <vrk>Edda</vrk>
          <lok>2008</lok>
        </fnt>.
      </ekz>
    </dif>
  </snc>
  <trdgrp lng="be">
    <trd>&c_u;&c_s;&c_k;&c_o;&c_ch;&c_y;&c_c;&c_mol; &c_u;
    <ind>&c_s;&c_ja;&c_d;&c_l;&c_o;</ind></trd>,
    <trd>&c_s;&c_je;&c_s;&c_mol;&c_c;&c_ib; &c_w; <ind>&c_s;&c_ja;&c_d;&c_l;&c_o;</ind></trd>
  </trdgrp>
  <trdgrp lng="ca">
    <trd>pujar<klr tip="amb"> (a un cavall, un ase, etc.)</klr></trd>
  </trdgrp>
  <trd lng="es">montar en <ind>silla</ind></trd>
  <trdgrp lng="fr">
    <trd>monter en selle</trd>,
    <trd>se mettre en <ind>selle</ind></trd>
  </trdgrp>
  <trdgrp lng="hu">
    <trd>nyeregbe &uuml;l</trd>,
    <trd>nyeregbe sz&aacute;ll</trd>
  </trdgrp>
  <trd lng="it">montare in <ind>sella</ind></trd>
  <trdgrp lng="ja">
    <trd>&#20055;&#39340;&#12377;&#12427;  <pr>&#12376;&#12423;&#12358;&#12400;&#12377;&#12427;</pr></trd>,
    <trd>&#33258;&#36578;&#36554;&#12395;&#20055;&#12427;  <pr>&#12376;&#12390;&#12435;&#12375;&#12419;&#12395;&#12398;&#12427;</pr></trd>
  </trdgrp>
  <trdgrp lng="pl">
    <trd>dosiada&cacute;</trd>,
    <trd>wsi&aogonek;&sacute;&cacute; na  <ind>siod&lstroke;o</ind></trd>
  </trdgrp>
  <trd lng="ru">&c_s;&c_je;&c_s;&c_t;&c_mol; &c_v; &c_s;&c_je;&c_d;&c_l;&c_o;</trd>
</drv>
</art>
