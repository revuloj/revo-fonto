    <kap>
      <rad>Konakri</rad>/o
    </kap>

<drv mrk="konakri.0o">
  <kap><tld/>o</kap>
  <uzo tip="fak">GEOG</uzo>
  <snc>
    <dif>
      La <ref tip="lst" lst="voko:&ccirc;efurboj" cel="urb.cxef0o.POL">&ccirc;efurbo</ref> de <ref tip="malprt"
      cel="gvine.G0o">Gvineo</ref>
situo: (<frm>9&#730;32&minute;N  13&#730;40&minute;W</frm>):
      <ekz>
        la sanga subpremado de manifestacioj la 28-an de septembro 2009 en <tld/>o
        <fnt>
          <vrk><url ref="&Tekstaro;?nomo=mondediplo-2008&amp;sekcio=MondeDiplo-1584">De Konakrio &gcirc;is
          Nairobo, Afrikanoj vo&ccirc;donas sed ne decidas</url></vrk>
          <lok>Tekstaro de Esperanto</lok>
        </fnt>;
      </ekz>
      <ekz>
        ba&ubreve;ksitaj minejoj de <nom>Fria</nom>, je du horoj a&ubreve;te norde de <tld/>o
        <fnt>
          <vrk><url ref="&Mondediplo;article1550.html">La rusoj kaj la &leftquot;eta
          juvelo&rightquot; de
          Gvineo</url></vrk>
          <lok>Le Monde diplomatique' en Esperanto</lok>
        </fnt>;
      </ekz>
      <ekz>
        unuaj malsani&gcirc;oj estis registritaj en <tld/>o kaj en suda parto de Gvineo la
        9-an de februaro 2014
        <fnt>
          <bib>Viki</bib>
          <vrk><url ref="&Viki;/Ebola_epidemio_en_Okcidentafriko_(2014)">Ebola epidemio en
          Okcidentafriko (2014)</url></vrk>
        </fnt>.
      </ekz>
    </dif>
    <trd lng="de">Conakry</trd>
    <trd lng="en">Conakry</trd>
    <trd lng="fr">Conakry</trd>
  </snc>
  <trd lng="be">&c_K;&c_a;&c_n;&c_a;&c_k;&c_r;&c_y;</trd>
  <trd lng="ca">Conakry</trd>
  <trd lng="ja">&#12467;&#12490;&#12463;&#12522;</trd>
  <trd lng="pl">Konakry</trd>
  <trdgrp lng="zh">
    <trd>&#26607;&#37027;&#20811;&#37324; <pr>K&emacron;n&agrave;k&egrave;l&#464;</pr></trd>,
    <trd>&#31185;&#32013;&#20811;&#37324; <pr>K&emacron;n&agrave;k&egrave;l&#464;</pr></trd>,
    <trd>&#31185;&#32013;&#20811;&#35041; <pr>k&emacron;n&agrave;k&egrave;l&#464;</pr></trd>
  </trdgrp>
</drv>
