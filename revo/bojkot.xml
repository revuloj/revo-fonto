<?xml version="1.0"?>
<!DOCTYPE vortaro SYSTEM "../dtd/vokoxml.dtd">
<vortaro>
<art mrk="$Id: bojkot.xml,v 1.24 2026/06/05 08:00:21 revo Exp $">
<kap>
  <ofc>2</ofc>
  <rad>bojkot</rad>/i
<fnt><bib>JED</bib></fnt></kap>
<drv mrk="bojkot.0i">
  <kap><tld/>i</kap>
  <gra><vspec>tr</vspec></gra>
  <uzo tip="fak">EKON</uzo>
  <snc>
    <dif>
      Rifuzi komercadon, dungi&gcirc;on, partoprenon, por protesti
      kontra&ubreve;
      la politiko de iu institucio kaj premi al &gcirc;ia modifo:
      <ekz>
        Berlino pasintjare e&ccirc; <tld/>is EU-konferencojn sub
        prezidado de
        Finnlando<fnt><aut>Stefan Maul</aut>: <vrk>Lingvopakto</vrk>,
        <bib>Monato</bib><lok>jaro 2000a, numero 12a, p. 7a</lok></fnt>.
      </ekz>
    </dif>
  <trd lng="be">&c_b;&c_a;&c_j;&c_k;&c_a;&c_t;&c_a;&c_v;&c_a;&c_c;&c_mol;</trd>
  <trdgrp lng="de">
    <trd>boykottieren</trd>,
    <trd>schneiden</trd>
  </trdgrp>
  <trd lng="en">boycott</trd>
  <trd lng="es">boicotear</trd>
  <trd lng="fr">boycotter</trd>
  <trd lng="hu">bojkott&aacute;l</trd>
  <trd lng="pl">bojkotowa&cacute;</trd>
  <trd lng="ru">&c_b;&c_o;&c_j;&c_k;&c_o;&c_t;&c_i;&c_r;&c_o;&c_v;&c_a;&c_t;&c_mol;</trd>
  <trd lng="sk">bojkotova&tcaron;</trd>
  </snc>
  <trdgrp lng="ca">
    <trd>boicotejar</trd>,
    <trd>boicotar</trd>,
    <trd>fer el <ind>boicot</ind></trd>
  </trdgrp>
  <trd lng="cs">bojkotovat</trd>
  <trd lng="he">&het;&#1461;&resh;&#1462;&fmem;</trd>
  <trd lng="ja">&#12508;&#12452;&#12467;&#12483;&#12488;&#12377;&#12427;  <pr>&#12412;&#12356;&#12371;&#12387;&#12392;&#12377;&#12427;</pr></trd>
  <trd lng="uk">&c_b;&c_o;&c_j;&c_k;&c_o;&c_t;&c_u;&c_v;&c_a;&c_t;&c_i;</trd>
</drv>

<drv mrk="bojkot.0o">
  <kap><tld/>o</kap>
  <uzo tip="fak">EKON</uzo>
  <snc>
    <dif>
      Publike protesta nepartopreno:
      <ekz>
        ekstrem-maldekstra balotkoalicio plendis, ke &gcirc;i perdis du
        mandatojn pro televida <tld/>o<fnt><aut>Baard Hekland</aut>:
        <vrk>Triumfas tedulo</vrk>, <bib>Monato</bib><lok>jaro 2001a,
        numero 11a, p. 6a</lok></fnt>.
      </ekz>
    </dif>
  <trd lng="be">&c_b;&c_a;&c_j;&c_k;&c_o;&c_t;</trd>
  <trd lng="de">Boykott</trd>
  <trd lng="en">boycott</trd>
  <trdgrp lng="es">
    <trd>boicot</trd>,
    <trd>boicoteo</trd>
  </trdgrp>
  <trdgrp lng="fr">
    <trd>boycott</trd>,
    <trd>boycottage</trd>
  </trdgrp>
  <trd lng="hu">bojkott</trd>
  <trd lng="pl">bojkot</trd>
  <trd lng="ru">&c_b;&c_o;&c_j;&c_k;&c_o;&c_t;</trd>
  </snc>
  <trd lng="ca">boicot</trd>
  <trd lng="cs">bojkot</trd>
  <trd lng="he">&het;&#1461;&resh;&#1462;&fmem;</trd>
  <trd lng="ja">&#12508;&#12452;&#12467;&#12483;&#12488;  <pr>&#12412;&#12356;&#12371;&#12387;&#12392;</pr></trd>
  <trd lng="sk">bojkot</trd>
  <trd lng="uk">&c_b;&c_o;&c_j;&c_k;&c_o;&c_t;</trd>
</drv>
</art>
