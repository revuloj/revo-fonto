<vortaro>
<art mrk="$Id: cxinghaj.xml,v 1.2 2026/07/15 14:06:08 afido Exp $">
<kap>
    <rad>&Ccirc;inghaj</rad>/o <fnt><bib>PIV2</bib></fnt>
</kap>
<drv mrk="cxinghaj.0o">
  <kap><tld/>o</kap>
  <snc mrk="cxinghaj.0o.GEOG">
    <uzo tip="fak">GEOG</uzo>
    <uzo tip="fak">POL</uzo>
    <dif>
      Provinco en la centra parto de <ref tip="malprt" cel="cxin.CX0ujo">&Ccirc;inujo</ref>:
      <ekz>
        du aliaj tradiciaj provincoj (<nom>Kham</nom> kaj <nom>Amdo</nom>) estis integritaj en la &ccirc;inan provincon <tld/>o
        <fnt>
          <aut>M. Vernerey, trad. V. Lutermano</aut>
          <vrk><url ref="https://eo.mondediplo.com/2008/04/article1344">
          Anta&ubreve;tempa bur&gcirc;onado de la printempo de Lasao</url></vrk>
          <lok>Le monde diplomatique, 2008-04</lok>
        </fnt>.
      </ekz>
    </dif>
  </snc>
  <trd lng="bo">&t_ma;&t_tsha;&t_naro;&t_tsheg;&t_sa;&t_ngata;&t_naro;&t_na;&t_tsheg;&t_zha;&t_gigu;&t_nga;&t_tsheg;&t_cha;&t_drengbu;&t_na;</trd>
  <trd lng="de">Qinghai</trd>
  <trd lng="fr">Qinghai</trd>
<trd lng="zh">&#x9752;&#x6D77; <pr>Q&imacron;ngh&#x1CE;i</pr></trd>
</drv>
</art>

