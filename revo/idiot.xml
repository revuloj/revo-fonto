<art mrk="$Id: idiot.xml,v 1.31 2026/05/02 20:00:22 revo Exp $">
<kap>
  <ofc>1</ofc>
  <rad>idiot</rad>/o
<fnt><bib>JED</bib></fnt></kap>

<drv mrk="idiot.0o">
  <kap><tld/>o</kap>
  <snc mrk="idiot.0o.MED">
    <uzo tip="fak">MED</uzo>
    <dif>
      Homo senigita je inteligenteco pro cerbaj difektoj:
      <ekz>alkoholismo &ccirc;e la patro igas ofte la infanojn
<tld/>oj.</ekz>
    </dif>
  <trdgrp lng="hu">
    <trd>gyengeelm&eacute;j&udblac;</trd>,
    <trd>idi&oacute;ta</trd>
  </trdgrp>
  <trd lng="pl">idiota</trd>
  </snc>
  <snc mrk="idiot.0o.KOMUNE">
    <dif>
      Homo tute ne inteligenta, malsa&gcirc;ega.
    </dif>
    <ref tip="vid" cel="stult.0a">stulta.</ref>
  <trdgrp lng="hu">
    <trd>h&uuml;lye</trd>,
    <trd>ostoba</trd>
  </trdgrp>
    <trd lng="sv">idiot</trd>
    <trd lng="ru">&c_b;&c_o;&c_l;&c_v;&c_a;&c_n;</trd>
  </snc>
  <ref tip="vid" cel="kreten.0o">kreteno.</ref>
  <trd lng="be">&c_ib;&c_d;&c_y;&c_jo;&c_t;</trd>
  <trd lng="bg">&c_i;&c_d;&c_i;&c_o;&c_t;</trd>
  <trd lng="ca">idiota</trd>
  <trd lng="de">Idiot</trd>
  <trd lng="en">idiot</trd>
  <trd lng="es">idiota</trd>
  <trdgrp lng="fr">
    <trd>idiot</trd>,
    <trd>abruti</trd>,
    <trd>imb&eacute;cile</trd>,
    <trd>cr&eacute;tin</trd></trdgrp>
  <trdgrp lng="id">
    <trd>idiot</trd>,
    <trd>tunagrahita</trd>
  </trdgrp>
  <trdgrp lng="ja">
    <trd>&#37325;&#24230;&#30693;&#30340;&#38556;&#23475;&#32773;  <pr>&#12376;&#12421;&#12358;&#12393;&#12385;&#12390;&#12365;&#12375;&#12423;&#12358;&#12364;&#12356;&#12375;&#12419;</pr></trd>,
    <trd>&#30333;&#30196;  <pr>&#12383;&#12431;&#12369;</pr></trd>,
    <trd>&#24858;&#12363;&#32773;  <pr>&#12362;&#12429;&#12363;&#12418;&#12398;</pr></trd>
  </trdgrp>
  <trd lng="nl">idioot</trd>
  <trdgrp lng="pl">
    <trd>idiota</trd>,
    <trd>g&lstroke;upek</trd>
  </trdgrp>
  <trd lng="pt">idiota<klr tip="ind"> (subst.)</klr></trd>
  <trd lng="ru">&c_i;&c_d;&c_i;&c_o;&c_t;</trd>
  <trdgrp lng="sk">
    <trd>hlup&aacute;k</trd>,
    <trd>idiot</trd>
  </trdgrp>
  <trdgrp lng="cs">
    <trd>blbec</trd>,
    <trd>idiot</trd>
  </trdgrp>
  <trdgrp lng="uk">
    <trd>&c_ib;&c_d;&c_ib;&c_o;&c_t;</trd>,
    <trd>&c_shch;&c_je; &c_j;&c_o;&c_l;&c_o;&c_p;</trd>,
    <trd>&c_b;&c_o;&c_v;&c_d;&c_u;&c_r;</trd>,
    <trd>&c_b;&c_je;&c_v;&c_z;&c_mol;</trd>,
    <trd>&c_t;&c_je;&c_l;&c_je;&c_p;&c_je;&c_n;&c_mol;</trd>,
    <trd>&c_l;&c_o;&c_b;&c_u;&c_r;</trd>,
    <trd>&c_d;&c_u;&c_r;&c_je;&c_n;&c_mol;</trd>
  </trdgrp>
  <trdgrp lng="zh">
    <trd>&#20667;&#23376; <pr>sh&#462;zi</pr></trd>,
    <trd>&#20667;&#29916; <pr>sh&#462;gu&amacron;</pr></trd>,
    <trd>&#21574;&#23376; <pr>d&amacron;izi</pr></trd>,
    <trd>&#21574;&#29916; <pr>d&amacron;igu&amacron;</pr></trd>,
    <trd>&#25000;&#23376; <pr>h&amacron;nzi</pr></trd>,
    <trd>&#31528;&#34507; <pr>b&egrave;nd&agrave;n</pr></trd>,
    <trd>&#30196; <pr>ch&#299;</pr></trd>,
    <trd>&#20108;&#23620; <pr>&egrave;rb&#299;</pr></trd>
  </trdgrp>
</drv>

<drv mrk="idiot.0eco">
  <kap><tld/>eco</kap>
  <snc mrk="idiot.0eco.MED">
    <uzo tip="fak">MED</uzo>
    <dif>
      <ref tip="lst" cel="san.mal0o.MED" lst="voko:malsanoj">Malsano</ref> de <tld/>o <sncref
      ref="idiot.0o.MED"/>.
    </dif>
    <adm>
    Kontroli trd nl. La antauxa difino tekstis nur
    "stato de ~o". Mi sxovis la tradukojn al la medicina
    senco, sed ne certas. <aut>MB</aut>
    </adm>
    <trd lng="ca">idi&ograve;cia</trd>
    <trd lng="de">Idiotismus</trd>
    <trdgrp lng="hu">
      <trd>gyengeelm&eacute;j&udblac;s&eacute;g</trd>,
      <trd>idi&oacute;tizmus</trd>
    </trdgrp>
    <trd lng="nl">idiotie</trd>
    <trd lng="pl">idiotyzm</trd>
  </snc>
  <snc mrk="idiot.0eco.KOMUNE">
    <dif>
      Stato de <tld/>o <sncref ref="idiot.0o.KOMUNE"/>.
    </dif>
    <trdgrp lng="ca">
      <trd>idiotesa</trd>,
      <trd>estupidesa</trd>,
      <trd>estupididat</trd>,
      <trd>imbecil&middot;litat</trd>
    </trdgrp>
    <trd lng="de">Idiotie</trd>
    <trdgrp lng="hu">
      <trd>h&uuml;lyes&eacute;g</trd>,
      <trd>ostobas&aacute;g</trd>
    </trdgrp>
  <trdgrp lng="pl">
    <trd>idiotyzm</trd>,
    <trd>g&lstroke;upota</trd>
  </trdgrp>
  </snc>
  <trd lng="be">&c_ib;&c_d;&c_y;&c_ja;&c_t;&c_y;&c_z;&c_m;</trd>
  <trdgrp lng="cs">
    <trd>blbost</trd>,
    <trd>choromyslnost</trd>,
    <trd>du&scaron;evn&iacute; zaostalost</trd>,
    <trd>idiocie</trd>,
    <trd>idiotie</trd>,
    <trd>idiotstv&iacute;</trd>,
    <trd>slabomyslnost</trd>
  </trdgrp>
  <trd lng="en">idiocy</trd>
  <trd lng="es">idiotez</trd>
  <trd lng="fr">idiotie<klr tip="ind"> (&eacute;tat, maladie)</klr></trd>
  <trdgrp lng="ja">
    <trd>&#37325;&#24230;&#12398;&#30693;&#30340;&#38556;&#23475; 
    <pr>&#12376;&#12421;&#12358;&#12393;&#12398;&#12385;&#12390;&#12365;&#12375;&#12423;&#12358;&#12364;&#12356;</pr></trd>,
    <trd>&#30333;&#30196;  <pr>&#12383;&#12431;&#12369;</pr></trd>
  </trdgrp>
  <trd lng="pt">idiotice<klr tip="ind"> (subst.)</klr></trd>
  <trd lng="ru">&c_i;&c_d;&c_i;&c_o;&c_t;&c_i;&c_z;&c_m;</trd>
  <trdgrp lng="sk">
    <trd>idiotstvo</trd>,
    <trd>slabomyse&lcaron;nos&tcaron;</trd>
  </trdgrp>
  <trdgrp lng="uk">
    <trd>&c_ib;&c_d;&c_ib;&c_o;&c_t;&c_i;&c_z;&c_m;</trd>,
    <trd>&c_n;&c_je;&c_d;&c_o;&c_u;&c_m;&c_k;&c_u;&c_v;&c_a;&c_t;&c_ib;&c_s;&c_t;&c_mol;</trd>
  </trdgrp>
  <trdgrp lng="zh">
    <trd>&#30333;&#30196; <pr>b&aacute;ich&#299;</pr></trd>,
    <trd>&#30333;&#30305; <pr>b&aacute;ich&#299;</pr></trd>
  </trdgrp>
</drv>

<drv mrk="idiot.0igi">
  <kap><tld/>igi</kap>
  <snc>
    <dif>
      Igi iun <tld/>o:
      <ekz>la kutima ebrieco <tld/>igas.</ekz>
    </dif>
  </snc>
  <trdgrp lng="be">
    <trd>&c_r;&c_a;&c_b;&c_ib;&c_c;&c_mol; <ind>&c_ib;&c_d;&c_y;&c_jo;&c_t;&c_a;&c_m;</ind></trd>,
    <trd>&c_v;&c_y;&c_k;&c_l;&c_ib;&c_k;&c_a;&c_c;&c_mol;
    <ind>&c_ib;&c_d;&c_y;&c_ja;&c_t;&c_y;&c_z;&c_m;</ind></trd>
  </trdgrp>
  <trdgrp lng="ca">
    <trd>fer tornar <ind>idiota</ind></trd>,
    <trd>idiotitzar</trd>
  </trdgrp>
  <trd lng="cs">zblbnout <klr>(n&ecaron;koho)</klr></trd>
  <trd lng="de">verbl&ouml;den</trd>
  <trd lng="es">idiotizar</trd>
  <trdgrp lng="fr">
    <trd>rendre <ind>idiot</ind></trd>,
    <trd>abrutir</trd>,
    <trd>cr&eacute;tiniser</trd>
  </trdgrp>
  <trd lng="ja">&#24858;&#12363;&#12395;&#12377;&#12427; 
  <pr>&#12362;&#12429;&#12363;&#12395;&#12377;&#12427;</pr></trd>
  <trd lng="pl">og&lstroke;upia&cacute;</trd>
  <trd lng="pt">idiotizar</trd>
  <trd lng="sk">zblbn&uacute;&tcaron; <klr>(niekoho)</klr></trd>
  <trdgrp lng="uk">
    <trd>&c_r;&c_o;&c_b;&c_i;&c_t;&c_i; &c_ib;&c_d;&c_ib;&c_o;&c_t;&c_o;&c_m;</trd>,
    <trd>&c_p;&c_r;&c_i;&c_z;&c_v;&c_o;&c_d;&c_i;&c_t;&c_i; &c_d;&c_o;
    &c_ib;&c_d;&c_ib;&c_o;&c_t;&c_i;&c_z;&c_m;&c_u;</trd>
  </trdgrp>
</drv>
