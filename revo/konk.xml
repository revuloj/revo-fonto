<kap>
  <ofc>*</ofc>
  <rad>konk</rad>/o
<fnt><bib>UV</bib></fnt></kap>
<drv mrk="konk.0o">
  <kap>
    <ofc>*</ofc><tld/>o
  </kap>
  <snc mrk="konk.0o.tego">
    <uzo tip="fak">ZOO</uzo>
    <dif>
      Kalka tega&jcirc;o de iuj
      <ref tip="malprt" cel="molusk.0oj">moluskoj</ref>:
      <ekz>
	<tld/>o de heliko, mitulo, ostro.
      </ekz>
      <ekz>
	en la kuirejo trovi&gcirc;is abunda provizo da ranoj sur rostostango,
	limakaj <tld/>oj kun far&ccirc;o el infanaj fingroj kaj salatoj el
	semoj de fungoj
	<fnt><bib>Fab2</bib>, <lok>Monteto de elfoj</lok></fnt>
      </ekz>
      <ekz>
	li pripalpu la malgrandan <tld/>on de la limako
	<fnt><bib>Fab2</bib>, <lok>Feli&ccirc;a familio</lok></fnt>
      </ekz>
    </dif>
      <trdgrp lng="fr">
	<trd>coquille</trd>
      </trdgrp>
      <trd lng="hu">kagyl&oacute;h&eacute;j</trd>
      <trd lng="pl">muszla</trd>
      <trd lng="pt">concha <klr tip="amb">(zool.)</klr></trd>
      <trd lng="ro">coaj&abreve;</trd>
  </snc>
  <snc mrk="konk.0o.molusko">
    <uzo tip="stl">KOMUNE</uzo>
    <dif>
      Molusko havanta <tld/>on:
      <ekz>
	la tegmento estas farita el <tld/>oj kiuj sin fermas kaj malfermas
	la&ubreve; la fluo de la akvo
	<fnt><bib>Fab1</bib>, <lok>La virineto de maro</lok></fnt>
      </ekz>
      <ekz>
	en &ccirc;iu <tld/>o ku&scirc;as brilantaj perloj el
	kiuj &ccirc;iu sola jam estus efektiva beliga&jcirc;o en la krono
	de re&gcirc;ino
	<fnt><bib>Fab1</bib>, <lok>La virineto de maro</lok></fnt>
      </ekz>
    </dif>
    <ref tip="malprt" cel="valv.du0uloj">duvalvuloj</ref>
    <trdgrp lng="fr">
      <trd>coquillage</trd>
    </trdgrp>
    <trd lng="hu">kagyl&oacute;</trd>
    <trd lng="pt">concha <klr tip="amb">(zool.)</klr></trd>
  </snc>
  <snc mrk="konk.0o.konkoforma">
    <dif>
      Diversaj <tld/>oformaj objektoj:
      <ekz>
	<tld/>o de la orelo;
      </ekz>
      <ekz>
	marmora <tld/>ego de fontano.
      </ekz>
    </dif>
    <trd lng="ca">pavell&oacute;<klr tip="amb"> (de l&#8217;orella)</klr></trd>
    <trdgrp lng="fr">
      <trd>coquille</trd>
    </trdgrp>
    <trd lng="hu">kagyl&oacute;</trd>
    <trd lng="pl">muszla</trd>
    <trd lng="pt">concha</trd>
    <trd lng="ro">coaj&abreve;</trd>
  </snc>
