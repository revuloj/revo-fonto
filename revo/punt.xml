<?xml version="1.0"?>
<!DOCTYPE vortaro SYSTEM "../dtd/vokoxml.dtd">
<vortaro>
<art mrk="$Id: punt.xml,v 1.25 2026/07/14 06:22:49 revo Exp $">
<kap>
  <ofc>*</ofc>
  <rad>punt</rad>/o
<fnt><bib>UV</bib></fnt></kap>
<drv mrk="punt.0o">
  <kap><ofc>*</ofc><tld/>o</kap>
  <uzo tip="fak">TEKS</uzo>
  <snc mrk="punt.0o.TEKS">
    <dif>
      Maldensa, artisme interspacigita <ref tip="super" cel="teks.0ajxo.TEKS">teksa&jcirc;o</ref>,
      konsistanta en delikata reto el silkaj a&ubreve; linaj fadenoj, servanta kiel fono por flora&jcirc;oj
      a&ubreve; ornama&jcirc;oj faritaj per kudrilo a&ubreve; &scirc;piniletoj:
      <ekz>
        inter la <tld/>oj kaj la brusta banto elstaris la kolo
        <fnt>
          <bib>Fab3</bib>
          <lok>Kolo de botelo</lok>
        </fnt>;
      </ekz>
      <ekz>
        kufo ornamita per <tld/>oj
        <fnt>
          <bib>IK</bib>
        </fnt>;
      </ekz>
      <ekz>
        garnituro da kremkoloraj <tld/>oj
        <fnt>
          <bib>FK</bib>
        </fnt>;
      </ekz>
      <ekz>
        dancistino, kies tuta kostumo konsistis el ora ringo
        sur la kapo kaj el tuko delikata, kiel aranea <tld/>o
        <fnt>
          <bib>Far1</bib>
          <lok>&Ccirc;apitro XIII</lok>
        </fnt>;
      </ekz>
      <ekz>
        <uzo tip="stl">FIG</uzo>
        maro, kiu de &ccirc;iuj flankoj pu&scirc;is siajn kunmiksitajn ondojn kun brilantaj &scirc;a&ubreve;maj <tld/>oj
        <fnt>
          <bib>FdO</bib>
        </fnt>;
      </ekz>
      <ekz>
        marmora ponto, fortika, sed konstruita tiel arte kaj
        delikate, kvaza&ubreve; &gcirc;i estus el <tld/>oj kaj vitraj perloj
        <fnt>
          <bib>Fab1</bib>
          <lok>&Gcirc;ardeno de la paradizo</lok>
        </fnt>.
      </ekz>
    </dif>
  </snc>
  <rim>
    En &leftquot;La Interrompita Kanto&rightquot; tradukita de Kabe
    aperas &leftquot;pinto&rightquot; sinonime kun &leftquot;<tld/>o&rightquot;,
    eble influita de la germana.
  </rim>
  <trd lng="be">&c_k;&c_a;&c_r;&c_u;&c_n;&c_k;&c_ib;</trd>
  <trd lng="bg">&c_d;&c_a;&c_n;&c_t;&c_je;&c_l;&c_a;</trd>
  <trd lng="ca">punta</trd>
  <trd lng="cs">krajka</trd>
  <trd lng="de">Spitze <klr>(Textil)</klr></trd>
  <trd lng="en">lace</trd>
  <trd lng="es">encaje</trd>
  <trd lng="fr">dentelle</trd>
  <trd lng="hu">csipke</trd>
  <trd lng="ja">&#x30EC;&#x30FC;&#x30B9;  <pr>&#x308C;&#x30FC;&#x3059;</pr></trd>
  <trd lng="nl">kant</trd>
  <trd lng="pl">koronka</trd>
  <trdgrp lng="pt">
   <trd>renda (tecido)</trd>
  </trdgrp>
  <trd lng="ru">&c_k;&c_r;&c_u;&c_zh;&c_je;&c_v;&c_o;</trd>
  <trd lng="sk">&ccaron;ipka</trd>
  <trd lng="uk">&c_m;&c_je;&c_r;&c_je;&c_zh;&c_i;&c_v;&c_o;</trd>
  <trdgrp lng="zh">
    <trd>&#x82B1;&#x8FB9; <pr>hu&amacron;bi&amacron;n</pr></trd>,
    <trd>&#x82B1;&#x908A; <pr>hu&amacron;bi&amacron;n</pr></trd>,
    <trd>&#x857E;&#x4E1D; <pr>l&ecaron;is&imacron;</pr></trd>,
    <trd>&#x857E;&#x7D72; <pr>l&ecaron;is&imacron;</pr></trd>
  </trdgrp>
</drv>

<drv mrk="punt.0a">
  <kap>
    <tld/>a
  </kap>
  <snc mrk="punt.0a.TEKS">
    <uzo tip="fak">TEKS</uzo>
    <dif>
      El <tld/>o:
      <ekz>
        vento levis <tld/>an kolumon de mia bluzo
        <fnt>
          <bib>OIP</bib>
          <lok>Ombro sur interna pejza&gcirc;o</lok>
        </fnt>;
      </ekz>
      <ekz>
        sur leda kanapo duonku&scirc;is sinjorino, <klr>[&#x2026;]</klr> en silka, ne tre pura vesto,
        <klr>[&#x2026;]</klr> kaj kun <tld/>a tuko sur la kapo
        <fnt>
          <bib>PatrojFiloj</bib>
          <lok>XIII</lok>
        </fnt>.
      </ekz>
    </dif>

  <trdgrp lng="de">
    <trd>Spitzen- <klr>(Textil)</klr></trd>,
    <trd>aus <ind>Spitze</ind></trd>
  </trdgrp>
  </snc>
  <snc mrk="punt.0a.FIG">
    <dif>
      Kvaza&ubreve; el <tld/>o, filigrana:
      <ekz>
        la <tld/>a teksa&jcirc;o de l' arbaroj
        <fnt>
          <bib>Mizero</bib>
          <lok>I</lok>
        </fnt>;
      </ekz>
      <ekz>
        li rigardis la violkolorajn <tld/>ajn ombrojn de l&#x2019; arboj
        <fnt>
          <bib>Metrop</bib>
        </fnt>;
      </ekz>
      <ekz>
        mi fermas okulojn por porti &gcirc;is la domo <tld/>ajn maizsiluetojn &ccirc;efenestrajn
        <fnt>
          <bib>OIP</bib>
          <lok>Ombro sur interna pejza&gcirc;o</lok>
        </fnt>.
      </ekz>
    </dif>
    <ref tip="vid" cel="ajxur.0a">a&jcirc;ura</ref>
    <trdgrp lng="de">
      <trd>filigran</trd>,
      <trd>durchbrochen</trd>
    </trdgrp>
  </snc>
</drv>

</art>
