<?xml version="1.0"?>
<!DOCTYPE vortaro SYSTEM "../dtd/vokoxml.dtd">
<vortaro>
<art mrk="$Id: altruist.xml,v 1.22 2026/05/14 20:01:29 revo Exp $">
<kap>
  <rad>altruist</rad>/o  <fnt><bib>PIV1</bib></fnt>
</kap>
<drv mrk="altruist.0o">
  <kap><tld/>o</kap>
  <snc>
    <dif>
      <ref tip="vid" cel="altrui.0a">Altruisma</ref> persono,
      mal<ref tip="ant" cel="ego.0isto">egoisto</ref>:
      <ekz>
        homo elstare nobla kaj <tld/>a, sed anka&ubreve; sendepende inteligenta
        <fnt>
          <bib>Plumamikoj</bib>
          <lok>Prozo nefikcia</lok>
        </fnt>;
      </ekz>
      <ekz>
        la longa sinjoro, kiu estis <tld/>o en la plej alta grado, ne pensante pri la
        &jcirc;aluzo
        <fnt>
          <bib>IdO</bib>
          <lok>Kvara Parto</lok>
        </fnt>;
      </ekz>
      <ekz>
        nur tiuj povas tiel pre&gcirc;i, kiuj ebrii&gcirc;as pro
        <tld/>aj celdifinoj de la Amo
        <fnt><aut>J. Baghy</aut>, <vrk>Sur Sanga Tero</vrk>,
        <lok>1933</lok></fnt>.
      </ekz>
    </dif>
    <trd lng="be">&c_a;&c_l;&c_mol;&c_t;&c_r;&c_u;&c_ib;&c_s;&c_t;</trd>
    <trdgrp lng="de">
      <trd>Altruist</trd>,
      <trd>selbstloser Mensch</trd>,
      <trd>uneigenn&uuml;tzige Person</trd>
    </trdgrp>
    <trd lng="en">altruist</trd>
    <trd lng="es">altruista</trd>
    <trd lng="fr">altruiste<klr tip="ind"> (subst.)</klr></trd>
    <trdgrp lng="hu">
      <trd>&ouml;nzetlen ember</trd>,
      <trd>altruista</trd>
    </trdgrp>
    <trd lng="pl">altruista</trd>
    <trd lng="ru">&c_a;&c_l;&c_mol;&c_t;&c_r;&c_u;&c_i;&c_s;&c_t;</trd>
    <trd lng="sk">altruista</trd>
  </snc>
  <rim>
    La&ubreve; <fnt><bib>BL</bib></fnt>: Prefere diru <ke>bonfaranto</ke>.
  </rim>

  <trdgrp lng="cs">
    <trd>altruista</trd>,
    <trd>nezi&scaron;tn&yacute; &ccaron;lov&ecaron;k</trd>
  </trdgrp>
  <trd lng="he">&alef;&lamed;&tet;&resh;&vav;&alef;&yod;&samekh;&tet;</trd>
  <trd lng="ja">&#x5229;&#x4ED6;&#x4E3B;&#x7FA9;&#x8005;  <pr>&#x308A;&#x305F;&#x3057;&#x3085;&#x304E;&#x3057;&#x3083;</pr></trd>
  <trd lng="sk">nezi&scaron;tn&yacute; &ccaron;lovek</trd>
  <trd lng="uk">&c_a;&c_l;&c_mol;&c_t;&c_r;&c_u;&c_ji;&c_s;&c_t;</trd>
</drv>
</art>
