<?xml version="1.0"?>
<!DOCTYPE vortaro SYSTEM "../dtd/vokoxml.dtd">
<vortaro>
<art mrk="$Id: bulk.xml,v 1.31 2026/06/14 16:00:24 revo Exp $">
<kap>
  <ofc>*</ofc> <rad>bulk</rad>/o<fnt><bib>UV</bib></fnt>
</kap>
<drv mrk="bulk.0o">
  <kap><ofc>*</ofc><tld/>o</kap>
  <snc mrk="bulk.0o.paneto">
    <uzo tip="fak">KUI</uzo>
    <dif>
      <ref tip="super" cel="pan.0o">Paneto</ref>, pankuko el pli malpli
      delikata faruno:
      <ekz>
        oni disdonadis <tld/>ojn kaj <ref tip="vid" cel="kring.0o">kringo</ref>jn
        <fnt>
          <bib>Fab1</bib>
          <lok>Fluganta kofro</lok>
        </fnt>;
      </ekz>
      <ekz>
        oni a&ccirc;etis &ccirc;e la <tld/>isto spesdekan <ref tip="vid" cel="kraken.0o">krakeno</ref>n, oni
        ricevis kiel
        aldonon ses grandajn <tld/>ojn, kaj tiuj <tld/>oj e&ccirc; estis kun sekvinberoj
        <fnt>
          <bib>Fab1</bib>
          <lok>Vojkamarado</lok>
        </fnt>;
      </ekz>
      <ekz>
        &scirc;i opiniis, ke per glaso da lakto kaj per kelke da <tld/>oj &ccirc;iutage &scirc;i povos dum
        kelka tempo sufi&ccirc;e subteni siajn fortojn
        <fnt>
          <bib>Marta</bib>
        </fnt>;
      </ekz>
      <ekz>
        kiu ne preferus tritikan <tld/>on, ol hordean
        <fnt>
          <bib>Far2</bib>
          <lok>&Ccirc;apitro 9a</lok>
        </fnt>?
      </ekz>
      <ekz>
        mi scias, ke kio en mia familio nomi&gcirc;as &leftquot;<tld/>o&rightquot;, ne aspektas
        kiel la &leftquot;<tld/>o&rightquot; de iu familio alilanda
        <fnt>
          <bib>HejmVort</bib>
          <lok>&ccirc;ap. &leftquot;Kiel uzi la vortaron&rightquot;</lok>
        </fnt>.
      </ekz>
    </dif>
    <ref tip="sub" cel="skon.0o">skono</ref>
    <trd lng="zh">&#23567;&#38754;&#21253; <pr>xi&#462;omi&agrave;nb&amacron;o</pr></trd>
  </snc>
  <trd lng="be">&c_b;&c_u;&c_l;&c_k;&c_a;</trd>
  <trd lng="bg">&c_h;&c_l;&c_je;&c_b;&c_ch;&c_je;</trd>
  <trd lng="ca">panet</trd>
  <trd lng="cs">houska</trd>
  <trd lng="de">Br&ouml;tchen</trd>
  <trdgrp lng="en">
    <trd>roll</trd>,
    <trd>bun</trd>
  </trdgrp>
  <trd lng="es">panecillo</trd>
  <trd lng="fr">petit <ind>pain</ind></trd>
  <trd lng="he">&lamed;&het;&mem;&nun;&yod;&he;</trd>
  <trd lng="hu">zsemlye</trd>
  <trdgrp lng="ja">
    <trd>&#12525;&#12540;&#12523;&#12497;&#12531;</trd>,
    <trd>&#33747;&#23376;&#12497;&#12531;  <pr>&#12363;&#12375;&#12497;&#12531;</pr></trd>
  </trdgrp>
  <trd lng="nl">broodje</trd>
  <trd lng="pl">bu&lstroke;ka</trd>
  <trd lng="pt">p&atilde;ozinho</trd>
  <trd lng="ro">franzel&abreve;</trd>
  <trdgrp lng="ru">
    <trd>&c_b;&c_u;&c_l;&c_k;&c_a;</trd>,
    <trd>&c_h;&c_l;&c_je;&c_b;&c_je;&c_c;</trd>
  </trdgrp>
    <trdgrp lng="sk">
    <trd>pletenka</trd>,
    <trd>&zcaron;em&lcaron;a</trd>
  </trdgrp>
  <trdgrp lng="uk">
    <trd>&c_b;&c_u;&c_l;&c_k;&c_a;</trd>,
    <trd>&c_h;&c_l;&c_ib;&c_b;&c_je;&c_c;&c_mol;</trd>
  </trdgrp>
</drv>

<drv mrk="bulk.korno0o">
  <kap>korno<tld/>o,
  <var><kap>korn<tld/>o</kap></var>,
  <var><kap>korna <tld/>o</kap></var>,
  <var><kap>lunarka <tld/>o</kap></var>
  </kap>
  <snc mrk="bulk.korno0o.KUI">
    <uzo tip="fak">KUI</uzo>
    <dif>
      <ref tip="super" cel="bulk.0o.paneto"><tld lit="B"/>o</ref>
      kuirita en formo kurba kaj dupinta:
      <ekz>
        la patrino ekiris, por a&ccirc;eti fre&scirc;ajn korn<tld/>ojn &ccirc;e la panvendejo
        <fnt>
          <aut>J. Sigmond</aut>
          <vrk><url ref="https://verkoj.com/verkistoj/julia-sigmond/alfi/">Alfi</url></vrk>
          <lok>2017</lok>
        </fnt>;
      </ekz>
      <ekz>
        butera korno<tld/>o
        <fnt>
          <aut>F. Moln&aacute;r, trad. J. Horvath</aut>
          <vrk><url ref="https://verkoj.com/tradukistoj/jozefo-horvath/jocxjo_kpl.pdf">
          Jo&ccirc;jo kaj aliaj komedietoj</url></vrk>
          <lok>2025</lok>
        </fnt>;
      </ekz>
      <ekz>
        iu viro permesas, ke ni tendumu sur lia tereno, kaj li matene donacas al ni lunarkan
        <tld/>on
        <fnt>
          <aut>Cirilo kaj Roz'</aut>
          <vrk><url ref="https://www.horizonto.net/vojo2/homoj-bonfarantoj-01.html">
          Niaj Bonfarantoj</url></vrk>
          <lok>[vidita en 2026]</lok>
        </fnt>.
      </ekz>
    </dif>
  </snc>
  <trd lng="ca">croissant</trd>
  <trd lng="fr">croissant<klr> (p&acirc;tisserie)</klr></trd>
</drv>
</art>
