   <rad>&scirc;par</rad>/i <fnt><bib>UV</bib></fnt>
</kap>

<drv mrk="sxpar.0i">
  <kap><ofc>*</ofc><tld/>i</kap>
  <gra><vspec>tr</vspec></gra>
  <snc mrk="sxpar.0i.kolekti">
    <dif>
      Kolekti provizon de io, precipe de mono, danke al
      modera elspezo a&ubreve; uzo:
      <ekz>
        <tld/>inte kelkajn dolarojn <klr>[&#x2026;]</klr> mi edzi&gcirc;is kun mia Mario
        <fnt>
          <bib>FK</bib>
          <lok>Fundamenta Krestomatio de la lingvo Esperanto</lok>
        </fnt>;
      </ekz>
      <ekz>
        vi volis <tld/>i la monon, pagatan al la gardistoj
        <fnt>
          <bib>Far2</bib>
          <lok>&Ccirc;apitro XV</lok>
        </fnt>;
      </ekz>
      <ekz>
        kiu<klr>[&#x2026;]</klr> povas <tld/>i iom da mono, komencas preparigadi al la estonta
        kongreso esperantista
        <fnt>
          <bib>Paroloj</bib>
          <vrk>Parolado anta&ubreve; la Kvina Kongreso Esperantista en Barcelona en la 6a de septembro
          1909</vrk>
        </fnt>;
      </ekz>
      <ekz>
        &scirc;i prenis interdoman, solecan vojeton por <tld/>i tempon
        <fnt>
          <bib>I&scirc;tar</bib>
          <lok>&Ccirc;apitro XIII</lok>
        </fnt>;
      </ekz>
      <ekz>
        vi devas <tld/>i viajn kisojn por via edzo
        <fnt>
          <bib>KKl</bib>
          <lok>&Ccirc;apitro 6</lok>
        </fnt>;
      </ekz>
      <ekz>
        iomete <tld/>i, iomete dividi
        <fnt>
          <bib>LGA</bib>
          <lok>I.</lok>
        </fnt>;
      </ekz>
      <ekz>
        se vi ne <tld/>is &gcirc;is nun e&ccirc; por sentrua mantelo, viaj meritoj ne estas ver&scirc;ajne
        eminentaj
        <fnt>
          <bib>QuV</bib>
          <lok>&Ccirc;apitro XIII</lok>
        </fnt>;
      </ekz>
      <ekz>
        bonan vorton <klr>[&#x2026;]</klr> <tld/>u por amato de la dioj
        <fnt>
          <bib>Ifigenio</bib>
          <lok>Ifigenio en Ta&ubreve;rido</lok>
        </fnt>!
      </ekz>
      <ekz>
         <tld/>u gro&scirc;on, vi havos plenan po&scirc;on
         <fnt><bib>PrV</bib></fnt>;
      </ekz>
      <ekz>
         <tld/>u kiam bone, vi havos kiam bezone
         <fnt><bib>PrV</bib></fnt>;
      </ekz>
      <ekz>
         <ind>vivi de <tld/>ita kaso</ind>
         <trd lng="fr">vivre sur ses r&eacute;serves</trd>
         <fnt><bib>PrV</bib></fnt>.
      </ekz>
    </dif>
    <refgrp tip="vid">
       <ref cel="rezerv.0i">rezervi</ref>
    </refgrp>
    <trd lng="hu">megtakar&iacute;t</trd>
    <trdgrp lng="pl">
       <trd>oszcz&eogonek;dza&cacute;</trd>,
       <trd>ciu&lstroke;a&cacute;</trd>
    </trdgrp>
  </snc>
  <snc mrk="sxpar.0i.moderi">
    <dif>
      Modere kaj singarde uzi;
      <ref tip="sin" cel="domagx.0i.avari">doma&gcirc;i</ref>:
      <ekz>
        la mastro ne <tld/>is la po&scirc;on de la junulo kaj diris, ke li devas aldoni
        ankora&ubreve; du orajn monerojn
        <fnt>
          <bib>ElektFab</bib>
          <lok>Tablo , la orazeno kaj bastono el sako</lok>
        </fnt>;
      </ekz>
      <ekz>
        la senlaca loka organiza komitato <klr>[&#x2026;]</klr> ne <tld/>is laboron por la plej
        bona aran&gcirc;o de nia kongreso
        <fnt>
          <bib>Paroloj</bib>
          <vrk>Parolado anta&ubreve; la Oka Kongreso Esperantista en Krakow en la 11a de a&ubreve;gusto 1912</vrk>
        </fnt>;
      </ekz>
      <ekz>
        la edzino ne <tld/>is vortojn, nek mildajn nek akrajn
        <fnt>
          <bib>HsT</bib>
          <lok>Feli&ccirc;a homo</lok>
        </fnt>;
      </ekz>
      <ekz>
        oni povas sekve tre mallongigi al si la vojon, <klr>[&#x2026;]</klr> per tio mi
        <tld/>as ja preska&ubreve; duonmejlon
        <fnt>
          <bib>Fab1</bib>
          <lok>Malgranda Niko kaj granda Niko</lok>
        </fnt>;
      </ekz>
      <ekz>
        kiu <tld/>as sian vergon, tiu malamas sian filon
        <fnt>
          <bib>MT</bib>
          <lok>Sentencoj 13:24</lok>
        </fnt>;
      </ekz>
      <ekz>
        <tld/>u viajn malbenojn
        <fnt>
          <bib>MrA</bib>
          <lok>&Ccirc;apitro X</lok>
        </fnt>;
      </ekz>
      <ekz>
         vortojn <tld/>u, agojn faru
         <fnt><bib>PrV</bib></fnt>.
       </ekz>
     </dif>
     <refgrp tip="vid">
     <ref cel="avar.0i.elspezi">avari<sncref/></ref>
    </refgrp>
    <trd lng="en">to be <ind>sparing</ind> of</trd>
    <trd lng="hu">takar&eacute;koskodik</trd>
    <trd lng="pl">oszcz&eogonek;dza&cacute;</trd>
  </snc>
  <snc mrk="sxpar.0i.indulgi">
    <uzo tip="klr">(al iu)</uzo>
    <dif>
      Indulge, kompate evitigi; <ref tip="dif" cel="sxpar.0igi">&scirc;parigi</ref>:
      <ekz>
        mi diris nenion, por <tld/>i al vi &ccirc;agrenon
        <fnt>
          <bib>Far3</bib>
          <lok>&Ccirc;apitro XVI</lok>
        </fnt>;
      </ekz>
      <ekz>
        Tualeton &scirc;i ne faras, &parsl; Kaj &scirc;i tiel al la patro &parsl; &Ccirc;iujare sumojn <tld/>as
        <fnt>
          <bib>LSB</bib>
          <lok>Vila&gcirc;anino</lok>
        </fnt>;
      </ekz>
      <ekz>
        gloro estu al la dioj orientaj kaj okcidentaj, ke vi eliris viva <klr>[&#x2026;]</klr>
        oni <tld/>is vin certe tial, &ccirc;ar vi estas patricio
        <fnt>
          <bib>QuV</bib>
          <lok>&Ccirc;apitro XXVIII</lok>
        </fnt>;
      </ekz>
      <ekz>
        li nur petegis Kriston, ke Li <tld/>u al <nom>Ligia</nom> la cirkan turmenton kaj lasu &scirc;in
        endormi&gcirc;i trankvile en la malliberejo
        <fnt>
          <bib>QuV</bib>
          <lok>&Ccirc;apitro LXIV</lok>
        </fnt>.
      </ekz>
    </dif>
    <refgrp tip="vid">
      <ref cel="domagx.0i.kompati">doma&gcirc;i<sncref/></ref>,
      <ref cel="indulg.0i">indulgi</ref>,
      <ref cel="kompat.0i">kompati</ref>
    </refgrp>
    <trdgrp lng="de">
      <trd>aussparen</trd>,
      <trd><klr>(jmd. etwas) </klr>ersparen</trd>,
      <trd>verschonen</trd>
    </trdgrp>
  </snc>
   <trdgrp lng="be">
     <trd>&c_a;&c_sh;&c_ch;&c_a;&c_d;&c_zh;&c_a;&c_c;&c_mol;</trd>,
     <trd>&c_z;&c_a;&c_h;&c_o;&c_w;&c_v;&c_a;&c_c;&c_mol;</trd>,
     <trd>&c_z;&c_mol;&c_b;&c_je;&c_r;&c_a;&c_g;&c_a;&c_c;&c_mol;</trd>,
     <trd>&c_e;&c_k;&c_a;&c_n;&c_o;&c_m;&c_ib;&c_c;&c_mol;</trd>
   </trdgrp>
   <trdgrp lng="ca">
    <trd>estalviar</trd>,
    <trd>economitzar</trd>,
    <trd>alforrar</trd>
  </trdgrp>
  <trd lng="de">sparen</trd>
   <trdgrp lng="en">
     <trd>spare</trd>,
     <trd>save</trd>,
     <trd><ind>keep</ind> for future use</trd>
   </trdgrp>
   <trd lng="es">ahorrar</trd>
   <trdgrp lng="fr">
     <trd>&eacute;conomiser</trd>,
     <trd>&eacute;pargner</trd>
   </trdgrp>
   <trdgrp lng="id">
     <trd><baz>cermat</baz>mencermati</trd>,
     <trd><baz>hemat</baz>menghemat</trd>,
     <trd><baz>hemat</baz>menghemati</trd>,
     <trd><baz>irit</baz>mengirit</trd>
   </trdgrp>
   <trdgrp lng="it">
     <trd>economizzare</trd>,
     <trd>risparmiare</trd>
   </trdgrp>
   <trd lng="nl">sparen</trd>
   <trdgrp lng="pt">
     <trd>economizar</trd>,
     <trd>poupar</trd>
   </trdgrp>
   <trdgrp lng="ru">
     <trd>&c_s;&c_b;&c_je;&c_r;&c_je;&c_g;&c_a;&c_t;&c_mol;</trd>,
     <trd>&c_e;&c_k;&c_o;&c_n;&c_o;&c_m;&c_i;&c_t;&c_mol;</trd>
   </trdgrp>
   <trd lng="sv">spara</trd>
  <trdgrp lng="zh">
    <trd>&#x7BC0;&#x7701; <pr>ji&eacute;sh&ecaron;ng</pr></trd>,
    <trd>&#x8282;&#x7701; <pr>ji&eacute;sh&ecaron;ng</pr></trd>,
    <trd>&#x7BC0;&#x7D04; <pr>ji&eacute;yu&emacron;</pr></trd>,
    <trd>&#x8282;&#x7EA6; <pr>ji&eacute;yu&emacron;</pr></trd>,
    <trd>&#x79EF;&#x84C4; <pr>j&imacron;x&ugrave;</pr></trd>,
    <trd>&#x7A4D;&#x84C4; <pr>j&imacron;x&ugrave;</pr></trd>,
    <trd>&#x7701;&#x9322; <pr>sh&ecaron;ngqi&aacute;n</pr></trd>,
    <trd>&#x7701;&#x94B1; <pr>sh&ecaron;ngqi&aacute;n</pr></trd>,
    <trd>&#x7701;&#x53BB; <pr>sh&ecaron;ngq&ugrave;</pr></trd>
  </trdgrp>
</drv>

<drv mrk="sxpar.0ajxo">
  <kap><tld/>a&jcirc;o</kap>
  <snc mrk="sxpar.0ajxo.EKON">
    <dif>
      Tio, kion oni <tld/>is:
      <ekz>
        la lastaj <tld/>a&jcirc;oj jam konsumi&gcirc;is
        <fnt>
          <aut>F. Ko&zcaron;&iacute;k, trad. J. Karen kaj J. Vondrou&scaron;ek</aut>,
          <vrk>La plej eminenta inter Pierotoj</vrk>,
          <lok>2001</lok>
        </fnt>;
      </ekz>
      <ekz>
        Matildo sen&scirc;ancele forlasis siajn tutajn <tld/>a&jcirc;ojn de fra&ubreve;lino
        <klr>(vd <ref cel="dot.0o">doto</ref>)</klr>
        <fnt>
          <bib>KPr</bib>
          <lok>&Ccirc;apitro Na&ubreve;a</lok>
        </fnt>;
      </ekz>
      <ekz>
        en tia entrepreno trovi&gcirc;as tiom da eblaj surpriza&jcirc;oj, ke estas <klr>[&#x2026;]</klr>
        krimo, englutigi en &gcirc;in la <tld/>a&jcirc;ojn de neri&ccirc;uloj
        <fnt>
          <bib>ChL</bib>
          <lok>&Ccirc;apitro Unua</lok>
        </fnt>.
      </ekz>
    </dif>
  </snc>
  <trd lng="be">&c_a;&c_sh;&c_ch;&c_a;&c_d;&c_zh;&c_a;&c_n;&c_n;&c_je;
  <klr>(&c_s;&c_r;&c_o;&c_d;&c_k;&c_ib;)</klr></trd>
  <trdgrp lng="ca">
    <trd>estalvis <klr>(pl)</klr></trd>,
    <trd>estalvi</trd>
  </trdgrp>
  <trdgrp lng="de">
    <trd>Ersparnisse</trd>,
    <trd>Sparguthaben</trd>
  </trdgrp>
  <trdgrp lng="fr">
    <trd>&eacute;conomies<klr> (&eacute;pargne)</klr></trd>,
    <trd>&eacute;pargne</trd>
  </trdgrp>
  <trdgrp lng="id">
    <trd>simpanan</trd>,
    <trd>tabungan</trd>
  </trdgrp>
  <trdgrp lng="ja">
    <trd>&#x305F;&#x304F;&#x308F;&#x3048;</trd>,
    <trd>&#x8CAF;&#x84C4;  <pr>&#x3061;&#x3087;&#x3061;&#x304F;</pr></trd>
  </trdgrp>
  <trd lng="pl">oszcz&eogonek;dno&sacute;ci</trd>
  <trd lng="uk">&c_z;&c_a;&c_o;&c_shch;&c_a;&c_d;&c_zh;&c_je;&c_n;&c_n;&c_ja;</trd>
  <trdgrp lng="zh">
    <trd>&#x79EF;&#x84C4; <pr>j&imacron;x&ugrave;</pr></trd>,
    <trd>&#x7A4D;&#x84C4; <pr>j&imacron;x&ugrave;</pr></trd>,
    <trd>&#x50A8;&#x84C4; <pr>ch&#x1D4;x&ugrave;</pr></trd>,
    <trd>&#x5132;&#x84C4; <pr>ch&#x1D4;x&ugrave;</pr></trd>
  </trdgrp>
</drv>

<drv mrk="sxpar.0ema">
  <kap><ofc>*</ofc><tld/>ema</kap>
  <snc mrk="sxpar.0ema.KOMUNE">
    <dif>
      Ne elspezema:
      <ekz>
        lia edzino estas tre laborema kaj <tld/>ema, sed &scirc;i estas anka&ubreve;
        tre babilema kaj kriema
        <fnt><bib>F</bib>, <lok>&FE; 41</lok></fnt>;
      </ekz>
      <ekz>
        pro <tld/>emeco ne lumigante la lampon
        <fnt>
          <bib>Marta</bib>
        </fnt>;
      </ekz>
      <ekz>
        kontentigante siajn bezonojn <klr>[&#x2026;]</klr> pli <tld/>eme ol &gcirc;is nun, &scirc;i povis
        kun tiaj enspezoj vivi kun sia infano
        <fnt>
          <bib>Marta</bib>
        </fnt>;
      </ekz>
      <ekz>
        <tld/>ema <klr>(&scirc;pariga)</klr> ma&scirc;ino, inventita de laboristo
        <fnt>
          <bib>Metrop</bib>
        </fnt>.
      </ekz>
    </dif>
    <refgrp tip="vid">
      <ref cel="avar.0a.elspezi">avara<sncref/></ref>
    </refgrp>
  </snc>
   <trdgrp lng="be">
     <trd>&c_a;&c_sh;&c_ch;&c_a;&c_d;&c_n;&c_y;</trd>,
     <trd>&c_b;&c_je;&c_r;&c_a;&c_zh;&c_l;&c_ib;&c_v;&c_y;</trd>,
     <trd>&c_e;&c_k;&c_a;&c_n;&c_o;&c_m;&c_n;&c_y;</trd>
   </trdgrp>
   <trdgrp lng="ca">
    <trd>estalviador</trd>,
    <trd>economitzador</trd>,
    <trd>alforrador</trd>
  </trdgrp>
  <trdgrp lng="de">
     <trd>sparsam</trd>
   </trdgrp>
   <trdgrp lng="en">
     <trd>saving</trd>,
     <trd>economical</trd>,
     <trd>frugal</trd>,
     <trd>thrifty</trd>
   </trdgrp>
   <trd lng="es">ahorrador</trd>
   <trd lng="fr">&eacute;conome<klr> (adj.)</klr></trd>
   <trd lng="hu">takar&eacute;kos</trd>
   <trdgrp lng="id">
     <trd>cermat</trd>,
     <trd>ekonomis</trd>,
     <trd>hemat</trd>,
     <trd>irit</trd>
   </trdgrp>
   <trdgrp lng="ja">
    <trd>&#x3064;&#x307E;&#x3057;&#x3044;</trd>,
    <trd>&#x7BC0;&#x7D04;&#x5BB6;&#x306E;  <pr>&#x305B;&#x3064;&#x3084;&#x304F;&#x304B;&#x306E;</pr></trd>,
    <trd>&#x7269;&#x60DC;&#x3057;&#x307F;&#x3059;&#x308B;  <pr>&#x3082;&#x306E;&#x304A;&#x3057;&#x307F;&#x3059;&#x308B;</pr></trd>
  </trdgrp>
  <trd lng="nl">zuinig</trd>
   <trd lng="pl">oszcz&eogonek;dny</trd>
   <trd lng="ru">&c_b;&c_je;&c_r;&c_je;&c_zh;&c_l;&c_i;&c_v;&c_y;&c_j;</trd>
  <trd lng="uk">&c_o;&c_shch;&c_a;&c_d;&c_l;&c_i;&c_v;&c_i;&c_j;</trd>
  <trdgrp lng="zh">
    <trd>&#x505A;&#x4EBA;&#x5BB6; <pr>zu&ograve;r&eacute;nji&amacron;</pr></trd>,
    <trd>&#x4ECE;&#x4FED; <pr>c&oacute;ngji&#x1CE;n</pr></trd>,
    <trd>&#x5F9E;&#x5109; <pr>c&oacute;ngji&#x1CE;n</pr></trd>,
    <trd>&#x6709;&#x7BC0;&#x5236; <pr>y&#x1D2;uji&eacute;zh&igrave;</pr></trd>,
    <trd>&#x6709;&#x8282;&#x5236; <pr>y&#x1D2;uji&eacute;zh&igrave;</pr></trd>,
    <trd>&#x4FED; <pr>ji&#x1CE;n</pr></trd>,
    <trd>&#x5109; <pr>ji&#x1CE;n</pr></trd>
  </trdgrp>
</drv>

<drv mrk="sxpar.0igi">
  <kap><tld/>igi</kap>
  <snc mrk="sxpar.0igi.ebligi">
    <dif>
      Ebligi, ke iu <tld/>u ion:
      <ekz>
        mi tuj skribis al li, <klr>[&#x2026;]</klr> ke mi atendas la duan leteron nur post du
        monatoj, tiel mi volis <tld/>igi al li lian tempon
        <fnt>
          <bib>IdO</bib>
          <lok>Unua Parto</lok>
        </fnt>;
      </ekz>
      <ekz>
        ni <tld/>igos, pere de la plej modernaj perfektigoj, al la sovetia &scirc;tato 50
        milionojn &ccirc;iujare
        <fnt>
          <bib>Metrop</bib>
        </fnt>;
      </ekz>
      <ekz>
        grenplanto, kiu nature forpelus afidojn, <klr>[&#x2026;]</klr> <tld/>igus insekticidon,
        laboron kaj monon
        <fnt>
          <bib>Monato</bib>
          <aut>Joyce Bunting</aut>
          <vrk><url ref="&Monato;/2013/010846.php"
              >Taktiko por noveca tritiko</url></vrk>
          <lok>2013</lok>
        </fnt>.
      </ekz>
    </dif>
  <trd lng="be">&c_d;&c_a;&c_c;&c_mol; &c_m;&c_a;&c_g;&c_ch;&c_y;&c_m;&c_a;&c_s;&c_mol;&c_c;&c_mol; <ind>&c_z;&c_mol;&c_b;&c_je;&c_r;&c_a;&c_g;&c_ch;&c_y;</ind></trd>
  <trdgrp lng="id">
    <trd><baz>cermat</baz>mencermati</trd>,
    <trd><baz>hemat</baz>menghemat</trd>,
    <trd><baz>hemat</baz>menghemati</trd>,
    <trd><baz>irit</baz>mengirit</trd>
  </trdgrp>
  </snc>
  <snc mrk="sxpar.0igi.evitigi">
    <uzo tip="stl">FIG</uzo>
    <dif>
      <ref tip="super" cel="evit.0igi">Evitigi</ref> ion malbonan al iu:
      <ekz>
         ni volis <tld/>i al li tiun dolorigan baton;
      </ekz>
      <ekz>
         <tld/>igi al &scirc;i larmojn;
      </ekz>
      <ekz>
        kion vi nomas honesta? <klr>[&#x2026;]</klr> liberigi Dion de kelkaj tedaj pensiuloj,
        <tld/>igi al li militon
        <fnt>
          <bib>Rabistoj</bib>
          <lok>Akto Unua</lok>
        </fnt>.
      </ekz>
    </dif>
    <refgrp tip="vid">
      <ref cel="domagx.0i.kompati">doma&gcirc;i<sncref/></ref>,
      <ref cel="indulg.0i">indulgi</ref>,
      <ref cel="kompat.0i">kompati</ref>,
      <ref cel="sxpar.0i.indulgi">&scirc;pari<sncref/></ref>
    </refgrp>
    <trdgrp lng="be">
     <trd>&c_z;&c_mol;&c_b;&c_je;&c_r;&c_a;&c_g;&c_ch;&c_y;</trd>,
     <trd>&c_u;&c_p;&c_ib;&c_l;&c_mol;&c_n;&c_a;&c_v;&c_a;&c_c;&c_mol;</trd>,
     <trd>&c_u;&c_s;&c_mol;&c_c;&c_je;&c_r;&c_a;&c_g;&c_ch;&c_y;</trd>
    </trdgrp>
    <trd lng="ca">estalviar <klr>(a alg&uacute; alguna cosa)</klr></trd>
    <trdgrp lng="en">
      <trd>spare</trd>,
      <trd>save</trd>
    </trdgrp>
    <trdgrp lng="fr">
     <trd>&eacute;pargner<klr> (quelque chose &agrave;
quelqu'un)</klr></trd>
    </trdgrp>
    <trd lng="hu">megk&iacute;m&eacute;l<klr tip="ind"> (vkit
vmit&odblac;l)</klr></trd>
