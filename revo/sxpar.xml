      </ekz>
      <ekz>
         por kio ni vane mal<tld/>as tempon
         <fnt>
           <aut>I. Efremov, trad. J. Finkel</aut>,
           <vrk><url ref="http://www.esperanto.mv.ru/Efremov/horo.html">
           Horo de Bovo</url></vrk>,
           <lok>2005-2011</lok>
         </fnt>;
       </ekz>
