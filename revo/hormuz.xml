<?xml version="1.0"?>
<!DOCTYPE vortaro SYSTEM "../dtd/vokoxml.dtd">

<vortaro>
  <art mrk="$Id: hormuz.xml,v 1.1 2026/04/18 18:41:48 afido Exp $">
    <kap>
      <rad>Hormuz</rad>/o,
      <var><kap><rad var="O">Ormuz</rad>/o</kap></var>
    </kap>

<drv mrk="hormuz.0o">
  <kap><tld/>o, <var><kap><tld var="O"/>o</kap></var></kap>
  <snc>
    <uzo tip="fak">HIS</uzo>
    <dif>
      Antikva havenurbo proksime de la hodia&ubreve;a urbo <nom>Minab</nom>, kaj samnoma re&gcirc;lando (10a - 17a jc).
    </dif>
    <trd lng="de">Ormus</trd>
    <trd lng="en">Hormuz</trd>
    <trd lng="ru">&c_O;&c_r;&c_m;&c_u;&c_z;</trd>
  </snc>
  <snc mrk="hormuz.0o.insulo">
    <uzo tip="fak">GEOG</uzo>
    <dif>
      Insulo en la <tld/>a Markolo, al kiu transloki&gcirc;is la &ccirc;efurbo de la re&gcirc;lando en la 14a
      jc, 8&#x202F;km sude de la irana marbordo:
      <ekz>
        <nom>William Baffin</nom> <klr>[&#x2026;]</klr> mortis &ccirc;e <tld/>o, kiam trafis lin kanona kuglo
        <fnt>
          <bib>Viki</bib>
          <lok><url ref="https://eo.wikipedia.org/?curid=42178"
              >William Baffin</url></lok>
        </fnt>.
      </ekz>
    </dif>
    <trd lng="de">Hormus</trd>
  </snc>
</drv>

<drv mrk="hormuz.0a_Markolo">
  <kap>
    <tld/>a Markolo
  </kap>
  <snc>
    <dif>
      <ref tip="super" cel="kol.mar0o">Markolo</ref> liganta la Omanan kun la Persa Golfo:
      <ekz>
        <nom>Trump</nom> en klara maniero anoncis <klr>[ke]</klr> kun la markolo de <tld/>o kaj la
        saud-arabaj instala&jcirc;oj en flamoj, la timemaj klientoj povus esti bone
        konsilitaj se ili a&ccirc;etas usonajn energiojn
        <fnt>
          <aut>Manuel E. Yepe, trad. Vilhelmo Lutermano</aut>
          <vrk><url ref="https://esperanto.mv.ru/komunistoj/art/yepe_2010_10_19.html"
              >Kiu profitis la atakon kontra&ubreve; Saud-Arabujo?</url></vrk>
        </fnt>.
      </ekz>
    </dif>
  </snc>
  <trd lng="ar">&a_m;&a_D;&a_y;&a_q; &a_h;&a_r;&a_m;&a_z;</trd>
  <trd lng="de">Stra&szlig;e von Hormus</trd>
  <trd lng="en">strait of Hormus</trd>
  <trd lng="fa">&a_t;&a_n;&f_g;&a_h; &a_h;&a_r;&a_m;&a_z;</trd>
</drv>

  </art>

