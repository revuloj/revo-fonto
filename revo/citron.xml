<?xml version="1.0"?>
<!DOCTYPE vortaro SYSTEM "../dtd/vokoxml.dtd">
<vortaro>
<art mrk="$Id: citron.xml,v 1.40 2026/05/17 12:00:21 revo Exp $">
<kap>
<ofc>*</ofc>
<rad>citron</rad>/o
<fnt><bib>UV</bib></fnt></kap>

<drv mrk="citron.0o">
  <kap><tld/>o</kap>
  <snc>
    <uzo tip="fak">KUI</uzo>
    <dif>
      Hele flava, ovoforma, acidsuka <ref tip="super" cel="frukt.0o">frukto</ref> de <tld/>ujo:
      <ekz>
        la bonodoro de <tld/>oj
        <fnt>
          <bib>MT</bib>
          <lok>Alta kanto 7:8</lok>
        </fnt>;
      </ekz>
      <ekz>
        en la arbaroj pendis <tld/>oj kaj oran&gcirc;oj
        <fnt>
          <bib>Fab1</bib>
          <lok>Elinjo-fingreto</lok>
        </fnt>;
      </ekz>
      <ekz>
        la unua floro bezonis &gcirc;uste unu jaron, por ke ni povu rikolti la
        unuan <tld/>on
        <fnt>
          <bib>Monato</bib>
          <aut>Sigmond J&uacute;lia</aut>
          <vrk><url ref="&Monato;/2007/008896.php">Sep
          citronsemoj</url></vrk>
        </fnt>;
      </ekz>
      <ekz>
        estas malfacile kompari pomojn kun <tld/>oj
        <fnt>
          <bib>Monato</bib>
          <aut>Petro Desmet'</aut>
          <vrk><url ref="&Monato;/2007/009302.php">La
          dika Krause? ... kredu min, sinjorino!</url></vrk>
        </fnt>.
      </ekz>
    </dif>
  </snc>
  <trd lng="be">&c_l;&c_ib;&c_m;&c_o;&c_n;</trd>
  <trd lng="bg">&c_l;&c_i;&c_m;&c_o;&c_n;</trd>
  <trdgrp lng="br">
    <trd>suraval</trd>,
    <trd>sitron</trd>
  </trdgrp>
  <trdgrp lng="ca">
    <trd>llimona</trd>,
    <trd>llima</trd>,
    <trd>llim&oacute;</trd>
  </trdgrp>
  <trd lng="cs">citr&oacute;n</trd>
  <trd lng="de">Zitrone</trd>
  <trd lng="el">&lambda;&epsilon;&my;&omikron_ton;&ny;&jota;</trd>
  <trd lng="en">lemon</trd>
  <trd lng="es">lim&oacute;n</trd>
  <trd lng="fr">citron</trd>
  <trd lng="he">&lamed;&yod;&mem;&vav;&fnun;</trd>
  <trd lng="hu">citrom</trd>
  <trdgrp lng="id">
    <trd>jeruk sitrun</trd>,
    <trd>lemon</trd>,
    <trd>limau</trd>,
    <trd>limun</trd>,
    <trd>sitrun</trd>
  </trdgrp>
  <trd lng="it">limone<klr> (frutto)</klr></trd>
  <trdgrp lng="ja">
    <trd>&#12524;&#12514;&#12531;  <pr>&#12428;&#12418;&#12435;</pr></trd>,
    <trd>&#12471;&#12488;&#12525;&#12531;</trd>
  </trdgrp>
  <trd lng="nl">citroen</trd>
  <trd lng="no">sitron</trd>
  <trd lng="pl">cytryna</trd>
  <trd lng="pt">lim&atilde;o</trd>
  <trd lng="ro">l&abreve;m&acirc;ie</trd>
  <trd lng="ru">&c_l;&c_i;&c_m;&c_o;&c_n;</trd>
  <trdgrp lng="sk">
    <trd>citr&oacute;n</trd>,
    <trd>citr&oacute;n</trd>
  </trdgrp>
  <trd lng="sv">citron</trd>
  <trd lng="tr">limon</trd>
  <trdgrp lng="uk">
    <trd>&c_l;&c_i;&c_m;&c_o;&c_n;</trd>,
    <trd>&c_c;&c_i;&c_t;&c_r;&c_i;&c_n;&c_a; (&c_p;&c_l;&c_ib;&c_d;)</trd>
  </trdgrp>
  <trdgrp lng="zh">
    <trd>&#27308; <pr>m&eacute;ng</pr></trd>,
    <trd>&#26592; <pr>n&iacute;ng</pr></trd>,
    <trd>&#39321;&#27260; <pr>xi&amacron;ngyu&aacute;n</pr></trd>,
    <trd>&#26592;&#27308; <pr>n&iacute;ngm&eacute;ng</pr></trd>
  </trdgrp>
</drv>

<drv mrk="citron.0ujo">
  <kap><tld/>ujo,
  <var><kap><tld/>arbo</kap></var>
   <fnt><bib>Viki</bib>, <lok><url ref="&Viki;/citrono">citrono</url></lok></fnt>
  </kap>
  <snc>
    <uzo tip="fak">BOT</uzo>
    <dif>
      Specio de <ref tip="super" cel="citrus.0o">citruso</ref>
      (<trd lng="la">Citrus medica</trd>), anka&ubreve; nomata &leftquot;limono&rightquot;:
      <ekz>
        mia <tld/>arbo i&gcirc;is sepjara
        <fnt>
          <bib>Monato</bib>
          <aut>Sigmond J&uacute;lia</aut>
          <vrk><url ref="&Monato;/2007/008896.php">Sep
          citronsemoj</url></vrk>
        </fnt>.
      </ekz>
    </dif>
    <refgrp tip="vid">
      <ref cel="lime.0o">limeo</ref>,
      <ref cel="limed.0o">limedo</ref>
    </refgrp>
  </snc>
  <trd lng="be">&c_l;&c_ib;&c_m;&c_o;&c_n;&c_a;&c_v;&c_a;&c_je; &c_d;&c_r;&c_e;&c_v;&c_a;</trd>
  <trd lng="br">suravalenn</trd>
  <trdgrp lng="ca">
    <trd>llimoner</trd>,
    <trd>llimonera</trd>,
    <trd>llimera</trd>,
    <trd>llimer</trd>
  </trdgrp>
  <trdgrp lng="cs">
    <trd>citronovn&iacute;k</trd>,
    <trd>citron&iacute;k</trd>
  </trdgrp>
  <trd lng="de">Zitronenbaum</trd>
  <trd lng="el">&lambda;&epsilon;&my;&omikron;&ny;&jota;&alfa_ton;</trd>
  <trd lng="en">lemon tree</trd>
  <trd lng="es">limonero</trd>
  <trd lng="fr">citronnier</trd>
  <trd lng="he">&ayin;&ftsadi; &lamed;&yod;&mem;&vav;&fnun;</trd>
  <trd lng="hu">citromfa</trd>
  <trdgrp lng="id">
    <trd>pohon jeruk sitrun</trd>,
    <trd>pohon lemon</trd>,
    <trd>pohon limau</trd>,
    <trd>pohon limun</trd>,
    <trd>pohon sitrun</trd>
  </trdgrp>
  <trd lng="it">limone<klr> (pianta)</klr></trd>
  <trdgrp lng="ja">
    <trd>&#12524;&#12514;&#12531;  <pr>&#12428;&#12418;&#12435;</pr></trd>,
    <trd>&#12471;&#12488;&#12525;&#12531;</trd>
  </trdgrp>
  <trd lng="nl">citroenboom</trd>
  <trd lng="no">sitrontre</trd>
  <trd lng="pl">cytryna</trd>
  <trd lng="pt">limoeiro</trd>
  <trd lng="ru">&c_l;&c_i;&c_m;&c_o;&c_n;&c_n;&c_o;&c_je; &c_d;&c_je;&c_r;&c_je;&c_v;&c_o;</trd>
  <trd lng="sk">citr&oacute;novn&iacute;k</trd>
  <trd lng="tr">limon</trd>
  <trd lng="uk">&c_l;&c_i;&c_m;&c_o;&c_n;&c_n;&c_je; &c_d;&c_je;&c_r;&c_je;&c_v;&c_o;</trd>
</drv>
</art>
