<?xml version="1.0"?>
<!DOCTYPE vortaro SYSTEM "../dtd/vokoxml.dtd">

<vortaro>
  <art mrk="$Id: nafar.xml,v 1.3 2026/06/07 09:33:39 afido Exp $">
    <kap>
      <rad>Nafar</rad>/o,
      <var><kap><rad var="v">Navar</rad>/o <fnt><bib>PIV1</bib></fnt></kap></var>
    </kap>

<drv mrk="nafar.0o">
  <kap><tld/>o, <var><kap><tld var="v"/>o</kap></var></kap>
  <uzo tip="fak">GEOG</uzo><uzo tip="fak">POL</uzo>
  <snc>
    <dif>
      <ref tip="malprt" cel="hispan.H0ujo">Hispana</ref> <ref tip="super" cel="provin.0o.POL">provinco</ref> (iama re&gcirc;lando)
      limanta kun E&ubreve;skujo en la okcidento kaj Pireneoj en la nordo:
      <ekz>
        en la anta&ubreve;aj municipaj elektoj, en 1999, EH estis la dua plej subtenata grupo
        en la e&ubreve;ska a&ubreve;tonoma komunumo (20 %) kaj la tria en <tld/>o (16 %)
        <fnt>
          <bib>Monato</bib>
          <aut>Hektor Alos I Font</aut>
          <vrk><url ref="&Monato;/2003/008145.html"
              >150 000 orfoj</url></vrk>
          <lok>2003</lok>
        </fnt>;
      </ekz>
      <ekz>
        la&ubreve; malnovaj romiaj vojoj norde de Hispanio, <klr>[&#x2026;]</klr> tra la aragonaj kaj
        tra la <tld lit="n" var="v"/>aj <klr>[Pireneoj]</klr>
        <fnt>
          <bib>Monato</bib>
          <aut>Rafaela Urue&ntilde;a</aut>
          <vrk>Hispanio: Vojoj al la sankta urbo</vrk>
        </fnt>;
      </ekz>
      <ekz>
        la registaroj de la e&ubreve;ska kaj <tld lit="n"/>a a&ubreve;tonomaj komunumoj subvenciis la &jcirc;urnalon
        <fnt>
          <bib>Monato</bib>
          <aut>Hektor Alos I Font</aut>
          <vrk><url ref="&Monato;/2003/008082.html"
              >Kiam arestoj pruvas terorismajn ligojn ...</url></vrk>
          <lok>2003</lok>
        </fnt>.
      </ekz>
    </dif>
    <trd lng="de">Navarra</trd>
    <trd lng="en">Navarre</trd>
    <trd lng="es">Navarra</trd>
    <trd lng="eu">Nafarroa</trd>
    <trd lng="fr">Navarre</trd>
    <trd lng="ru">&c_N;&c_a;&c_v;&c_a;&c_r;&c_r;&c_a;</trd>
  </snc>
</drv>

  </art>

