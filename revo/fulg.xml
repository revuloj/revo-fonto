<?xml version="1.0"?>
<!DOCTYPE vortaro SYSTEM "../dtd/vokoxml.dtd">
<vortaro>
<art mrk="$Id: fulg.xml,v 1.26 2026/04/22 08:07:05 revo Exp $">
<kap><ofc>*</ofc>
<rad>fulg</rad>/o<fnt><bib>UV</bib></fnt></kap>
<drv mrk="fulg.0o">
  <kap><ofc>*</ofc><tld/>o</kap>
  <snc>
    <dif>
      Nigra densa materio lasita de fumo en kamentuboj:
      <ekz>
        <ind><tld/>okolora</ind>.
        <trd lng="fr">fuligineux<klr tip="ind"> (couleur)</klr></trd>
        <trd lng="hu">koromfekete</trd>
        <trd lng="nl">roetkleurig</trd>
      </ekz>
    </dif>
    <refgrp tip="vid">
      <ref cel="bistr.0o">bistro</ref>.
    </refgrp>
  </snc>
  <trd lng="ja">&#29028;  <pr>&#12377;&#12377;</pr></trd>
  <trd lng="kek">ab&#789;aq</trd>
  <trdgrp lng="be">
    <trd>&c_s;&c_a;&c_zh;&c_a;</trd>,
    <trd>&c_k;&c_u;&c_r;&c_o;&c_d;&c_y;&c_m;</trd>
  </trdgrp>
  <trd lng="bg">&c_s;&c_a;&c_zh;&c_d;&c_i;</trd>
  <trdgrp lng="cs">
    <trd>kopt</trd>,
    <trd>saze</trd>,
    <trd>&#x10D;er&ncaron;</trd>
  </trdgrp>
  <trd lng="de">Ru&szlig;</trd>
  <trd lng="en">soot</trd>
  <trd lng="fr">suie</trd>
  <trd lng="hu">korom</trd>
  <trdgrp lng="id">
    <trd>jelaga</trd>,
    <trd>sulang (2)</trd>
  </trdgrp>
  <trd lng="nl">roet</trd>
  <trdgrp lng="pl">
    <trd>sadza</trd>,
    <trd>kope&cacute;<klr> (przest.)</klr></trd>
  </trdgrp>
  <trdgrp lng="pt">
    <trd>fuligem</trd>,
    <trd>picum&atilde;</trd>
  </trdgrp>
  <trd lng="ru">&c_s;&c_a;&c_zh;&c_a;</trd>
  <trd lng="sk">sadza</trd>
  <trd lng="uk">&c_s;&c_a;&c_zh;&c_a;</trd>
  <trdgrp lng="zh">
    <trd>&#x70B2; <pr>tai</pr></trd>,
    <trd>&#x78B3;&#x9ED1; <pr>t&#xE0;nh&emacron;i</pr></trd>,
    <trd>&#x6CB9;&#x70DF; <pr>y&#xF3;uy&amacron;n</pr></trd>,
    <trd>&#x70B1; <pr>t&#xE1;i</pr></trd>,
    <trd>&#x70AD;&#x9ED1; <pr>t&#xE0;nh&emacron;i</pr></trd>,
    <trd>&#29028;&#28784; <pr>m&#xE9;ihu&#x12B;</pr></trd>
  </trdgrp>
</drv>

<drv mrk="fulg.0igi">
  <kap><tld/>igi</kap>
  <snc>
    <dif>
      Nigrigi, makuli per <tld/>o:
      <ekz>
        <tld/>igita kameno.
      </ekz>
    </dif>
  </snc>
  <trdgrp lng="be">
    <trd>&c_k;&c_u;&c_r;&c_e;&c_c;&c_mol;</trd>
    <trd>&c_k;&c_u;&c_r;&c_o;&c_d;&c_y;&c_m;&c_ib;&c_c;&c_mol;</trd>,
    <trd>&c_z;&c_a;&c_k;&c_u;&c_r;&c_o;&c_d;&c_y;&c_m;&c_ib;&c_c;&c_mol;</trd>
  </trdgrp>
  <trd lng="cs">za&#x10D;adit</trd>
  <trd lng="de">ru&szlig;en</trd>
  <trd lng="en">blacken <klr tip="amb">(with soot)</klr></trd>
  <trd lng="fr">noircir &agrave; la suie</trd>
  <trd lng="hu">bekormoz</trd>
  <trdgrp lng="id">
    <trd><baz>jelaga</baz>menjelagai</trd>,
    <trd><baz>sulang</baz>menyulangi</trd>,
    <trd><baz>hitam</baz>menghitamkan dgn jelaga/sulang</trd>
  </trdgrp>
  <trd lng="ja">&#12377;&#12377;&#12369;&#12373;&#x305B;&#x308B;</trd>
  <trd lng="nl">zwartblakeren</trd>
  <trdgrp lng="pl">
    <trd>kopci&cacute;</trd>,
    <trd>okapca&cacute;</trd>
  </trdgrp>
  <trd lng="ru">&c_z;&c_a;&c_k;&c_o;&c_p;&c_t;&c_i;&c_t;&c_mol;</trd>
  <trd lng="sk">za&#x10D;adi&tcaron;</trd>
  <trd lng="zh">&#29028;&#28784; <pr>m&#xE9;ihu&#x12B;</pr></trd>
</drv>
</art>
