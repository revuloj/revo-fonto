<?xml version="1.0"?>
<!DOCTYPE vortaro SYSTEM "../dtd/vokoxml.dtd">
<vortaro>
<art mrk="$Id: dribl.xml,v 1.11 2026/04/09 15:52:44 revo Exp $">
<kap>
  <rad>dribl</rad>/i
  <fnt><bib>PIV1</bib></fnt>
</kap>

<drv mrk="dribl.0i">
  <kap><tld/>i</kap>
  <gra><vspec>x</vspec></gra>
  <snc mrk="dribl.0i.finti">
    <uzo tip="fak">SPO</uzo>
    <dif>
      <ref tip="super" cel="ruz.super0i">Superruzi</ref> la kontra&ubreve;ulon per lertaj movoj a&ubreve;
      fintoj kaj tiamaniere malhelpi &gcirc;in akiri la pilkon:
      <ekz>
        la dua golo de <nom>Maradona</nom> estis unu el la plej famaj en la historio, &ccirc;ar li
        memstare <tld/>is kvin anglajn ludantojn anta&ubreve; ol <tld/>i anka&ubreve; la pordiston
        kaj fari la golon
        <fnt>
          <bib>Viki</bib>
          <lok><url ref="https://eo.wikipedia.org/?curid=248491">La mano de Dio</url></lok>
        </fnt>;
      </ekz>
      <ekz>
        lerta avanulo de rapidegaj kaj embarasigaj <tld/>oj
        <fnt>
          <bib>Monato</bib>
          <aut>Jozefo Lej&ccirc;</aut>
          <vrk><url ref="&Monato;/2011/010331.php"
              >Adia&ubreve;as fenomeno</url></vrk>
          <lok>2011</lok>
        </fnt>.
      </ekz>
    </dif>
    <refgrp tip="vid">
      <ref cel="fint.0i">finti</ref>
    </refgrp>
    <trdgrp lng="pl">
     <trd>dryblowa&cacute;</trd>,
     <trd>okiwa&cacute;<klr> (pot.)</klr></trd>
    </trdgrp>
    <trd lng="pt">driblar</trd>
  </snc>
  <snc mrk="dribl.0i.pusxi">
    <uzo tip="fak">SPO</uzo>
    <dif>
      Konduki la pilkon per (teren-)pu&scirc;oj a&ubreve; batoj ktp, la&ubreve; la reguloj de la sporto:
      <ekz>
        sen <tld/>o, la ludanto rajtas pa&scirc;i nur 3-foje kaj rezervi la pilkon nur por 3
        sekundoj, poste <klr>[li]</klr> devas &gcirc;in plu&jcirc;eti
        <fnt>
          <bib>Viki</bib>
          <lok><url ref="https://eo.wikipedia.org/?curid=28596">Manpilkado</url></lok>
        </fnt>.
      </ekz>
    </dif>
    <trd lng="pl">dryblowa&cacute;</trd>
    <trd lng="pt">conduzir <klr tip="amb"> (a bola; esporte)</klr></trd>
  </snc>
  <trd lng="be">&c_v;&c_je;&c_s;&c_mol;&c_c;&c_ib; <klr>(&c_u; &c_g;&c_u;&c_l;&c_mol;&c_n;&c_ib;: &c_m;&c_ja;&c_ch;, &c_sh;&c_a;&c_j;&c_b;&c_u;)</klr></trd>
  <trdgrp lng="ca">
    <trd>driblar</trd>,
    <trd>regatejar</trd>
  </trdgrp>
  <trd lng="cs">driblovat</trd>
  <trd lng="de">dribbeln</trd>
  <trd lng="en">dribble</trd>
  <trd lng="fr">dribbler</trd>
  <trd lng="he">&lamed;&kaf;&dalet;&resh;&resh;</trd>
  <trd lng="sk">driblova&tcaron;</trd>
  <trdgrp lng="uk">
    <trd>&c_v;&c_je;&c_s;&c_t;&c_i; &c_m;&#x2019;&c_ja;&c_ch;</trd>,
    <trd>&c_sh;&c_a;&c_j;&c_b;&c_u;</trd>
  </trdgrp>
  <trd lng="zh">&#x5E26;&#x7403; <pr>d&agrave;iqi&uacute;</pr></trd>
  <adm>
      Alia ebla distingo estas: (a) horizontala rapida tien, reen-pu&scirc;ado (b) vertikala
      pu&scirc;o, resalto de pilko
      <aut>WD</aut>
    </adm>
</drv>

</art>

