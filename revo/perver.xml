<art mrk="$Id: perver.xml,v 1.25 2026/06/26 07:02:05 revo Exp $">
<kap>
  <rad>pervers</rad>/a
  <fnt><bib>PV</bib></fnt>
</kap>
<drv mrk="perver.0a">
  <kap><tld/>a</kap>
  <snc mrk="perver.0a.malbonmora">
    <dif>
      Inklina al konduto neprudenta, neakceptebla, malbonmora, malica
      malgra&ubreve; konscio pri la konsekvencoj:
      <ekz>
        <tld/>eco estas en lia koro, li intencas malbonon, en &ccirc;iu tempo li semas malpacon
        <fnt>
          <bib>MT</bib>
          <lok>Sentencoj 6:14</lok>
        </fnt>;
      </ekz>
      <ekz>
        tia homo <tld/>i&gcirc;is kaj pekas, estante memkondamnita
        <fnt>
          <bib>NT</bib>
          <lok>Tito 3:11</lok>
        </fnt>;
      </ekz>
      <ekz>
        &ccirc;arma junulo, kun pla&ccirc;a viza&gcirc;o, sed io <tld/>a en la okuloj
        <fnt>
          <bib>ChM</bib>
          <lok>8</lok>
        </fnt>;
      </ekz>
      <ekz>
        pruntado de mono kontra&ubreve; interezo estas <tld/>a maniero akiri
        hava&jcirc;on, la&ubreve; Aristotelo
        <fnt><aut>Bo Sandelin</aut>:
        <vrk>Anta&ubreve;merkantilisma ekonomia pensado</vrk>,
        <bib>Monato</bib><lok>jaro 2001a, numero 2a, p. 16a</lok></fnt>.
      </ekz>
    </dif>
    <trdgrp lng="de">
      <trd>unmoralisch</trd>,
      <trd>sittenlos</trd>
    </trdgrp>
    <trdgrp lng="es">
      <trd>perverso</trd>,
      <trd>pernicioso</trd>
    </trdgrp>
    <trdgrp lng="fr">
      <trd>pernicieux</trd>
    </trdgrp>
    <trd lng="hu">elvetem&uuml;lt</trd>
    <trdgrp lng="pt">
      <trd>mau</trd>,
      <trd>perverso</trd>,
      <trd>malvado</trd>
    </trdgrp>
    <trdgrp lng="ru">
      <trd>&c_v;&c_r;&c_je;&c_d;&c_n;&c_y;&c_j;</trd>,
      <trd>&c_p;&c_o;&c_r;&c_o;&c_ch;&c_n;&c_y;&c_j;</trd>,
    </trdgrp>
  </snc>
  <snc mrk="perver.0a.strangvolupta">
    <dif>
      Inklina al nenormalaj voluptoj:
      <ekz>
        <tld/>a estas vi <klr>[&#x2026;]</klr>, kiu montras al mi tiom da porna&jcirc;oj
        <fnt>
          <bib>KrB</bib>
          <lok>Elementoj de absoluta geometrio</lok>
        </fnt>!
      </ekz>
      <ekz>
        envere pedofilio estas <tld/>a
        <fnt>
          <bib>Monato</bib>
          <aut>Roberto Pigro</aut>
          <vrk><url ref="&Monato;/2010/010098.php"
              >Paradoksa aserto</url></vrk>
          <lok>2010</lok>
        </fnt>.
      </ekz>
    </dif>
    <trdgrp lng="de">
      <trd>abartig <klr>(sexuell)</klr></trd>,
      <trd>pervers</trd>
    </trdgrp>
    <trdgrp lng="fr">
      <trd>d&eacute;prav&eacute;</trd>
    </trdgrp>
    <trdgrp lng="hu">
      <trd>perverz</trd>,
      <trd>fajtalan</trd>
    </trdgrp>
    <trd lng="es">pervertido</trd>
    <trd lng="pt">pervertido</trd>
    <trdgrp lng="ru">
      <trd>&c_p;&c_o;&c_r;&c_o;&c_ch;&c_n;&c_y;&c_j;</trd>,
      <trd>&c_r;&c_a;&c_z;&c_v;&c_r;&c_a;&c_shch;&c_jo;&c_n;&c_n;&c_y;&c_j;</trd>,
      <trd>&c_i;&c_z;&c_v;&c_r;&c_a;&c_shch;&c_jo;&c_n;&c_n;&c_y;&c_j;</trd>
    </trdgrp>
  </snc>
  <trd lng="be">&c_r;&c_a;&c_z;&c_b;&c_e;&c_sh;&c_ch;&c_a;&c_n;&c_y;</trd>
  <trdgrp lng="cs">
    <trd>perverzn&iacute;</trd>,
    <trd>p&rcaron;ekroucen&yacute;</trd>,
    <trd>zvrhl&yacute;</trd>
  </trdgrp>
  <trdgrp lng="fr">
    <trd>pervers</trd>,
    <trd>vicieux</trd>
  </trdgrp>
  <trdgrp lng="ja">
    <trd>&#x90AA;&#x60AA;&#x306A;  <pr>&#x3058;&#x3083;&#x3042;&#x304F;&#x306A;</pr></trd>,
    <trd>&#x3088;&#x3053;&#x3057;&#x307E;&#x306A;</trd>,
    <trd>&#x5012;&#x932F;&#x3057;&#x305F; <pr>&#x3068;&#x3046;&#x3055;&#x304F;&#x3057;&#x305F;</pr></trd>
  </trdgrp>
  <trd lng="nl">pervers<klr tip="ind"> (bn.)</klr></trd>
  <trdgrp lng="pl">
    <trd>perwersyjny</trd>,
    <trd>przewrotny</trd>
  </trdgrp>
  <trdgrp lng="ro">
    <trd>pervers</trd>,
    <trd>iritabil</trd>
  </trdgrp>
  <trd lng="sk">perverzn&yacute;</trd>
  <trdgrp lng="uk">
    <trd>&c_r;&c_o;&c_z;&c_b;&c_je;&c_shch;&c_je;&c_n;&c_i;&c_j;</trd>,
    <trd>&c_z;&c_ib;&c_p;&c_s;&c_o;&c_v;&c_a;&c_n;&c_i;&c_j;</trd>,
    <trd>&c_p;&c_o;&c_r;&c_o;&c_ch;&c_n;&c_i;&c_j;</trd>
  </trdgrp>
  <trdgrp lng="zh">
    <trd>&#x5012;&#x932F; <pr>d&agrave;ocu&ograve;</pr></trd>,
    <trd>&#x5012;&#x9519; <pr>d&agrave;ocu&ograve;</pr></trd>,
    <trd>&#x6B7B;&#x53D8;&#x6001; <pr>s&#x1D0;bi&agrave;nt&agrave;i</pr></trd>,
    <trd>&#x6B7B;&#x8B8A;&#x614B; <pr>s&#x1D0;bi&agrave;nt&agrave;i</pr></trd>
  </trdgrp>
</drv>

<drv mrk="perver.0e">
  <kap><tld/>e</kap>
  <snc>
    <dif>
      &Gcirc;ue agante kun malico:
      <ekz>
        viroj <tld/>e parolantaj, por forlogi post si la dis&ccirc;iplojn
        <fnt>
          <bib>NT</bib>
          <lok>La agoj 20:30</lok>
        </fnt>;
      </ekz>
      <ekz>
        la emo de a&jcirc;oj kaj aferoj misiri kvaza&ubreve; <tld/>e
        <fnt><aut>Marjorie
        Boulton</aut>: <vrk>Tiu le&gcirc;o de Murphy</vrk>,
        <bib>Monato</bib><lok>jaro 1997a, numero 4a, p. 26a</lok></fnt>.
      </ekz>
    </dif>
  </snc>
  <trd lng="be">&c_r;&c_a;&c_z;&c_b;&c_e;&c_sh;&c_ch;&c_a;&c_n;&c_a;</trd>
  <trdgrp lng="fr">
    <trd>pernicieusement</trd>,
    <trd>vicieusement</trd>
  </trdgrp>
    <trdgrp lng="es">
      <trd>perversamente</trd>,
      <trd>perniciosamente</trd>
    </trdgrp>
  <trd lng="hu">perverz m&oacute;don</trd>
  <trd lng="nl">pervers<klr tip="ind"> (bw.)</klr></trd>
  <trdgrp lng="pl">
    <trd>perwersyjnie</trd>,
    <trd>przewrotnie</trd>
  </trdgrp>
  <trd lng="ro">pervers</trd>
  <trd lng="ru">&c_n;&c_a;&c_z;&c_l;&c_o;</trd>
</drv>

<drv mrk="perver.0eco">
  <kap>
    <tld/>eco
  </kap>
  <snc>
    <dif>
      <tld lit="P"/>a inklino:
      <ekz>
        <tld/>eco estas en lia koro, li intencas malbonon
        <fnt>
          <bib>MT</bib>
          <lok>Sentencoj 6:14</lok>
        </fnt>;
      </ekz>
      <ekz>
        ho, via perverseco! &ccirc;u la potfaristo estas rigardata kiel egala al la argilo
        <fnt>
          <bib>MT</bib>
          <lok>Jesaja 29:16</lok>
        </fnt>?
      </ekz>
      <ekz>
        jen iuj urbestroj organizas publikan propagandadon de ekstravaganco kaj
        <tld/>eco sub la preteksto pri &leftquot;homaj rajtoj&rightquot;
        <fnt>
          <bib>Monato</bib>
          <aut>Atanasije Marjanovi&cacute;</aut>
          <vrk><url ref="&Monato;/2013/010942.php"
              >Lasta vorto</url></vrk>
          <lok>2013</lok>
        </fnt>.
      </ekz>
    </dif>
  </snc>
  <trdgrp lng="de">
    <trd>Sittenlosigkeit</trd>,
    <trd>Sittenverfall</trd>,
    <trd>Unmoral</trd>,
    <trd>Perversion</trd>
  </trdgrp>
  <trd lng="en">perversion</trd>
  <trd lng="fr">perversion</trd>
</drv>

</art>
