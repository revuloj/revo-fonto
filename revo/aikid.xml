<kap>
  <rad>aikid</rad>/o <fnt><bib>EncJap</bib></fnt>
</kap>
<drv mrk="aikid.0o">
  <kap><tld/>o</kap>
  <uzo tip="fak">SPO</uzo>
  <snc>
    <dif>
      Japan-devena korpogarda, senperforta luktarto,
      kompilita de <nom>Ueshiba Morihei</nom>,
      per kiu oni evitas atakanton, alidirektadas lian energion
      kaj senpovigas per artiko-tordo:
      <ekz>
        <nom>Mireille Grosjean</nom> <klr>[&#8230;]</klr> &#8208; fakdelegito de UEA pri pacedukado,
        fremdlingvoinstruado kaj <tld/>o
        <fnt>
          <bib>Viki</bib>
          <lok><url ref="https://eo.wikipedia.org/?curid=206340">Mireille Grosjean</url></lok>
        </fnt>.
      </ekz>
    </dif>
  </snc>
  <trd lng="be">&c_a;&c_j;&c_k;&c_ib;&c_d;&c_o;</trd>
  <trd lng="ca">aikido</trd>
  <trd lng="cs">aikido</trd>
  <trd lng="de">Aikido</trd>
  <trd lng="en">aikido</trd>
  <trd lng="es">aikido</trd>
  <trd lng="fr">a&iuml;kido</trd>
  <trd lng="hu">aikido</trd>
  <trd lng="it">aikido</trd>
  <trd lng="ja">&#21512;&#27671;&#36947; 
  <pr>&#12354;&#12356;&#12365;&#12393;&#12358;</pr></trd>
  <trd lng="nl">aikido</trd>
  <trd lng="pl">aikido</trd>
  <trd lng="pt">aiquid&ocirc;</trd>
  <trd lng="ru">&c_a;&c_j;&c_k;&c_i;&c_d;&c_o;</trd>
  <trd lng="sk">aikido</trd>
  <trd lng="uk">&c_a;&c_j;&c_k;&c_ib;&c_d;&c_o; (&c_v;&c_i;&c_d; &c_ja;&c_p;&c_o;&c_n;&c_s;&c_mol;&c_k;&c_o;&c_ji; &c_b;&c_o;&c_r;&c_o;&c_t;&c_mol;&c_b;&c_i;)</trd>
</drv>
