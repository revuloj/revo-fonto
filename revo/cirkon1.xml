<kap>
  <ofc>*</ofc>
  <rad>cirkonstanc</rad>/o
<fnt><bib>UV</bib></fnt></kap>
<drv mrk="cirkon1.0o">
  <kap><ofc>*</ofc><tld/>o</kap>
  <snc>
    <dif>
      Detala aparta&jcirc;o, kiu akompanas fakton, flankfakto:
      <ekz>favora
      <tld/>o;
      </ekz> <ekz>tio dependas de la <tld/>oj;
      </ekz> <ekz>pro <tld/>a le&gcirc;o;
      </ekz> <ekz>malpligravigaj <tld/>oj.
      </ekz>
    </dif>
    <refgrp tip="vid">
      <ref cel="kondic1.0o">kondi&ccirc;o</ref>,
      <ref cel="okaz.0o">okazo</ref>.
    </refgrp>
  </snc>
  <trd lng="be">&c_a;&c_k;&c_a;&c_l;&c_ib;&c_ch;&c_n;&c_a;&c_s;&c_mol;&c_c;&c_mol;</trd>
  <trd lng="bg">&c_o;&c_b;&c_s;&c_t;&c_o;&c_ja;&c_t;&c_je;&c_l;&c_s;&c_t;&c_v;&c_o;</trd>
  <trd lng="bo">&#xF42;&#xF53;&#xF66;&#xF0B;&#xF5A;&#xF74;&#xF63;&#xF0B;</trd>
  <trd lng="ca">circumst&agrave;ncia</trd>
  <trdgrp lng="cs">
    <trd>okolnost</trd>,
    <trd>prost&rcaron;ed&#xED;</trd>
  </trdgrp>
  <trd lng="de">Umstand</trd>
  <trd lng="en">circumstance</trd>
  <trd lng="es">circunstancia</trd>
  <trd lng="fr">circonstance</trd>
  <trd lng="he">&#x5E0;&#x5E1;&#x5D9;&#x5D1;&#x5D5;&#x5EA;</trd>
  <trd lng="hu">k&ouml;r&uuml;lm&eacute;ny</trd>
  <trd lng="id"><baz>ada</baz>keadaan</trd>
  <trd lng="it">circonstanza</trd>
  <trdgrp lng="ja">
    <trd>&#21608;&#x56F2;&#x306E;&#x4E8B;&#x60C5;  <pr>&#12375;&#12421;&#12358;&#12356;&#x306E;&#12376;&#12376;&#12423;&#12358;</pr></trd>,
    <trd>&#x72B6;&#x6CC1;  <pr>&#12376;&#12423;&#12358;&#x304D;&#12423;&#12358;</pr></trd>
  </trdgrp>
  <trd lng="nl">omstandigheid</trd>
  <trd lng="pl">okoliczno&sacute;&cacute;</trd>
  <trd lng="pt">circunst&acirc;ncia</trd>
  <trd lng="ru">&c_o;&c_b;&c_s;&c_t;&c_o;&c_ja;&c_t;&c_je;&c_l;&c_mol;&c_s;&c_t;&c_v;&c_o;</trd>
  <trd lng="sk">okolnos&tcaron;</trd>
  <trd lng="uk">&#x43E;&c_b;&c_s;&c_t;&c_a;&c_v;&c_i;&#x43D;&c_a;</trd>
  <trdgrp lng="zh">
    <trd>&#x60C5;&#22659; <pr>q&#xED;ngj&#xEC;ng</pr></trd>,
    <trd>&#x65F6;&#x8FD0; <pr>sh&#xED;y&#xF9;n</pr></trd>
  </trdgrp>
</drv>

<drv mrk="cirkon1.0aro">
  <kap><tld/>aro</kap>
  <snc>
    <dif>
      La tuto de la <tld/>oj, kiuj karakterizas situacion
    </dif>
    <refgrp tip="sin">
      <ref cel="konjun3.0o">konjunkturo</ref>.
    </refgrp>
  </snc>
  <trd lng="be">&c_s;&c_t;&c_a;&c_n;&c_o;&c_v;&c_ib;&c_sh;&c_ch;&c_a;</trd>
  <trd lng="bg">&c_p;&c_o;&c_l;&c_o;&c_zh;&c_je;&c_n;&c_i;&c_je; <klr>(&c_n;&c_a; &c_n;&c_je;&c_shch;&c_a;&c_t;&c_a;)</klr></trd>
  <trd lng="ca">conjuntura</trd>
  <trdgrp lng="cs">
    <trd>okolnosti</trd>,
    <trd>souhrn okolnost&#xED;</trd>
  </trdgrp>
  <trd lng="de">Umst&auml;nde</trd>
  <trdgrp lng="en">
    <trd>circumstances</trd>,
    <trd>conjuncture</trd>,
    <trd>conditions</trd>,
    <trd>state of things</trd>,
    <trd>situation</trd>
  </trdgrp>
  <trd lng="fr">conjoncture</trd>
  <trdgrp lng="hu">
    <trd>helyzet<klr tip="ind">
    (k&ouml;r&uuml;lm&eacute;nyek)</klr></trd>,
    <trd>k&ouml;r&uuml;lm&eacute;nyek</trd>
  </trdgrp>
  <trd lng="id">situasi</trd>
  <trdgrp lng="it">
    <trd>circonstanze</trd>,
    <trd>congiuntura<klr> (fig.)</klr></trd>
  </trdgrp>
  <trdgrp lng="ja">
    <trd>&#x60C5;&#x52E2;  <pr>&#12376;&#12423;&#12358;&#x305B;&#12356;</pr></trd>,
    <trd>&#x5C40;&#38754;  <pr>&#x304D;&#12423;&#x304F;&#12417;&#12435;</pr></trd>
  </trdgrp>
  <trd lng="nl">samenloop<klr> (van omstandigheden)</klr></trd>
  <trd lng="pl">okoliczno&sacute;ci</trd>
  <trd lng="ru">&c_o;&c_b;&c_s;&c_t;&c_a;&c_n;&c_o;&c_v;&c_k;&c_a;</trd>
  <trdgrp lng="sk">
    <trd>okolnosti</trd>,
    <trd>s&#xFA;hrn okolnost&#xED;</trd>
  </trdgrp>
  <trdgrp lng="uk">
    <trd>&c_s;&c_u;&#x43A;&c_u;&#x43F;&#x43D;&c_ib;&c_s;&c_t;&#x44C; &#x43E;&c_b;&c_s;&c_t;&c_a;&c_v;&c_i;&#x43D;</trd>,
    <trd>&#x43E;&c_b;&c_s;&c_t;&c_a;&#x43D;&#x43E;&c_v;&#x43A;&c_a;</trd>
  </trdgrp>
</drv>
</art>
