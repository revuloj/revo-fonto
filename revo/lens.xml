<?xml version="1.0"?>
<!DOCTYPE vortaro SYSTEM "../dtd/vokoxml.dtd">
<vortaro>
<art mrk="$Id: lens.xml,v 1.27 2026/03/15 20:44:36 revo Exp $">
<kap>
  <ofc>4</ofc>
  <rad>lens</rad>/o
<fnt><bib>PVEF</bib></fnt></kap>

<drv mrk="lens.0o">
  <kap><tld/>o</kap>
  <snc mrk="lens.0o.FOT">
    <uzo tip="fak">FOT</uzo>
    <dif>
      Disko el travidebla materialo, limigita per unu
      a&ubreve; du kurbaj surfacoj, kaj havanta la econ regule deviigi
      la lumradiojn:
      <ekz>
        la libron li en&scirc;ovis &ccirc;e la demandita pa&gcirc;o en la aparaton, kaj mi devis enrigardi
        tra iu <tld/>o
        <fnt>
          <bib>VaK</bib>
          <lok>Kvara &Ccirc;apitro</lok>
        </fnt>;
      </ekz>
      <ekz>
        okulvitroj kun unu <tld/>o ru&gcirc;a kaj la alia verda <klr>[&#x2026;]</klr> tra kiuj eblas
        admiri apartajn bildojn ta&ubreve;ge presitajn por aspekti reliefe
        <fnt>
          <bib>Monato</bib>
          <vrk>Stereogramoj</vrk>
          <lok>95/01</lok>
        </fnt>;
      </ekz>
      <ekz>
        <uzo tip="stl">FIG</uzo>
        sub la <tld/>o de la scienco
        <fnt>
          <bib>Kon11</bib>
          <lok>&Ccirc;efartikolo</lok>
        </fnt>;
      </ekz>
      <ekz>
        Afrikano Gbeglo rakontas kontemple pri siaj impresoj, do la Centran Oficejon ni
        vidas tra lia <tld/>o
        <fnt>
          <bib>Monato</bib>
          <aut>Carlo Minnaja</aut>
          <vrk><url ref="&Monato;/2003/007927.html"
              >Promene tra la Centra Oficejo</url></vrk>
          <lok>2003</lok>
        </fnt>.
      </ekz>
    </dif>
    <ref tip="vid" cel="objekt2.0o">objektivo</ref>
  </snc>
  <trd lng="be">&c_l;&c_ib;&c_n;&c_z;&c_a;</trd>
  <trd lng="bg">&c_l;&c_je;&c_shch;&c_a;</trd>
  <trd lng="ca">lent</trd>
  <trd lng="de">Linse</trd>
  <trd lng="el">&phi;&alfa;&kappa;&omikron_ton;&sigma_fina;</trd>
  <trd lng="en">lens</trd>
  <trd lng="es">lente</trd>
  <trd lng="fa">&a_ayn;&a_d;&a_s;&f_y;</trd>
  <trd lng="fr">lentille</trd>
  <trd lng="hu">lencse <klr tip="ind">(optikai)</klr></trd>
  <trd lng="it">lente</trd>
  <trd lng="ja">&#x30EC;&#x30F3;&#x30BA;  <pr>&#x308C;&#x3093;&#x305A;</pr></trd>
  <trd lng="nl">lens</trd>
  <trd lng="pl">soczewka</trd>
  <trd lng="pt">lente</trd>
  <trd lng="ro">lentil&abreve; <klr>(optic&abreve;)</klr></trd>
  <trd lng="ru">&c_l;&c_i;&c_n;&c_z;&c_a;</trd>
  <trd lng="uk">&c_l;&c_ib;&c_n;&c_z;&c_a;</trd>
  <trdgrp lng="zh">
    <trd>&#x93E1; <pr>j&igrave;ng</pr></trd>,
    <trd>&#x955C; <pr>j&igrave;ng</pr></trd>,
    <trd>&#x93E1;&#x7247; <pr>j&igrave;ngpi&agrave;n</pr></trd>,
    <trd>&#x955C;&#x7247; <pr>j&igrave;ngpi&agrave;n</pr></trd>,
    <trd>&#x6676;&#x72B6;&#x4F53; <pr>j&imacron;ngzhu&agrave;ngt&#x1D0;</pr></trd>,
    <trd>&#x6676;&#x72C0;&#x9AD4; <pr>j&imacron;ngzhu&agrave;ngt&#x1D0;</pr></trd>,
    <trd>&#x900F;&#x93E1; <pr>t&ograve;uj&igrave;ng</pr></trd>,
    <trd>&#x900F;&#x955C; <pr>t&ograve;uj&igrave;ng</pr></trd>,
    <trd>&#x93E1;&#x982D; <pr>j&igrave;ngt&oacute;u</pr></trd>,
    <trd>&#x955C;&#x5934; <pr>j&igrave;ngt&oacute;u</pr></trd>
  </trdgrp>
</drv>

<drv mrk="lens.0aro">
  <kap>
    <tld/>aro
  </kap>
  <snc>
    <dif>
      Aran&gcirc;o de pluraj <tld/>oj:
      <ekz>
        du imagaj rektaj linioj <klr>[&#x2026;]</klr> interkruci&gcirc;as meze de la &leftquot;lensaro&rightquot; de
        niaj okuloj kaj poste direkti&gcirc;as al la retinoj
        <fnt>
          <aut>Gang &Gcirc;engfang</aut>
          <vrk><url ref="https://eduinf.waw.pl/esp/lern/librejo/0170/0007.php"
              >Brilas Sa&gcirc;o</url></vrk>
          <lok>Du &leftquot;manoj&rightquot; de la homaj okuloj</lok>
        </fnt>;
      </ekz>
      <ekz>
        al&gcirc;ustigi <tld/>aron &gcirc;is certa objekto venas en la fokuson
        <fnt>
          <aut>Lode Van de Velde</aut>
          <vrk><url ref="https://www.eventoj.hu/steb/vortaroj/fotografia_terminaro_2018.pdf"
              >Fotografia terminaro</url></vrk>
        </fnt>.
      </ekz>
    </dif>
    <refgrp tip="sub">
      <ref cel="objekt2.0o">objektivo</ref>,
      <ref cel="okular.0o">okulario</ref>
    </refgrp>
  </snc>
  <trd lng="de">Optik <klr>(Linsensystem)</klr></trd>
  <trd lng="en">lenses</trd>
  <trd lng="fr">syst&egrave;me optique</trd>
</drv>

<drv mrk="lens.en0igi">
  <kap>en<tld/>igi</kap>
  <gra><vspec>tr</vspec></gra>
  <snc mrk="lens.en0igi.FOT">
    <uzo tip="fak">FOT</uzo>
    <dif>
      Aperigi en la <tld/>o de optika aparato:
      <ekz>
        Jozefo tute kapti&gcirc;is: ne povis de&scirc;iri sin de la teleskopo,
        kaj se longe li ne povis en<tld/>igi la knabinon, li ne man&gcirc;is,
        ne dormis, nek havis humoron por io ajn
        <fnt>
          <aut>M. J&oacute;kai, trad. J. Horvath</aut>
          <vrk>La du salikoj de Nagyenyed</vrk>
          <lok>2002</lok>
        </fnt>.
      </ekz>
    </dif>
    <ref tip="vid" cel="fokus.0i.KOMUNE">fokusi<sncref/></ref>
  </snc>
  <trd lng="be">&c_l;&c_a;&c_v;&c_ib;&c_c;&c_mol; &c_u; &c_a;&c_b;&#x2019;&c_je;&c_k;&c_t;&c_y;&c_w;</trd>
  <trdgrp lng="de">
    <trd>mit der <ind>Linse</ind> einfangen</trd>,
    <trd>anvisieren</trd>,
    <trd><klr>(ein Fernrohr)</klr> <ind>ausrichten</ind> auf</trd>
  </trdgrp>
  <trd lng="fr">mettre au point<klr> (opt.)</klr></trd>
</drv>
</art>
