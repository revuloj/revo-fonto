<?xml version="1.0"?>
<!DOCTYPE vortaro SYSTEM "../dtd/vokoxml.dtd">
<vortaro>
<art mrk="$Id: kerub.xml,v 1.32 2026/05/31 11:51:41 revo Exp $">
<kap>
  <ofc>*</ofc> <rad>kerub</rad>/o <fnt><bib>UV</bib></fnt>,
  <var><kap><rad var="&hcirc;">&hcirc;erub</rad>/o</kap></var>
</kap>
<drv mrk="kerub.0o">
  <kap><ofc>*</ofc><tld/>o,
  <var><kap><tld var="&hcirc;"/>o</kap></var></kap>
  <snc mrk="kerub.0o.BIB">
    <uzo tip="fak">BIB</uzo>
    <dif>
      Supernatura esta&jcirc;o, en formo de flugilhava virbovo kun homa
      kapo:
      <ekz>
        Li elpelis Adamon, kaj lokis anta&ubreve; la Edena &gcirc;ardeno la <tld/>on
        kaj la turni&gcirc;antan flaman glavon, por gardi la vojon al la arbo de vivo
        <fnt>
          <bib>MT</bib>
          <lok><url ref="&Steloj;biblio/">&Gen; 3:24</url></lok>
        </fnt>;
      </ekz>
      <ekz>
        la <tld/>oj estu etendantaj siajn flugilojn supren, kovrante per siaj
        flugiloj la fermoplaton, kaj iliaj viza&gcirc;oj estu unu kontra&ubreve; la alia,
        al la fermoplato estu turnitaj la viza&gcirc;oj de la <tld/>oj
        <fnt>
          <bib>MT</bib>
          <lok><url ref="&Steloj;biblio/">&Eli; 25:20</url></lok>
        </fnt>;
      </ekz>
      <ekz>
        Li ekrajdis sur <tld/>o kaj ekflugis,  kaj Li porti&gcirc;is sur la flugiloj de la vento
        <fnt>
          <bib>MT</bib>
          <lok><url ref="&Steloj;biblio/">&Sa2; 22:11</url></lok>
        </fnt>.
      </ekz>
    </dif>
    <trd lng="de">Cherub</trd>
    <trdgrp lng="en"><trd>cherub</trd>, <trd>shedu</trd>,
    <trd>lamassu</trd></trdgrp>
    <trd lng="es">querub&iacute;n</trd>
    <trd lng="fa">&f_k;&a_r;&a_w;&a_b;&f_y;</trd>
    <trd lng="fr">ch&eacute;rubin<klr tip="ind"> (ange zoomorphe)</klr>
    </trd>
    <trd lng="hu">kerub</trd>
    <trd lng="it">cherubino</trd>
    <trd lng="pl">cherub</trd>
    <trdgrp lng="zh">
    <trd>&#x667A;&#22825;&#x4F7F; <pr>zh&#xEC;ti&amacron;nsh&#x1D0;</pr></trd>,
    <trd>&#x57FA;&#x8DEF;&#x4F2F; <pr>j&#x12B;l&#xF9;b&#xF3;</pr></trd>
  </trdgrp>
  </snc>
  <snc mrk="kerub.0o.angxel">
    <uzo tip="fak">REL</uzo>
    <dif>
      <ref tip="super" cel="angxel.0o.REL">An&gcirc;elo</ref> de la dua &ccirc;iela &hcirc;oro:
      <ekz>
        anta&ubreve; Vi <tld var="&hcirc;"/>oj falas kaj serafoj
        <fnt>
          <aut>R. Heber, trad. A. L. Curry</aut>
          <vrk><url ref="https://hymnary.org/text/sankta_sankta_sankta_dio_eternulo">Sankta, Sankta,
          Sankta!</url></vrk>
          <lok>1918</lok>
        </fnt>.
      </ekz>
    </dif>
    <refgrp tip="vid">
      <ref cel="seraf.0o">serafo</ref>.
    </refgrp>
    <trd lng="de">Cherub</trd>
    <trd lng="en">cherub</trd>
    <trd lng="es">querub&iacute;n</trd>
    <trdgrp lng="fa">
      <trd>&f_k;&a_r;&a_w;&a_b;&f_y;</trd>
      <trd>&a_f;&a_r;&a_sh;&a_t;&a_h;&#x200C;&f_y; &a_m;&a_q;&a_r;&a_b;</trd>
    </trdgrp>
    <trd lng="fr">ch&eacute;rubin<klr tip="ind">
    (ange du deuxi&egrave;me ch&oelig;ur)</klr></trd>
    <trd lng="hu">kerub</trd>
    <trd lng="it">cherubino</trd>
    <trdgrp lng="pl">
      <trd>cherub</trd>,
      <trd>cherubin</trd>
    </trdgrp>
    <trd lng="ru">&c_h;&c_je;&c_r;&c_u;&c_v;&c_i;&c_m;</trd>
  </snc>
  <snc mrk="kerub.0o.skulpt">
    <uzo tip="fak">ARKI</uzo>
    <dif>
      Pentra&jcirc;o a&ubreve; skulpta&jcirc;o prezentanta flugilhavan
      infanon (plej ofte virknabon) a&ubreve; nur la kapon.
    </dif>
    <rim>
      &Gcirc;i forme ne similas al <ref cel="kerub.0o.angxel">kerubo<sncref/></ref>
      sed al Eroso.
    </rim>
    <trd lng="de">Putte</trd>
    <trd lng="en">cherub</trd>
    <trdgrp lng="es">
      <trd>&aacute;ngel</trd>
    </trdgrp>
    <trd lng="fr">putto</trd>
    <trdgrp lng="it">
      <trd>cherubino</trd>,
      <trd>angioletto</trd>,
      <trd>putto</trd>,
      <trd>amorino</trd>
    </trdgrp>
    <trdgrp lng="pl">
      <trd>putto</trd>,
      <trd>amorek</trd>,
      <trd>cherubinek<klr> (pot., niepoprawnie)</klr></trd>,
      <trd>anio&lstroke;ek<klr> (pot.)</klr></trd>
    </trdgrp>
  </snc>
  <snc mrk="kerub.0o.infano">
    <uzo tip="stl">FIG</uzo>
    <dif>
      &Ccirc;arma <ref tip="super" cel="infan.0o.juna">infano</ref>:
      <ekz>
        mi prenis la knabon sur la manojn; li mire, serioze rigardis min, kvaza&ubreve; <tld/>o, kiu &jcirc;us
        falis de l&#8217; &ccirc;ielo
        <fnt>
          <aut>M. Konopnicka, trad. K. Bein</aut>
          <vrk>Mia Onklinjo</vrk>
          <lok>en: Pola antologio, 1909</lok>
        </fnt>;
      </ekz>
      <ekz>
        la fremdulo rigardas lin kaj lin frapas la beleco de la knabo <klr>[&#8230;]</klr>;
        li staras tie kiel <tld/>o, kaj &ccirc;ar li &scirc;ajne ne kura&gcirc;as alproksimi&gcirc;i
        <fnt>
          <aut>H. J. Bulthuis</aut>
          <vrk>Idoj de Orfeo</vrk>
          <lok>1923</lok>
        </fnt>.
      </ekz>
    </dif>
    <trdgrp lng="bg">
      <trd>&c_h;&c_je;&c_r;&c_u;&c_v;&c_i;&c_m;&c_ch;&c_je;</trd>,
      <trd>&c_a;&c_n;&c_g;&c_je;&c_l;&c_ch;&c_je;</trd>
    </trdgrp>
    <trd lng="br">kaezhig Doue</trd>
    <trdgrp lng="de">
      <trd>Augenstern</trd>,
      <trd>goldiges Kind</trd>
    </trdgrp>
    <trd lng="en">cherub</trd>
    <trd lng="es">&aacute;ngel<klr tip="ind"> (ni&ntilde;o encantador)</klr></trd>
    <trdgrp lng="fr">
      <trd>ch&eacute;rubin<klr tip="ind"> (enfant charmant)</klr></trd>,
      <trd>ange<klr tip="ind"> (enfant charmant)</klr></trd>
    </trdgrp>
    <trd lng="hu">kisangyal</trd>
    <trdgrp lng="it">
      <trd>cherubino</trd>,
      <trd>angioletto</trd>,
      <trd>amore<klr> (amorino, putto)</klr></trd>
    </trdgrp>
    <trd lng="ru">&c_h;&c_je;&c_r;&c_u;&c_v;&c_i;&c_m;</trd>
  </snc>
  <trd lng="be">&c_h;&c_je;&c_r;&c_u;&c_v;&c_ib;&c_m;</trd>
  <trd lng="bg">&c_h;&c_je;&c_r;&c_u;&c_v;&c_i;&c_m;</trd>
  <trd lng="br">kerubin</trd>
  <trdgrp lng="cs">
    <trd>cherub</trd>,
    <trd>cherub&iacute;n</trd>
  </trdgrp>
  <trdgrp lng="ja">
    <trd>&#22825;&#x4F7F;&#x30B1;&#x30EB;&#x30D3;&#x30E0; 
    <pr>&#12390;&#12435;&#12375;&#x30B1;&#x30EB;&#x30D3;&#x30E0;</pr></trd>,
    <trd>&#x30B1;&#x30EB;&#x30D3;&#x30E0;</trd>,
    <trd>&#x667A;&#22825;&#x4F7F;  <pr>&#12385;&#12390;&#12435;&#12375;</pr></trd>,
    <trd>&#x4E38;&#x307D;&#12385;&#12419;&#38996;&#x306E;&#x304B;&#x308F;&#12356;&#12356;&#x5B50;&#12393;&#12418; 
    <pr>&#x307E;&#x308B;&#x307D;&#12385;&#12419;&#x304B;&#x304A;&#x306E;&#x304B;&#x308F;&#12356;&#12356;&#12371;&#12393;&#12418;</pr></trd>
  </trdgrp>
  <trd lng="nl">cherubijn</trd>
  <trdgrp lng="pl">
    <trd>cherubinek</trd>,
    <trd>amorek</trd>,
    <trd>anio&lstroke;ek</trd>
  </trdgrp>
  <trdgrp lng="sk">
    <trd>cherub</trd>,
    <trd>cherub&iacute;n</trd>
  </trdgrp>
  <trd lng="uk">&c_h;&c_je;&c_r;&c_u;&c_v;&c_i;&#x43C;</trd>
</drv>
</art>
