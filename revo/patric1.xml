<?xml version="1.0"?>
<!DOCTYPE vortaro SYSTEM "../dtd/vokoxml.dtd">
<vortaro>
<art mrk="$Id: patric1.xml,v 1.20 2026/07/02 09:31:02 revo Exp $">
<kap>
  <ofc>4</ofc>
  <rad>patrici</rad>/o
  <fnt><bib>JED</bib></fnt>
</kap>
<drv mrk="patric1.0o">
  <kap><tld/>o</kap>
  <uzo tip="fak">HIS</uzo>
  <snc>
    <dif>
      Ano de <ref tip="malprt" cel="elit.0o">elito</ref>, kiu posedis la politikan potencon
      en <ref tip="malprt" cel="imperi.Roma_0o">Roma Imperio</ref> a&ubreve; en kelkaj
      mezepokaj landoj:
      <ekz>
        imperiestro Konstantino la 1-a enkondukis la titolon <tld/>o kiel honoron por meritplenaj
        civitanoj
        <fnt>
          <bib>Viki</bib>
          <lok><url ref="https://eo.wikipedia.org/?curid=134880">Patricio</url></lok>
        </fnt>.
      </ekz>
    </dif>
  </snc>
  <trd lng="be">&c_p;&c_a;&c_t;&c_r;&c_y;&c_c;&c_y;&c_j;</trd>
  <trdgrp lng="cs">
    <trd>patricij</trd>,
    <trd>patricius</trd>
  </trdgrp>
  <trd lng="de">Patrizier</trd>
  <trd lng="en">patrician</trd>
  <trd lng="fr">patricien</trd>
  <trd lng="hu">patr&iacute;cius</trd>
  <trd lng="ja">&#x30D1;&#x30C8;&#x30EA;&#x30AD;</trd>
  <trd lng="pl">patrycjusz</trd>
  <trd lng="nl">patrici&euml;r</trd>
  <trd lng="ro">patrician</trd>
  <trd lng="ru">&c_p;&c_a;&c_t;&c_r;&c_i;&c_c;&c_i;&c_j;</trd>
  <trd lng="sk">patr&iacute;cius</trd>
  <trd lng="uk">&c_p;&c_a;&c_t;&c_r;&c_i;&c_c;&c_ib;&c_j;</trd>
</drv>

<drv mrk="patric1.0aro">
  <kap>
    <tld/>aro
  </kap>
  <uzo tip="fak">HIS</uzo>
  <snc>
    <dif>
      La reganta <ref tip="super" cel="elit.0o">elito</ref> de <tld/>oj en la antikva Roma Imperio
      a&ubreve; en iuj mezepokaj urboj:
      <ekz>
        plen&scirc;topitaj estas la cirkoj... jen la aristokrata <tld/>aro observas la
        elegantajn konkurojn sur la Marsa Stadio
        <fnt>
          <aut>Francisco C&acirc;ndido Xavier, trad. L. C. Porto Carreiro Neto</aut>
          <vrk><url ref="https://libro.ee/file.php?id=408"
              >Anta&ubreve; du mil jaroj...</url></vrk>
          <lok>Intime Kun Emmanuel, p. 21</lok>
        </fnt>;
      </ekz>
      <ekz>
        tiel okazis la t.n. la unua praga trafenestrigo 30. 7. 1419, la husana Prago
        forigis la potencon de la malnova &ccirc;efe germana <tld/>aro kaj de la ri&ccirc;i&gcirc;inta
        roma eklezio
        <fnt>
          <vrk><url ref="https://www.esperanto.cz/soubory/patera-jiri_praha.pdf"
              >Prago</url></vrk>
          <lok>La historia evoluo de Prago</lok>
        </fnt>.
      </ekz>
    </dif>
  </snc>
  <trd lng="de">Patrizierschaft</trd>
</drv>

</art>
