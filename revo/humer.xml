<kap>
  <ofc>2</ofc>
  <rad>humer</rad>/o
  <fnt><bib>JED</bib></fnt>
</kap>
<drv mrk="humer.0o">
  <kap><tld/>o</kap>
  <uzo tip="fak">ANA</uzo>
  <snc>
    <dif>
      <ref tip="super" cel="ost.0o">Osto</ref>
      de la <ref tip="prt" cel="brak.0o.homa_membro">brako</ref>,
      liganta la kubuton al la &scirc;ultro:
      <ekz>
        &scirc;ultro estas artiko komponata de tri ostoj: la  <ref tip="prt"
        cel="klavik.0o">klaviklo</ref>, la  <ref tip="prt" cel="skapol.0o">skapolo</ref> kaj la
        <tld/>o
        <fnt>
          <bib>Viki</bib>
          <lok><url ref="https://eo.wikipedia.org/?curid=51575">&Scirc;ultro</url></lok>
        </fnt>.
      </ekz>
    </dif>
  </snc>
  <trd lng="be">&c_r;&c_a;&c_m;&c_jo;&c_n;&c_a;&c_k;</trd>
  <trd lng="br">paler</trd>
  <trd lng="ca">h&uacute;mer</trd>
  <trdgrp lng="cs">
    <trd>humerus</trd>,
    <trd>kost pa&zcaron;n&iacute;</trd>,
    <trd>nadlokt&iacute;</trd>,
    <trd>ramenn&iacute; kost</trd>
  </trdgrp>
  <trdgrp lng="de">
    <trd>Oberarmknochen</trd>,
    <trd>Humerus <klr>(Oberarmknochen)</klr></trd>
  </trdgrp>
  <trd lng="en">humerus</trd>
  <trd lng="es">h&uacute;mero</trd>
  <trd lng="fr">hum&eacute;rus</trd>
  <trd lng="hu">felkarcsont</trd>
  <trd lng="it">omero</trd>
  <trd lng="ja">&#19978;&#33109;&#39592;  <pr>&#12376;&#12423;&#12358;&#12431;&#12435;&#12371;&#12388;</pr></trd>
  <trdgrp lng="nl">
    <trd>opperarmbeen</trd>,
    <trd>humerus</trd>
  </trdgrp>
  <trd lng="pl">ko&sacute;&cacute; ramieniowa</trd>
  <trd lng="pt">&uacute;mero</trd>
  <trd lng="ru">&c_p;&c_l;&c_je;&c_ch;&c_je;&c_v;&c_a;&c_ja; &c_k;&c_o;&c_s;&c_t;&c_mol;</trd>
  <trdgrp lng="sk">
    <trd>nadlaktie</trd>,
    <trd>ramenn&aacute; kos&tcaron;</trd>
  </trdgrp>
  <trd lng="uk">&c_p;&c_l;&c_je;&c_ch;&c_o;&c_v;&c_a; &c_k;&c_ib;&c_s;&c_t;&c_k;&c_a;</trd>
  <trdgrp lng="zh">
    <trd>&#32945;&#39592; <pr>g&#333;ngg&#468;</pr></trd>,
    <trd>&#32945; <pr>g&#333;ng</pr></trd>,
    <trd>&#32945;&#37096; <pr>g&#333;ngb&ugrave;</pr></trd>
  </trdgrp>
</drv>
</art>
