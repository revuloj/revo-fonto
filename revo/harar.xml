<drv mrk="harar.0o">
  <kap><tld/>o</kap>
  <uzo tip="fak">GEOG</uzo><uzo tip="fak">POL</uzo>
  <snc>
    <dif>
      La <ref tip="lst" lst="voko:&ccirc;efurboj" cel="urb.cxef0o.POL">&ccirc;efurbo</ref>
      de <ref tip="malprt" cel="zimbabv.Z0o">Zimbabvo</ref>:
      situo:  (<frm>17&#730;49&minute; S  31&#730;03&minute; E</frm>):
      <ekz>
        intertempe 579 lokaj Esperanto-grupoj trovi&gcirc;as sur la grupaj mapoj de
        EsperantoLand, de Kordobo en Argentino &gcirc;is la Amikeca Klubo de <tld/>o en
        Zimbabvo
        <fnt>
          <bib>Viki</bib>
          <vrk><url ref="http://esperantoland.org/eo/plu.php?msgid=515">Voja&gcirc;ado &#8208; 579
          Esperanto-grupoj el la tuta mondo</url></vrk>
          <lok>Esperantoland.de</lok>
        </fnt>;
      </ekz>
      <ekz>
        <tld/>o estis fondita en 1890 kiel <nom>Fort Salisbury</nom>
        <fnt>
          <vrk><url ref="&Viki;/Hararo_(Zimbabvo)">Hararo (Zimbabvo) - Vikipedio</url></vrk>
        </fnt>.
      </ekz>
    </dif>
    <trd lng="be">&c_H;&c_a;&c_r;&c_a;&c_r;&c_e;</trd>
    <trd lng="de">Harare</trd>
    <trd lng="en">Harare</trd>
    <trd lng="fr">Harare</trd>
    <trd lng="id">Harare</trd>
    <trd lng="pl">Harare</trd>
  </snc>
  <rim>
    La tuton de ies haroj oni anka&ubreve; nomas <ref tip="hom" cel="har.0aro">hararo</ref>.
  </rim>
  <trd lng="ca">Harare</trd>
  <trd lng="es">Harare</trd>
  <trd lng="uk">&c_H;&c_a;&c_r;&c_a;&c_r;&c_je; (&c_s;&c_t;&c_o;&c_l;&c_i;&c_c;&c_ja;
  &c_Z;&c_ib;&c_m;&c_b;&c_a;&c_b;&c_v;&c_je;)</trd>
  <trd lng="zh">&#21704;&#25289;&#38647; <pr>h&amacron;lal&eacute;i</pr></trd>
</drv>
