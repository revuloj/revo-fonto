<?xml version="1.0"?>
<!DOCTYPE vortaro SYSTEM "../dtd/vokoxml.dtd">
<vortaro>
<art mrk="$Id: jezuit.xml,v 1.32 2026/03/13 07:10:29 revo Exp $">
<kap>
  <ofc>1</ofc>
  <rad>jezuit</rad>/o
<fnt><bib>JED</bib></fnt></kap>
<drv mrk="jezuit.0o">
  <kap><tld/>o</kap>
  <snc mrk="jezuit.0o.REL">
    <uzo tip="fak">REL</uzo>
    <dif>
      <ref tip="super" cel="membr.0o.ano">Membro</ref>
      de la religiula societo (propranome kompanio) fondita de
      Ignaco de <nom>Lojola</nom>:
      <ekz>
        la <tld/>oj permesis fumi kaj flari tabakon tiom, kiom &gcirc;i servas al la digestado kaj al la
        sano
        <fnt>
          <bib>FK</bib>
        </fnt>;
      </ekz>
      <ekz>
        ekde 1580 dum sep jaroj Nagasako estis fe&ubreve;do de <tld/>oj
        <fnt>
          <bib>Monato</bib>
          <aut>Hori Yasuo</aut>
          <vrk><url ref="&Monato;/2008/009358.php">Nagasako</url></vrk>
        </fnt>.
      </ekz>
    </dif>
    <trd lng="be">&c_je;&c_z;&c_u;&c_ib;&c_t;</trd>
    <trd lng="bg">&c_j;&c_je;&c_z;&c_u;&c_i;&c_t;</trd>
    <trd lng="de">Jesuit</trd>
    <trd lng="en">Jesuit</trd>
    <trd lng="es">jesuita</trd>
    <trd lng="fr">j&eacute;suite<klr tip="ind"> (subst.,
    religieux)</klr></trd>
    <trd lng="nl">Jesu&iuml;et</trd>
    <trd lng="pl">jezuita</trd>
    <trd lng="sv">jesuit</trd>
    <trd lng="it">gesuita</trd>
    <trdgrp lng="zh">
    <trd>&#x8036;&#x7A23;&#x4F1A;&#x58EB; <pr>Y&emacron;s&umacron;hu&igrave;sh&igrave;</pr></trd>,
    <trd>&#x8036;&#x9165;&#x4F1A;&#x58EB; <pr>Y&emacron;s&umacron;hu&igrave;sh&igrave;</pr></trd>
  </trdgrp>
</snc>
  <snc mrk="jezuit.0o.hipokritulo">
    <uzo tip="stl">FIG</uzo>
    <fnt><bib>VdE</bib></fnt>
    <dif>
      Timinda <ref tip="super" cel="hipokr.0ulo">hipokritulo</ref>:
      <ekz>
        vipura &jcirc;urnalismo en stilo de <tld/>o
        <fnt>
          <aut>Gilbert Ledon</aut>
            <vrk><url ref="&Monato;/2000/007264.php">Morti miskomprene (1)</url></vrk>
            <bib>Monato</bib>
            <lok>2000/12, p. 4</lok>
          </fnt>.
      </ekz>
    </dif>
    <trd lng="be">&c_k;&c_r;&c_y;&c_v;&c_a;&c_d;&c_u;&c_sh;&c_n;&c_ib;&c_k;</trd>
    <trd lng="de">Heuchler</trd>
    <trd lng="en">jesuit</trd>
    <trdgrp lng="fr">
      <trd>j&eacute;suite<klr tip="ind"> (fig.)</klr></trd>,
      <trd>fourbe<klr tip="ind"> (subst.)</klr></trd>,
      <trd>hypocrite<klr tip="ind"> (subst.)</klr></trd>
    </trdgrp>
    <trd lng="nl">huichelaar</trd>
    <trd lng="pl">jezuita</trd>
    <trdgrp lng="sv">
      <trd>hypokrit</trd>,
      <trd>hycklare</trd>
    </trdgrp>
  </snc>
  <trdgrp lng="cs">
    <trd>jezovita</trd>,
    <trd>jezuita</trd>,
    <trd>loyolita</trd>
  </trdgrp>
  <trd lng="hu">jezsuita</trd>
  <trdgrp lng="it">
      <trd>ipocrita</trd>,
      <trd>gesuita<klr> (fig.)</klr></trd>
    </trdgrp>
  <trdgrp lng="ja">
    <trd>&#x30A4;&#x30A8;&#x30BA;&#x30B9;&#x4F1A;&#x58EB;
    <pr>&#x30A4;&#x30A8;&#x30BA;&#x30B9;&#x304B;&#x3044;&#x3057;</pr></trd>,
    <trd>&#x9670;&#x967A;&#x306A;&#x4EBA;  <pr>&#x3044;&#x3093;&#x3051;&#x3093;&#x306A;&#x3058;&#x3093;</pr></trd>,
    <trd>&#x7B56;&#x8B00;&#x5BB6;  <pr>&#x3055;&#x304F;&#x307C;&#x3046;&#x304B;</pr></trd>
  </trdgrp>
  <trd lng="pt">jezu&iacute;ta</trd>
  <trd lng="ru">&c_i;&c_je;&c_z;&c_u;&c_i;&c_t;</trd>
  <trd lng="sk">jezuita</trd>
  <trdgrp lng="uk">
    <trd>&c_jeu;&c_z;&c_u;&c_ji;&c_t; (&c_t;&c_zh; &c_p;&c_je;&c_r;&c_je;&c_n;.)</trd>,
    <trd>&c_ch;&c_l;&c_je;&c_n; &c_jeu;&c_z;&c_u;&c_ji;&c_t;&c_s;&c_mol;&c_k;&c_o;&c_g;&c_o; &c_o;&c_r;&c_d;&c_je;&c_n;&c_a;</trd>
  </trdgrp>
</drv>

<drv mrk="jezuit.0a">
  <kap>
    <tld/>a
  </kap>
  <snc>
    <dif>
      Rilata al <tld/>oj:
      <ekz>
        en <tld/>aj mezaj lernejoj (kolegioj), la klasoj estis nomataj la&ubreve; &ccirc;efa
        instruata latina objekto: gramatiko, sintakso, poezio, retoriko (elokventeco)
        <fnt>
          <bib>SrT</bib>
          <lok>Libro VI.</lok>
        </fnt>;
      </ekz>
      <ekz>
        li prenis la <tld/>an robon
        <fnt>
          <bib>Kandid</bib>
          <lok>&Ccirc;apitro XV</lok>
        </fnt>;
      </ekz>
      <ekz>
        lia malamo kontra&ubreve; la <tld/>a societo speguli&gcirc;as tra multaj pa&gcirc;oj
        <fnt>
          <bib>Kandid</bib>
          <lok>Anta&ubreve;parolo</lok>
        </fnt>.
      </ekz>
    </dif>
    <trd lng="de">Jesuiten-</trd>
  </snc>
  <snc mrk="jezuit.0a.hipokrita">
    <uzo tip="stl">FIG</uzo>
    <dif>
      <ref tip="dif" cel="hipokr.0a">Hipokrita</ref>, <ref cel="ruz.0a">ruza</ref>:
      <ekz>
        ili diskutas pri votoj, pri &ccirc;asteco, abatinoj, volupto, pento&ccirc;emizoj kaj fine
        venas al <tld/>a kompromiso
        <fnt>
          <bib>KrB</bib>
          <lok>Jen kiaj ni estas!</lok>
        </fnt>;
      </ekz>
      <ekz>
        sub &gcirc;iaj respektemo kaj humilo ka&scirc;i&gcirc;as plej <tld/>a kovardo, neniu kapablas pli
        bone ol &gcirc;i &gcirc;ustatempe ka&scirc;e proksimi&gcirc;i kaj mordi je kruro
        <fnt>
          <bib>LOdE</bib>
          <lok>1999, No 12 (62)</lok>
        </fnt>.
      </ekz>
    </dif>
    <trd lng="de">scheinheilig</trd>
  </snc>
</drv>

</art>
