<kap>
  <ofc>9</ofc><rad>nan</rad>/o <fnt><bib>PVEF</bib></fnt>
</kap>
<drv mrk="nan.0o">
  <kap><ofc>9</ofc><tld/>o</kap>
  <snc mrk="nan.0o.MED">
   <dif>
    <ref tip="dif" cel="grand.mal0egulo">Malgrandegulo</ref> :
    <ekz>Kiam tute mallumi&gcirc;is, venis la mastroj de la dometo, sep nanoj,
    fosistoj de metaloj en la montoj.  <fnt><bib>ElektFab</bib>,
      <lok>Ne&gcirc;ulino</lok></fnt></ekz>
     </dif>
  </snc>
  <rim mrk="nan.0o.RIM_HOM">
    <ref cel="nano.0">nano-</ref> estas
    prefikso en la Sistemo Internacia de unuoj.
  </rim>
  <trd lng="be">&c_k;&c_a;&c_r;&c_l;&c_ib;&c_k;</trd>
  <trd lng="bg">&c_d;&c_zh;&c_u;&c_d;&c_zh;&c_je;</trd>
  <trd lng="br">korr</trd>
  <trd lng="ca">nan</trd>
  <trd lng="de">Zwerg</trd>
  <trdgrp lng="en">
    <trd>dwarf</trd>,
    <trd>midget</trd>,
    <trd>little person</trd>
  </trdgrp>
  <trd lng="es">enano</trd>
  <trd lng="fa">&f_k;&a_w;&a_t;&a_w;&a_l;&a_h;</trd>
  <trd lng="fr">nain <klr>(subst.)</klr></trd>
  <trd lng="hu">t&ouml;rpe</trd>
  <trd lng="id">kurcaci</trd>
  <trdgrp lng="ja">
    <trd>&#x5C0F;&#x4EBA;  <pr>&#12375;&#12423;&#12358;&#x306B;&#12435;</pr></trd>,
    <trd>&#x77EE;&#x5C0F;&#x4F53;  <pr>&#x308F;&#12356;&#12375;&#12423;&#12358;&#x305F;&#12356;</pr></trd>
  </trdgrp>
  <trd lng="nl">dwerg</trd>
  <trd lng="pl">karze&lstroke;</trd>
  <trd lng="pt">an&atilde;o</trd>
  <trd lng="ro">pitic</trd>
  <trd lng="ru">&c_k;&c_a;&c_r;&c_l;&c_i;&c_k;</trd>
  <trd lng="sv">dv&auml;rg</trd>
  <trdgrp lng="uk">
    <trd>&#x43A;&c_a;&c_r;&#x43B;&c_i;&#x43A;</trd>,
    <trd>(&c_z;&c_ib;&c_r;&#x43A;&c_a;-)&#x43A;&c_a;&c_r;&#x43B;&c_i;&#x43A;</trd>
  </trdgrp>
  <trdgrp lng="zh">
    <trd>&#x4F8F;&#20754; <pr>zh&#x16B;r&#xFA;</pr></trd>,
    <trd>&#34966;&#x73CD;&#x4EBA; <pr>xi&#xF9;zh&emacron;nr&#xE9;n</pr></trd>,
    <trd>&#x77EE;&#x5B50; <pr>&#x1CE;izi</pr></trd>,
    <trd>&#x4F8F; <pr>zh&#x16B;</pr></trd>
  </trdgrp>
</drv>

<drv mrk="nan.0a">
  <kap><ofc>9</ofc><tld/>a <fnt><bib>PV</bib></fnt></kap>
  <snc mrk="nan.0a.MED">
   <dif>
     Malgrandega :
     <ekz>
       Tie sur la nana tero <fnt><bib>ElektFab</bib>,
       <lok>Ne&gcirc;ulino</lok></fnt>
     </ekz>
   </dif>
  </snc>
  <trd lng="be">&c_k;&c_a;&c_r;&c_l;&c_ib;&c_k;&c_a;&c_v;&c_y;</trd>
  <trd lng="fr">nain <klr>(adj.)</klr></trd>
  <trdgrp lng="ja">
    <trd>&#x5C0F;&#x4EBA;&#x306E;  <pr>&#12371;&#12403;&#12392;&#x306E;</pr></trd>,
    <trd>&#x77EE;&#24615;&#x306E;  <pr>&#x308F;&#12356;&#x305B;&#12356;&#x306E;</pr></trd>
  </trdgrp>
  <trd lng="pl">kar&lstroke;owaty</trd>
  <trd lng="ro">minuscul</trd>
  <trd lng="uk">&#x43A;&c_a;&c_r;&#x43B;&c_i;&#x43A;&#x43E;&c_v;&c_i;&c_j;</trd>
  <trd lng="zh">&#x4F8F;&#20754; <pr>zh&#x16B;r&#xFA;</pr></trd>
</drv>

</art>
