<?xml version="1.0"?>
<!DOCTYPE vortaro SYSTEM "../dtd/vokoxml.dtd">
<vortaro>
<art mrk="$Id: inert.xml,v 1.31 2026/06/20 17:46:49 revo Exp $">
<kap>
  <ofc>4</ofc>
  <rad>inert</rad>/a
<fnt><bib>JED</bib></fnt></kap>
<drv mrk="inert.0a">
  <kap><tld/>a</kap>
  <snc mrk="inert.0a.senmova">
    <dif>
      Ne havanta propran movon:
      <ekz>
        <tld/>a &scirc;tono, kadavro;
      </ekz>
      <ekz>
        delikate <tld/>a, velkanta vaksfloro
        <fnt>
          <bib>KKr</bib>
        </fnt>;
      </ekz>
      <ekz>
        jen la ha&ubreve;to de la korposubo subite <tld/>i&gcirc;is, ekcedis kaj malfermi&gcirc;is
        <fnt>
          <bib>KKr</bib>
        </fnt>;
      </ekz>
      <ekz>
        la policistoj povis fari halton kun ebriulo, <tld/>e pendanta inter iliaj krudaj
        brakoj
        <fnt>
          <bib>VRA</bib>
        </fnt>;
      </ekz>
      <ekz>
        dekstre kreskis maljuna, <tld/>a, de likenoj venkita abio
        <fnt>
          <bib>VRA</bib>
        </fnt>;
      </ekz>
      <ekz>
        la animo &scirc;telis dormmomenton interne, en sia nesto de <tld/>i&gcirc;intaj muskoloj
        <fnt>
          <bib>VRA</bib>
        </fnt>;
      </ekz>
      <ekz>
        la aliulo certe pensus, ke mi estas <tld/>ulo
        <fnt>
          <bib>KrM</bib>
        </fnt>;
      </ekz>
      <ekz>
        <tld/>a homo <fnt><bib>VdE</bib></fnt>
        <klr>(senmova, kvaza&ubreve; senviva)</klr>.
      </ekz>
    </dif>
    <refgrp tip="vid">
      <ref cel="rigid.0a">rigida</ref>,
      <ref cel="mov.sen0a">senmova</ref>,
      <ref cel="viv.sen0a">senviva</ref>
    </refgrp>
    <trdgrp lng="de">
      <trd>bewegungslos</trd>,
      <trd>unbeweglich</trd>
    </trdgrp>
    <trdgrp lng="hu">
      <trd>tehetetlen</trd>,
      <trd>mozdulatlan</trd>
    </trdgrp>
    <trd lng="nl">bewegingsloos</trd>
    <trdgrp lng="pl">
      <trd>odr&eogonek;twia&lstroke;y</trd>,
      <trd>bezw&lstroke;adny</trd>
    </trdgrp>
    <trd lng="ru">&c_i;&c_n;&c_je;&c_r;&c_t;&c_n;&c_y;&c_j;</trd>
  </snc>
  <snc mrk="inert.0a.KEM">
    <uzo tip="fak">KEM</uzo>
    <fnt><bib>PIV1</bib></fnt>
    <dif>
      Ne reaganta &hcirc;emie:
      <ekz>
        <ind><tld/>a gaso</ind>
        <klr>(<ref tip="vid" cel="gas.nobla0o">nobla gaso</ref>)</klr>.
        <trd lng="be">&c_ib;&c_n;&c_e;&c_r;&c_t;&c_n;&c_y; <ind>&c_g;&c_a;&c_z;</ind></trd>
        <trdgrp lng="ca">
          <trd><ind>gas</ind> noble</trd>,
          <trd><ind>gas</ind> inert</trd>,
          <trd><ind>gas</ind> rar</trd>
        </trdgrp>
        <trd lng="de">Edelgas</trd>
        <trdgrp lng="en">
          <trd>inert <ind>gas</ind></trd>,
          <trd>noble <ind>gas</ind></trd>
        </trdgrp>
        <trdgrp lng="fr">
          <trd>gaz rare</trd>,
          <trd>gaz inerte</trd>
          <trd>gaz noble</trd>
        </trdgrp>
        <trd lng="hu">nemesg&aacute;z</trd>
        <trdgrp lng="it">
          <trd>gas inerte</trd>,
          <trd>gas nobile</trd>
        </trdgrp>
        <trd lng="nl">edelgas</trd>
        <trd lng="pl">gaz szlachetny</trd>
        <trd lng="pt">g&aacute;s nobre</trd>
        <trd lng="ru">&c_i;&c_n;&c_je;&c_r;&c_t;&c_n;&c_y;&c_j; &c_g;&c_a;&c_z;</trd>
      </ekz>
    </dif>
    <trdgrp lng="de">
      <trd>inert</trd>,
      <trd>reaktionstr&auml;ge</trd>
    </trdgrp><trdgrp lng="hu">
      <trd>semleges k&eacute;mhat&aacute;s&uacute;</trd>,
      <trd>vegyileg <ind>k&ouml;z&ouml;mb&ouml;s</ind></trd>
    </trdgrp>
  </snc>
  <snc mrk="inert.0a.FIG">
    <uzo tip="stl">FIG</uzo>
    <dif>
      Ne <ref tip="ant" cel="ag.0ema">agema</ref>, ne havanta
      iniciatokapablon, sen<ref tip="ant" cel="energi.0a">energia</ref>:
      <ekz>
        resti <tld/>a anta&ubreve; la dan&gcirc;ero;
      </ekz>
      <ekz>
        <tld/>a <klr>(pasiva)</klr> kontra&ubreve;staro;
      </ekz>
      <ekz>
        la fumo iom vekis lin el lia <tld/>a stato
        <fnt>
          <bib>InfanTorent2</bib>
        </fnt>;
      </ekz>
      <ekz>
        fidante ke tiu <tld/>a amaso sekvos la decidojn de siaj gvidantoj
        <fnt>
          <bib>EeP</bib>
        </fnt>;
      </ekz>
      <ekz>
        vi, viroj, estas <tld/>a &scirc;afaro!
        <fnt>
          <bib>KKr</bib>
        </fnt>!
      </ekz>
      <ekz>
        la ombroj kaj memoroj pri Solferino lin tute obsedis, sed ili nun ne <tld/>igis
        lin
        <fnt>
          <bib>KKr</bib>
        </fnt>.
      </ekz>
    </dif>
    <refgrp tip="vid">
      <ref cel="indife.0a.iu">indiferenta<sncref/></ref>,
      <ref cel="pasiv.0a.malagema">pasiva<sncref/></ref>,
      <ref cel="pigr.0a.KOMUNE">pigra<sncref/></ref>
    </refgrp>
    <trd lng="de">tr&auml;ge</trd>
    <trdgrp lng="hu">
      <trd>tehetetlen</trd>,
      <trd>tunya</trd>
    </trdgrp>
    <trdgrp lng="nl">
      <trd>energieloos</trd>,
      <trd>inert</trd>,
      <trd>traag</trd>
    </trdgrp>
    <trdgrp lng="ru">
      <trd>&c_i;&c_n;&c_je;&c_r;&c_t;&c_n;&c_y;&c_j;</trd>,
      <trd>&c_k;&c_o;&c_s;&c_n;&c_y;&c_j;</trd>
    </trdgrp>
  </snc>
  <trd lng="be">&c_ib;&c_n;&c_e;&c_r;&c_t;&c_n;&c_y;</trd>
  <trd lng="ca">inert</trd>
  <trdgrp lng="cs">
    <trd>inertn&iacute;</trd>,
    <trd>nereaguj&iacute;c&iacute; na nic</trd>,
    <trd>nete&ccaron;n&yacute;</trd>
  </trdgrp>
  <trd lng="en">inert</trd>
  <trd lng="es">inerte</trd>
  <trd lng="fr">inerte</trd>
  <trd lng="it">inerte<klr tip="ind"> (agg.)</klr></trd>
  <trdgrp lng="ja">
    <trd>&#x60F0;&#24615;&#30340;&#x306A;  <pr>&#12384;&#x305B;&#12356;&#12390;&#x304D;&#x306A;</pr></trd>,
    <trd>&#28961;&#x6C17;&#x529B;&#x306A;  <pr>&#12416;&#x304D;&#x308A;&#12423;&#x304F;&#x306A;</pr></trd>,
    <trd>&#x6D88;&#26997;&#30340;&#x306A;  <pr>&#12375;&#12423;&#12358;&#x304D;&#12423;&#x304F;&#12390;&#x304D;&#x306A;</pr></trd>,
    <trd>&#x4E0D;&#x6D3B;&#24615;&#x306E;  <pr>&#12405;&#x304B;&#12387;&#x305B;&#12356;&#x306E;</pr></trd>
  </trdgrp>
  <trd lng="pt">inerte</trd>
  <trdgrp lng="sk">
    <trd>nev&scaron;&iacute;mav&yacute;</trd>,
    <trd>&lcaron;ahostajn&yacute;</trd>
  </trdgrp>
  <trdgrp lng="uk">
    <trd>&c_ib;&c_n;&c_je;&c_r;&c_t;&c_n;&c_i;&c_j;</trd>,
    <trd>&c_b;&c_je;&c_z;&c_d;&c_ib;&c_ja;&c_l;&c_mol;&c_n;&c_i;&c_j;</trd>,
    <trd>&c_v;&#8217;&c_ja;&c_l;&c_i;&c_j;</trd>,
    <trd>&c_b;&c_je;&c_z;&c_ib;&c_n;&c_ib;&c_c;&c_ib;&c_a;&c_t;&c_i;&c_v;&c_n;&c_i;&c_j;</trd>,
    <trd>&c_ib;&c_n;&c_je;&c_r;&c_t;&c_n;&c_i;&c_j;</trd>
  </trdgrp>
  <trd lng="zh">&#x60F0;&#24615; <pr>du&ograve;x&igrave;ng</pr></trd>
</drv>

<drv mrk="inert.0eco">
  <kap><tld/>eco, <var><kap><tld/>o</kap></var></kap>
  <snc mrk="inert.0eco.FIZ">
    <uzo tip="fak">FIZ</uzo>
    <fnt><bib>VdE</bib></fnt>
    <dif>
      Natura eco de la materio, la&ubreve; kiu korpo emas resti en la sama
      stato de movo a&ubreve; senmovo kaj ne povas mem modifi tiun staton:
      <ekz>
        la <tld/>eco de korpo mezuri&gcirc;as per ties
        <ref cel="mas.0o.FIZ">maso</ref>;
      </ekz>
      <ekz>
        <ref cel="fort.inerto0o"><tld/>oforto</ref>;
      </ekz>
      <ekz>
        <ref cel="rad.inerto0o"><tld/>orado</ref>.
      </ekz>
    </dif>
    <ref tip="sin" cel="inerci.0o.FIZ">inercio <sncref/>.</ref>
    <trd lng="fr">inertie<klr tip="ind"> (phys.)</klr></trd>
    <trd lng="hu">tehetetlens&eacute;g</trd>
    <trd lng="it">inerzia<klr tip="ind"> (fis.)</klr></trd>
    <trd lng="ru">&c_i;&c_n;&c_je;&c_r;&c_c;&c_i;&c_ja;</trd>
  </snc>
  <snc mrk="inert.0eco.psika">
    <uzo tip="stl">FIG</uzo>
    <dif>
      Manko de iniciato, neagemo, senenergieco:
      <ekz>
        al &ccirc;iuj admonoj li respondas per nevenkebla <tld/>eco;
      </ekz>
      <ekz>
        libertempo kaj kristnasko plenigis ilin per kreviga &gcirc;ojo, kiu forigis ilian
        vintran <tld/>on
        <fnt>
          <bib>InfanTorent2</bib>
        </fnt>;
      </ekz>
      <ekz>
        ili estas teksitaj el laceco, <tld/>eco kaj samtempe el obstina sed sencela
        vivovolo
        <fnt>
          <bib>Tor</bib>
        </fnt>;
      </ekz>
      <ekz>
        pri tio ne kulpas la demokrateco de UEA, <klr>[&#8230;]</klr> sed neinteresi&gcirc;o kaj
        <tld/>eco
        <fnt>
          <bib>EeP</bib>
        </fnt>.
      </ekz>
    </dif>
    <ref tip="sin" cel="inerci.0o.psika">inercio <sncref/></ref>
    <refgrp tip="vid">
      <ref cel="apati.0o">apatio</ref>,
      <ref cel="deprim.0o">deprimo</ref>,
      <ref cel="enu.0o">enuo</ref>,
      <ref cel="farnient.0o">farniento</ref>,
      <ref cel="flegm.0o">flegmo</ref>,
      <ref cel="vigl.mal0o">malviglo</ref>,
      <ref cel="marasm.0o.FIG">marasmo<sncref/></ref>,
      <ref cel="langvor.0o">langvoro</ref>
    </refgrp>
    <trd lng="de">Antriebslosigkeit</trd>
    <trdgrp lng="fr">
      <trd>inertie</trd>,
      <trd>apathie</trd>,
      <trd>inaction</trd>,
      <trd>l&eacute;thargie</trd>
    </trdgrp>
    <trdgrp lng="hu">
      <trd>tunyas&aacute;g</trd>,
      <trd>tehetetlens&eacute;g</trd>
    </trdgrp>
    <trdgrp lng="it">
      <trd>inerzia</trd>,
      <trd>apatia</trd>,
      <trd>inanit&agrave;</trd>,
      <trd>inazione</trd>,
      <trd>letargia</trd>
    </trdgrp>
    <trdgrp lng="ru">
      <trd>&c_i;&c_n;&c_je;&c_r;&c_t;&c_n;&c_o;&c_s;&c_t;&c_mol;</trd>,
      <trd>&c_k;&c_o;&c_s;&c_n;&c_o;&c_s;&c_t;&c_mol;</trd>
    </trdgrp>
  </snc>
  <trdgrp lng="be">
    <trd>&c_ib;&c_n;&c_e;&c_r;&c_c;&c_y;&c_ja;</trd>,
    <trd>&c_ib;&c_n;&c_e;&c_r;&c_t;&c_n;&c_a;&c_s;&c_mol;&c_c;&c_mol;</trd>
  </trdgrp>
  <trd lng="ca">in&egrave;rcia</trd>
  <trdgrp lng="cs">
    <trd>ne&ccaron;innost</trd>,
    <trd>zkostnat&ecaron;lost</trd>
  </trdgrp>
  <trd lng="de">Tr&auml;gheit</trd>
  <trd lng="en">inertia</trd>
  <trd lng="es">inercia</trd>
  <trdgrp lng="ja">
    <trd>&#x60F0;&#24615;  <pr>&#12384;&#x305B;&#12356;</pr></trd>,
    <trd>&#28961;&#x6C17;&#x529B;  <pr>&#12416;&#x304D;&#x308A;&#12423;&#x304F;</pr></trd>,
    <trd>&#x4E0D;&#x6D3B;&#24615;  <pr>&#12405;&#x304B;&#12387;&#x305B;&#12356;</pr></trd>
  </trdgrp>
  <trd lng="nl">traagheid</trd>
  <trdgrp lng="pl">
    <trd>bezruch</trd>,
    <trd>zast&oacute;j</trd>
  </trdgrp>
  <trd lng="pt">in&eacute;rcia</trd>
  <trdgrp lng="sk">
    <trd>apatia</trd>,
    <trd>skostnatenos&tcaron;</trd>,
    <trd>&lcaron;ahostajnos&tcaron;</trd>
  </trdgrp>
  <trdgrp lng="uk">
    <trd>&c_ib;&c_n;&c_je;&c_r;&c_t;&c_n;&c_ib;&c_s;&c_t;&c_mol;</trd>,
    <trd>&c_b;&c_je;&c_z;&c_d;&c_ib;&c_ja;&c_l;&c_mol;&c_n;&c_ib;&c_s;&c_t;&c_mol;</trd>,
    <trd>&c_v;&#8217;&c_ja;&c_l;&c_ib;&c_s;&c_t;&c_mol;</trd>,
    <trd>&c_b;&c_je;&c_z;&c_ib;&c_n;&c_ib;&c_c;&c_ib;&c_a;&c_t;&c_i;&c_v;&c_n;&c_ib;&c_s;&c_t;&c_mol;</trd>,
    <trd>&c_ib;&c_n;&c_je;&c_r;&c_t;&c_n;&c_ib;&c_s;&c_t;&c_mol;</trd>,
    <trd>&c_a;&c_p;&c_a;&c_t;&c_ib;&c_ja;</trd>
  </trdgrp>
  <trdgrp lng="zh">
    <trd>&#x60F0;&#24615; <pr>du&ograve;x&igrave;ng</pr></trd>,
    <trd>&#x60EF;&#x91CF; <pr>gu&agrave;nli&agrave;ng</pr></trd>,
    <trd>&#x60EF;&#24615; <pr>gu&agrave;nx&igrave;ng</pr></trd>,
    <trd>&#x60EF;&#24615;&#x539F;&#29702; <pr>gu&agrave;nx&igrave;ngyu&aacute;nl&#x1D0;</pr></trd>,
    <trd>&#x60EF;&#x529B; <pr>gu&agrave;nl&igrave;</pr></trd>,
    <trd>&#x60EF;&#24615;&#x529B; <pr>gu&agrave;nx&igrave;ngl&igrave;</pr></trd>
  </trdgrp>
</drv>

<drv mrk="inert.0eca">
  <kap><tld/>eca</kap>
  <uzo tip="fak">FIZ</uzo>
  <snc>
    <dif>
      Rilata al <ref cel="inert.0eco.FIZ"><tld/>eco <sncref/></ref>:
      <ekz>
        <ind><tld/>eca principo</ind> <klr>(korpo, submetata al eksteraj
        fortoj, kies sumo estas nula, restas senmova a&ubreve; movi&gcirc;as
        rektlinie kun konstanta rapido)</klr>;
        <trd lng="ca">principi d'<ind>in&egrave;rcia</ind></trd>
        <trdgrp lng="fr">
          <trd>principe d'inertie</trd>,
          <trd>principio d'inerzia</trd>
        </trdgrp>
        <trd lng="pl">zasada bezw&lstroke;adno&sacute;ci</trd>
      </ekz>
      <ekz>
        <ind><tld/>eca referenco-sistemo</ind> <klr>(tia
        referenco-sistemo,
        ke en &gcirc;i validas la <tld/>eca principo)</klr>;
        <trd lng="ca">sistema de refer&egrave;ncia <ind>inercial</ind></trd>
        <trdgrp lng="fr">
          <trd>r&eacute;f&eacute;rentiel d'inertie</trd>,
          <trd>r&eacute;f&eacute;rentiel inertiel</trd>
        </trdgrp>
        <trd lng="it">sistema di riferimento inerziale</trd>
        <trd lng="pl">inercjalny uk&lstroke;ad odniesienia</trd>
        <trd lng="ru">&c_i;&c_n;&c_je;&c_r;&c_c;&c_i;&c_a;&c_l;&c_mol;&c_n;&c_a;&c_ja; &c_s;&c_i;&c_s;&c_t;&c_je;&c_m;&c_a;
        &c_o;&c_t;&c_s;&c_ch;&c_jo;&c_t;&c_a;</trd>
      </ekz>
      <ekz>
        <ind><tld/>eca forto</ind>
        <fnt><bib>PV</bib><lok>alia difino</lok></fnt>
        <klr>(forto, kiun necesas aldoni al la
        eksteraj fortoj, por ke la <tld/>eca principo &scirc;ajnu
        apliki&gcirc;i anka&ubreve; en la ne<tld/>ecaj
        referenco-sistemoj; ekz-e <ref cel="centri.0a.FIZ">centrifuga</ref>
        forto)</klr>.
        <trd lng="be">&c_s;&c_ib;&c_l;&c_a; <ind>&c_ib;&c_n;&c_e;&c_r;&c_c;&c_y;&c_ib;</ind></trd>
        <trd lng="ca">for&ccedil;a <ind>inercial</ind></trd>
        <trd lng="de">Tr&auml;gheitskraft</trd>
        <trd lng="es">fuerza de <ind>inercia</ind></trd>
        <trd lng="fr">force d'inertie</trd>
        <trdgrp lng="hu">
          <trd>tehetetlens&eacute;gi er&odblac;</trd>,
          <trd>t&ouml;meger&odblac;</trd>
        </trdgrp>
        <trdgrp lng="it">
          <trd>forza apparente</trd>,
          <trd>forza inerziale</trd>,
          <trd>forza fittizia</trd>
        </trdgrp>
        <trd lng="nl">inertie</trd>
        <trd lng="pl">si&lstroke;a bezw&lstroke;adno&sacute;ci</trd>
        <trd lng="ru">&c_s;&c_i;&c_l;&c_a; <ind>&c_i;&c_n;&c_je;&c_r;&c_c;&c_i;&c_i;</ind></trd>
      </ekz>
    </dif>
    <refgrp tip="sin">
      <ref cel="inerci.0a">inercia</ref>,
      <ref cel="inerci.0uma">inerciuma</ref>
    </refgrp>
  </snc>
  <adm>
    La terminon "referenco-sistemo" restas por difini a&ubreve; por
    anstata&ubreve;igi per io pli konvena. Mi prenis &gcirc;in en PIV2,
    artikolo "inerciuma", sed trovis difinon nek sub "sistemo",
    nek sub "referenco".
    <aut>MB</aut>
  </adm>
  <trd lng="be">&c_ib;&c_n;&c_e;&c_r;&c_c;&c_y;&c_ja;&c_l;&c_mol;&c_n;&c_y;</trd>
  <trd lng="ca">inercial</trd>
  <trd lng="en">inertial</trd>
  <trdgrp lng="fr">
    <trd>d'<ind>inertie</ind></trd>,
    <trd>inertiel</trd>
  </trdgrp>
  <trdgrp lng="hu">
    <trd>tehetetlens&eacute;gi</trd>,
    <trd>inerci&aacute;lis</trd>
  </trdgrp>
  <trd lng="it">inerziale</trd>
  <trdgrp lng="pl">
    <trd>inercyjny</trd>,
    <trd>bezw&lstroke;adny</trd>
  </trdgrp>
  <trd lng="pt">inercial</trd>
  <trdgrp lng="ru">
    <trd>&c_i;&c_n;&c_je;&c_r;&c_c;&c_i;&c_a;&c_l;&c_mol;&c_n;&c_y;&c_j;</trd>,
    <trd>&c_i;&c_n;&c_je;&c_r;&c_c;&c_i;&c_o;&c_n;&c_n;&c_y;&c_j;</trd>
  </trdgrp>
  <trd lng="zh">&#x60F0;&#24615; <pr>du&ograve;x&igrave;ng</pr></trd>
</drv>

<drv mrk="inert.0igi">
  <kap>
    <tld/>igi
  </kap>
  <snc>
    <dif>
      Ka&ubreve;zi <tld/>econ:
      <ekz>
        la ombroj kaj memoroj pri Solferino lin tute obsedis, sed ili nun ne <tld/>igis
        lin, sed spronis la &ccirc;evalon de lia fantazio
        <fnt>
          <bib>KKr</bib>
          <lok>V</lok>
        </fnt>;
      </ekz>
