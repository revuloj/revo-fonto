<?xml version="1.0"?>
<!DOCTYPE vortaro SYSTEM "../dtd/vokoxml.dtd">
<vortaro>
<art mrk="$Id: ancxov.xml,v 1.28 2026/04/21 16:00:21 revo Exp $">
<kap>
  <ofc>1</ofc>
  <rad>an&ccirc;ov</rad>/o
<fnt><bib>JED</bib></fnt></kap>
<drv mrk="ancxov.0o">
  <kap><tld/>o</kap>
  <snc mrk="ancxov.0o.KUI">
    <uzo tip="fak">KUI</uzo>
    <dif>
      Spicita <ref cel="sardel.0o">sardelo</ref> a&ubreve;
      <ref cel="sprot.0o">sproto</ref>, konservita en ladskatolo:
      <ekz>
        konsumu malmulte da ru&gcirc;a viando, sed pli da grasa fi&scirc;o (salmo, skombro, haringo,
        <tld/>o kaj sardinoj)
        <fnt>
          <bib>Monato</bib>
          <aut>Lode Van De Velde</aut>
          <vrk><url ref="&Monato;/2013/010934.php">Sablohorlo&gcirc;o for&scirc;ovas piramidon</url></vrk>
        </fnt>;
      </ekz>
      <ekz>
        en 1747 oni inventis mustardon kun aldona&jcirc;oj (kaporoj, <tld/>oj, vinbera suko)
        <fnt>
          <bib>Viki</bib>
          <lok><url ref="https://eo.wikipedia.org/?curid=25639">Mustardo</url></lok>
        </fnt>.
      </ekz>
    </dif>
    <trd lng="ca">anxova<klr tip="amb"> (adobada)</klr></trd>
    <trdgrp lng="hu">
      <trd>szardellagy&udblac;r&udblac;</trd>,
      <trd>ringli<klr tip="ind"> (szardella)</klr></trd>
    </trdgrp>
    <trdgrp lng="pl">
      <trd>anchois<klr> [czyt. anszu&lstroke;a]</klr></trd>,
      <trd>sardela</trd>
    </trdgrp>
  </snc>
  <snc mrk="ancxov.0o.ZOO">
    <uzo tip="fak">ZOO</uzo>
    <dif>
      <ref tip="dif" cel="sardel.0o">Sardelo</ref>:
      <ekz>
        en la areo de Markolo ili anka&ubreve; fi&scirc;kaptas tinusojn, pil&ccirc;ardojn, <tld/>ojn kaj
        skombrojn
        <fnt>
          <bib>Viki</bib>
          <lok><url ref="https://eo.wikipedia.org/?curid=3808">A&ubreve;tonoma regiono Sicilio</url></lok>
        </fnt>.
      </ekz>
    </dif>
    <trdgrp lng="ca">
      <trd>seit&oacute;</trd>,
      <trd>aladroc</trd>,
      <trd>anxova</trd>
    </trdgrp>
    <trd lng="pl">sardela</trd>
  </snc>
  <trd lng="bg">&c_a;&c_n;&c_sh;&c_o;&c_a;</trd>
  <trd lng="be">&c_a;&c_n;&c_ch;&c_o;&c_w;&c_s;</trd>
  <trd lng="de">Anchovis</trd>
  <trd lng="en">anchovy</trd>
  <trd lng="es">anchoa</trd>
  <trd lng="fr">anchois</trd>
  <trdgrp lng="he">
    <trd>&alef;&nun;&shin;&vav;&bet;&yod;</trd>,
    <trd>&ayin;&pe;&yod;&yod;&fnun;</trd>
  </trdgrp>
  <trdgrp lng="hu">
    <trd>szardella</trd>,
    <trd>aj&oacute;ka</trd>
  </trdgrp>
  <trdgrp lng="ja">
    <trd>&#27833;&#28460;&#12369;&#12398;&#12452;&#12527;&#12471; 
    <pr>&#12354;&#12406;&#12425;&#12389;&#12369;&#12398;&#12452;&#12527;&#12471;</pr></trd>,
    <trd>&#12450;&#12531;&#12481;&#12519;&#12499;&#12540;</trd>,
    <trd>&#12459;&#12479;&#12463;&#12481;&#12452;&#12527;&#12471;</trd>
  </trdgrp>
  <trd lng="nl">ansjovis</trd>
  <trd lng="ru">&c_a;&c_n;&c_ch;&c_o;&c_u;&c_s;</trd>
  <trd lng="sk">sardela</trd>
  <trdgrp lng="uk">
    <trd>&c_a;&c_n;&c_ch;&c_o;&c_u;&c_s;</trd>,
    <trd>&c_h;&c_a;&c_m;&c_s;&c_a;</trd>
  </trdgrp>
</drv>
</art>
