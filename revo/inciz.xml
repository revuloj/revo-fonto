<?xml version="1.0"?>
<!DOCTYPE vortaro SYSTEM "../dtd/vokoxml.dtd">

<vortaro>
  <art mrk="$Id: inciz.xml,v 1.1 2026/06/02 10:54:55 afido Exp $">
    <kap>
      <rad>inciz</rad>/i
      <fnt><bib>PIV1</bib></fnt>
    </kap>

<drv mrk="inciz.0i">
  <kap><tld/>i</kap>
  <snc mrk="inciz.0i.MED">
    <uzo tip="fak">MED</uzo>
    <dif>
      Surface <ref tip="super" cel="trancx.en0i">entran&ccirc;i</ref>:
      <ekz>
        Vla&ccirc;jo <tld/>is la peritoneon &gcirc;is la pubia simfizo
        <fnt>
          <aut>Jurij German, trad. Jurij Finkel</aut>
          <vrk><url ref="https://eduinf.waw.pl/esp/lern/librejo/0294/0014.php"
              >La afero, al kiu vi servas</url></vrk>
          <lok>&Ccirc;apitro dekkvara, Kiel fartas via brutaro?</lok>
        </fnt>;
      </ekz>
      <ekz>
        mi bone vidis la &scirc;losilon kun la <tld/>ita kapeto, figuranta kantantan kokon
        <fnt>
          <aut>Aleksandro &Scirc;arov, trad. Andreo &Hcirc;i&jcirc;njak</aut>
          <vrk><url ref="https://eduinf.waw.pl/esp/lern/librejo/0301/0004.php"
              >Pizulo kaj Simplulo</url></vrk>
          <lok>&Ccirc;apitro tria: La Magistro, Tondilo kaj Luno</lok>
        </fnt>.
      </ekz>
    </dif>
    <ref tip="vid" cel="sekc.0i.ANA">sekci<sncref/></ref>
    <trdgrp lng="de">
      <trd>inzidieren</trd>,
      <trd>einschneiden</trd>
    </trdgrp>
    <trd lng="en">incise</trd>
    <trd lng="fr">inciser</trd>
  </snc>
</drv>

  </art>

