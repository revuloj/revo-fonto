<art mrk="$Id: apik.xml,v 1.18 2026/03/29 07:18:53 revo Exp $">
<kap>
  <rad>apik</rad>/a
<fnt><bib>PVEF</bib></fnt></kap>
<drv mrk="apik.0a">
  <kap><tld/>a</kap>
  <snc>
    <dif>
      Krute <ref tip="super" cel="vertik.0a.FIZ">vertikala</ref>:
      <ekz>
        <tld/>a roko;
      </ekz>
      <ekz>
        murda <tld/>a faligo
        <fnt>
          <bib>ChV</bib>
          <lok>14</lok>
        </fnt>;
      </ekz>
      <ekz>
        <uzo tip="stl">FIG</uzo>
        tia sinteno de multaj demokratoj <klr>[&#x2026;]</klr> anstata&ubreve; bremsi la reakcion,
        alfundigis nin <tld/>e en la duan mondmiliton
        <fnt>
          <vrk><url ref="https://www.gazetoteko.com/kajeroj/k024/k024problemoj.html"
              >Problemoj en nia laborista familio</url></vrk>
          <lok>Kajeroj el la Sudo, n-ro 24, 1994</lok>
        </fnt>.
      </ekz>
    </dif>
    <ref tip="vid" cel="krut.0a">kruta</ref>
  </snc>
  <trdgrp lng="be">
    <trd>&c_s;&c_t;&c_r;&c_o;&c_m;&c_y;</trd>,
    <trd>&c_s;&c_t;&c_r;&c_o;&c_m;&c_k;&c_ib;</trd>,
    <trd>&c_v;&c_e;&c_r;&c_t;&c_y;&c_k;&c_a;&c_l;&c_mol;&c_n;&c_y;</trd>
  </trdgrp>
  <trdgrp lng="cs">
    <trd>prudk&yacute;</trd>,
    <trd>p&rcaron;&iacute;kr&yacute;</trd>,
    <trd>strm&yacute;</trd>
  </trdgrp>
  <trdgrp lng="de">
     <trd>steil</trd>,
     <trd>fast <ind>senkrecht</ind></trd>,
     <trd>nahezu senkrecht</trd>
  </trdgrp>
  <trdgrp lng="en">
    <trd>tilted</trd>
  </trdgrp>
  <trdgrp lng="fr">
    <trd>&agrave; <ind>pic</ind></trd>,
    <trd>escarp&eacute;</trd>
  </trdgrp>
  <trd lng="he">&tav;&lamed;&vav;&lamed;</trd>
  <trd lng="hu">meredek</trd>
  <trd lng="ja">&#x5782;&#x76F4;&#x306B;&#x5207;&#x7ACB;&#x3063;&#x305F;  <pr>&#x3059;&#x3044;&#x3061;&#x3087;&#x304F;&#x306B;&#x304D;&#x308A;&#x305F;&#x3063;&#x305F;</pr></trd>
  <trdgrp lng="ru">
    <trd>&c_k;&c_r;&c_u;&c_t;&c_o;&c_j;</trd>,
    <trd>&c_v;&c_je;&c_r;&c_t;&c_i;&c_k;&c_a;&c_l;&c_mol;&c_n;&c_y;&c_j;</trd>
  </trdgrp>
  <trdgrp lng="sk">
    <trd>pr&iacute;kry</trd>,
    <trd>strm&yacute;</trd>,
    <trd>zvisl&yacute;</trd>
  </trdgrp>
  <trdgrp lng="uk">
    <trd>&c_a;&c_p;&c_ib;&c_k;&c_a;&c_l;&c_mol;&c_n;&c_i;&c_j;</trd>,
    <trd>&c_v;&c_je;&c_r;&c_h;&c_ib;&c_v;&c_k;&c_o;&c_v;&c_i;&c_j;</trd>
  </trdgrp>
</drv>
</art>
