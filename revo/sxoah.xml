<vortaro>
  <art mrk="$Id: sxoah.xml,v 1.1 2026/04/23 14:22:31 afido Exp $">
    <kap>
      <rad>&Scirc;oah</rad>/o
    </kap>

<drv mrk="sxoah.0o">
  <kap><tld/>o</kap>
  <snc>
    <uzo tip="fak">HIS</uzo>
    <dif>
      La <ref tip="super" cel="genocid.0o">genocido</ref> al la judoj fare de la nazioj:
      <ekz>
        <nom>Herschel Grynszpan</nom> <klr>[&#x2026;]</klr> ver&scirc;ajne mortis kiel viktimo de la <tld/>o en la
        koncentrejo <nom>Sachsenhausen</nom>
        <fnt>
          <bib>Viki</bib>
          <lok><url ref="https://eo.wikipedia.org/?curid=228389"
              >Herschel Grynszpan</url></lok>
        </fnt>;
      </ekz>
      <ekz>
        neante la <tld lit="&scirc;"/>on a&ubreve; for-interpretante &gcirc;iajn faktojn &gcirc;is preska&ubreve;a
        nuligo, tiu episkopo kreis grandan embarason <klr>[&#x2026;]</klr> &ccirc;e papo Benedikto
        la 16a
        <fnt>
          <bib>Monato</bib>
          <aut>Armando Zecchin</aut>
          <vrk><url ref="&Monato;/2009/009762.php"
              >La papo pardonpetas</url></vrk>
          <lok>2009</lok>
        </fnt>.
      </ekz>
    </dif>
    <ref tip="sin" cel="holokauxst.0o">holoka&ubreve;sto</ref>
    <trd lng="de">Schoa</trd>
    <trd lng="fr">Shoah</trd>
    <trd lng="he">&he;&#x5B7;&shin;&#x5BC;&#x5C1;&vav;&#x5B9;&alef;&#x5B8;&he;</trd>
  </snc>
</drv>

