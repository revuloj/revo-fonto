<art mrk="$Id: ferdek.xml,v 1.26 2026/06/01 18:00:20 revo Exp $">
<kap>
<ofc>*</ofc>
<rad>ferdek</rad>/o <fnt><bib>UV</bib></fnt>
</kap>
<drv mrk="ferdek.0o">
  <kap><ofc>*</ofc><tld/>o</kap>
  <snc mrk="ferdek.0o.MAR">
   <uzo tip="fak">MAR</uzo>
    <dif>
      Planko kovranta la tutan kavon de la &scirc;ipo,
      a&ubreve; formanta super &gcirc;i eta&gcirc;ojn:
      <ekz>
        <ind>du<tld/>a</ind>, tri<tld/>a &scirc;ipo;
        <trd lng="be">&c_d;&c_v;&c_u;&c_h;&c_p;&c_a;&c_l;&c_u;&c_b;&c_n;&c_y;</trd>
        <trd lng="hu">dupla <ind>fed&eacute;lzet&udblac;</ind></trd>
        <trd lng="ru">&c_d;&c_v;&c_u;&c_h;&c_p;&c_a;&c_l;&c_u;&c_b;&c_n;&c_y;&c_j;</trd>
      </ekz>
      <ekz>
        &scirc;nuregoj etenditaj tie kaj tie &ccirc;i por faciligi maristojn sur la <tld/>o estis
        anka&ubreve; bonega gvidilo por mia promenado
        <fnt>
          <aut>Jamazaki, trad. K. Takahashi</aut>
          <vrk>Doloro ricevita de la lasta militego</vrk>
          <lok>en: Orienta Almanako, 1913</lok>
        </fnt>.
      </ekz>
    </dif>
  </snc>
  <trd lng="be">&c_p;&c_a;&c_l;&c_u;&c_b;&c_a;</trd>
  <trd lng="bg">&c_p;&c_a;&c_l;&c_u;&c_b;&c_a;</trd>
  <trd lng="ca">coberta<klr tip="amb"> (d'un vaixell)</klr></trd>
  <trd lng="cs">paluba</trd>
  <trdgrp lng="de">
     <trd>Deck</trd>,
     <trd>Verdeck</trd></trdgrp>
  <trd lng="en">deck<klr tip="amb"> (ship)</klr></trd>
  <trd lng="es">cubierta <klr tip="ind"> (na&uacute;tica)</klr></trd>
  <trd lng="fr">pont<klr tip="ind"> (d'un navire)</klr></trd>
  <trd lng="hu">fed&eacute;lzet</trd>
  <trdgrp lng="ja">
    <trd>&#30002;&#26495;  <pr>&#12371;&#12358;&#12356;&#12383;</pr></trd>,
    <trd>&#12487;&#12483;&#12461;</trd>,
    <trd>&#19978;&#30002;&#26495;  <pr>&#12376;&#12423;&#12358;&#12363;&#12435;&#12401;&#12435;</pr></trd>
  </trdgrp>
  <trd lng="nl">dek<klr tip="ind"> (v.e.schip)</klr></trd>
  <trd lng="pl">pok&lstroke;ad</trd>
  <trdgrp lng="pt">
    <trd>conv&eacute;s</trd>,
    <trd>tolda</trd>,
    <trd>ponte</trd>
  </trdgrp>
  <trdgrp lng="ro">
    <trd>strat</trd>,
    <trd>punte</trd>
  </trdgrp>
  <trd lng="ru">&c_p;&c_a;&c_l;&c_u;&c_b;&c_a;</trd>
  <trd lng="sk">paluba</trd>
  <trd lng="uk">&c_p;&c_a;&c_l;&c_u;&c_b;&c_a;</trd>
  <trd lng="zh">&#30002;&#26495; <pr>ji&#462;b&#462;n</pr></trd>
</drv>
</art>
