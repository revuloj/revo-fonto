<?xml version="1.0"?>
<!DOCTYPE vortaro SYSTEM "../dtd/vokoxml.dtd">
<vortaro>
<art mrk="$Id: hajnan.xml,v 1.2 2026/07/15 14:06:15 afido Exp $">
<kap>
    <rad>Hajnan</rad>/o <fnt><bib>PIV2</bib></fnt>
</kap>
<drv mrk="hajnan.0o">
  <kap><tld/>o</kap>
  <snc mrk="hajnan.0o.GEOG">
    <uzo tip="fak">GEOG</uzo>
    <dif>
      <ref tip="lst" lst="voko:insuloj" cel="insul.0o.GEOG">Insulo</ref>
      &ccirc;e la sudo de kontinenta <ref tip="malprt" cel="cxin.CX0ujo">&Ccirc;inujo</ref>:
      <ekz>
        tiujn &ccirc;i multegajn &leftquot;dialektojn&rightquot; oni povus <klr>[&#x2026;]</klr> dividi en la sekvantajn
        ok &ccirc;efajn klasojn: la Kantona, Hakka, Amoja, Svatana, &Scirc;an&hcirc;aja, Ningpoa,
        <tld/>a kaj Mandarina
        <fnt>
          <bib>FK</bib>
          <lok>Fundamenta Krestomatio de la lingvo Esperanto</lok>
        </fnt>;
      </ekz>
      <ekz>
        en <tld/>o la teamo vizitis la projekton de <nom>Dennis Keefe</nom> &leftquot;Esperanto-Insulo&rightquot;
        <fnt>
          <aut>P. Bal&aacute;&zcaron;</aut>
          <vrk>E@I kaj lernu.net vizitis &Ccirc;inion</vrk>
          <lok>Revuo Esperanto, 2008-2012</lok>
        </fnt>
      </ekz>
    </dif>
    <trdgrp lng="zh">
      <trd>&#x6D77;&#x5357;&#x5CF6; <pr>H&#x1CE;in&aacute;n D&#x1CE;o</pr></trd>,
      <trd>&#x6D77;&#x5357;&#x5C9B; <pr>H&#x1CE;in&aacute;n D&#x1CE;o</pr></trd>
    </trdgrp>
  </snc>
  <snc mrk="hajnan.0o.POL">
    <uzo tip="fak">POL</uzo>
    <dif>
      Provinco en la suda parto de <ref tip="malprt" cel="cxin.CX0ujo">&Ccirc;inujo</ref>
      konsistanta el la insulo <tld lit="H"/>o kaj &ccirc;irka&ubreve;aj pli malgrandaj insuloj.
    </dif>
    <trd lng="zh">&#x6D77;&#x5357;&#x7701; <pr>H&#x1CE;in&aacute;n Sh&ecaron;ng</pr></trd>
  </snc>
  <trd lng="de">Hainan</trd>
  <trd lng="fr">Hainan</trd>
</drv>
</art>

