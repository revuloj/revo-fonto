<drv mrk="nemez.0o">
  <kap><tld/>o</kap>
  <snc mrk="nemez.0o.MIT">
    <uzo tip="fak">MIT</uzo>
    <dif>
      <klr>(en la grekaj mitoj)</klr> <ref tip="super" cel="di.0ino">Diino</ref>
      de <ref cel="vengx.0o">ven&gcirc;o</ref>:
      <ekz>
        ho, nekomprenebla fingro de la ven&gcirc;ema <tld/>o
        <fnt>
          <bib>Rabistoj</bib>
          <lok>Akto Kvara</lok>
        </fnt>!
      </ekz>
      <ekz>
        lia sola teatra&jcirc;o, <tld/>o, tragedio en kvar aktoj, estis presita &jcirc;us anta&ubreve; lia
        morto
        <fnt>
          <bib>Monato</bib>
          <aut>Edward Kusters</aut>
          <vrk><url ref="&Monato;/2006/009100.php"
              >Alfred Nobel: nobelo inter la sciencistoj kaj lingvistoj</url></vrk>
          <lok>2006</lok>
        </fnt>.
      </ekz>
    </dif>
    <trd lng="de">Nemesis</trd>
    <trd lng="en">Nemesis</trd>
    <trd lng="fr">N&eacute;m&eacute;sis</trd>
    <trd lng="grc">&Ny;&epsilon_ton;&my;&epsilon;&sigma;&jota;&sigma_fina;</trd>
  </snc>
</drv>

