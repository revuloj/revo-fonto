<?xml version="1.0"?>
<!DOCTYPE vortaro SYSTEM "../dtd/vokoxml.dtd">
<vortaro>
<art mrk="$Id: cxad.xml,v 1.26 2026/07/12 06:00:22 revo Exp $">
<kap><ofc>10</ofc>
  <rad>&Ccirc;ad</rad>/o
</kap>

<drv mrk="cxad.CX0o">
  <kap>
    <tld lit="&Ccirc;"/>o
  </kap>
  <snc mrk="cxad.CX0o.GEOG">
    <uzo tip="fak">GEOG</uzo>
    <uzo tip="fak">POL</uzo>
    <fnt><bib>RLN</bib></fnt>
    <mlg kod="ISO-3166">TD</mlg>
    <dif>
      <ref lst="voko:&scirc;tatoj" cel="sxtat.0o.POL">&Scirc;tato</ref>
      en la centra <ref tip="malprt" cel="afrik.A0o">Afriko</ref>
      kun &ccirc;efurbo N&gcirc;ameno; teritorio de Respubliko <tld/>o,
      limanta kun
      <ref tip="vid" cel="afrik.CentrA0o.GEOG">Centr-Afriko</ref>,
      <ref tip="vid" cel="kamerun.K0o.GEOG">Kameruno</ref>,
      <ref tip="vid" cel="libi.L0o.GEOG">Libio</ref>,
      <ref tip="vid" cel="nigxer.N0o.lando">Ni&gcirc;ero</ref>,
      <ref tip="vid" cel="nigxeri.N0o.GEOG">Ni&gcirc;erio</ref>
      kaj <ref tip="vid" cel="sudan.S0o.GEOG">Sudano</ref>:
      <ekz>
        unuflanke ari&gcirc;as soldatoj de KDR, Angolo, Namibio, <tld/>o kaj
        Zimbabvo,
        aliflanke tiuj de Ruando, Ugando, Burundo kaj ribelantaj trupoj
        el KDR
        <fnt>
          <aut>Zanandu Ntomono Zola/PG</aut>
            <vrk><url ref="&Monato;/2000/006802.php">Soldatoj, sed neniaj solvoj</url></vrk>
            <bib>Monato</bib>
            <lok>2000/02, p. 6</lok>
          </fnt>;
      </ekz>
      <ekz>
        akri&gcirc;is la atakoj aparte en &scirc;tato Borno, kiu dividas landlimon
        kun <tld/>o
        <fnt>
          <bib>Monato</bib>
          <aut>Princo Henriko Oguinye</aut>
          <vrk><url ref="&Monato;/2009/009885.php">Mortigoj
          religiaj</url></vrk>
        </fnt>.
      </ekz>
    </dif>
    <trd lng="be">&c_Ch;&c_a;&c_d; <klr>(&c_k;&c_r;&c_a;&c_ib;&c_n;&c_a;)</klr></trd>
    <trd lng="bg">&c_Ch;&c_a;&c_d;</trd>
    <trdgrp lng="ca">
      <trd>el <ind>Txad</ind></trd>,
      <trd>Rep&uacute;blica del <ind>Txad</ind></trd>
    </trdgrp>
    <trd lng="de">Tschad</trd>
    <trd lng="en">Chad</trd>
    <trd lng="fr">Tchad</trd>
    <trd lng="hu">Cs&aacute;d</trd>
    <trd lng="id">Chad</trd>
    <trd lng="it">Ciad</trd>
    <trd lng="nl">Tsjaad</trd>
    <trdgrp lng="pl">
      <trd>Czad</trd>,
      <trd>Republika <ind>Czadu</ind></trd>
    </trdgrp>
    <trd lng="pt">Chade</trd>
    <trdgrp lng="zh">
    <trd>&#20045;&#24471; <pr>zh&agrave;d&eacute;</pr></trd>,
    <trd>&#20045;&#24471;&#20849;&#21644;&#22269; <pr>zh&agrave;d&eacute;g&ograve;ngh&eacute;gu&oacute;</pr></trd>
  </trdgrp>
</snc>
  <snc mrk="cxad.CX0o.lago">
    <dif>
      Sendeflua <ref tip="super" cel="lag.0o">lago</ref>
      &ccirc;e la Sudo de <ref tip="super" cel="sahar.0o">Saharo</ref>,
      situanta en la landoj <tld/>o, Kameruno, Ni&gcirc;erio kaj Ni&gcirc;ero:
      <ekz>
        estis diskutitaj ekzemple la agrikulturaj politikoj, la
        ekologiaj katastrofoj,
        la lokaj bataloj kontra&ubreve; akvo-&scirc;telo, la problemo de la lago
        <tld/>o,
        <klr>[&#8230;]</klr>
        <fnt>
          <bib>Monato</bib>
          <aut>Ren&eacute;e Triolle</aut>
          <vrk><url ref="&Monato;/2012/010696.php">&Ccirc;u vivofonto a&ubreve;
          profitfonto?</url></vrk>
        </fnt>;
      </ekz>
    </dif>
    <trd lng="be">&c_Ch;&c_a;&c_d; <klr>(&c_v;&c_o;&c_z;&c_je;&c_r;&c_a;)</klr></trd>
    <trd lng="ca">el llac <ind>Txad</ind></trd>
    <trd lng="de">Tschadsee</trd>
    <trd lng="id">Danau Chad</trd>
    <trd lng="pt">Lago Chade</trd>
    <trd lng="zh">&#20045;&#24471;&#28246; <pr>zh&agrave;d&eacute;h&uacute;</pr></trd>
</snc>

  <trd lng="ja">&#12481;&#12515;&#12489;&#28246;  <pr>&#12481;&#12515;&#12489;&#12371;</pr></trd>
  <trd lng="uk">&c_Ch;&c_a;&c_d;</trd>
</drv>

</art>

