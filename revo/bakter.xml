<?xml version="1.0"?>
<!DOCTYPE vortaro SYSTEM "../dtd/vokoxml.dtd">
<vortaro>
<art mrk="$Id: bakter.xml,v 1.35 2026/05/04 14:41:17 revo Exp $">
<kap>
  <ofc>2</ofc>
  <rad>bakteri</rad>/o <fnt><bib>JED</bib></fnt>
</kap>

<drv mrk="bakter.0o">
  <kap><tld/>o</kap>
  <snc mrk="bakter.0o.BAK">
    <uzo tip="fak">BAK</uzo>
    <dif>
      Mikroskopa vivulo, kiu ka&ubreve;zas fermentadon, putradon, puson
      kaj diversajn malsanojn:
      <ekz>
        &ccirc;e <tld/>oj pliofti&gcirc;as la kapablo rezisti
        antibiotikojn
        <fnt>
          <aut>V. Lemelev</aut>,
          <vrk>Malamikoj de bakterioj</vrk>,
          <bib>Monato</bib>,
          <lok>jaro 2000a, numero 1a, p. 14a</lok>
        </fnt>;
      </ekz>
      <ekz>
        desinfektilo, <klr>[kiu per]</klr> radiado <klr>[&#x2026;]</klr> ekstermas
        kelkajn specojn de la virusoj kaj <tld/>oj
        <fnt>
          <bib>VaK</bib>
          <lok>Sesa &Ccirc;apitro</lok>
        </fnt>;
      </ekz>
      <ekz>
        70-jara virino mortis en Usono viktime de super<tld/>o, la kuracistoj intencis
        uzi 26 antibiotikojn en la kuracado, sed neniu el la alternativoj kapablis
        venki &gcirc;in
        <fnt>
          <bib>Kon11</bib>
          <lok>Kontaktek</lok>
        </fnt>.
      </ekz>
    </dif>
    <refgrp tip="super">
      <ref cel="mikrob.0o">mikrobo</ref>,
      <ref cel="prokariot.0o">prokarioto</ref>
    </refgrp>
    <ref tip="sub" cel="bacil.0o">bacilo</ref>
    <refgrp tip="vid">
      <ref cel="arhxe.0o">ar&hcirc;eo</ref>
    </refgrp>
    <trdgrp lng="zh">
    <trd>&#x7D30;&#x83CC; <pr>x&imacron;j&umacron;n</pr></trd>,
      <trd>&#x7D30;&#x83CC;&#x7E41;&#x6B96; <pr>x&imacron;j&umacron;nf&aacute;nzh&iacute;</pr></trd>
    </trdgrp>
  </snc>
  <trd lng="be">&c_b;&c_a;&c_k;&c_t;&c_e;&c_r;&c_y;&c_ja;</trd>
  <trd lng="bg">&c_b;&c_a;&c_k;&c_t;&c_je;&c_r;&c_i;&c_ja;</trd>
  <trd lng="ca">bacteri</trd>
  <trd lng="cs">bakterie</trd>
  <trd lng="de">Bakterie</trd>
  <trd lng="el">&beta;&alfa;&kappa;&tau;&eta_ton;&rho;&jota;&omikron;</trd>
  <trd lng="en">bacterium</trd>
  <trd lng="es">bacteria</trd>
  <trd lng="fa">&a_b;&a_A;&f_k;&a_t;&a_r;&f_y;</trd>
  <trd lng="fr">bact&eacute;rie</trd>
  <trd lng="he">&bet;&#x5BC;&#x5B7;&qof;&tet;&#x5B6;&resh;&#x5B4;&yod;&#x5B8;&he;</trd>
  <trd lng="hu">bakt&eacute;rium</trd>
  <trd lng="id">bakteri</trd>
  <trdgrp lng="ja">
    <trd>&#x30D0;&#x30AF;&#x30C6;&#x30EA;&#x30A2;</trd>,
    <trd>&#x7D30;&#x83CC;  <pr>&#x3055;&#x3044;&#x304D;&#x3093;</pr></trd>
  </trdgrp>
  <trd lng="nl">bacterie</trd>
  <trd lng="pl">bakteria</trd>
  <trd lng="ru">&c_b;&c_a;&c_k;&c_t;&c_je;&c_r;&c_i;&c_ja;</trd>
  <trd lng="sk">bakt&eacute;ria</trd>
  <trd lng="sv">bakterie</trd>
  <trd lng="uk">&c_b;&c_a;&c_k;&c_t;&c_je;&c_r;&c_ib;&c_ja;</trd>
</drv>

<drv mrk="bakter.ciano0oj">
  <kap>ciano<tld/>oj</kap>
  <snc mrk="bakter.ciano0oj.BAK">
    <uzo tip="fak">BAK</uzo>
    <dif>
      <ref tip="super" cel="bakter.0o.BAK">Bakterioj</ref> kapablaj je
      fotosintezo (<trd lng="la">Cyanobacteria</trd>), aperantaj kiel maldika blu-verda tavolo sur
      akvo a&ubreve; en aliaj lokoj
      (ar&hcirc;aika nomo: <ref tip="sin" cel="alg.blu0o.BAK">bluaj algoj</ref>):
      <ekz>
        la&ubreve; la supra evolua historio, Prokloro ja estas
        ano de la ciano<tld/>oj
        <fnt>
          <aut>J. Badger</aut>,
          <vrk><url ref="http://groups.google.be/group/soc.culture.esperanto/msg/3a164e3a487ee13c">
          biologia klasifiko</url></vrk>,
          <lok>soc.culture.esperanto, 1999-12-04</lok>
        </fnt>.
      </ekz>
    </dif>
  </snc>
  <trd lng="be">&c_c;&c_y;&c_ja;&c_n;&c_a;&c_b;&c_a;&c_k;&c_t;&c_e;&c_r;&c_y;&c_ib;</trd>
  <trdgrp lng="ca">
    <trd>esquizof&iacute;cies</trd>,
    <trd>cianof&iacute;cies</trd>,
    <trd>cianobacteris</trd>
  </trdgrp>
  <trd lng="fr">cyanobact&eacute;rie</trd>
  <trd lng="id">sianobakteri</trd>
  <trd lng="ja">&#x30B7;&#x30A2;&#x30CE;&#x30D0;&#x30AF;&#x30C6;&#x30EA;&#x30A2;</trd>
  <trd lng="uk">&c_s;&c_i;&c_n;&c_mol;&c_o;-&c_z;&c_je;&c_l;&c_je;&c_n;&c_ib; &c_b;&c_a;&c_k;&c_t;&c_je;&c_r;&c_ib;&c_ji;</trd>
  <trdgrp lng="zh">
    <trd>&#x84DD;&#x85FB; <pr>l&aacute;nz&#x1CE;o</pr></trd>,
    <trd>&#x84DD;&#x85FB;&#x754C; <pr>l&aacute;nz&#x1CE;oji&egrave;</pr></trd>
  </trdgrp>
</drv>
</art>
