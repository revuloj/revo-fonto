<?xml version="1.0"?>
<!DOCTYPE vortaro SYSTEM "../dtd/vokoxml.dtd">
<vortaro>
<art mrk="$Id: pir.xml,v 1.50 2026/07/22 06:43:10 revo Exp $">
<kap>
  <ofc>*</ofc>
  <rad>pir</rad>/o
<fnt><bib>UV</bib></fnt></kap>
<drv mrk="pir.0o">
  <kap><ofc>*</ofc><tld/>o</kap>
  <snc mrk="pir.0o.KUI">
    <uzo tip="fak">KUI</uzo>
    <dif>
      <ref tip="super" cel="frukt.0o.KUI">Frukto</ref> de <ref tip="malprt"
      cel="pir.0ujo"><tld/>arbo</ref>, ekstere verda,
      flava a&ubreve; ru&gcirc;eta, la&ubreve; specoj globa a&ubreve;
      tubera &ccirc;e la supra ekstremo, kun iom malmola, dol&ccirc;a karno:
      <ekz>
        apude staris du korboj plenaj de sova&gcirc;aj <tld/>oj kaj pomoj
        <fnt>
          <bib>ElektFab</bib>
          <lok>Pa&scirc;tistino de anseroj apud puto</lok>
        </fnt>;
      </ekz>
      <ekz>
        ru&gcirc;aj pomoj kaj grandaj <tld/>oj sin apogis al melono
        <fnt>
          <bib>IK</bib>
        </fnt>;
      </ekz>
      <ekz>
        duonon de tiu &ccirc;i <tld/>o mi man&gcirc;is, kvaronon mi donis al mia nevo, kaj la lastan
        kvaronon mi for&jcirc;etis
        <fnt>
          <bib>DL</bib>
        </fnt>;
      </ekz>
      <ekz>
        kompari <tld/>ojn kun pomoj
        <klr>(kompari nekompareble diversajn aferojn)</klr>
        <fnt>
          <bib>Monato</bib>
          <aut>Stefan Maul</aut>
          <vrk><url ref="&Monato;/2005/008522.php">Histerio</url></vrk>
        </fnt>.
        <trd lng="de">&Auml;pfel mit Birnen vergleichen</trd>
      </ekz>
    </dif>
    <ref tip="super" cel="frukt.plur0o">plurfrukto</ref>
    <bld
    lok="&WCU;/thumb/4/43/Peer_'Bonne_Louise_d'Avranches'_(Pyrus_communis).jpg/250px-Peer_'Bonne_Louise_d'Avranches'_(Pyrus_communis).jpg"
    prm="CC-BY-SA-3.0">du <tld/>oj
        <fnt>
          <aut>Rasbak, propra verko</aut>
          <lok><url
          ref="&WCW;/File:Peer_'Bonne_Louise_d'Avranches'_(Pyrus_communis).jpg">&WCW;/File:Peer_'Bonne_Louise_d'Avranches'_(Pyrus_communis).jpg</url></lok>
        </fnt>
    </bld>
  </snc>
  <trdgrp lng="be">
    <trd>&c_g;&c_r;&c_u;&c_sh;&c_a;
    <klr>(&c_p;&c_l;&c_o;&c_d;)</klr></trd>,
    <trd>&c_ib;&c_g;&c_r;&c_u;&c_sh;&c_a;
    <klr>(&c_p;&c_l;&c_o;&c_d;)</klr></trd>
  </trdgrp>
  <trd lng="bg">&c_k;&c_r;&c_u;&c_sh;&c_a;</trd>
  <trd lng="bo">&t_la;&t_gigu;&t_tsheg;</trd>
  <trd lng="br">perenn<klr tip="ind"> (frouezhenn)</klr></trd>
  <trd lng="ca">pera</trd>
  <trd lng="cs">hru&scaron;ka</trd>
  <trd lng="de">Birne</trd>
  <trd lng="en">pear</trd>
  <trd lng="es">pera</trd>
  <trd lng="fr">poire</trd>
  <trd lng="hu">k&ouml;rte</trd>
  <trd lng="id">pir</trd>
  <trdgrp lng="ja">
    <trd>&#12490;&#12471;</trd>,
    <trd>&#27915;&#12490;&#12471;  <pr>&#12424;&#12358;&#12394;&#12375;</pr></trd>
  </trdgrp>
  <trd lng="nl">peer</trd>
  <trd lng="pl">gruszka</trd>
  <trd lng="pt">p&ecirc;ra</trd>
  <trd lng="ru">&c_g;&c_r;&c_u;&c_sh;&c_a; <klr tip="amb">(&c_p;&c_l;&c_o;&c_d;)</klr></trd>
  <trd lng="sk">hru&scaron;ka</trd>
  <trd lng="tr">armut</trd>
  <trd lng="uk">&c_g;&c_r;&c_u;&c_sh;&c_a; (&c_p;&c_l;&c_ib;&c_d;)</trd>
  <trdgrp lng="zh">
    <trd>&#26792; <pr>l&iacute;</pr></trd>,
    <trd>&#26792;&#23376; <pr>l&iacute;zi</pr></trd>
  </trdgrp>
</drv>

<drv mrk="pir.0ujo">
  <kap><tld/>ujo,
    <var><kap><tld/>arbo</kap></var></kap>
  <snc mrk="pir.0ujo.BOT">
    <uzo tip="fak">BOT</uzo>
    <dif>
      <ref tip="lst" cel="arb.0o" lst="voko:rozoparencoj">Arbo</ref>
      el kiu unu specio (<trd lng="la">Pyrus communis</trd>) estas
      kulturata en multaj varia&jcirc;oj pro la  fruktoj,
      <ref tip="lst" cel="genr.0o.BIO" lst="voko:botanikaj_genroj">genro</ref> el familio <ref
      tip="malprt" cel="rozac.0oj">rozacoj</ref>
      (<trd lng="la">Pyrus</trd>):
      <ekz>
        mi komencis a&ccirc;eti belajn arbojn kaj plantis ilin en la herbaro: ekzemple
        <klr>[&#8230;]</klr> <tld/>arbon kaj pomujojn
       <fnt>
          <aut>M&aacute;ire NicAoidh</aut>
          <vrk><url ref="&Monato;/2000/006878.php">&Gcirc;ardenumi</url></vrk>
          <bib>Monato</bib>
          <lok>2000/04, p. 20</lok>
          </fnt>;
      </ekz>
      <ekz>
        sur e&ubreve;ropaj <tld/>ujoj, ili povas utili kiel indikilo de la rikoltoperiodo de la
        fruktoj, &ccirc;ar helaj lenticeloj sur nematura frukto malheli&gcirc;as kaj esti&gcirc;as
        brunaj
        <fnt>
          <bib>Viki</bib>
          <lok><url ref="https://eo.wikipedia.org/?curid=435391">Lenticelo</url></lok>
        </fnt>.
      </ekz>
    </dif>
  </snc>
  <trdgrp lng="be">
    <trd>&c_g;&c_r;&c_u;&c_sh;&c_a;
    <klr>(&c_d;&c_r;&c_e;&c_v;&c_a;)</klr></trd>,
    <trd>&c_ib;&c_g;&c_r;&c_u;&c_sh;&c_a;
    <klr>(&c_d;&c_r;&c_e;&c_v;&c_a;)</klr></trd>
  </trdgrp>
  <trdgrp lng="br">
    <trd>gwezenn-ber</trd>,
    <trd>perenn<klr tip="ind"> (gwezenn)</klr></trd>
  </trdgrp>
  <trdgrp lng="ca">
    <trd>perera</trd>,
    <trd>perer</trd>
  </trdgrp>
  <trd lng="cs">hru&scaron;e&ncaron;</trd>
  <trd lng="de">Birnbaum</trd>
  <trd lng="en">pear tree</trd>
  <trd lng="es">peral</trd>
  <trd lng="fr">poirier</trd>
  <trd lng="hu">k&ouml;rtefa</trd>
  <trd lng="id">pohon pir</trd>
  <trd lng="ja">&#12490;&#12471;</trd>
  <trdgrp lng="nl">
    <trd>perelaar</trd>,
    <trd>perenboom</trd>
  </trdgrp>
  <trd lng="pl">grusza</trd>
  <trd lng="ru">&c_g;&c_r;&c_u;&c_sh;&c_a; <klr
  tip="amb">(&c_d;&c_je;&c_r;&c_je;&c_v;&c_o;)</klr></trd>
  <trd lng="sk">hru&scaron;ka <klr>(strom)</klr></trd>
  <trd lng="uk">&c_g;&c_r;&c_u;&c_sh;&c_a; (&c_d;&c_je;&c_r;&c_je;&c_v;&c_o;)</trd>
  <trdgrp lng="zh">
    <trd>&#26792;&#26641; <pr>l&iacute;sh&ugrave;</pr></trd>,
    <trd>&#26792;&#27193; <pr>l&iacute;sh&ugrave;</pr></trd>,
    <trd>&#30333;&#26792; <pr>b&aacute;il&iacute;</pr></trd>
  </trdgrp>
</drv>

<drv mrk="pir.ter0o">
  <kap>ter<tld/>o</kap>
  <snc mrk="pir.ter0o.BOT">
    <uzo tip="fak">BOT</uzo>
    <dif>
      <ref tip="lst" cel="flor.sun0o.BOT" lst="voko:asteroparencoj">Sunfloro</ref>
      kreskanta precipe en norda Ameriko, kies tubera radiko estas
      uzata kiel man&gcirc;a&jcirc;o por homoj a&ubreve; brutoj
      (<trd lng="la">Helianthus tuberosus</trd>):
      <ekz>
        topinamburo (anka&ubreve; ter<tld/>o, tubera helianto) estas plurjara, moltiga planto,
        havanta tigotuberojn utiligeblajn kiel legomo, precipe por diabetuloj
        <fnt>
          <bib>Monato</bib>
          <aut>Julius Hauser</aut>
          <vrk><url ref="&Monato;/2012/010553.php">Topinamburo &ccirc;u herba&ccirc;o?</url></vrk>
        </fnt>.
      </ekz>
    </dif>
    <ref tip="sin" cel="helian.tubera0o">tubera helianto</ref>
    <bld
    lok="&WCU;/thumb/0/04/Helianthus_tuberosus_ENBLA06.jpg/330px-Helianthus_tuberosus_ENBLA06.jpg"
    prm="CC BY-SA 4.0">floraroj de ter<tld/>o  (Helianthus tuberosus), Italujo
        <fnt>
          <aut>Enrico Blasutto, propra verko</aut>
          <lok><url
          ref="&WCW;/File:Helianthus_tuberosus_ENBLA06.jpg">&WCW;/File:Helianthus_tuberosus_ENBLA06.jpg</url></lok>
        </fnt>
    </bld>
    <bld
    lok="&WCU;/thumb/b/b2/Helianthus_tuberosus_(rhizomes).jpg/330px-Helianthus_tuberosus_(rhizomes).jpg"
    prm="CC BY-SA 3.0">tuberoj de ter<tld/>o
        <fnt>
          <aut>Earendil, propra verko</aut>
          <lok><url
          ref="&WCW;/File:Helianthus_tuberosus_(rhizomes).jpg">&WCW;/File:Helianthus_tuberosus_(rhizomes).jpg</url></lok>
        </fnt>
    </bld>
  </snc>
  <trd lng="be">&c_t;&c_a;&c_p;&c_ib;&c_n;&c_a;&c_m;&c_b;&c_u;&c_r;</trd>
  <trd lng="br">perenn-douar</trd>
  <trd lng="ca">ny&agrave;mera</trd>
  <trd lng="cs">slune&ccaron;nice topinambur</trd>
  <trdgrp lng="de">
    <trd>Topinambur</trd>,
    <trd>Erdbirne</trd>
  </trdgrp><trdgrp lng="de">
    <trd>Topinambur</trd>,
    <trd>Erdbirne</trd>
  </trdgrp>
  <trdgrp lng="en">
    <trd>Jerusalem artichoke</trd>,
    <trd>Jerusalem artichoke</trd>,
    <trd>sunroot</trd>,
    <trd>sunchoke</trd>,
    <trd>topinambur</trd>,
    <trd>earth apple</trd>
  </trdgrp>
  <trd lng="fr">topinambour</trd>
  <trd lng="hu">csics&oacute;ka</trd>
  <trdgrp lng="id">
    <trd>artisyok Yerusalem</trd>,
    <trd>topinambur</trd>
  </trdgrp>
  <trd lng="ja">&#12461;&#12463;&#12452;&#12514;</trd>
  <trd lng="nl">aardpeer</trd>
  <trdgrp lng="pl">
    <trd>s&lstroke;onecznik bulwiasty</trd>,
    <trd>topinambur</trd>
  </trdgrp>
  <trd lng="ru">&c_t;&c_o;&c_p;&c_i;&c_n;&c_a;&c_m;&c_b;&c_u;&c_r;</trd>
  <trd lng="sk">topinambur</trd>
  <trdgrp lng="uk">
    <trd>&c_t;&c_o;&c_p;&c_ib;&c_n;&c_a;&c_m;&c_b;&c_u;&c_r;</trd>,
    <trd>&c_z;&c_je;&c_m;&c_l;&c_ja;&c_n;&c_a; &c_g;&c_r;&c_u;&c_sh;&c_a;</trd>
  </trdgrp>
  <trdgrp lng="zh">
    <trd>&#27915;&#23004; <pr>y&aacute;ngji&amacron;ng</pr></trd>,
    <trd>&#27915;&#34193; <pr>y&aacute;ngji&amacron;ng</pr></trd>,
    <trd>&#33738;&#33419; <pr>j&uacute;y&ugrave;</pr></trd>,
    <trd>&#27915;&#23004; <pr>y&aacute;ngji&amacron;ng</pr></trd>
  </trdgrp>
</drv>

<drv mrk="pir.0vino">
  <kap><tld/>vino</kap>
  <snc mrk="pir.0vino.KUI">
    <uzo tip="fak">KUI</uzo>
    <dif>
      Fermentanta <ref tip="lst" lst="voko:trinka&jcirc;oj" cel="trink.0ajxo.KUI">trinka&jcirc;o</ref>
      ekstraktita el <tld/>oj.
    </dif>
  </snc>
  <trd lng="be">&c_g;&c_r;&c_u;&c_sh;&c_a;&c_v;&c_a;&c_je; <ind>&c_v;&c_ib;&c_n;&c_o;</ind></trd>
  <trd lng="br">sistr-per</trd>
  <trd lng="ca">sidra de peres</trd>
  <trd lng="cs">hru&scaron;kov&eacute; v&iacute;no</trd>
  <trd lng="de">Birnenwein</trd>
  <trdgrp lng="en">
    <trd>perry</trd>,
    <trd>pear wine</trd>
  </trdgrp>
  <trd lng="fr">poir&eacute;</trd>
  <trd lng="hu">k&ouml;rtebor</trd>
  <trdgrp lng="id">
    <trd>anggur pir</trd>,
    <trd>sari buah pir</trd>
  </trdgrp>
  <trd lng="ja">&#12506;&#12522;&#12540;&#37202;  <pr>&#12410;&#12426;&#12540;&#12373;&#12369;</pr></trd>
  <trd lng="nl">perenwijn</trd>
  <trd lng="sk">hru&scaron;kov&eacute; v&iacute;no</trd>
  <trd lng="uk">&c_g;&c_r;&c_u;&c_sh;&c_je;&c_v;&c_je; &c_v;&c_i;&c_n;&c_o;</trd>
</drv>
</art>
