<?xml version="1.0"?>
<!DOCTYPE vortaro SYSTEM "../dtd/vokoxml.dtd">
<vortaro>
<art mrk="$Id: puli.xml,v 1.23 2026/05/12 21:39:12 revo Exp $">
<kap>
  <rad>puli</rad>/o <fnt><bib>PVEF</bib></fnt>
</kap>
<drv mrk="puli.0o">
  <kap><tld/>o</kap>
  <snc mrk="puli.0o.TEK">
    <uzo tip="fak">TEK</uzo>
    <dif>
      Ligna a&ubreve; metala <ref tip="super" cel="rad.0o">rado</ref>, turni&gcirc;anta &ccirc;irka&ubreve; akso kaj havanta kavigitan
      randon por glitigi en &gcirc;i &scirc;nuron, rimenon:
      <ekz>
        oni bezonas <tld/>on kaj rimenon, la &scirc;nurveturo de bordo al bordo postulas
        kura&gcirc;on
        <fnt>
          <bib>Monato</bib>
          <aut>Minosun</aut>
          <vrk><url ref="&Monato;/2011/010360.php"
              >&Scirc;nurveturi</url></vrk>
          <lok>2011</lok>
        </fnt>;
      </ekz>
      <ekz>
        levma&scirc;inoj kies <tld/>o hurle rustoknaras
        <fnt>
          <bib>LOdE</bib>
          <lok>2002, &#x2116;6</lok>
        </fnt>;
      </ekz>
      <ekz>
        oni povis <klr>[&#x2026;]</klr> dank' al <tld/>a &ccirc;ensistemo, la&ubreve;vole
        pli- a&ubreve; malplialtigi &gcirc;ian pozicion
        <fnt><bib>KielAkvo</bib>, <lok>1:3</lok></fnt>.
      </ekz>
    </dif>
    <refgrp tip="vid">
      <ref cel="blok.rul0o.MAR">rulbloko<sncref/></ref>,
      <ref cel="takel.0o">takelo</ref>
    </refgrp>
  </snc>
  <trdgrp lng="be">
    <trd>&c_b;&c_l;&c_jo;&c_k;</trd>,
    <trd>&c_sh;&c_k;&c_ib;&c_w;</trd>,
    <trd>&c_r;&c_o;&c_l;&c_ib;&c_k;</trd>
  </trdgrp>
  <trd lng="cs">kladka</trd>
  <trdgrp lng="de">
    <trd>Rolle <klr>(Flaschenzug)</klr></trd>,
    <trd>Riemscheibe</trd>,
    <trd>Seilscheibe</trd>
  </trdgrp>
  <trd lng="en">pulley</trd>
  <trd lng="fr">poulie</trd>
  <trd lng="hu">csiga<klr tip="ind"> (k&ouml;t&eacute;lcsiga)</klr></trd>
  <trdgrp lng="ja">
    <trd>&#x6ED1;&#x8ECA;  <pr>&#x304B;&#x3063;&#x3057;&#x3083;</pr></trd>,
    <trd>&#x30D7;&#x30FC;&#x30EA;&#x30FC;</trd>
  </trdgrp>
  <trdgrp lng="nl">
    <trd>poelie</trd>,
    <trd>katrolschijf</trd>
  </trdgrp>
  <trd lng="pl">wielokr&aogonek;&zdot;ek zwyk&lstroke;y</trd>
  <trd lng="pt">polia <klr>(t&eacute;cn.)</klr></trd>
  <trd lng="ro">scripete</trd>
  <trdgrp lng="ru">
    <trd>&c_b;&c_l;&c_o;&c_k;</trd>,
    <trd>&c_sh;&c_k;&c_i;&c_v;</trd>,
    <trd>&c_r;&c_o;&c_l;&c_i;&c_k;</trd>
  </trdgrp>
  <trdgrp lng="sk">
    <trd>kladka</trd>,
    <trd>&scaron;kripec</trd>
  </trdgrp>
  <trdgrp lng="sv">
    <trd>block<klr tip="amb"> (hissanordning)</klr></trd>,
    <trd>remskiva</trd>
  </trdgrp>
  <trdgrp lng="uk">
    <trd>&c_b;&c_l;&c_o;&c_k;</trd>,
    <trd>&c_sh;&c_k;&c_ib;&c_v;</trd>,
    <trd>&c_r;&c_o;&c_l;&c_i;&c_k;</trd>
  </trdgrp>
</drv>

<drv mrk="puli.0aro">
  <kap>
    <tld/>aro
  </kap>
  <snc>
    <dif>
      La <tld/>oj de <ref tip="malprt" cel="blok.rul0o.MAR">rulbloko</ref>
      a&ubreve; <ref tip="malprt" cel="takel.0o">takelo</ref>:
      <ekz>
        takelo <klr>[&#x2026;]</klr> konsistas el du <tld/>aroj, unu fiksa kaj unu libera,
        kunigitaj per &scirc;nuro
        <fnt>
          <aut>Walter Bernard</aut>
          <vrk><url ref="https://www.eventoj.hu/steb/fiziko/fiziklibro/1_fiziklibro.pdf"
              >Fiziko, baza kurzo</url></vrk>
          <lok>5.7.2 Takelo, p. 64</lok>
        </fnt>.
      </ekz>
    </dif>
  </snc>
</drv>

</art>
