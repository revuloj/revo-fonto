<drv mrk="soldat.stana_0o">
  <kap>
    stana <tld/>o,
    <var><kap>stan<tld/>o</kap></var>
  </kap>
  <uzo tip="fak">SPO</uzo>
  <snc>
    <dif>
      <ref tip="lst" lst="voko:ludiloj" cel="lud.0ilo">Ludfiguro</ref>
      el stano a&ubreve; alojo en formo de soldato:
      <ekz>
        la papero dis&scirc;iri&gcirc;is, kaj la stana <tld/>o trafalis
        <fnt>
          <bib>Fab1</bib>
          <lok>Persista stana soldato</lok>
        </fnt>;
      </ekz>
      <ekz>
        entrepreno fondita de <nom>William Britain Jr.</nom>
        <klr>[&#8230;]</klr> en 1893 inventis
        la procezon de fandomuldado en plumbo, kaj revoluciigis la
        produktadon de
        ludilsoldatoj <klr>[&#8230;]</klr> ekde tiam en kelkaj lingvoj
        oni parolas pri plumbo<tld/>oj a&ubreve; stan<tld/>oj
        <fnt>
          <bib>Viki</bib>
          <lok><url ref="https://eo.wikipedia.org/?curid=540633">Soldatludilo</url></lok>
        </fnt>.
      </ekz>
    </dif>
  </snc>
  <trdgrp lng="be">
    <trd>&c_c;&c_y;&c_n;&c_o;&c_v;&c_y; <ind>&c_zh;&c_a;&c_w;&c_n;&c_je;&c_r;&c_y;&c_k;</ind></trd>,
    <trd>&c_a;&c_l;&c_a;&c_v;&c_ja;&c_n;&c_y;
    <ind>&c_zh;&c_a;&c_w;&c_n;&c_je;&c_r;&c_y;&c_k;</ind></trd>
  </trdgrp>
  <trd lng="ca">soldadet de plom</trd>
  <trd lng="de">Zinnsoldat</trd>
  <trd lng="es">soldadito de plomo</trd>
  <trd lng="pl">&zdot;o&lstroke;nierz cynowy</trd>
</drv>

