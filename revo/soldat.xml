<drv mrk="soldat.0ejo">
  <kap><tld/>ejo</kap>
  <uzo tip="fak">MIL</uzo>
  <snc>
    <dif>
      <ref tip="dif" cel="kazern.0o">Kazerno</ref>:
      <ekz>
        eksonis la trumpeto, kaj la Azianoj komencis amase eliri el la
        <tld/>ejoj, tirante post si la &ccirc;evalojn
        <fnt>
          <bib>Far3</bib>
          <lok>&Ccirc;apitro XVII</lok>
        </fnt>;
      </ekz>
      <ekz>
        unu fojon oni e&ccirc; prenis min por &ccirc;efa militestro: la
        <tld/>oj elsaltis el la <tld/>ejo kaj donis al mi honoron per la
        pafiloj
        <fnt>
          <bib>Revizoro</bib>
          <lok>Akto tria</lok>
        </fnt>.
      </ekz>
    </dif>
  </snc>
  <trd lng="be">&c_k;&c_a;&c_z;&c_a;&c_r;&c_m;&c_a;</trd>
