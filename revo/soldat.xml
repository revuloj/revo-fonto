<drv mrk="soldat.duaklasa0o">
  <kap>duaklasa <tld/>o</kap>
  <uzo tip="fak">MIL</uzo>
  <snc>
    <dif>
      <ref tip="dif" cel="soldat.0o.senranga_terarmeano"><tld lit="S"/>o<sncref/></ref>:
      <ekz>
        <nom>Marie Marvingt</nom> <klr>[&#8230;]</klr> trovis okazon
        vire maskovesti&gcirc;i
        kaj <klr>[&#8230;]</klr> militservi kiel duaklasa soldato
        <klr>[&#8230;]</klr> en la 42a Bataliono de &Ccirc;asistoj
        <fnt>
          <bib>Viki</bib>
          <lok><url ref="https://eo.wikipedia.org/?curid=263442">Marie
          Marvingt</url></lok>
        </fnt>.
      </ekz>
    </dif>
  </snc>
  <adm>
    Internacieco kontrolenda.
    <aut>MB</aut>
  </adm>
  <trd lng="be">&c_r;&c_a;&c_d;&c_a;&c_v;&c_y; <klr
  tip="amb">(&c_zh;&c_a;&c_w;&c_n;&c_je;&c_r;)</klr></trd>
  <trd lng="ca">soldat ras</trd>
  <trd lng="de">einfacher <ind>Soldat</ind></trd>
  <trdgrp lng="fr">
    <trd>soldat<klr tip="ind"> (simple soldat)</klr></trd>,
    <trd>deuxi&egrave;me <ind>classe</ind><klr tip="ind">
    (soldat)</klr></trd>,
    <trd><ind>soldat</ind> de deuxi&egrave;me classe</trd>
    <trd>simple <ind>soldat</ind></trd>
  </trdgrp>
  <trdgrp lng="it">
    <trd>soldato</trd>,
    <trd><ind>soldato</ind> semplice</trd>
  </trdgrp>
  <trd lng="pl">szeregowiec</trd>
</drv>

<drv mrk="soldat.dungo0o">
  <kap>dungo<tld/>o</kap>
  <uzo tip="fak">MIL</uzo>
  <fnt><bib>PIV1</bib></fnt>
  <snc>
    <dif>
      <ref tip="super" cel="milit.0isto">Militisto</ref> ne apartenanta
      al &scirc;tata armeo, sed kontra&ubreve; pago preta servi en
      milito:
      <ekz>
        <klr>[la eksaj anoj de <nom>Al-Kaida</nom>]</klr> povus
        anka&ubreve; servi
        kiel dungo<tld/>oj por sekretaj servoj, kiel faris siatempe
        la palestinano <nom>Abu Nidal</nom> kaj <nom>Carlos</nom>
        <fnt>
        <aut>trad V. Lutermano</aut>
        <vrk>Le Monde Diplomatique en Esperanto</vrk>
        <lok><url ref="&Mondediplo;article930.html">2004-09</url></lok>
        </fnt>;
      </ekz>
      <ekz>
        Karlo la 1-a Malatesta <klr>[&#8230;]</klr> estis
        <klr>[&#8230;]</klr> dungo<tld/>o dum la militoj de Lombardio
        <fnt>
          <bib>Viki</bib>
          <lok><url ref="https://eo.wikipedia.org/?curid=264802">Karlo
          la 1-a Malatesta</url></lok>
        </fnt>;
      </ekz>
      <ekz>
        proponante dungotan <tld/>aron pere de kiu UN protektu
        senkulpajn viktimojn de kruelaj freneza&jcirc;oj
        <klr>[&#8230;]</klr>
        <fnt>
          <aut>Werner Schad</aut>
            <vrk><url ref="&Monato;/2001/007281.php">Fremdula UN-legio</url></vrk>
            <bib>Monato</bib>
            <lok>2001/02, p. 4</lok>
          </fnt>.
      </ekz>
    </dif>
    <refgrp tip="sin">
      <ref cel="soldat.lu0o">lu<tld/>o</ref>,
      <ref cel="sold.0ulo">soldulo</ref>
    </refgrp>
  </snc>
  <trdgrp lng="be">
    <trd>&c_n;&c_a;&c_j;&c_m;&c_ib;&c_t;</trd>,
    <trd>&c_n;&c_a;&c_jo;&c_m;&c_n;&c_ib;&c_k;</trd>
  </trdgrp>
  <trdgrp lng="ca">
    <trd>mercenari</trd>,
    <trd>soldat de fortuna</trd>
  </trdgrp>
  <trdgrp lng="cs">
    <trd>voj&aacute;k z povol&aacute;n&iacute;</trd>,
    <trd>&zcaron;oldn&eacute;&rcaron;</trd>
  </trdgrp>
  <trd lng="de">S&ouml;ldner</trd>
  <trdgrp lng="en">
    <trd>mercenary soldier</trd>,
    <trd>soldier of fortune</trd>
  </trdgrp>
  <trd lng="fr">mercenaire<klr tip="ind"> (subst.)</klr></trd>
  <trdgrp lng="id">
    <trd><baz>prajurit</baz>prajurit bayaran</trd>,
    <trd><baz>prajurit</baz>prajurit sewaan</trd>,
    <trd><baz>serdadu</baz>serdadu bayaran</trd>,
    <trd><baz>serdadu</baz>serdadu sewaan</trd>,
    <trd><baz>tentara</baz>tentara bayaran</trd>,
    <trd><baz>tentara</baz>tentara sewaan</trd>
  </trdgrp>
  <trd lng="it">mercenario<klr tip="ind"> (sost.)</klr></trd>
  <trdgrp lng="ja">
    <trd>&#20653;&#20853;  <pr>&#12424;&#12358;&#12408;&#12356;</pr></trd>,
    <trd>&#38599;&#12356;&#20853;  <pr>&#12420;&#12392;&#12356;&#12408;&#12356;</pr></trd>
  </trdgrp>
  <trdgrp lng="nl">
    <trd>mercenair</trd>,
    <trd>huursoldaat</trd>
  </trdgrp>
  <trd lng="pl">najemnik</trd>
  <trd lng="sk">&zcaron;oldnier</trd>
  <trdgrp lng="uk">
    <trd>&c_n;&c_a;&c_j;&c_m;&c_a;&c_n;&c_je;&c_c;&c_mol;</trd>,
    <trd>&c_n;&c_a;&c_jeu;&c_m;&c_n;&c_i;&c_k;</trd>
  </trdgrp>
  <trdgrp lng="zh">
    <trd>&#20853;&#30174; <pr>b&#299;ngp&#464;</pr></trd>,
