  <snc>
    <dif>
      <ref tip="super" cel="milit.0isto">Militisto</ref>, ano
      de <ref tip="malprt" cel="arme.mar0o">mararmeo</ref>:
      <ekz>
        en 1571 <klr>[<nom>Cervantes</nom>]</klr> kiel mar<tld/>o
        partoprenis
        la marbatalon de Lepanto
