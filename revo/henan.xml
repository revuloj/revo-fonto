<kap>
    <rad>Henan</rad>/o <fnt><bib>Po&scirc;Atlas</bib></fnt>
</kap>
<drv mrk="henan.0o">
  <kap><tld/>o</kap>
  <snc mrk="henan.0o.GEOG">
    <uzo tip="fak">GEOG</uzo>
    <uzo tip="fak">POL</uzo>
    <dif>
      Provinco en la orienta parto de <ref tip="malprt" cel="cxin.CX0ujo">&Ccirc;inujo</ref>:
      <ekz>
        la plej malnova trova&jcirc;o de man&gcirc;obastonetoj estas paro el bronzo,
        trovita en tombo de <nom>Yin</nom>-ruinoj &ccirc;e <nom>Houjiazhuang</nom>, <nom>Anyang</nom>,
        <tld lit="H"/>o,
        datita de &ccirc;. 1200 a.K.
        <fnt>
          <aut>-</aut>
          <vrk><url ref="https://eo.wikipedia.org/wiki/Man%C4%9Dobastonetoj">
          Man&gcirc;obastonetoj</url></vrk>
          <lok>Vikipedio, 2026-03-28</lok>
        </fnt>.
      </ekz>
    </dif>
  </snc>
  <trd lng="de">Henan</trd>
  <trd lng="fr">Henan</trd>
  <trd lng="zh">&#x6CB3;&#x5357; <pr>H&eacute;n&aacute;n</pr></trd>
</drv>
</art>

