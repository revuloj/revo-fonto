<?xml version="1.0"?>
<!DOCTYPE vortaro SYSTEM "../dtd/vokoxml.dtd">
<vortaro>
<art mrk="$Id: ozon.xml,v 1.33 2026/06/28 08:00:21 revo Exp $">
<kap>
  <ofc>2</ofc> <rad>ozon</rad>/o
<fnt><bib>JED</bib></fnt></kap>
<drv mrk="ozon.0o">
  <kap><tld/>o</kap>
  <snc mrk="ozon.0o.KEM">
  <uzo tip="fak">KEM</uzo>
    <dif>
      Triopa <ref tip="prt" cel="oksige.0o">oksigeno</ref>
      (<frm>O<sub>3</sub></frm>)  kaj diferenca de tiu gaso per 
      karakteriza odoro kaj pli forta oksidiga kapablo:
      <ekz>
        la <ind><tld/>tavolo</ind> en la <ref tip="malprt" cel="stratosfer.0o">stratosfero</ref>
        protektas nin de altenergia sunradiado;
        <trdgrp lng="ca">
          <trd>capa d'<ind>oz&oacute;</ind></trd>,
          <trd>ozonosfera</trd>
        </trdgrp>
        <trdgrp lng="en">
          <trd>ozone layer</trd>,
          <trd>ozonosphere</trd>
        </trdgrp>
        <trdgrp lng="es">
          <trd>capa de <ind>ozono</ind></trd>,
          <trd>ozonosfera</trd>
        </trdgrp>
        <trdgrp lng="fr">
          <trd>couche d'<ind>ozone</ind></trd>,
          <trd>ozonosph&egrave;re</trd>
        </trdgrp>
      </ekz>
      <ekz>
        &jcirc;us atingas nin plia katastrofa informo: la antarkta <ind><tld/>-truo</ind> &ccirc;i-jare estas
        tiom giganta, kiom neniam anta&ubreve;e
        <fnt>
          <bib>Monato</bib>
          <aut>Stefan Maul</aut>
          <vrk><url ref="&Monato;/2008/009637.php">Katastrofaj ciferoj</url></vrk>
          <lok>2008</lok>
        </fnt>;
        <trdgrp lng="ca">
          <trd>forat d'<ind>oz&oacute;</ind></trd>,
          <trd>forat de la capa d'<ind>oz&oacute;</ind></trd>
        </trdgrp>
        <trdgrp lng="en">
          <trd>ozone hole</trd>
        </trdgrp>
        <trdgrp lng="es">
          <trd>agujero de <ind>ozono</ind></trd>
          <trd>agujero de la capa de <ind>ozono</ind></trd>
        </trdgrp>
        <trdgrp lng="fr">
          <trd>trou d'<ind>ozone</ind></trd>,
          <trd>trou de la couche d'<ind>ozone</ind></trd>
        </trdgrp>

      </ekz>
      <ekz>
        en dense lo&gcirc;ataj regionoj la nivelo de <tld/>o en la
        surfacproksima aerzono regule superas la limvaloron permesitan
        de EU
        <fnt><aut>Roland Rotsaert</aut>: <vrk>Medio-indulgo de la
        &ccirc;efaj ekonomiaj sektoroj</vrk>, <bib>Monato</bib><lok>jaro 2001a,
        numero 3a, p. 18a</lok></fnt>.
      </ekz>
    </dif>
  </snc>
  <trd lng="be">&c_a;&c_z;&c_o;&c_n;</trd>
  <trd lng="bg">&c_o;&c_z;&c_o;&c_n;</trd>
  <trd lng="ca">oz&oacute;</trd>
  <trdgrp lng="cs">
    <trd>kysl&iacute;k s troj atomovou molekulou</trd>,
    <trd>oz&oacute;n</trd>
  </trdgrp>
  <trd lng="de">Ozon</trd>
  <trd lng="el">&omikron_ton;&zeta;&omikron;&ny;</trd>
  <trd lng="en">ozone</trd>
  <trd lng="es">ozono</trd>
  <trd lng="fa">&a_A;&a_damma;&a_z;&a_w;&a_n;</trd>
  <trdgrp lng="fr">
    <trd>ozone</trd>
  </trdgrp>
  <trd lng="hu">&oacute;zon</trd>
  <trd lng="id">ozon</trd>
  <trd lng="ja">&#12458;&#12478;&#12531;  <pr>&#12362;&#12382;&#12435;</pr></trd>
  <trd lng="nl">ozon</trd>
  <trd lng="pl">ozon</trd>
  <trd lng="pt">oz&ocirc;nio</trd>
  <trd lng="ro">ozon</trd>
  <trd lng="ru">&c_o;&c_z;&c_o;&c_n;</trd>
  <trdgrp lng="sk">
    <trd>O3</trd>,
    <trd>oz&oacute;n</trd>
  </trdgrp>
  <trd lng="sv">ozon</trd>
  <trd lng="uk">&c_o;&c_z;&c_o;&c_n;</trd>
  <trd lng="zh">&#33261;&#27687; <pr>ch&ograve;uy&#462;ng</pr></trd>
</drv>

<drv mrk="ozon.0i">
  <kap><tld/>i</kap>
  <gra><vspec>tr</vspec></gra>
  <snc mrk="ozon.0i.TEK">
  <uzo tip="fak">TEK</uzo>
    <dif>
      Elektrizi la oksigenon de l' aero, por &gcirc;in aliigi en
      <tld/>on.
    </dif>
  </snc>
  <trd lng="be">&c_a;&c_z;&c_a;&c_n;&c_a;&c_v;&c_a;&c_c;&c_mol;</trd>
  <trd lng="bg">&c_o;&c_z;&c_o;&c_n;&c_i;&c_r;&c_a;&c_m;</trd>
  <trd lng="ca">ozonitzar</trd>
  <trd lng="cs">p&uring;sobit oz&oacute;nem</trd>
  <trd lng="de">ozonisieren</trd>
  <trd lng="en">ozonize</trd>
  <trd lng="fr">ozoniser</trd>
  <trd lng="hu">&oacute;zoniz&aacute;l</trd>
  <trd lng="nl">ozoniseren</trd>
  <trd lng="pl">ozonowa&cacute;</trd>
  <trd lng="ro">ozonul</trd>
  <trd lng="ru">&c_o;&c_z;&c_o;&c_n;&c_i;&c_r;&c_o;&c_v;&c_a;&c_t;&c_mol;</trd>
  <trdgrp lng="sk">
    <trd>ozonizova&tcaron;</trd>,
    <trd>p&ocirc;sobi&tcaron; oz&oacute;nom</trd>
  </trdgrp>
</drv>
</art>
