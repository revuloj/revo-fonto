<kap>
  <ofc>*</ofc>
  <rad>malic</rad>/a
<fnt><bib>UV</bib></fnt></kap>
<drv mrk="malic.0a">
  <kap><ofc>*</ofc><tld/>a</kap>
  <snc>
    <uzo tip="klr">(iu)</uzo>
    <dif>
      Konscie malbonfarema kontra&ubreve; la aliaj, deziranta malutilon kaj
      malfeli&ccirc;on al la aliaj, &gcirc;ojanta pro la malfeli&ccirc;o
      de la aliaj:
      <ekz>
        <tld/>a homo, karaktero;
      </ekz>
      <ekz>
        kiu intencas fari malbonon, tiun oni nomas
        <tld/>ulo
        <fnt>
          <bib>MT</bib>
          <lok>Sentencoj 24:8</lok>
        </fnt>;
      </ekz>
      <ekz>
        vi agas <klr>[&#x2026;]</klr> kun <tld/>ulo la&ubreve; lia <tld/>eco
        <fnt>
          <bib>MT</bib>
          <lok>II. Samuel 22:27</lok>
        </fnt>.
      </ekz>
    </dif>
    <trdgrp lng="hu">
      <trd>rosszindulat&uacute;</trd>,
      <trd>k&aacute;r&ouml;rvend&odblac;</trd>,
      <trd>rosszm&aacute;j&uacute;</trd>,
      <trd>malici&oacute;zus</trd>
    </trdgrp>
  </snc>
  <snc>
    <uzo tip="klr">(io)</uzo>
    <dif>
      Farata kun deziro malutili al iu, malfeli&ccirc;igi iun:
      <ekz>
        <tld/>a ago, parolo;
      </ekz>
      <ekz>
        <tld/>aj intencoj
        <fnt>
          <bib>MT</bib>
          <lok>Psalmaro 35:20</lok>
        </fnt>;
      </ekz>
      <ekz>
        <ind><tld/>a &gcirc;ojo</ind>
        <trd lng="de">Schadenfreude</trd>
      </ekz>
      <ekz>
        ne ekzistas juneco sen kapricoj, nek maljuneco sen <tld/>oj
        <fnt>
          <bib>PrV</bib>
        </fnt>;
      </ekz>
      <ekz>
        kiu havas <tld/>an celon, ofte perdas sian propran felon
        <fnt><bib>PrV</bib></fnt>;
      </ekz>
      <ekz>
        ilia ventro pretigas <tld/>a&jcirc;on
        <fnt>
          <bib>MT</bib>
          <lok>Ijob 15:35</lok>
        </fnt>;
      </ekz>
      <ekz>
        mi scias viajn <klr>[&#x2026;]</klr> argumentojn, kiujn vi <tld/>e kolektas kontra&ubreve; mi
        <fnt>
          <bib>MT</bib>
          <lok>Ijob 21:27</lok>
        </fnt>.
      </ekz>
    </dif>
    <trdgrp lng="hu">
      <trd>gonosz</trd>,
      <trd>gal&aacute;d</trd>
    </trdgrp>
  </snc>
  <refgrp tip="sub">
     <ref cel="perfid.0a">perfida</ref>,
     <ref cel="insid.0a">insida</ref>
  </refgrp>
  <refgrp tip="vid">
     <ref cel="intrig.0i">intrigi</ref>,
     <ref cel="damagx.0i">dama&gcirc;i</ref>
  </refgrp>
  <trdgrp lng="be">
    <trd>&c_z;&c_l;&c_y;</trd>,
    <trd>&c_z;&c_l;&c_o;&c_s;&c_n;&c_y;</trd>,
    <trd>&c_z;&c_l;&c_a;&c_s;&c_mol;&c_l;&c_ib;&c_v;&c_y;</trd>,
    <trd>&c_k;&c_a;&c_v;&c_a;&c_r;&c_n;&c_y;</trd>
  </trdgrp>
  <trd lng="bo">&t_nga;&t_na;&t_tsheg;&t_pa;&t_tsheg;</trd>
  <trdgrp lng="cs">
    <trd>dol&oacute;zn&iacute;</trd>,
    <trd>j&iacute;zliv&yacute;</trd>,
    <trd>zlomysln&yacute;</trd>,
    <trd>zlovoln&yacute;</trd>
  </trdgrp>
  <trdgrp lng="de">
    <trd>b&ouml;se</trd>,
    <trd>geh&auml;ssig</trd>,
    <trd>boshaft</trd>,
    <trd>b&ouml;swillig</trd>
  </trdgrp>
  <trdgrp lng="en">
    <trd>malicious</trd>,
    <trd>malevolent</trd>,
    <trd>spiteful</trd>
  </trdgrp>
  <trdgrp lng="es">
    <trd>malicioso</trd>,
    <trd>malvado</trd>
  </trdgrp>
  <trdgrp lng="fr">
    <trd>perfide</trd>,
    <trd>m&eacute;chant</trd>
  </trdgrp>
  <trdgrp lng="ja">
    <trd>&#x60AA;&#x610F;&#x306E;  <pr>&#x3042;&#x304F;&#x3044;&#x306E;</pr></trd>,
    <trd>&#x610F;&#x5730;&#x60AA;&#x306A;  <pr>&#x3044;&#x3058;&#x308F;&#x308B;&#x306A;</pr></trd>,
    <trd>&#x90AA;&#x60AA;&#x306A;  <pr>&#x3058;&#x3083;&#x3042;&#x304F;&#x306A;</pr></trd>,
    <trd>&#x8179;&#x9ED2;&#x3044;  <pr>&#x306F;&#x3089;&#x3050;&#x308D;&#x3044;</pr></trd>
  </trdgrp>
  <trdgrp lng="nl">
    <trd>boos</trd>,
    <trd>boosaardig</trd>
  </trdgrp>
  <trdgrp lng="pl">
    <trd>podst&eogonek;pny</trd>,
    <trd>przewrotny</trd>
  </trdgrp>
  <trdgrp lng="pt">
    <trd>malicioso</trd>,
    <trd>malvado</trd>,
    <trd>maldoso</trd>,
    <trd>perverso</trd>
  </trdgrp>
  <trdgrp lng="ru">
    <trd>&c_z;&c_l;&c_o;&c_b;&c_n;&c_y;&c_j;</trd>,
    <trd>&c_z;&c_l;&c_o;&c_j;</trd>,
    <trd>&c_k;&c_o;&c_v;&c_a;&c_r;&c_n;&c_y;&c_j;</trd>
  </trdgrp>
  <trdgrp lng="sk">
    <trd>zlomyse&lcaron;n&yacute;</trd>,
    <trd>&scaron;kodoradostn&yacute;</trd>
  </trdgrp>
  <trd lng="sv">elak</trd>
  <trd lng="tok">ike</trd>
  <trdgrp lng="uk">
    <trd>&c_z;&c_l;&c_i;&c_j;</trd>,
    <trd>&c_z;&c_l;&c_o;&c_s;&c_t;&c_i;&c_v;&c_i;&c_j;</trd>,
    <trd>&c_z;&c_l;&c_o;&c_s;&c_l;&c_i;&c_v;&c_i;&c_j;</trd>,
    <trd>&c_z;&c_l;&c_ib;&c_s;&c_n;&c_i;&c_j;</trd>,
    <trd>&c_p;&c_ib;&c_d;&c_s;&c_t;&c_u;&c_p;&c_n;&c_i;&c_j;</trd>
  </trdgrp>
  <trdgrp lng="zh">
    <trd>&#x6076;&#x6BD2; <pr>&egrave;d&uacute;</pr></trd>,
    <trd>&#x60E1;&#x6BD2; <pr>&egrave;d&uacute;</pr></trd>,
    <trd>&#x9669;&#x6076; <pr>xi&#x1CE;n&egrave;</pr></trd>,
    <trd>&#x96AA;&#x60E1; <pr>xi&#x1CE;n&egrave;</pr></trd>,
    <trd>&#x72E0;&#x6BD2; <pr>h&ecaron;nd&uacute;</pr></trd>
  </trdgrp>
</drv>

<drv mrk="malic.0eta">
  <kap><tld/>eta</kap>
  <snc mrk="malic.0eta.inklina">
    <dif>
      Inklina iom mokpetoli sen deziro malutili:
      <ekz>
        <tld/>eta infano;
      </ekz>
      <ekz>
        e&ccirc; dum la minutoj de la plej gala humoro, <klr>[&#x2026;]</klr> mi estas tute ne
        malica, e&ccirc; ne <tld/>eta
        <fnt>
          <bib>LOdE</bib>
          <lok>2002, &#x2116;7</lok>
        </fnt>.
      </ekz>
    </dif>
  </snc>
  <snc mrk="malic.0eta.montranta">
    <dif>
      Montranta mokpetolemon sen deziro malutili:
      <ekz>
        <tld/>eta rido, okulo, &scirc;erco;
      </ekz>
      <ekz>
        liaj artikoloj, spicitaj per <tld/>etaj komentoj, estis amuza lega&jcirc;o
        <fnt>
          <bib>Monato</bib>
          <aut>Stefan Maul</aut>
          <vrk><url ref="&Monato;/2009/009914.php">Gazet-eraroj</url></vrk>
          <lok>2009</lok>
        </fnt>;
      </ekz>
      <ekz>
        maljuna pasa&gcirc;erino haltigas &scirc;in kaj diras kun <tld/>eta mieno: &ndash; fra&ubreve;lino, vi
        forgesis la viskion, kien la poezio
        <fnt>
          <bib>KrB</bib>
          <lok>Excelsior!</lok>
        </fnt>?
      </ekz>
    </dif>
  </snc>
  <refgrp tip="vid">
     <ref cel="mok.0ema">mokema</ref>,
     <ref cel="amik.mal0a">malamika</ref>,
     <ref cel="blag.0i">blagi</ref>,
     <ref cel="incit.0i">inciti</ref>
  </refgrp>
  <trdgrp lng="be">
    <trd>&c_g;&c_a;&c_r;&c_e;&c_z;&c_mol;&c_l;&c_ib;&c_v;&c_y;</trd>,
    <trd>&c_p;&c_a;&c_k;&c_je;&c_p;&c_l;&c_ib;&c_v;&c_y;</trd>
  </trdgrp>
  <trd lng="cs">&scaron;k&aacute;dliv&yacute;</trd>
  <trdgrp lng="de">
    <trd>garstig</trd>,
    <trd>gemein</trd>,
    <trd>zeckend</trd>
  </trdgrp>
  <trd lng="en">ill-natured</trd>
  <trd lng="fr">malicieux</trd>
  <trdgrp lng="hu">
    <trd>huncut</trd>,
    <trd>gonoszkod&oacute;</trd>
  </trdgrp>
  <trdgrp lng="ja">
    <trd>&#x3044;&#x305F;&#x305A;&#x3089;&#x306A;</trd>,
    <trd>&#x304B;&#x3089;&#x304B;&#x3044;&#x306E;</trd>
  </trdgrp>
  <trdgrp lng="nl">
    <trd>ondeugend</trd>,
    <trd>stout</trd>
  </trdgrp>
  <trd lng="pl">z&lstroke;o&sacute;liwy</trd>
  <trdgrp lng="ru">
    <trd>&c_o;&c_z;&c_o;&c_r;&c_n;&c_o;&c_j;</trd>,
    <trd>&c_p;&c_r;&c_o;&c_k;&c_a;&c_z;&c_l;&c_i;&c_v;&c_y;&c_j;</trd>
  </trdgrp>
  <trd lng="sk">&scaron;tip&lcaron;av&yacute; <klr>(pren.)</klr></trd>
  <trd lng="uk">&c_l;&c_u;&c_k;&c_a;&c_v;&c_i;&c_j;</trd>
  <trdgrp lng="zh">
    <trd>&#x7F3A;&#x5FB7; <pr>qu&emacron;d&eacute;</pr></trd>,
    <trd>&#x8ABF;&#x76AE; <pr>ti&aacute;op&iacute;</pr></trd>,
    <trd>&#x8C03;&#x76AE; <pr>ti&aacute;op&iacute;</pr></trd>,
    <trd>&#x4E0D;&#x6D01;&#x5730; <pr>b&ugrave;ji&eacute;de</pr></trd>,
    <trd>&#x4E0D;&#x6F54;&#x5730; <pr>b&ugrave;ji&eacute;de</pr></trd>,
    <trd>&#x574F;&#x5FC3;&#x773C; <pr>hu&agrave;ix&imacron;ny&#x1CE;n</pr></trd>,
    <trd>&#x58DE;&#x5FC3;&#x773C; <pr>hu&agrave;ix&imacron;ny&#x1CE;n</pr></trd>,
    <trd>&#x6781;&#x6076;&#x52A3; <pr>j&iacute;&egrave;li&egrave;</pr></trd>,
    <trd>&#x6975;&#x60E1;&#x52A3; <pr>j&iacute;&egrave;li&egrave;</pr></trd>,
    <trd>&#x96BE;&#x7F20; <pr>n&aacute;nch&aacute;n</pr></trd>,
    <trd>&#x96E3;&#x7E8F; <pr>n&aacute;nch&aacute;n</pr></trd>
  </trdgrp>
</drv>

<drv mrk="malic.sen0a">
  <kap>
    sen<tld/>a
  </kap>
  <snc>
    <dif>
      Sen malbona intenco:
      <ekz>
        en la okulfendoj lumis sen<tld/>a ironio
        <fnt>
          <bib>MkM</bib>
          <lok>25</lok>
        </fnt>;
      </ekz>
      <ekz>
        &gcirc;is la revolucio en 1668 oni kutime ka&scirc;is en sen<tld/>e sonantaj frazoj
        politikajn mokojn kontra&ubreve; la tirano
        <fnt>
          <bib>KrB</bib>
          <lok>Bervala&jcirc;o</lok>
        </fnt>.
      </ekz>
    </dif>
    <refgrp tip="vid">
      <ref cel="afabl.0a.KOMUNE">afabla</ref>,
      <ref cel="intenc.bon0a">bonintenca</ref>,
      <ref cel="vol.bon0emo">bonvolema</ref>
    </refgrp>
  </snc>
  <trdgrp lng="de">
    <trd>arglos</trd>,
    <trd>unschludig <klr>(arglos)</klr></trd>
  </trdgrp>
  <trd lng="en">guileless</trd>
  <trd lng="fr">candide</trd>
</drv>

