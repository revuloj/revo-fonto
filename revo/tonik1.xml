<?xml version="1.0"?>
<!DOCTYPE vortaro SYSTEM "../dtd/vokoxml.dtd">
<vortaro>
  <art mrk="$Id: tonik1.xml,v 1.8 2026/07/13 14:00:20 afido Exp $">
    <kap>
      <rad>tonik</rad>/o
    <fnt><bib>PVEF</bib></fnt></kap>

<drv mrk="tonik1.0o">
  <kap><tld/>o</kap>
  <snc mrk="tonik1.0o.MUZ">
    <uzo tip="fak">MUZ</uzo>
    <dif>
      La <ref tip="sin" cel="ton.0o.MUZ_baza">baza tono</ref>
      de <ref tip="super" cel="gam.0o.MUZ">gamo</ref>:
      <ekz>
        en antikva kaj mezepoka Barato la arto de muziko kaj danco &ccirc;iam estis tre rekte
        ligita al <klr>[&#8230;]</klr> fiksa sono, <tld/>o
        <fnt>
          <vrk><url
          ref="https://esperantaretradio.blogspot.com/2017/10/kion-ludas-la-mondo.html">Bakit anka&ubreve;
          estis komponistino kaj muzika instruistino en la egipta...</url></vrk>
        </fnt>.
      </ekz>
    </dif>
    <trd lng="be">&c_t;&c_o;&c_n;&c_ib;&c_k;&c_a;</trd>
    <trdgrp lng="de">
      <trd>Tonika</trd>,
      <trd>Grundton</trd>
    </trdgrp>
    <trd lng="fr">tonique<klr> (ina subst.)</klr><klr tip="ind">
    (subst.)</klr></trd>
    <trd lng="it">tonica<klr> (sost.)</klr></trd>
    <trd lng="nl">stamtoon</trd>
    <trdgrp lng="pl">
      <trd>tonika</trd>,
      <trd>tonacja</trd>
    </trdgrp>
    <trd lng="pt">t&ocirc;nica</trd>
  </snc>
  <ref tip="hom" cel="tonik.0o.MED">toniko (vigligilo)</ref>
  <trd lng="ca">t&ograve;nica<klr tip="amb"> (m&uacute;s.)</klr></trd>
  <trd lng="cs">t&oacute;nika</trd>
  <trdgrp lng="ja">
    <trd>&#20027;&#38899;  <pr>&#12375;&#12421;&#12362;&#12435;</pr></trd>,
    <trd>&#12461;&#12540;&#12494;&#12540;&#12488;</trd>,
    <trd>&#24375;&#22766;&#21092;  <pr>&#12365;&#12423;&#12358;&#12381;&#12358;&#12374;&#12356;</pr></trd>
  </trdgrp>
  <trd lng="sk">tonikum</trd>
  <trdgrp lng="uk">
    <trd>&c_t;&c_o;&c_n;&c_ib;&c_k;&c_a;</trd>,
    <trd>&c_o;&c_s;&c_n;&c_o;&c_v;&c_n;&c_i;&c_j; &c_t;&c_o;&c_n;</trd>,
    <trd>&c_o;&c_s;&c_n;&c_o;&c_v;&c_n;&c_a; &c_ch;&c_a;&c_s;&c_t;&c_o;&c_t;&c_a;</trd>,
    <trd>&c_t;&c_o;&c_n;&c_ib;&c_z;&c_u;&c_ju;&c_ch;&c_a; &c_r;&c_je;&c_ch;&c_o;&c_v;&c_i;&c_n;&c_a;</trd>,
    <trd>&c_t;&c_o;&c_n;&c_ib;&c_z;&c_u;&c_ju;&c_ch;&c_i;&c_j; &c_z;&c_a;&c_s;&c_ib;&c_b;</trd>,
    <trd>&c_t;&c_o;&c_n;&c_ib;&c_k; (&c_n;&c_a;&c_p;&c_ib;&c_j;)</trd>
  </trdgrp>
</drv>

<drv mrk="tonik1.0a">
  <kap>
    <tld/>a
  </kap>
  <snc mrk="tonik1.0a.MUZ">
    <uzo tip="fak">MUZ</uzo>
    <dif>
      Referanta al la <ref tip="vid" cel="tonik1.0o.MUZ">toniko</ref>.
    </dif>
    <trd lng="be">&c_t;&c_a;&c_n;&c_ib;&c_ch;&c_n;&c_y;</trd>
    <trd lng="nl">betr. hebbend op de <ind>stamtoon</ind></trd>
    <trdgrp lng="pl">
      <trd>toniczny</trd>,
      <trd>w <ind>tonacji</ind></trd>
    </trdgrp>
    <trd lng="pt">t&ocirc;nico</trd>
  </snc>
  <trd lng="ca">t&ograve;nic<klr tip="amb"> (m&uacute;s)</klr></trd>
  <trd lng="fr">tonique<klr tip="ind"> (adj.)</klr></trd>
  <trd lng="it">tonico<klr> (agg.)</klr></trd>
  <trdgrp lng="ja">
    <trd>&#20027;&#38899;&#12398;  <pr>&#12354;&#12427;&#12376;&#12362;&#12392;&#12398;</pr></trd>,
    <trd>&#24375;&#22766;&#12395;&#12377;&#12427;  <pr>&#12365;&#12423;&#12358;&#12381;&#12358;&#12395;&#12377;&#12427;</pr></trd>
  </trdgrp>
</drv>


