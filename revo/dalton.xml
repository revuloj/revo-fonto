<?xml version="1.0"?>
<!DOCTYPE vortaro SYSTEM "../dtd/vokoxml.dtd">
<vortaro>
<art mrk="$Id: dalton.xml,v 1.32 2026/06/06 08:46:50 revo Exp $">
<kap>
  <rad>daltonism</rad>/o
  <fnt><bib>PVEF</bib></fnt>
</kap>

<drv mrk="dalton.0o">
  <kap><tld/>o</kap>
  <snc mrk="dalton.0o.MED">
    <uzo tip="fak">MED</uzo>
    <dif>
      Nenormaleco en la perceptado de koloroj,
      precipe nekapablo distingi inter ru&gcirc;o kaj verdo:
      <ekz>
        <tld/>o estas herede ligita kun sekso;
      </ekz>
      <ekz>
        medicina afero &ndash; kvankam ne malsano, nur anomalio &ndash; estas la <tld/>o
        <fnt>
          <aut>Ada Csisz&aacute;r</aut>
          <vrk><url ref="https://tempa.bitarkivo.org/gazetoj/HungaraVivo/HungaraVivo_1971_4.pdf"
              >Koloroj</url></vrk>
          <lok>Hungara Vivo, n-ro 4 1971/1072, p. 10</lok>
        </fnt>;
      </ekz>
      <ekz>
        <nom>Swyley</nom> malamis fi&scirc;ojn kaj spinacon e&ccirc; pli ol li malamis la testojn, al kiuj oni
        lin submetadis, kaj post unu semajno li estis trafita de severa <tld/>o, kion
        li pruvis per tio, ke li kapablis vidi tute nenion e&ccirc; sur la plej simplaj
        trejnaj bildoj
        <fnt>
          <aut>James Patrick Hogan, trad. Jerzy Wa&lstroke;aszek</aut>
          <vrk><url ref="https://eduinf.waw.pl/esp/lern/librejo/9993/0003.php"
              >La Invado El Pasinteco</url></vrk>
          <lok>&Ccirc;apitro I</lok>
        </fnt>.
      </ekz>
    </dif>
    <ref tip="lst" cel="san.mal0o.MED" lst="voko:malsanoj">malsano</ref>
  </snc>
  <rim>
    La&ubreve; <fnt><bib>BL</bib></fnt>: Prefere diru <ke>kolorblindeco</ke>;
    (kiel plej ofte priparolata formo de kolorblindeco en la komuna lingvo) prefere diru <ke>ru&gcirc;verdblindeco</ke>.
  </rim>

  <trd lng="be">&c_d;&c_a;&c_l;&c_mol;&c_t;&c_a;&c_n;&c_ib;&c_z;&c_m;</trd>
  <trd lng="bg">&c_d;&c_a;&c_l;&c_t;&c_o;&c_n;&c_i;&c_z;&c_malmol;&c_m;</trd>
  <trd lng="ca">daltonisme</trd>
  <trdgrp lng="cs">
    <trd>barvoslepost</trd>,
    <trd>daltonizmus</trd>
  </trdgrp>
  <trdgrp lng="de">
    <trd>Farbblindheit</trd>,
    <trd>Farbenblindheit</trd>,
    <trd>Daltonismus</trd>
  </trdgrp>
  <trd lng="en">color blindness</trd>
  <trd lng="es">daltonismo</trd>
  <trdgrp lng="fa">
    <trd>&f_k;&a_w;&a_r;&a_r;&a_n;&f_g;&f_y;</trd>,
    <trd>&a_r;&a_n;&f_g;&zwnj;&f_k;&a_w;&a_r;&f_y;</trd>,
    <trd>&a_d;&a_A;&a_l;&a_t;&a_w;&a_n;&f_y;&a_s;&a_m;</trd>
  </trdgrp>
  <trd lng="fr">daltonisme</trd>
  <trd lng="he">&ayin;&yod;&vav;&vav;&resh;&vav;&fnun; &tsadi;&bet;&ayin;&yod;&fmem;</trd>
  <trdgrp lng="hu">
     <trd>daltonizmus</trd>,
     <trd>v&ouml;r&ouml;s-z&ouml;ld <ind>sz&iacute;nt&eacute;veszt&eacute;s</ind></trd>
  </trdgrp>
  <trdgrp lng="id">
    <trd><ind>buta</ind> warna</trd>,
    <trd>daltonisme</trd>
  </trdgrp>
  <trdgrp lng="ja">
    <trd>&#x5148;&#x5929;&#x6027;&#x8D64;&#x7DD1;&#x8272;&#x76F2;  <pr>&#x305B;&#x3093;&#x3066;&#x3093;&#x305B;&#x3044;&#x3042;&#x304B;&#x307F;&#x3069;&#x308A;&#x3057;&#x304D;&#x3082;&#x3046;</pr></trd>,
    <trd/>,
    <trd>&#x8272;&#x76F2;  <pr>&#x3057;&#x304D;&#x3082;&#x3046;</pr></trd>
  </trdgrp>
  <trd lng="nl">kleurenblindheid</trd>
  <trdgrp lng="pl">
    <trd>daltonizm</trd>,
    <trd>&sacute;lepota barwna</trd>
  </trdgrp>
  <trd lng="pt">daltonismo</trd>
  <trd lng="ru">&c_d;&c_a;&c_l;&c_mol;&c_t;&c_o;&c_n;&c_i;&c_z;&c_m;</trd>
  <trdgrp lng="sk">
    <trd>daltonizmus <klr>(druh farbosleposti)</klr></trd>,
    <trd>farboslepos&tcaron;</trd>
  </trdgrp>
  <trd lng="uk">&c_d;&c_a;&c_l;&c_mol;&c_t;&c_o;&c_n;&c_ib;&c_z;&c_m;</trd>
  <trd lng="zh">&#x8272;&#x76F2; <pr>s&egrave;m&aacute;ng</pr></trd>
</drv>

<drv mrk="dalton.0ulo">
  <kap><tld/>ulo</kap>
  <snc mrk="dalton.0ulo.MED">
    <uzo tip="fak">MED</uzo>
    <dif>
      Homo suferanta je <tld/>o.
    </dif>
  </snc>
  <trd lng="be">&c_d;&c_a;&c_l;&c_mol;&c_t;&c_o;&c_n;&c_ib;&c_k;</trd>
    <trd lng="ca">daltoni&agrave;</trd>
    <trd lng="cs">daltonista</trd>
    <trd lng="de">Farbenblinder</trd>
    <trd lng="es">dalt&oacute;nico</trd>
    <trd lng="fa">&f_k;&a_w;&a_r;&a_r;&a_n;&f_g;</trd>
    <trd lng="fr">daltonien<klr tip="ind"> (subst.)</klr></trd>
    <trd lng="he">&ayin;&yod;&vav;&vav;&resh; &tsadi;&bet;&ayin;&yod;&fmem;</trd>
  <trd lng="hu">v&ouml;r&ouml;s-z&ouml;ld <ind>sz&iacute;nt&eacute;veszt&odblac;</ind></trd>
    <trd lng="nl">kleurenblinde</trd>
    <trd lng="pl">daltonista</trd>
</drv>
</art>
