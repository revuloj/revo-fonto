<?xml version="1.0"?>
<!DOCTYPE vortaro SYSTEM "../dtd/vokoxml.dtd">
<vortaro>
<art mrk="$Id: lanc.xml,v 1.35 2026/06/06 12:00:20 revo Exp $">
<kap>
  <ofc>1</ofc>
  <rad>lanc</rad>/o
<fnt><bib>JED</bib></fnt></kap>
<drv mrk="lanc.0o">
  <kap>
    <tld/>o
  </kap>
  <uzo tip="fak">MIL</uzo>
  <snc mrk="lanc.0o.batalilo">
    <dif>
      <ref tip="lst" lst="voko:bataliloj" cel="batal.0ilo.ARM">Batalilo</ref>
      konsistanta el longa ligna stango kun akra ferpinto:
      <ekz>
        &ccirc;u iu vidis &scirc;ildon a&ubreve; <tld/>on &ccirc;e la kvardek miloj
        <fnt>
          <bib>MT</bib>
          <lok>Ju&gcirc;istoj 5:8</lok>
        </fnt>?
      </ekz>
      <ekz>
        la <tld/>o eliris tra lia malanta&ubreve;a parto
        <fnt>
          <bib>MT</bib>
          <lok>II. Samuel 2:23</lok>
        </fnt>;
      </ekz>
      <ekz>
        <klr>[li]</klr> montris arbaron de <tld/>oj de la soldatoj, kiuj ekzerci&gcirc;is en
        la korto
        <fnt>
          <bib>Far3</bib>
          <lok>&Ccirc;apitro V</lok>
        </fnt>;
      </ekz>
      <ekz>
        malamikaj soldatoj kun brilantaj bataliloj kaj en diverskoloraj uniformoj, kun
        <tld/>oj kaj <ref tip="sub" cel="haleba.0o">halebardo</ref>j
        <fnt>
          <bib>Fab4</bib>
          <lok>Lasta son&gcirc;o de maljuna kverko</lok>
        </fnt>;
      </ekz>
      <ekz>
        pretigu ducent soldatojn <klr>[&#8230;]</klr> kun sepdek rajdistoj kaj ducent
        <ind><tld/>isto</ind>j
        <fnt>
          <bib>NT</bib>
          <lok>La agoj 23:23</lok>
        </fnt>.
        <trd lng="ca">llancer</trd>
	<trd lng="hu">l&aacute;ndzs&aacute;s</trd>
	<trd lng="pl">oszczepnik</trd>
	<trd lng="ru">&c_k;&c_o;&c_p;&c_je;&c_j;&c_shch;&c_i;&c_k;</trd>
      </ekz>
    </dif>
  </snc>
  <trd lng="be">&c_d;&c_z;&c_ib;&c_d;&c_a;</trd>
  <trd lng="ca">llan&ccedil;a</trd>
  <trdgrp lng="de">
     <trd>Lanze</trd>,
     <trd>Spie&szlig;</trd>
  </trdgrp>
  <trd lng="el">&delta;&omikron_ton;&rho;&ypsilon;</trd>
  <trdgrp lng="en">
    <trd>lance</trd>,
    <trd>spear</trd>
  </trdgrp>
  <trd lng="es">lanza</trd>
  <trdgrp lng="fa">
    <trd>&a_n;&f_y;&a_z;&a_h;</trd>,
    <trd>&a_z;&a_w;&a_b;&f_y;&a_n;</trd>
  </trdgrp>
  <trd lng="fr">lance</trd>
  <trd lng="hu">l&aacute;ndzsa</trd>
  <trdgrp lng="ja">
    <trd>&#27085;  <pr>&#12411;&#12371;</pr></trd>,
    <trd>&#37531;  <pr>&#12418;&#12426;</pr></trd>,
    <trd>&#39321;&#36554;  <pr>&#12365;&#12423;&#12358;&#12375;&#12419;</pr></trd>
  </trdgrp>
  <trd lng="nl">lans</trd>
  <trdgrp lng="pl">
    <trd>lanca</trd>,
    <trd>dzida</trd>,
    <trd>oszczep</trd>
  </trdgrp>
  <trd lng="pt">lan&ccedil;a</trd>
  <trdgrp lng="ru">
    <trd>&c_k;&c_o;&c_p;&c_mol;&c_jo;</trd>,
    <trd>&c_p;&c_i;&c_k;&c_a;</trd>
  </trdgrp>
  <trdgrp lng="sv">
    <trd>lans</trd>,
    <trd>spjut</trd>
  </trdgrp>
  <trdgrp lng="uk">
    <trd>&c_s;&c_p;&c_i;&c_s;</trd>,
    <trd>&c_d;&c_r;&c_o;&c_t;&c_i;&c_k;</trd>,
    <trd>&c_r;&c_o;&c_g;&c_a;&c_t;&c_i;&c_n;&c_a;</trd>
  </trdgrp>
  <trd lng="zh">&#30683; <pr>m&aacute;o</pr></trd>
</drv>

<drv mrk="lanc.0eto">
  <kap>
    <tld/>eto
  </kap>
  <snc mrk="lanc.0eto.KIR">
  <uzo tip="fak">KIR</uzo>
    <dif>
      &Hcirc;irurgia speciala <ref cel="trancx.0ilo">tran&ccirc;il</ref>eto, por piki vejnon,
      entran&ccirc;i absceson, kc:
      <ekz>
        kuracisto, kiu ne havas tiel nepre necesan rimedon... &ndash; se vi vidus liajn
        <tld/>etojn <klr>[&#8230;]</klr>
        <fnt>
          <bib>PatrojFiloj</bib>
        </fnt>;
      </ekz>
      <ekz>
        sub la <tld/>et&#8217; de la naturo, arto, menso, torturas karnon kaj spiriton la aku&scirc;&#8217;
        <fnt>
          <aut>Nikolaj Gumiljov</aut>
          <vrk><url ref="&Tekstaro;?nomo=ondo-de-esperanto">La sesa senso</url></vrk>
          <lok>La Ondo de Esperanto 2001 &ndash; 2004</lok>
        </fnt>.
      </ekz>
    </dif>
    <refgrp tip="vid">
       <ref cel="skalpe.0o">skalpelo</ref>,
       <ref cel="bistur.0o">bisturio</ref>
    </refgrp>
    <bld lok="&WCU;/thumb/7/7c/Lanzette.JPG/330px-Lanzette.JPG" prm="CC-BY-SA-3.0"><tld/>eto
        <fnt>
          <aut>Markus W&uuml;rfel, propra verko</aut>
          <lok><url ref="&WCW;/File:Lanzette.JPG">&WCW;/File:Lanzette.JPG</url></lok>
        </fnt>
    </bld>
  </snc>
  <trd lng="be">&c_l;&c_ja;&c_n;&c_c;&c_e;&c_t;</trd>
  <trd lng="ca">llanceta</trd>
  <trd lng="de">Lanzette</trd>
  <trd lng="el">&ny;&ypsilon;&sigma;&tau;&epsilon_ton;&rho;&jota;</trd>
  <trdgrp lng="en">
    <trd>lancet</trd>,
    <trd>scalpel</trd>
  </trdgrp>
  <trd lng="fa">&a_n;&f_y;&a_sh;&a_t;&a_r;</trd>
  <trd lng="fr">lancette</trd>
  <trd lng="hu">lancetta</trd>
  <trd lng="ja">&#12521;&#12531;&#12475;&#12483;&#12488;  <pr>&#12425;&#12435;&#12379;&#12387;&#12392;</pr></trd>
  <trd lng="nl">lancet</trd>
  <trdgrp lng="pl">
    <trd>lancet</trd>,
    <trd>skalpel</trd>
  </trdgrp>
  <trdgrp lng="pt">
    <trd>bisturi</trd>,
    <trd>escalpelo (&ecirc;)</trd>
  </trdgrp>
  <trd lng="ru">&c_l;&c_a;&c_n;&c_c;&c_je;&c_t;</trd>
  <trd lng="uk">&c_l;&c_a;&c_n;&c_c;&c_je;&c_t;</trd>
  <trdgrp lng="zh">
    <trd>&#26611;&#21494;&#20992; <pr>li&#468;y&egrave;d&amacron;o</pr></trd>,
    <trd>&#26611;&#33865;&#20992; <pr>li&#468;y&egrave;d&amacron;o</pr></trd>,
    <trd>&#21050;&#34880;&#37341; <pr>c&igrave;xi&ecaron;zh&emacron;n</pr></trd>,
    <trd>&#21050;&#34880;&#38024; <pr>c&igrave;xi&ecaron;zh&emacron;n</pr></trd>
  </trdgrp>
</drv>

<drv mrk="lanc.jxet0o">
  <kap>&jcirc;et<tld/>o</kap>
  <uzo tip="fak">MIL</uzo>
  <snc mrk="lanc.jxet0o.armilo">
    <dif>
      <ref tip="lst" lst="voko:bataliloj" cel="arm.0ilo">Armilo</ref>, simila je <tld/>o,
      kiun oni &jcirc;etas de malproksime:
      <ekz>
        cent &scirc;tonpintaj &jcirc;et<tld/>oj flugis al la besto kaj fine ili sukcesis &gcirc;in mortigi
        <fnt>
          <bib>SatirRak</bib>
        </fnt>;
      </ekz>
      <ekz>
        forta piko per lia &jcirc;et<tld/>o balda&ubreve; faris finon al la vivo de la bestego
        <fnt>
          <bib>I&scirc;tar</bib>
        </fnt>;
      </ekz>
      <ekz>
        skui &jcirc;et<tld/>on
        <fnt>
          <bib>Monato</bib>
          <aut>Pejno Simono</aut>
          <vrk><url ref="&Monato;/2012/010409.php">Etimologia ekskurso</url></vrk>
          <lok>2012</lok>
        </fnt>.
      </ekz>
    </dif>
    <trd lng="be">&c_d;&c_z;&c_ib;&c_d;&c_a;</trd>
    <trd lng="de">Speer</trd>
    <trd lng="en">javelin</trd>
    <trd lng="es">jabalina</trd>
    <trd lng="fr">javelot</trd>
    <trdgrp lng="hu">
      <trd>l&aacute;ndzsa</trd>,
      <trd>haj&iacute;t&oacute;d&aacute;rda</trd>
    </trdgrp>
    <trd lng="id">lembing</trd>
    <trd lng="nl">speer</trd>
    <trdgrp lng="pl">
      <trd>oszczep</trd>,
      <trd>w&lstroke;&oacute;cznia</trd>
    </trdgrp>
    <trd lng="ru">&c_k;&c_o;&c_p;&c_mol;&c_jo;</trd>
    <trd lng="it">giavellotto</trd>
    <trdgrp lng="zh">
    <trd>&#26797;&#37858; <pr>su&#333;bi&amacron;o</pr></trd>,
    <trd>&#26797;&#38230; <pr>su&#333;bi&amacron;o</pr></trd>,
    <trd>&#25133; <pr>y&#462;n</pr></trd>,
    <trd>&#30688; <pr>z&eacute;</pr></trd>
  </trdgrp>
</snc>
  <trdgrp lng="ca">
    <trd>javelina</trd>,
    <trd>dard</trd>,
    <trd>dardell</trd>,
    <trd>venable</trd>
  </trdgrp>
  <trd lng="ja">&#25237;&#12370;&#12420;&#12426;  <pr>&#12394;&#12370;&#12420;&#12426;</pr></trd>
  <trdgrp lng="uk">
    <trd>&c_d;&c_r;&c_o;&c_t;&c_i;&c_k;</trd>,
    <trd>&c_m;&c_je;&c_t;&c_a;&c_l;&c_mol;&c_n;&c_i;&c_j; &c_s;&c_p;&c_i;&c_s;</trd>,
    <trd>&c_s;&c_p;&c_i;&c_s;</trd>
  </trdgrp>
</drv>

</art>
