<?xml version="1.0"?>
<!DOCTYPE vortaro SYSTEM "../dtd/vokoxml.dtd">

<vortaro>
  <art mrk="$Id: kardinal1.xml,v 1.2 2026/04/19 13:44:51 afido Exp $">
    <kap>
      <rad>kardinal</rad>/o
      <fnt><bib>PIV2</bib></fnt>
    </kap>

<drv mrk="kardinal1.0o">
  <kap><tld/>o</kap>
  <snc mrk="kardin1.0o.MAT">
    <uzo tip="fak">MAT</uzo>
    <fnt><bib>MatVort</bib></fnt>
    <dif>
      Tia nocio asociita al &ccirc;iu <ref cel="ar.0o.MAT">aro</ref>,
      ke du aroj havas la saman <tld/>on, se kaj nur se ekzistas inter
      ili <ref cel="bijekc.0o">bijekcio</ref>; por finia aro:
      <ref cel="entjer.natura0o">natura entjero</ref> egala al la
      kvanto de &gcirc;iaj elementoj:
      <ekz>
        la <tld/>on de aro <frm am="bb E"><g>E</g></frm> oni signas per
        <frm am="&quot;kard&quot; bb E&quot;">kard <g>E</g></frm> a&ubreve;
        <frm am="|bb E|">|<g>E</g>|</frm>;
      </ekz>
      <ekz>
        <frm am="aleph_0">&#x2135;<sub>0</sub></frm> <klr> (legu:
        alef-nul)</klr>
        estas la plej malgranda <tld/>o malfinia;
      </ekz>
      <ekz>
        la <tld/>o de <ref cel="kun.0ajxo.aro">kuna&jcirc;o</ref> de
        finiaj aroj estas maksimume egala al la sumo de iliaj <tld/>oj.
      </ekz>
    </dif>
    <ref tip="sin" cel="pov.0o.MAT">povo<sncref/></ref>
    <rim>
      La&ubreve; nacilingva kutimo oni anka&ubreve; diras <ctl><tld/>a
      nombro</ctl>, kiel en <fnt><bib>MatTerm</bib>, <lok>p.
      18</lok></fnt>.
    </rim>
    <trd lng="be">&c_l;&c_ib;&c_k; &c_k;&c_a;&c_r;&c_d;&c_y;&c_n;&c_a;&c_l;&c_mol;&c_n;&c_y;</trd>
    <trd lng="ca">cardinalitat</trd>
    <trdgrp lng="de">
      <trd>Kardinalzahl</trd>,
      <trd>M&auml;chtigkeit</trd>
    </trdgrp>
    <trd lng="cs">kardin&aacute;ln&iacute; &ccaron;&iacute;slo</trd>
    <trdgrp lng="en">
      <trd>cardinal number</trd>,
      <trd>cardinality</trd>,
      <trd>power</trd>
    </trdgrp>
    <trdgrp lng="fr">
      <trd>cardinal<klr tip="ind"> (math.)</klr></trd>,
      <trd>puissance<klr tip="ind"> (d'un ensemble)</klr></trd>
    </trdgrp>
    <trd lng="hu">t&odblac;sz&aacute;m</trd>
    <trdgrp lng="it">
      <trd>cardinale<klr> (numero)</klr></trd>,
      <trd>cardinalit&agrave;</trd>,
      <trd>numero cardinale</trd>
    </trdgrp>
    <trd lng="nl">hoofdtelwoord</trd>
    <trdgrp lng="pl">
      <trd>liczba kardynalna</trd>,
      <trd>moc<klr tip="ind"> (zbioru)</klr></trd>
    </trdgrp>
    <trd lng="sk">kardin&aacute;lne &ccaron;&iacute;slo</trd>
    <trdgrp lng="ru">
      <trd>&c_k;&c_a;&c_r;&c_d;&c_i;&c_n;&c_a;&c_l;&c_mol;&c_n;&c_o;&c_je; &c_ch;&c_i;&c_s;&c_l;&c_o;</trd>,
      <trd>&c_m;&c_o;&c_shch;&c_n;&c_o;&c_s;&c_t;&c_mol;<klr tip="ind"> (&c_m;&c_n;&c_o;&c_zh;&c_je;&c_s;&c_t;&c_v;&c_a;)</klr></trd>
    </trdgrp>
  </snc>
  <ref tip="hom" cel="kardin.0o.KAT">kardinalo <klr>(katolika)</klr></ref>
</drv>

  </art>

