<kap>
  <rad>biostratigrafi</rad>/o <fnt><bib>Viki</bib></fnt>
</kap>

<drv mrk="biostratigrafi.0o">
  <kap><tld/>o</kap>
  <snc mrk="biostratigrafi.0o.PAL">
    <uzo tip="fak">PAL</uzo>
    <dif>
      <ref tip="vid" cel="kronol.0o.SCI">Kronologia</ref>
      metodo studanta la fosiliajn resta&jcirc;ojn de bestoj
      kaj vegeta&jcirc;oj en tertavoloj,
      kompletige al
      <ref tip="vid" cel="stratigrafi.0o.GEOL">stratigrafio</ref>:
      <ekz>
        la kvaternaraj subdividoj estis difinitaj surbaze de <tld/>o
        <fnt>
          <bib>Viki</bib>
          <vrk><url ref="&Viki;/Kvaternaro">
          Kvaternaro</url>, 2018-03-03</vrk>
        </fnt>.
      </ekz>
    </dif>
    <rim>
      La&ubreve; <fnt><bib>BL</bib></fnt>: Prefere diru <ke>viva&jcirc;a (ter)tavolscienco</ke>.
    </rim>
    <trd lng="be">&c_b;&c_ib;&c_ja;&c_s;&c_t;&c_r;&c_a;&c_t;&c_y;&c_g;&c_r;&c_a;&c_f;&c_ib;&c_ja;</trd>
    <trd lng="en">biostratigraphy</trd>
    <trd lng="fr">biostratigraphie</trd>
    <trd lng="pl">biostratygrafia</trd>
    <trdgrp lng="zh">
      <trd>&#29983;&#29289;&#22320;&#23618;&#23398;</trd>,
      <trd>&#29983;&#29289;&#22320;&#23652;&#23416;</trd>
    </trdgrp>
  </snc>
</drv>
</art>

