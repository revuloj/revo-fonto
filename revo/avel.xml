<?xml version="1.0"?>
<!DOCTYPE vortaro SYSTEM "../dtd/vokoxml.dtd">
<vortaro>
<art mrk="$Id: avel.xml,v 1.40 2026/05/17 12:00:21 revo Exp $">
<kap>
<ofc>*</ofc>
<rad>avel</rad>/o
<fnt><bib>UV</bib></fnt></kap>
<drv mrk="avel.0o">
  <kap><ofc>*</ofc><tld/>o</kap>
  <snc mrk="avel.0o.nukso">
    <uzo tip="fak">KUI</uzo>
    <dif>
      La man&gcirc;ebla <ref tip="super" cel="nuks.0o.BOT">nukso</ref>
      de <ref tip="malprt" cel="avel.0ujo"><tld/>ujo</ref>:
      <ekz>
        ili atingis la grandecon de pizeto, a&ubreve; <tld/>o, a&ubreve; nukso
        <fnt>
          <bib>Monato</bib>
          <aut>Sigmond J&uacute;lia</aut>
          <vrk><url ref="&Monato;/2007/008896.php">Sep citronsemoj</url></vrk>
        </fnt>;
      </ekz>
      <ekz>
        okuloj kiel <tld/>oj
        <fnt>
          <bib>Monato</bib>
          <aut>Julian Modest</aut>
          <vrk><url ref="&Monato;/2013/010962.php">La iluziisto</url></vrk>
        </fnt>;
      </ekz>
      <ekz>
        ne&gcirc;leporo <klr>[&#8230;]</klr> man&gcirc;as bran&ccirc;ojn, &scirc;osojn kaj &scirc;elojn
        de falfoliaj arboj, kiaj poplo, birdokaptista sorbuso, saliko, 
        betulo, <tld/>ujo, <klr>[&#8230;]</klr>
        <fnt>
          <bib>Viki</bib>
          <lok><url ref="https://eo.wikipedia.org/?curid=49904">Ne&gcirc;leporo</url></lok>
        </fnt>.
      </ekz>
    </dif>
    <trdgrp lng="zh">
    <trd>&#27035;&#26524; <pr>zh&#275;ngu&#466;</pr></trd>,
    <trd>&#27035;&#20161; <pr>zh&#275;nr&eacute;n</pr></trd>
  </trdgrp>
</snc>
  <snc mrk="avel.0o.planto">
    <dif>
      <ref tip="dif" cel="avel.0ujo"><tld lit="A"/>ujo</ref>:
      <ekz>
        la virino <klr>[&#8230;]</klr> &scirc;irkolektis al si plenan po&scirc;on da nuksoj <tld/>aj
        <fnt>
          <bib>Fab3</bib>
          <lok><url ref="&Steloj;fabeloj3/">Ib kaj malgranda kristino</url></lok>
        </fnt>;
      </ekz>
      <ekz>
        kiam li rajdis tra verdaj arbetoj, <tld/>a bran&ccirc;eto ekbatis lin kaj de&jcirc;etis lian &ccirc;apelon
        <fnt>
          <bib>ElektFab</bib>
          <lok><url ref="&Steloj;gfabeloj/index.html">Cindrulino</url></lok>
        </fnt>.
      </ekz>
    </dif>
    <trd lng="de">Hasel</trd>
    <trd lng="zh">&#27035; <pr>zh&#275;n</pr></trd>
</snc>
  <trdgrp lng="be">
    <trd>&c_l;&c_ja;&c_sh;&c_ch;&c_y;&c_n;&c_a;</trd>,
    <trd>&c_l;&c_ja;&c_s;&c_n;&c_y; &c_a;&c_r;&c_e;&c_h;</trd>
  </trdgrp>
  <trd lng="bg">&c_l;&c_je;&c_sh;&c_n;&c_i;&c_k;</trd>
  <trd lng="br">krao&ntilde;enn-gelvez</trd>
  <trd lng="ca">avellana</trd>
  <trd lng="cs">l&iacute;sk. o&rcaron;&iacute;&scaron;ek</trd>
  <trd lng="de">Haselnuss</trd>
  <trdgrp lng="en">
    <trd>hazelnut</trd>,
    <trd>filbert</trd>
  </trdgrp>
  <trd lng="es">avellana</trd>
  <trd lng="fr">noisette</trd>
  <trd lng="he">&alef;&gimel;&vav;&zayin; &lamed;&vav;&zayin;</trd>
  <trd lng="hu">mogyor&oacute;</trd>
  <trd lng="it">nocciola<klr> (bot.)</klr></trd>
  <trdgrp lng="ja">
    <trd>&#12495;&#12471;&#12496;&#12511;&#12398;&#23455;  <pr>&#12399;&#12375;&#12400;&#12415;&#12398;&#12415;</pr></trd>,
    <trd>&#12504;&#12540;&#12476;&#12523;&#12490;&#12483;&#12484;</trd>
  </trdgrp>
  <trd lng="nl">hazelnoot</trd>
  <trd lng="pl">orzech laskowy</trd>
  <trd lng="pt">avel&atilde;</trd>
  <trdgrp lng="ru">
    <trd>&c_l;&c_je;&c_shch;&c_i;&c_n;&c_a;</trd>,
    <trd>&c_l;&c_je;&c_s;&c_n;&c_o;&c_j; &c_o;&c_r;&c_je;&c_h;</trd>
  </trdgrp>
  <trd lng="sk">lieskovec</trd>
  <trd lng="sv">hasseln&ouml;t</trd>
  <trd lng="tr">f&inodot;nd&inodot;k</trd>
  <trd lng="uk">&c_g;&c_o;&c_r;&c_ib;&c_h;
<klr>(&c_z;&c_v;&c_i;&c_ch;&c_a;&c_j;&c_n;&c_i;&c_j;)</klr></trd>
</drv>

<drv mrk="avel.0ujo">
  <kap><tld/>ujo,
   <var><kap><tld/>arbo</kap></var>
  </kap>
  <snc>
    <uzo tip="fak">BOT</uzo>
    <dif>
      <ref tip="lst" lst="voko:botanikaj_specioj" cel="speci.0o">Specio</ref>
      el familio <ref tip="malprt" cel="betula.0oj">betulacoj</ref>
      (<trd lng="la">Corylus avellana</trd>):
      <ekz>
        sub la <tld/>arbetoj, kie la nuksoj pendis en formo de pezaj faskoj, sidis viro kaj virino
        <fnt>
          <bib>Fab3</bib>
          <lok><url ref="&Steloj;fabeloj3/">Historio de la jaro</url></lok>
        </fnt>;
      </ekz>
      <ekz>
        la tombo de la patrino sub la <tld/>arbo
        <fnt>
          <bib>ElektFab</bib>
          <lok><url ref="&Steloj;gfabeloj/index.html">Cindrulino</url></lok>
        </fnt>.
      </ekz>
    </dif>
    <bld lok="&WCU;/thumb/6/60/Corylus_avellana.jpg/500px-Corylus_avellana.jpg"
    prm="CC-BY-SA-3.0">nuksoj kaj folioj de <tld/>o (Corylus avellana)
        <fnt>
          <lok><url
          ref="&WCW;/File:Corylus_avellana.jpg">&WCW;/File:Corylus_avellana.jpg</url></lok>
        </fnt>
    </bld>
  </snc>
  <trdgrp lng="be">
    <trd>&c_a;&c_r;&c_e;&c_sh;&c_n;&c_ib;&c_k;</trd>,
    <trd>&c_l;&c_ja;&c_sh;&c_ch;&c_y;&c_n;&c_a;
      <klr>(&c_r;&c_a;&c_s;&c_mol;&c_l;&c_ib;&c_n;&c_a;)</klr></trd>
  </trdgrp>
  <trd lng="bg">&c_l;&c_je;&c_s;&c_k;&c_a;</trd>
  <trdgrp lng="br">
    <trd>kelvezenn</trd>,
    <trd>bod <ind>kelvez</ind></trd>
  </trdgrp>
  <trd lng="ca">avellaner</trd>
  <trd lng="cs">o&rcaron;ech l&iacute;ska ke&rcaron;</trd>
  <trd lng="de">Haselstrauch</trd>
  <trd lng="en">hazel tree</trd>
  <trd lng="fr">noisetier</trd>
  <trd lng="he">&ayin;&ftsadi; &alef;&#1457;&gimel;&vav;&#1465;&zayin;&#1461;&yod; &lamed;&vav;&#1468;&zayin;</trd>
  <trd lng="hu">mogyor&oacute;cserje</trd>
  <trd lng="it">nocciolo<klr> (albero)</klr></trd>
  <trd lng="ja">&#12495;&#12471;&#12496;&#12511;</trd>
  <trd lng="nl">hazelaar</trd>
  <trdgrp lng="pl">
    <trd>leszczyna</trd>,
    <trd>drzewo leszczynowe</trd>
  </trdgrp>
  <trd lng="ru">&c_o;&c_r;&c_je;&c_sh;&c_n;&c_i;&c_k;</trd>
  <trd lng="sk">lieska</trd>
  <trd lng="sv">hassel</trd>
  <trd lng="tr">f&inodot;nd&inodot;k</trd>
  <trdgrp lng="uk">
    <trd>&c_l;&c_ib;&c_shch;&c_i;&c_n;&c_a;</trd>,
    <trd>&c_g;&c_o;&c_r;&c_ib;&c_sh;&c_i;&c_n;&c_a;</trd>
  </trdgrp>
</drv>
</art>
