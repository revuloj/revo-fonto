<?xml version="1.0"?>
<!DOCTYPE vortaro SYSTEM "../dtd/vokoxml.dtd">
<vortaro>
<art mrk="$Id: gansu.xml,v 1.2 2026/07/15 14:06:10 afido Exp $">
<kap>
    <rad>Gansu</rad>/o <fnt><bib>PIV2</bib></fnt>
</kap>
<drv mrk="gansu.0o">
  <kap><tld/>o</kap>
  <snc mrk="gansu.0o.GEOG">
    <uzo tip="fak">GEOG</uzo>
    <uzo tip="fak">POL</uzo>
    <dif>
      Provinco en la centra parto de <ref tip="malprt" cel="cxin.CX0ujo">&Ccirc;inujo</ref> kun la &ccirc;efurbo
      <ref tip="prt" cel="langxoux.0o">Lan&gcirc;o&ubreve;o</ref>:
      <ekz>
        la du aliaj tradiciaj provincoj (<nom>Kham</nom> kaj <nom>Amdo</nom>) estis integritaj en la &ccirc;inan provincon
        &Ccirc;inghajo kaj en la okcidentajn mar&gcirc;enojn de <tld lit="G"/>o
        <fnt>
          <aut>M. Vernerey, trad. V. Lutermano</aut>
          <vrk><url ref="https://eo.mondediplo.com/2008/04/article1344">
          Anta&ubreve;tempa bur&gcirc;onado de la printempo de Lasao</url></vrk>
          <lok>Le Monde diplomatique, 2008-04</lok>
        </fnt>.
      </ekz>
    </dif>
  </snc>
  <trd lng="de">Gansu</trd>
  <trd lng="fr">Gansu</trd>
  <trdgrp lng="zh">
    <trd>&#x7518;&#x8085; <pr>G&amacron;ns&ugrave;</pr></trd>,
    <trd>&#x7518;&#x8083; <pr>G&amacron;ns&ugrave;</pr></trd>
  </trdgrp>
</drv>
</art>

