<kap>
    <rad>Kenet</rad>/o
</kap>
<drv mrk="kenet.0o">
  <kap><tld/>o</kap>
  <snc mrk="kenet.0o.NOM">
    <uzo tip="fak">NOM</uzo>
    <dif>
      Vira <ref tip="lst" cel="nom.antaux0o" lst="voko:personaj_nomoj">anta&ubreve;nomo</ref> irlanddevena:
      <ekz>
        <tld/>o <nom>Hall</nom> kunigis sin al la grupo, kaj balda&ubreve; estis sova&gcirc;a interpu&scirc;ado
        <fnt>
          <aut>D. W. Munns</aut>
          <vrk><url ref="https://mondmilito.hypotheses.org/files/2019/12/londonadinoj2.pdf">
          Londonanidoj</url></vrk>
          <lok>1946</lok>
        </fnt>;
      </ekz>
      <ekz>
        ekde 2011<klr>[&#x2026;]</klr> <tld/>o la&ubreve;tlegas la biblion en Esperanto
        <fnt>
          <aut>-</aut>
          <vrk>
          A&ubreve;debla Biblio en Esperanto</vrk>
          <lok><url
          ref="https://www.esperanto.de/sites/default/files/esperanto.de/ea-archiv/Esperanto%20aktuell%202012-1.pdf">
          Esperanto aktuell, 2012/1</url></lok>
        </fnt>.
      </ekz>
    </dif>
  </snc>
  <trd lng="de">Kenneth</trd>
  <trd lng="en">Kenneth</trd>
  <trd lng="fr">Kenneth</trd>
  <trd lng="he">&qof;&nun;&tav; <klr>(&pe;&yod;&resh;&vav;&shin;&vav;&nun;&yod;&fmem;)</klr></trd>
</drv>
