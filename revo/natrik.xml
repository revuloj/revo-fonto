<?xml version="1.0"?>
<!DOCTYPE vortaro SYSTEM "../dtd/vokoxml.dtd">

<vortaro>
  <art mrk="$Id: natrik.xml,v 1.1 2026/05/10 04:35:20 afido Exp $">
    <kap>
      <rad>natrik</rad>/o
      <fnt><bib>PIV2</bib></fnt>
    </kap>

<drv mrk="natrik.0o">
  <kap><tld/>o</kap>
  <uzo tip="fak">ZOO</uzo>
  <snc>
    <dif>
      <ref tip="lst" lst="voko:zoologiaj_genroj" cel="genr.0o.BIO">Genro</ref>
      de e&ubreve;ropaj nevenenaj <ref tip="lst" lst="voko:serpentoj" cel="serpen.0o.ZOO">serpentoj</ref>
      el la familio de <ref tip="malprt" cel="kolubr1.0oj">kolubredoj</ref>
      (<trd lng="la">Natrix</trd>),
      kun rondaj pupiloj, ovonaskaj, na&gcirc;kapablaj kaj kies dorsaj skvamoj havas kileton:
      <ekz>
        sciencistoj malkovris novan specion de natriko, kiu vivas en Turkio,
        Azerbaj&gcirc;ano, Armenio
        <fnt>
          <bib>Monato</bib>
          <aut>Julius Hauser</aut>
          <vrk><url ref="https://www.esperanto.be/fel/publika/012495p.php"
              >Nova natriko malkovrita</url></vrk>
          <lok>2020-07-07</lok>
        </fnt>;
      </ekz>
      <ekz>
        &ccirc;e la rivero <nom>Blanice</nom> <klr>[&#x2026;]</klr> vivis <klr>[&#x2026;]</klr> bufo, lacerto kaj
        <ind><tld/>o kolringa</ind>
        <fnt>
          <aut>Jarka Mal&aacute;</aut>
          <vrk><url ref="https://esperantaretradio.blogspot.com/2020/05/nia-rivero-blanice.html"
              >Nia rivero Blanice</url></vrk>
          <lok>Esperanta Retaradio, 2020-05-01</lok>
        </fnt>.
        <trd lng="de">Ringelnatter</trd>
        <trd lng="en">grass snake</trd>
        <trd lng="ru">&c_o;&c_b;&c_y;&c_k;&c_n;&c_o;&c_v;&c_je;&c_n;&c_n;&c_y;&c_j; &c_u;&c_zh;</trd>
      </ekz>
    </dif>
    <trd lng="de">Europ&auml;ische <ind>Wassernatter</ind></trd>
    <trd lng="en">natrix</trd>
    <trd lng="fr">natrix</trd>
    <trd lng="ru">&c_u;&c_zh;</trd>
  </snc>
</drv>

  </art>

