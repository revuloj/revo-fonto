<kap>
  <ofc>1</ofc>
  <rad>apopleksi</rad>/o
<fnt><bib>JED</bib></fnt></kap>
<drv mrk="apople.0o">
  <kap><tld/>o</kap>
  <uzo tip="fak">MED</uzo>
  <snc>
    <dif>
      Cerba sangalfluo, kiu senigas la <ref tip="lst" cel="san.mal0o.MED"
      lst="voko:malsanoj">malsan</ref>ulon je la
      sentoj kaj movoj,
      sed ne de la spirado:
      <ekz>
        la <tld/>o trafis &scirc;in tiun posttagmezon kaj embarasigis la
        kunvoja&gcirc;antojn<fnt><aut>Spomenka &Scirc;timec</aut>: <vrk>Morto en
        Melburna tramo</vrk>, <bib>Monato</bib><lok>jaro 1997a, numero
        8a,
        p. 24a</lok></fnt>.
      </ekz>
    </dif>
    <refgrp tip="vid">
      <ref cel="parali.0o">paralizo</ref>.
    </refgrp>
  </snc>
  <trd lng="be">&c_a;&c_p;&c_a;&c_p;&c_l;&c_je;&c_k;&c_s;&c_ib;&c_ja;</trd>
  <trdgrp lng="ca">
    <trd>accident vascular cerebral</trd>,
    <trd>accident cerebrovascular agut</trd>,
    <trd>apoplexia</trd>,
    <trd>ictus cerebral</trd>,
    <trd>feridura</trd>,
    <trd>atac de feridura</trd>
  </trdgrp>
  <trdgrp lng="cs">
    <trd>apoplexie</trd>,
    <trd>mrtvice</trd>,
    <trd>&scaron;lak</trd>
  </trdgrp>
  <trdgrp lng="de">
    <trd>Apoplexie</trd>,
    <trd>Schlaganfall</trd>
  </trdgrp>
  <trdgrp lng="en">
    <trd>apoplexy</trd>,
    <trd>stroke</trd>
  </trdgrp>
  <trd lng="es">apopleg&iacute;a</trd>
  <trdgrp lng="fr">
    <trd>apoplexie</trd>,
    <trd>ictus apoplectique</trd>
  </trdgrp>
  <trd lng="he">&shin;&bet;&ftsadi;</trd>
  <trdgrp lng="hu">
    <trd>sz&eacute;l&uuml;t&eacute;s</trd>,
    <trd>agyv&eacute;rz&eacute;s</trd>,
    <trd>sz&eacute;lh&udblac;d&eacute;s</trd>
  </trdgrp>
  <trdgrp lng="id">
    <trd>apopleksi</trd>,
    <trd>strok</trd>
  </trdgrp>
   <trdgrp lng="ja">
    <trd>&#21330;&#20013;  <pr>&#12381;&#12387;&#12385;&#12421;&#12358;</pr></trd>,
    <trd>&#33075;&#21330;&#20013;  <pr>&#12398;&#12358;&#12381;&#12387;&#12385;&#12421;&#12358;</pr></trd>
  </trdgrp>
  <trdgrp lng="pl">
    <trd>apopleksja</trd>,
    <trd>udar</trd>
  </trdgrp>
  <trdgrp lng="ru">
    <trd>&c_a;&c_p;&c_o;&c_p;&c_l;&c_je;&c_k;&c_s;&c_i;&c_ja;</trd>,
    <trd>&c_i;&c_n;&c_s;&c_u;&c_l;&c_mol;&c_t;</trd>,
    <trd>&c_u;&c_d;&c_a;&c_r;<klr tip="ind"> (&c_b;&c_o;&c_l;&c_je;&c_z;&c_n;&c_mol;)</klr></trd>
  </trdgrp>
  <trdgrp lng="sk">
    <trd>apoplexia</trd>,
    <trd>mozgov&aacute; <ind>por&aacute;&zcaron;ka</ind></trd>,
    <trd>mozgov&aacute; por&aacute;&zcaron;ka</trd>,
    <trd>m&racute;tvica</trd>
  </trdgrp>
  <trdgrp lng="uk">
    <trd>&c_a;&c_p;&c_o;&c_p;&c_l;&c_je;&c_k;&c_s;&c_ib;&c_ja;</trd>,
    <trd>&c_ib;&c_n;&c_s;&c_u;&c_l;&c_mol;&c_t;</trd>,
    <trd>&c_u;&c_d;&c_a;&c_r;</trd>
  </trdgrp>
</drv>
