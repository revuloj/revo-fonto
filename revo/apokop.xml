<?xml version="1.0"?>
<!DOCTYPE vortaro SYSTEM "../dtd/vokoxml.dtd">
<vortaro>
<art mrk="$Id: apokop.xml,v 1.25 2026/06/14 12:12:44 revo Exp $">
<kap>
  <rad>apokop</rad>/o
<fnt><bib>PVEF</bib></fnt></kap>
<drv mrk="apokop.0o">
  <kap><tld/>o</kap>
  <uzo tip="fak">GRA</uzo>
  <snc mrk="apokop.0o.GRA">
    <dif>
      Forlaso de unu a&ubreve; kelkaj silaboj en fino de
      vorto, ekzemple a&ubreve;t(omobil)o, fot(ografa&jcirc;)o, tram(veturil)o:
      <ekz>
        kelkaj retorikaj figuroj estas surbaze de la sonoj kaj morforlogio, &ndash; ekzemple
        aliteracio, <tld/>o
        <fnt>
          <vrk><url ref="https://www.eventoj.hu/steb/vortaroj/filozofia-vortaro/FESAPO-1.html"
              >Enciklopedio Simpozio</url></vrk>
          <lok>Figuro. Retorika... 2188</lok>
        </fnt>;
      </ekz>
      <ekz>
        infinitivoj, el vortoj latiniddevenaj, fini&gcirc;as per -a, -e, -i, kun <tld/>o de la
        originala fina -r: <nac>mira</nac><nac>&#x2026;</nac> (el <nac>mirar</nac>) &#x2018;rigardi&#x2019;,
        <nac>come</nac> (el <nac>comer</nac>) &#x2018;man&gcirc;i&#x2019;, <nac>drumi</nac>
        (el <nac>dormir</nac> kun metatezo) &#x2018;dormi&#x2019;
        <fnt>
          <vrk><url ref="https://libro.ee/file.php?id=4024"
              >Esperanto kaj papiamento</url></vrk>
          <lok>Epitomo de la gramatiko, p. 385; el: Heroldo de Esperanto 63. 1987:
          3 (1774), p. 1, 3; 415 (1775/76), p. 7.</lok>
        </fnt>.
      </ekz>
    </dif>
    <rim>
      La&ubreve; <fnt><bib>BL</bib></fnt>: Prefere diru <ke>finellaso</ke>.
    </rim>
  </snc>
  <trd lng="be">&c_a;&c_p;&c_o;&c_k;&c_a;&c_p;&c_a;</trd>
  <trd lng="bg">&c_a;&c_p;&c_o;&c_k;&c_o;&c_p;&c_a;</trd>
  <trd lng="ca">ap&ograve;cope</trd>
  <trd lng="cs">apokopa</trd>
  <trdgrp lng="de">
     <trd>Apokope</trd>,
     <trd>Abfall eines
     Auslauts</trd>
  </trdgrp>
  <trd lng="en">apocope</trd>
  <trd lng="es">ap&oacute;cope</trd>
  <trd lng="fa">&a_H;&a_dh;&a_f; &f_p;&a_A;&f_y;&a_A;&a_n;&f_y;</trd>
  <trd lng="fr">apocope</trd>
  <trd lng="ja">&#x8A9E;&#x5C3E;&#x97F3;&#x6D88;&#x5931;  <pr>&#x3054;&#x3073;&#x304A;&#x3068;&#x3057;&#x3087;&#x3046;&#x3057;&#x3064;</pr></trd>
  <trd lng="nl">apocope</trd>
  <trd lng="pl">apokopa</trd>
  <trd lng="ro">apocop&abreve;</trd>
  <trdgrp lng="ru">
    <trd>&c_a;&c_p;&c_o;&c_k;&c_o;&c_p;&c_a;</trd>,
    <trd>&c_u;&c_s;&c_je;&c_ch;&c_je;&c_n;&c_i;&c_je;</trd>
  </trdgrp>
  <trdgrp lng="sk">
    <trd>apokopa</trd>,
    <trd>hl&aacute;sok <klr>(aut(omobilo)</klr>o)</trd>,
    <trd>vynechanie slab&iacute;k</trd>
  </trdgrp>
  <trdgrp lng="uk">
    <trd>&c_a;&c_p;&c_o;&c_k;&c_o;&c_p;&c_a;</trd>,
    <trd>&c_u;&c_s;&c_ib;&c_k;&c_a;&c_n;&c_n;&c_ja;&nbsp;(&c_k;&c_ib;&c_n;&c_c;&c_je;&c_v;&c_i;&c_h; &c_z;&c_v;&c_u;&c_k;&c_ib;&c_v;
    &c_s;&c_l;&c_o;&c_v;&c_a;)</trd>
  </trdgrp>
</drv>
</art>
