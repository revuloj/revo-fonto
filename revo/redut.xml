<art mrk="$Id: redut.xml,v 1.25 2026/04/11 07:18:17 revo Exp $">
<kap>
  <rad>redut</rad>/o <fnt><bib>JED</bib></fnt>
</kap>
<drv mrk="redut.0o">
  <kap><tld/>o</kap>
  <snc mrk="redut.0o.MIL">
    <uzo tip="fak">ARKI</uzo>
    <uzo tip="fak">MIL</uzo>
    <dif>
      Kampa <ref tip="super" cel="fortik.0ajxo">fortika&jcirc;o</ref> en
      formo de &ccirc;irka&ubreve;fermita <ref tip="super" cel="rempar.0o">remparo</ref>:
      <ekz>
        sur la <tld/>o &leftquot;<nom>Cruys</nom>&rightquot; sonis seninterrompe la voko:
        &leftquot;Bone gardu! Bone gardu!&rightquot;
        <fnt>
          <aut>W. Raabe, trad. F. Wicke</aut>,
          <vrk>La Nigra Galero</vrk>,
          <lok>2a eld., 1922</lok>
        </fnt>;
      </ekz>
      <ekz>
        Graf&#8217; per se&gcirc;&#8217; al ili meze vojon baris, &#11005; Kaj sur <tld/>&#8217; malforta per pied&#8217;
        ekstaris
        <fnt>
          <bib>SrT</bib>
          <lok>Libro V.</lok>
        </fnt>.
      </ekz>
    </dif>
  </snc>
  <rim>
    La&ubreve; <fnt><bib>BL</bib></fnt>: Prefere diru <ke>fortika&jcirc;eto</ke>.
  </rim>

  <trd lng="be">&c_r;&c_e;&c_d;&c_u;&c_t;</trd>
  <trd lng="bg">&c_r;&c_je;&c_d;&c_u;&c_t;</trd>
  <trd lng="cs">ma&scaron;karn&iacute; ples</trd>
  <trdgrp lng="de">
    <trd>Redoute</trd>,
    <trd>Feldschanze</trd>,
    <trd><klr>(geschlossene)</klr> Schanze <klr>(Festungsbau)</klr></trd>
  </trdgrp>
  <trd lng="en">redoubt</trd>
  <trd lng="fr">redoute</trd>
  <trdgrp lng="hu">
    <trd>redut</trd>,
    <trd>z&aacute;rt <ind>s&aacute;nc</ind></trd>
  </trdgrp>
  <trd lng="it">ridotta<klr> (mil.)</klr></trd>
  <trd lng="ja">&#35282;&#38754;&#22561; <pr>&#12523;&#12489;&#12453;&#12540;&#12488;</pr></trd>
  <trdgrp lng="nl">
    <trd>redoute</trd>,
    <trd>schans</trd>
  </trdgrp>
  <trd lng="pl">reduta</trd>
  <trd lng="ro">redut&abreve;</trd>
  <trd lng="ru">&c_r;&c_je;&c_d;&c_u;&c_t;</trd>
  <trd lng="sk">po&lcaron;n&aacute; pevnos&tcaron;</trd>
  <trd lng="uk">&c_r;&c_je;&c_d;&c_u;&c_t;</trd>
</drv>
</art>
