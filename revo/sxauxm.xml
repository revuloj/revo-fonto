<!DOCTYPE vortaro SYSTEM "../dtd/vokoxml.dtd">
<vortaro>
<art mrk="$Id: sxauxm.xml,v 1.30 2026/05/31 04:51:35 revo Exp $">
<kap>
  <ofc>*</ofc>
  <rad>&scirc;a&ubreve;m</rad>/o <fnt><bib>UV</bib></fnt>
</kap>
<drv mrk="sxauxm.0o">
  <kap><ofc>*</ofc><tld/>o</kap>
  <snc mrk="sxauxm.0o.KOMUNE">
    <dif>
      Svarmo da <ref tip="prt" cel="vezik.0o.KOMUNE">veziketoj</ref>
      formi&gcirc;antaj el boligita a&ubreve; forte kirlita flua&jcirc;o:
      <ekz>
        <klr>[&scirc;i]</klr> kovris la harojn kaj bruston per <tld/>o de la maro
        <fnt>
          <bib>Fab1</bib>
          <lok>La virineto de maro</lok>
        </fnt>;
      </ekz>
      <ekz>
        ondoj krispi&gcirc;is kaj montris sin en vesto el <tld/>o
        <fnt>
          <bib>Fab1</bib>
          <lok>Sova&gcirc;aj cignoj</lok>
        </fnt>;
      </ekz>
      <ekz>
        &scirc;vito kovris la homojn, <tld/>o la &ccirc;evalojn
        <fnt>
          <bib>Far2</bib>
          <lok>&Ccirc;apitro 19a</lok>
        </fnt>;
      </ekz>
      <ekz>
        mi ku&scirc;i&gcirc;is en bankuvon plenan de <tld/>o
        <fnt>
          <bib>OIP</bib>
          <lok>Ombro sur interna pejza&gcirc;o</lok>
        </fnt>;
      </ekz>
      <ekz>
        &scirc;iaj brakoj &gcirc;is la kubutoj <klr>[&#8230;]</klr> estas kovritaj de la <ind>sapa <tld/>o</ind>
        <fnt>
          <bib>Metrop</bib>
        </fnt>;
        <trdgrp lng="en">
          <trd>lather</trd>,
          <trd>suds</trd>
        </trdgrp>
      </ekz>
      <ekz>
        ankora&ubreve; trovi&gcirc;as sanga <tld/>o en lia bu&scirc;o
        <fnt>
          <bib>I&scirc;tar</bib>
          <lok>&Ccirc;apitro 21a</lok>
        </fnt>;
      </ekz>
      <ekz>
        kovritaj, kvaza&ubreve; prujne, per suker&#8217;-<tld/>etoj
        <fnt>
          <bib>SrT</bib>
          <lok>Libro 12a</lok>
        </fnt>;
      </ekz>
      <ekz>
        <tld/>o, kovrita de &ccirc;okolado
        <fnt>
          <bib>Monato</bib>
          <aut>Walter Klag</aut>
          <vrk><url ref="&Monato;/2013/010973.php">Bombo-bankroto</url></vrk>
          <lok>2013</lok>
        </fnt>;
      </ekz>
      <ekz>
        estingiloj <klr>[&#8230;]</klr> ofte uzas toksajn kemiajn <tld/>ojn
        <fnt>
          <bib>Monato</bib>
          <aut>Roberto Pigro</aut>
          <vrk><url ref="&Monato;/2015/011481.php">Estingi fajron per sonoj</url></vrk>
          <lok>2015</lok>
        </fnt>;
      </ekz>
      <ekz>
        subite li ekkrias, kaj <klr>[konvulsias]</klr> kun bu&scirc;a <tld/>o
        <fnt>
          <bib>NT</bib>
          <lok>&Luk; 9:39</lok>
        </fnt>;
      </ekz>
      <ekz>
        malaperos Samario kun sia re&gcirc;o, kiel <tld/>o sur la supra&jcirc;o de akvo
        <fnt>
          <bib>MT</bib>
          <lok>&Hos; 10:7</lok>
        </fnt>.
      </ekz>
    </dif>
    <ref tip="super" cel="disper.0ajxo.KEM">dispersa&jcirc;o</ref>
    <refgrp tip="vid">
      <ref cel="vin.sxauxm0o">&scirc;a&ubreve;mvino</ref>
    </refgrp>
    <trd lng="bg">&c_p;&c_ja;&c_n;&c_a;</trd>
    <trd lng="de">Schaum</trd>
    <trdgrp lng="en">
      <trd>foam</trd>,
      <trd>froth</trd>,
      <trd>mousse</trd>
    </trdgrp>
    <trd lng="es">espuma</trd>
    <trdgrp lng="fr">
      <trd>&eacute;cume</trd>,
      <trd>mousse</trd>
    </trdgrp>
    <trdgrp lng="hu">
      <trd>hab</trd>,
      <trd>tajt&eacute;k</trd>
    </trdgrp>
    <trd lng="io">spumo</trd>
    <trdgrp lng="it">
      <trd>schiuma</trd>,
      <trd>spuma</trd>
    </trdgrp>
    <trdgrp lng="ja">
      <trd>&#27873; <pr>&#12354;&#12431;</pr></trd>,
      <trd>&#12354;&#12406;&#12367;</trd>,
      <trd>&#27873;&#27819; <pr>&#12411;&#12358;&#12414;&#12388;</pr></trd>
    </trdgrp>
    <trd lng="nl">schuim</trd>
    <trd lng="pt">espuma</trd>
  </snc>
<!-- dubinda senco, PIV ne plu havas &gcirc;in,
sed aldonas kiel sencon FIG "efemera&jcirc;o, malsolida&jcirc;o"...
  <snc mrk="sxauxm.0o.FIG">
    <uzo tip="stl">FIG</uzo>
    <dif>
      Plej malbona, plej malestiminda parto:
      <ekz>
        <tld/>o de la socio
      </ekz>
    </dif>
    <refgrp tip="vid">
      <ref cel="bala.0ajxo">balaa&jcirc;o</ref>,
      <ref cel="fecx.0o">fe&ccirc;o</ref>,
      <ref cel="rub.0o">rubo</ref>,
      <ref cel="skori.0o">skorio</ref>
    </refgrp>
    <trd lng="de">Abschaum</trd>
    <trdgrp lng="hu">
      <trd>s&ouml;pred&eacute;k</trd>,
      <trd>alja<klr tip="ind"> (pejorat&iacute;v)</klr></trd>
    </trdgrp>
    <trd lng="it">crema<klr> (fig.)</klr></trd>
  </snc>
-->
  <trd lng="be">&c_p;&c_je;&c_n;&c_a;</trd>
  <trdgrp lng="ca">
    <trd>escuma</trd>,
    <trd>bromera</trd>
  </trdgrp>
  <trdgrp lng="pl">
    <trd>piana</trd>,
    <trd>szumowiny</trd>
  </trdgrp>
  <trdgrp lng="pt">
    <trd>esc&oacute;ria</trd>,
    <trd>ral&eacute;</trd>
  </trdgrp>
  <trd lng="ru">&c_p;&c_je;&c_n;&c_a;</trd>
  <trdgrp lng="uk">
    <trd>&c_p;&c_ib;&c_n;&c_a;</trd>,
    <trd>&c_sh;&c_u;&c_m;</trd>,
    <trd>&c_sh;&c_u;&c_m;&c_o;&c_v;&c_i;&c_n;&c_n;&c_ja;</trd>
  </trdgrp>
  <trdgrp lng="zh">
    <trd>&#x6CAB; <pr>m&#xF2;</pr></trd>,
    <trd>&#x6CE1;&#x6CAB; <pr>p&#xE0;om&#xF2;</pr></trd>,
    <trd>&#x80A5;&#30338;&#x6CAB; <pr>f&#xE9;iz&#xE0;om&#xF2;</pr></trd>
  </trdgrp>
</drv>

<drv mrk="sxauxm.0i">
  <kap><tld/>i</kap>
  <gra><vspec>ntr</vspec></gra>
  <snc mrk="sxauxm.0i.KOMUNE">
    <dif>
      Formi <tld/>on el si:
      <ekz>
        la vino <tld/>as, plena de aroma&jcirc;o
        <fnt>
          <bib>MT</bib>
          <lok>&Psa; 75:8</lok>
        </fnt>;
      </ekz>
      <ekz>
        maljuna biero <tld/>is en glasoj
        <fnt>
          <bib>Fab3</bib>
          <lok>&Ccirc;io sur sian &gcirc;ustan lokon!</lok>
        </fnt>;
      </ekz>
      <ekz>
        <uzo tip="stl">FIG</uzo>
        li <tld/>as <klr>(pro furiozo)</klr> kaj grincigas la dentojn
        <fnt>
          <bib>NT</bib>
          <lok>&Mar; 9:18</lok>
        </fnt>;
      </ekz>
      <ekz>
        la maro <tld/>is kaj <tld/>is de la senforta kolero
        <fnt>
          <bib>FdO</bib>
        </fnt>;
      </ekz>
      <ekz>
        la potoj <tld/>is, ondi&gcirc;is, transbolis
        <fnt>
          <bib>Fab3</bib>
          <lok>Supo el kolbasaj bastonetoj</lok>
        </fnt>;
      </ekz>
      <ekz>
        fulgokovrita poto <tld/>is kaj vaporis super la flamanta kenfajro
        <fnt>
          <bib>HsT</bib>
          <lok>Feli&ccirc;a homo</lok>
        </fnt>;
      </ekz>
      <ekz>
        <uzo tip="stl">FIG</uzo>
        <klr>[ili]</klr> trafe nomi&gcirc;as &leftquot;<ind><tld/>isto</ind>j&rightquot;
        <klr>(kp <ref cel="fanfar1.0i">fanfaroni</ref>, <ref
        cel="pav.0i.FIG">pavi<sncref/></ref>)</klr>,
        oni legas ekzemple, ke
        <klr>[&#8230;]</klr> ni povis renkonti nur vic-konestablon <klr>[&#8230;]</klr> kaj
        &ccirc;efpromulgiston
        <fnt>
          <bib>LOdE</bib>
          <lok>2003, &#8470; 8-9 (106-107)</lok>
        </fnt>.
        <trd lng="de">Schaumschl&auml;ger</trd>
        <trd lng="en">hot-air merchant</trd>
      </ekz>
    </dif>
    <trdgrp lng="en">
      <trd>foam</trd>,
      <trd>spume</trd>,
      <trd>fizz</trd>
    </trdgrp>
    <trd lng="io">spumifar</trd>
    <trd lng="ja">&#27873;&#31435;&#12388; <pr>&#12354;&#12431;&#12384;&#12388;</pr></trd>
    <trdgrp lng="nl">
      <trd>schuimen</trd>,
      <trd>bruisen</trd>,
      <trd>mousseren</trd>
    </trdgrp>
  </snc>
  <snc mrk="sxauxm.0i.FIG">
    <uzo tip="stl">FIG</uzo>
    <dif>
      Tre <ref tip="super" cel="vigl.0i.KOMUNE">vigli</ref>,
      <ref tip="dif" cel="bol.0i.fervori">boli<sncref/></ref>:
      <ekz>
        la viv&gcirc;ojo <tld/>is en la templo de la dioj
        <fnt>
          <bib>RBa</bib>
          <lok>&Ccirc;apitro 3a</lok>
        </fnt>;
      </ekz>
      <ekz>
        la fluo de homaj vivoj <tld/>as kaj bruas pli intense ol alie
        <fnt>
          <bib>Tor</bib>
          <lok>5</lok>
        </fnt>;
      </ekz>
      <ekz>
        ekkriis <nom>Margarita</nom> a&ubreve;skultante la valson <tld/>i en la strateto
        <fnt>
          <bib>MkM</bib>
          <lok>20</lok>
        </fnt>.
      </ekz>
    </dif>
    <refgrp tip="vid">
      <ref cel="energi.0a">energia</ref>,
      <ref cel="suk.0a.FIG">suka<sncref/></ref>
    </refgrp>
    <trd lng="ja">&#27832;&#12365;&#31435;&#12388; <pr>&#12431;&#12365;&#12384;&#12388;</pr></trd>
    <trd lng="nl">bruisen</trd>
  </snc>
  <trd lng="be">&c_p;&c_je;&c_n;&c_ib;&c_c;&c_c;&c_a;</trd>
  <trd lng="ca">escumejar</trd>
  <trd lng="de">sch&auml;umen</trd>
  <trd lng="es">espumar</trd>
  <trdgrp lng="fr">
    <trd>&eacute;cumer<klr> (mousser)</klr></trd>,
    <trd>mousser</trd>
  </trdgrp>
  <trd lng="hu">habzik</trd>
  <trdgrp lng="it">
    <trd>schiumare</trd>,
    <trd>spumeggiare</trd>
  </trdgrp>
  <trdgrp lng="pl">
    <trd>pieni&cacute; si&eogonek;</trd>,
    <trd>kipie&cacute;</trd>,
    <trd>wrze&cacute;</trd>
  </trdgrp>
  <trd lng="pt">espumar</trd>
  <trd lng="ru">&c_p;&c_je;&c_n;&c_i;&c_t;&c_mol;&c_s;&c_ja;</trd>
  <trdgrp lng="uk">
    <trd>&c_sh;&c_u;&c_m;&c_u;&c_v;&c_a;&c_t;&c_i;</trd>,
    <trd>&c_p;&c_ib;&c_n;&c_i;&c_t;&c_i;&c_s;&c_ja;</trd>,
    <trd>&c_p;&c_ib;&c_n;&c_i;&c_t;&c_i;&c_s;&c_ja;</trd>,
    <trd>&c_k;&c_i;&c_p;&c_ib;&c_t;&c_i;</trd>,
    <trd>&c_b;&c_i;&c_t;&c_i; &c_k;&c_l;&c_ju;&c_ch;&c_je;&c_m;</trd>
  </trdgrp>
  <trdgrp lng="zh">
    <trd>&#x8D77;&#x6CE1; <pr>q&#x1D0;p&#xE0;o</pr></trd>,
    <trd>&#x8D77;&#x6CE1;&#x6CAB; <pr>q&#x1D0;p&#xE0;om&#xF2;</pr></trd>,
    <trd>&#x53D1;&#x6CE1; <pr>f&amacron;p&#xE0;o</pr></trd>,
    <trd>&#x767C;&#x6CE1; <pr>f&amacron;p&#xE0;o</pr></trd>
  </trdgrp>
</drv>

<drv mrk="sxauxm.0ajxo">
  <kap><tld/>a&jcirc;o</kap>
  <snc mrk="sxauxm.0ajxo.KUI">
    <uzo tip="fak">KUI</uzo>
    <dif>
      <tld lit="&Scirc;"/>igita man&gcirc;a&jcirc;o:
    </dif>
    <subsnc>
      <dif>
        dol&ccirc;a deserto, kutime el ovo kaj kremo <tld/>igitaj:
        <ekz>
          ni iru al glutejo kaj festu la renkonton per <tld/>a&jcirc;o
          <fnt>
            <bib>KrM</bib>
          </fnt>.
        </ekz>
      </dif>
    </subsnc>
    <subsnc>
      <dif>
        nedol&ccirc;a man&gcirc;a&jcirc;o, ofte el gelateno <tld/>igita.
      </dif>
    </subsnc>
    <trd lng="en">mousse<klr tip="amb"> (food)</klr></trd>
    <trd lng="ja">&#12512;&#12540;&#12473;</trd>
    <trd lng="nl">mousse<klr tip="amb"> (eten)</klr></trd>
  </snc>
  <snc>
    <dif>
      Materialo el solidi&gcirc;inta <tld/>o:
      <ekz>
        vinilon kaj polistirenan <tld/>a&jcirc;on erare man&gcirc;os fi&scirc;oj, <klr>[...]</klr> kaj pro tio multe
        da ili mortos
        <fnt>
          <aut>ISIKAWA Takasi</aut>,
          <vrk><url ref="&Monato;/2012/010800.php">Alflosa&jcirc;oj trans la oceano</url></vrk>,
          <bib>Monato</bib>,
          <lok>2012/10, p. 26</lok>
        </fnt>.
      </ekz>
    </dif>
    <trd lng="en">foam</trd>
    <trdgrp lng="ja">
      <trd>&#30330;&#27873;&#20307; <pr>&#12399;&#12387;&#12413;&#12358;&#12383;&#12356;</pr></trd>,
      <trd>&#12501;&#12457;&#12540;&#12512;</trd>
    </trdgrp>
    <trd lng="nl">schuim</trd>
  </snc>
  <adm>rapide verkitaj difinoj, ver&scirc;ajne ankora&ubreve; plibonigindaj</adm>
</drv>

<drv mrk="sxauxm.0igi">
  <kap><tld/>igi</kap>
  <gra><vspec>tr</vspec></gra>
  <snc mrk="sxauxm.0igi.KOMUNE">
    <dif>
      Ka&ubreve;zi <tld/>on en iu substanco:
      <ekz>
        la barbiro, prenis sian pladeton kaj sapon, <tld/>igis &gcirc;in
        <fnt>
          <bib>ElektFab</bib>
          <lok>Tri fratoj</lok>
        </fnt>,
      </ekz>
      <ekz>
        jen oni purigas la bovlojn, la ilojn, jen boligas kaj ver&scirc;as akvon, jen <tld/>igas la teon
        <fnt>
          <aut>&Jcirc;enja Amis</aut>,
          <vrk>Mia malkovro de Japanio</vrk>,
          <bib>Kon11</bib>,
          <lok>numero 254 (2013:2)</lok>
        </fnt>,
      </ekz>
      <ekz>
        super la senarban rokplata&jcirc;on preska&ubreve; &ccirc;iam blovas frosta vento, <tld/>iganta la maron
        kontra&ubreve; la kruta deklivo 307 m alta
        <fnt>
          <aut>Saliko</aut>,
          <vrk><url ref="&Monato;/2015/011433.php">Krozi la&ubreve; la norvega marbordo</url></vrk>,
          <bib>Monato</bib>,
          <lok>2015/11, p. 18</lok>
        </fnt>.
      </ekz>
    </dif>
  </snc>
  <trd lng="de">aufsch&auml;umen</trd>
  <trd lng="en">froth</trd>
  <trd lng="fr">faire mousser</trd>
  <trd lng="ja">&#27873;&#31435;&#12383;&#12379;&#12427; <pr>&#12354;&#12431;&#12384;&#12383;&#12379;&#12427;</pr></trd>
  <trd lng="nl">opschuimen</trd>
</drv>
</art>
