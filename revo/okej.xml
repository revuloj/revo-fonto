<?xml version="1.0"?>
<!DOCTYPE vortaro SYSTEM "../dtd/vokoxml.dtd">
<vortaro>
<art mrk="$Id: okej.xml,v 1.8 2026/06/08 23:25:11 revo Exp $">
<kap>
    <rad>okej</rad>,
  <var><kap><rad var="o">o kej</rad></kap></var>
</kap>
<drv mrk="okej.0">
  <kap><tld/>, <var><kap><tld var="o"/></kap></var></kap>
  <gra><vspec>ekkrio</vspec></gra>
  <snc>
    <dif>
      <ref tip="sin" cel="bon.0e">Bone</ref>, konsentite,
      <ref tip="sin" cel="ord.en0o">en ordo</ref>:
      <ekz>
        <tld/>, mi komprenas
        <fnt>
          <aut>Sequoia Edwards</aut>
          <vrk>La Chinuka Interlingvo Per Esperanto</vrk>
          <lok>pa&gcirc;o 40a</lok>
        </fnt>;
      </ekz>
      <ekz>
        - do, &ccirc;u ni iru?
        - <tld/>!
        <fnt>
          <aut>Lode Van de Velde</aut>
          <vrk>Aspiroj</vrk>
          <lok>pa&gcirc;o 157a</lok>
        </fnt>;
      </ekz>
      <ekz>
        <tld var="o"/>, la manon al vi mi cedas
        <fnt>
          <aut>Paulo Silas</aut>
          <vrk><url
          ref="https://books.google.nl/books?id=K5k9CQAAQBAJ&amp;pg=PA61&amp;q=o%20kej#v=onepage">Responde
          al Nicola Ruggiero</url></vrk>
        </fnt>.
      </ekz>
    </dif>
  </snc>
  <rim>
    <nom>Bertilo Wennergren</nom> skribis en Plena Manlibro de
    Esperanta Gramatiko, ke la literumo <em>okej</em> estas erara kaj
    oni devus skribi <em>o kej</em>, &ccirc;ar oni &ccirc;iam efektive elparolas
    la vorton kun akcento je la lasta silabo.
    <fnt>
      <aut>Bertilo Wennergren</aut>
      <vrk>Plena Manlibro de Esperanta Gramatiko</vrk>
      <lok><url ref="&PMEG;gramatiko/ekkrioj_sonimitoj/elparolado_skribado.html">18.4. Elparolado
      kaj skribado de ekkriaj vortetoj kaj
        sonimitoj</url></lok>
    </fnt>
  </rim>
  <rim>
    Konsiderinda kvanto da esperantistoj evitas &ccirc;i tiun vorton, kaj
    preferas anstata&ubreve;e uzi diversajn alternativojn. La&ubreve; <fnt><bib>BL</bib></fnt>:
    Prefere diru <ke>en ordo!</ke>, <ke>enorde!</ke>, <ke>jes!</ke>, <ke>&gcirc;uste!</ke>.
  </rim>

  <trd lng="ar">&a_A_hamza_sure;&a_w;&a_k;&a_y;</trd>
  <trdgrp lng="be">
    <trd>&c_a;&c_k;&c_e;&c_j;!</trd>,
    <trd>&c_d;&c_o;&c_b;&c_r;&c_a;!</trd>
  </trdgrp>
  <trdgrp lng="de">
    <trd>OK</trd>,
    <trd>okay</trd>
  </trdgrp>
  <trdgrp lng="en">
    <trd>OK</trd>,
    <trd>okay</trd>
  </trdgrp>
  <trd lng="es">okey</trd>
  <trdgrp lng="fr">
    <trd>OK</trd>,
    <trd>d'ac</trd>
  </trdgrp>
  <trd lng="he">&alef;&vav;&qof;&yod;&yod;</trd>
  <trdgrp lng="ja">
    <trd>&#12458;&#12540;&#12465;&#12540;</trd>,
    <trd>&#12458;&#12483;&#12465;&#12540;</trd>,
    <trd>&#12424;&#12375;</trd>
  </trdgrp>
  <trd lng="nl">ok&eacute;</trd>
  <trd lng="pl">okej</trd>
  <trd lng="ru">&c_o;&c_k;&c_je;&c_j;</trd>
  <trdgrp lng="zh">
    <trd>&#19981;&#24046; <pr>b&ugrave;ch&agrave;</pr></trd>,
    <trd>&#22909;&#21834; <pr>h&#462;o&agrave;</pr></trd>,
    <trd>&#34892; <pr>x&iacute;ng</pr></trd>,
    <trd>&#20446; <pr>y&uacute;</pr></trd>,
    <trd>&#35469;&#21487; <pr>r&egrave;nk&ecaron;</pr></trd>,
    <trd>&#35748;&#21487; <pr>r&egrave;nk&ecaron;</pr></trd>,
    <trd>&#22909;&#21862; <pr>h&#462;ola</pr></trd>
  </trdgrp>
</drv>

<drv mrk="okej.0i">
  <kap><tld/>i</kap>
  <gra><vspec>ntr</vspec></gra>
  <snc>
    <dif>
      Esti en ordo, akceptebla, senproblema, permesita:
      <ekz>
        kompreneble mi pensis ke <tld/>as eliri
        <fnt>
          <aut>Christin Granat</aut>
          <vrk>Al la &#8221;Guchoj&#8221; kaj la malsanuleja sekcio 357</vrk>
          <lok><url
          ref="https://www.esperanto-gbg.org/oraklubo/Ora_Jxurnalo_n-ro_39.pdf#page=18">Ora &Jcirc;urnalo,
          numero 39</url>, aprilo 2021, p.18</lok>
        </fnt>;
      </ekz>
      <ekz>
        A kaj B <tld/>as, sed la C estas superflua
        <fnt>
          <aut>Siv Burell</aut>
          <vrk>Espeporko meditas</vrk>
          <lok><url ref="https://www.esperanto-gbg.org/80/#L3">Ora &Jcirc;urnalo, numero 80</url>, januaro
          2025</lok>
        </fnt>;
      </ekz>
      <ekz>
         &ccirc;u uzi <nac>OK</nac> <tld/>as?
        <fnt>
          <aut>USUI Hiroyuki</aut>
          <vrk><url ref="http://espero.chinareports.org.cn/2017-07/03/content_41139901.htm">Bye-bye,
          hello, OK, sorry kaj e&ccirc; mini: en la &ccirc;ina pli kaj pli multi&gcirc;as anglaj
          pruntvortoj</url></vrk>
          <bib>EP&Ccirc;</bib>
          <lok>2017-07-03</lok>
        </fnt>.
      </ekz>
    </dif>
    <trd lng="en">to be <ind>OK</ind><klr tip="amb"> (acceptable, permitted)</klr></trd>
    <trd lng="nl">ok&eacute; zijn</trd>
  </snc>
</drv>

</art>

