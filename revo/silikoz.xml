<art mrk="$Id: silikoz.xml,v 1.13 2026/05/01 16:00:22 revo Exp $">
<kap>
  <rad>silikoz</rad>/o <fnt><bib>PIV1</bib></fnt>
</kap>
<drv mrk="silikoz.0o">
  <kap><tld/>o</kap>
  <snc mrk="silikoz.0o.MED">
    <uzo tip="fak">MED</uzo>
    <dif>
     <ref tip="lst" cel="san.mal0o" lst="voko:malsanoj">Malsano</ref>
      ka&ubreve;zita de enspiro de silica, karba a&ubreve; alia &scirc;tona polvo,
      rezultanta plejofte en kronika pulm-inflamo:
      <ekz>
        ili fari&gcirc;is &gcirc;ibuloj kaj <tld/>uloj
        <fnt><aut>Robert Roze</aut>,
        <vrk><url ref="&Monato;/2000/006945.php">Flagrantaj koloroj</url></vrk>,
        <bib>Monato</bib>,
        <lok>2000/06, p. 17</lok>
        </fnt>;
      </ekz>
      <ekz>
        tiu suferas de la malsano <tld/>o kiel multaj 
        ministoj en suda kimrio kiuj dum la tuta kariero enspiris 
        karban polvon
        <fnt>
          <aut>Eriketo</aut>,
          <vrk>Kimrangla...</vrk>,
          <lok><url ref="http://eriketo.blogspot.com">[blogo]</url>, 
          2008-06-30</lok>
        </fnt>.
      </ekz>
    </dif>
  </snc>
  <trd lng="be">&c_s;&c_y;&c_l;&c_ib;&c_k;&c_o;&c_z;</trd>
  <trd lng="ca">silicosi</trd>
  <trdgrp lng="de">
    <trd>Quarzstaublunge</trd>,
    <trd>Silikose</trd>
  </trdgrp>
  <trd lng="en">silicosis</trd>
  <trd lng="es">silicosis</trd>
  <trd lng="fr">silicose</trd>
  <trd lng="id">silikosis</trd>
  <trd lng="ja">&#29674;&#32954;  <pr>&#12369;&#12356;&#12399;&#12356;</pr></trd>
  <trdgrp lng="pl">
    <trd>pylica krzemowa</trd>,
    <trd>krzemica</trd>
  </trdgrp>
  <trd lng="uk">&c_s;&c_i;&c_l;&c_ib;&c_k;&c_o;&c_z;</trd>
  <trdgrp lng="zh">
    <trd>&#30707;&#26411;&#32954; <pr>sh&iacute;m&ograve;f&egrave;i</pr></trd>,
    <trd>&#30952;&#24037;&#30149; <pr>m&ograve;g&#333;ngb&igrave;ng</pr></trd>,
    <trd>&#30707;&#21280;&#30184; <pr>sh&iacute;ji&agrave;ngl&aacute;o</pr></trd>,
    <trd>&#30707;&#21280;&#30278; <pr>sh&iacute;ji&agrave;ngl&aacute;o</pr></trd>,
    <trd>&#30707;&#26411;&#27785;&#30528;&#30149; <pr>sh&iacute;m&ograve;ch&eacute;nzhu&oacute;b&igrave;ng</pr></trd>,
    <trd>&#30707;&#26411;&#27785;&#33879;&#30149; <pr>sh&iacute;m&ograve;ch&eacute;nzhu&oacute;b&igrave;ng</pr></trd>,
    <trd>&#30717;&#26411;&#30149; <pr>x&#299;m&ograve;b&igrave;ng</pr></trd>,
    <trd>&#30717;&#32954; <pr>x&#299;f&egrave;i</pr></trd>,
    <trd>&#30717;&#32954;&#30149; <pr>x&#299;f&egrave;ib&igrave;ng</pr></trd>,
    <trd>&#30789;&#32954;&#30149; <pr>gu&#299;f&egrave;ib&igrave;ng</pr></trd>
  </trdgrp>
</drv>
