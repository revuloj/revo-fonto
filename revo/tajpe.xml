<?xml version="1.0"?>
<!DOCTYPE vortaro SYSTEM "../dtd/vokoxml.dtd">
<vortaro>
<art mrk="$Id: tajpe.xml,v 1.8 2026/07/09 15:34:11 afido Exp $">
<kap>
      <rad>Tajpe</rad>/o <fnt><bib>PIV1</bib></fnt>,
      <var><kap><rad var="ej">Tajpej</rad>/o</kap></var>
</kap>

<drv mrk="tajpe.0o">
  <kap><tld/>o, <var><kap><tld var="ej"/>o</kap></var></kap>
  <snc mrk="tajpe.0o.GEOG">
    <uzo tip="fak">GEOG</uzo>
    <dif>
      La <ref tip="lst" lst="voko:&ccirc;efurboj" cel="urb.cxef0o.POL">&ccirc;efurbo</ref>
      de <ref tip="malprt" cel="tajvan.0o.sxtato">Tajvano</ref>:
      <ekz>
        <tld/>on <klr>[&#8230;]</klr> &ccirc;irka&ubreve;as du riveroj, la Kilungo kaj la &Scirc;indjano
        <fnt>
          <bib>Viki</bib>
          <vrk><url ref="&Viki;/Tajpeo">Tajpeo</url></vrk>
          <lok>2026-06-05</lok>
        </fnt>;
      </ekz>
      <ekz>
        kun Esperantistoj el Indonezio <klr>[&#8230;]</klr> en <tld/>o
        <fnt>
          <aut>Perdi&gcirc;ulo</aut>
          <vrk><url ref="https://www.youtube.com/watch?v=-jMyj2h8sts">Eta Renkonti&gcirc;o kun
          Esperantistoj en Tajpeo</url></vrk>
          <lok>2018</lok>
        </fnt>;
      </ekz>
      <ekz>
         vizito al <tld var="ej"/>o
        <fnt>
          <aut>J. M. Werdin</aut>
          <vrk><url ref="https://www.youtube.com/watch?v=Hdyd9Q6F28M">Vizito al Tajpejo</url></vrk>
          <lok>youtube, 2023</lok>
        </fnt>;
      </ekz>
      <ekz>
        manifestacio en <tld var="ej"/>o
        <fnt>
          <aut>-</aut>
          <vrk><url
          ref="https://eo.wikipedia.org/wiki/Milito_de_Rusio_kontra%C5%AD_Ukrainio_ekde_2022">
          Milito de Rusio kontra&ubreve; Ukrainio ekde 2022</url></vrk>
          <lok>Vikipedio, 2026-05-25</lok>
        </fnt>.
      </ekz>
    </dif>
  </snc>
    <trd lng="be">&c_T;&c_a;&c_j;&c_b;&c_e;&c_j;</trd>
    <trd lng="de">Taipeh</trd>
    <trd lng="en">Taipeh</trd>
    <trd lng="fr">Taipeh</trd>
    <trd lng="ja">&#x30BF;&#x30A4;&#x30DA;&#x30A4;</trd>
    <trd lng="pl">Tajpej</trd>
    <trd lng="uk">&c_T;&c_a;&c_j;&c_b;&c_je;&c_j; (&c_s;&c_t;&#x43E;&#x43B;&c_i;&c_c;&#x44F;)</trd>
  <trdgrp lng="zh">
    <trd>&#x53F0;&#21271; <pr>T&#xE1;ib&#x11B;i</pr></trd>,
    <trd>&#x81FA;&#21271; <pr>T&#xE1;ib&#x11B;i</pr></trd>
  </trdgrp>
</drv>
  </art>

