<kap>
  <rad>paled</rad>/o
</kap>
<drv mrk="paled.0o">
  <kap><tld/>o</kap>
  <fnt><bib>KrDE</bib></fnt>
  <fnt><bib>KrED</bib></fnt>
  <fnt><bib>TK</bib></fnt>
  <snc mrk="paled.0o.TRA">
    <uzo tip="fak">TRA</uzo>
    <dif>
      Plata framo, plej ofte el ligno, por stakado kaj transporto de
      komerca&jcirc;oj, subveturebla per forka &ccirc;arelo:
      <ekz>
        la dimensioj de normitaj <tld/>oj estas 1000 mm x 1200 mm (ISO) 
        kaj 800 mm x 1200 mm (CEN);        
      </ekz>
      <ekz>
        halego el normaj <tld/>oj
        <fnt>
          <aut>R. R&ouml;ssler-Buckel</aut>,
          <vrk>Metio kaj Formo...</vrk>,
          <bib>Monato</bib>,
          <lok>jaro 2007a, numero 6a, p. 19-21a</lok>
        </fnt>.
      </ekz>
    </dif>
  </snc>
  <trd lng="be">&c_p;&c_a;&c_d;&c_d;&c_o;&c_n;</trd>
  <trdgrp lng="ca">
    <trd>palet</trd>,
    <trd>paleta</trd>
  </trdgrp>
  <trdgrp lng="cs">
    <trd>manipula&ccaron;n&iacute; paleta</trd>,
    <trd>ploch&aacute; paleta</trd>
  </trdgrp>
  <trdgrp lng="de">
    <trd>Palette</trd>,
    <trd>Transportpalette</trd>
  </trdgrp>
  <trd lng="en">pallet</trd>
  <trd lng="es">pal&eacute;</trd>
  <trd lng="fr">palette</trd>
  <trd lng="hu">raklap</trd>
  <trdgrp lng="ja">
    <trd>&#12497;&#12524;&#12483;&#12488;</trd>,
    <trd>&#33655;&#36939;&#12403;&#21488;  <pr>&#12395;&#12399;&#12371;&#12403;&#12384;&#12356;</pr></trd>
  </trdgrp>
  <trdgrp lng="nl">
    <trd>pallet</trd>,
    <trd>laadbord</trd>
  </trdgrp>
  <trd lng="pl">paleta</trd>
  <trd lng="sk">manipula&ccaron;n&aacute; paleta</trd>
  <trd lng="uk">&c_p;&c_ib;&c_d;&c_d;&c_o;&c_n;</trd>
  <trdgrp lng="zh">
    <trd>&#25176;&#30424; <pr>tu&#333;p&aacute;n</pr></trd>,
    <trd>&#25176;&#30436; <pr>tu&#333;p&aacute;n</pr></trd>,
    <trd>&#26632;&#26495; <pr>zh&agrave;nb&#462;n</pr></trd>,
    <trd>&#26855;&#26495; <pr>zh&agrave;nb&#462;n</pr></trd>,
    <trd>&#36008;&#30436; <pr>hu&ograve;p&aacute;n</pr></trd>,
    <trd>&#36135;&#30424; <pr>hu&ograve;p&aacute;n</pr></trd>,
    <trd>&#25176;&#26495; <pr>tu&#333;b&#462;n</pr></trd>,
    <trd>&#35351;&#26495; <pr>tu&#333;b&#462;n</pr></trd>
  </trdgrp>
