<?xml version="1.0"?>
<!DOCTYPE vortaro SYSTEM "../dtd/vokoxml.dtd">
<vortaro>
<art mrk="$Id: sardel.xml,v 1.26 2026/04/21 08:00:21 revo Exp $">
<kap>
  <ofc>*</ofc>
  <rad>sardel</rad>/o <fnt><bib>UV</bib></fnt>,
  <var><kap><rad var="e">engra&ubreve;l</rad>/o
  <fnt><bib>JED</bib></fnt></kap></var>
</kap>
<drv mrk="sardel.0o">
  <kap><ofc>*</ofc><tld/>o, <var><kap><tld var="e"/>o</kap></var></kap>
  <snc mrk="sardel.0o.ZOO">
    <uzo tip="fak">ZOO</uzo>
    <uzo tip="fak">KUI</uzo>
    <dif>
      <ref tip="lst" cel="fisx.mar0o" lst="voko:fi&scirc;oj">Marfi&scirc;o</ref>
      relative malgranda inter 10&nbsp;cm kaj 20&nbsp;cm, kun mallar&gcirc;a
      longa
      korpo, vivanta en grandaj svarmoj,
      kies unu specion ()
      estas man&gcirc;ebla, sed havas iom akre amaran guston,
      pro kio &gcirc;i estas preparata kiel <ref cel="ancxov.0o">an&ccirc;ovo</ref>;
      <ref tip="lst" cel="genr.0o.BIO" lst="voko:zoologiaj_genroj">genro</ref> el la ordo <ref
      tip="malprt" cel="klupe.0oformaj">klupeoformaj</ref>
      ():
      <ekz>
        ili kunpremi&gcirc;is simile al <tld/>oj
        <fnt>
          <aut>H. Heine, trad. L. L. Zamenhof</aut>
          <vrk>La Rabeno de Ba&hcirc;ara&hcirc;</vrk>,
          <lok>1929</lok>
        </fnt>;
      </ekz>
      <ekz>
        Gastono englutis unuan <tld/>on, kaj duan, kaj trian, sin interrompante nur por
        trinki
        <fnt>
          <bib>KPr</bib>
          <lok>&Ccirc;apitro Dekoka</lok>
        </fnt>;
      </ekz>
      <ekz>
        oni faras la fi&scirc;farunon kaj fi&scirc;oleon &ccirc;efe el grasaj fi&scirc;aj specioj kiel el
        engra&ubreve;lo, haringo, sardino
        <fnt>
          <bib>Viki</bib>
          <lok><url ref="https://eo.wikipedia.org/?curid=87287"
              >Fi&scirc;faruno</url></lok>
        </fnt>.
      </ekz>
    </dif>
    <ref tip="vid" cel="ancxov.0o">an&ccirc;ovo</ref>
  </snc>
  </drv>
</art>
