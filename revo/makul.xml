<?xml version="1.0"?>
<!DOCTYPE vortaro SYSTEM "../dtd/vokoxml.dtd">
<vortaro>
<art mrk="$Id: makul.xml,v 1.51 2026/06/11 10:57:50 revo Exp $">
<kap>
  <ofc>*</ofc>
  <rad>makul</rad>/o <fnt><bib>UV</bib></fnt>
</kap>
<drv mrk="makul.0o">
  <kap><ofc>*</ofc><tld/>o</kap>
  <snc mrk="makul.0o.KOMUNE">
    <dif>
      Hazarda alikolora&jcirc;o sur io.
    </dif>
    <subsnc mrk="makul.0o.malpurajxo">
      <dif>
        Malpurigita a&ubreve; difektita loko sur io:
        <ekz>
          <ind>sang<tld/>o</ind>
          <fnt>
            <bib>IdO</bib>
            <lok>Tria Parto</lok>
          </fnt>;
          <trd lng="de">Blutfleck</trd>
          <trd lng="id">bercak darah</trd>
        </ekz>
        <ekz>
          nigra <ind>ink<tld/>o</ind>
          <fnt>
            <bib>IdO</bib>
            <lok>Kvina Parto</lok>
          </fnt>;
          <trd lng="de">Tintenfleck</trd>
          <trd lng="id">bercak tinta</trd>
        </ekz>
        <ekz>
          iom malzorge vestita kun kelkaj <ind>gras<tld/>o</ind>j sur la ve&scirc;to
          <fnt>
            <bib>MrA</bib>
            <lok>&Ccirc;apitro XIV</lok>
          </fnt>;
          <trd lng="de">Fettfleck</trd>
          <trd lng="id">bercak minyak</trd>
        </ekz>
        <ekz>
          sur la karno de la brulvundo aperos <tld/>o ru&gcirc;ete-blanka
          <fnt>
            <bib>MT</bib>
            <lok>Levidoj 13:24</lok>
          </fnt>;
        </ekz>
        <ekz>
          anstata&ubreve; beleco estos brul<tld/>oj
          <fnt>
            <bib>MT</bib>
            <lok>Jesaja 3:24</lok>
          </fnt>;
        </ekz>
        <ekz>
          dis&scirc;irita, gras<tld/>ita lana &ccirc;apo
          <fnt>
            <bib>FK</bib>
          </fnt>;
        </ekz>
        <ekz>
          ne&gcirc;<tld/>oj persistis sur la bruna, <klr>[&#x2026;]</klr> kaj verda tereno
          <fnt>
            <bib>KKr</bib>
            <lok>I</lok>
          </fnt>;
        </ekz>
        <ekz>
          tra la kordono videblis anka&ubreve; la du bril<tld/>oj sur la brusto de la centuriestro
          <fnt>
            <bib>MkM</bib>
            <lok>16</lok>
          </fnt>;
        </ekz>
        <ekz>
          tra amba&ubreve; fenestroj <klr>[&#x2026;]</klr> brilas la malalta suno <klr>[&#x2026;]</klr> kaj en
          &ccirc;i varmaj sun<tld/>oj saltas kaj dancas knabeto
          <fnt>
            <bib>Kiso</bib>
            <lok>La Brulanta Urbo</lok>
          </fnt>;
        </ekz>
        <ekz>
          vi spertis la koincidojn de la
          protuberancoj kaj de la sun<tld/>oj
          <fnt>
            <bib>VaK</bib>
            <lok>Dekoka &Ccirc;apitro</lok>
          </fnt>;
        </ekz>
        <ekz>
          e&ccirc; sur la suno trovi&gcirc;as <tld/>oj
          <fnt>
            <bib>PrV</bib>
          </fnt>.
        </ekz>
      </dif>
      <ref tip="vid" cel="pur.mal0ajxo">malpura&jcirc;o</ref>
      <trd lng="cs">skvrna</trd>
      <trd lng="de">Fleck</trd>
      <trdgrp lng="hu">
        <trd>folt</trd>,
        <trd>petty</trd>
      </trdgrp>
      <trdgrp lng="id">
        <trd>bercak</trd>,
        <trd>flek</trd>,
        <trd>noda</trd>,
        <trd>noktah</trd>
      </trdgrp>
      <trd lng="nl">vlek</trd>
      <trd lng="pl">plama</trd>
    </subsnc>
    <subsnc mrk="makul.0o.natura">
      <dif>
        Natura kolora <ref tip="super" cel="punkt.0o.makuleto">punkto</ref>:
        <ekz>
          sur &scirc;iaj <klr>[&#x2026;]</klr> vangoj aperis ru&gcirc;aj <tld/>oj
          <fnt>
            <bib>Marta</bib>
          </fnt>;
        </ekz>
        <ekz>
          oni lin konas, kiel <klr>[&#x2026;]</klr> <tld/>haran hundon
          <fnt>
            <bib>PrV</bib>
          </fnt>.
        </ekz>
      </dif>
      <trd lng="cs">skvrna</trd>
      <trdgrp lng="de">
        <trd>Fleck</trd>,
        <trd>Klecks</trd>,
        <trd>Tupfen</trd>
      </trdgrp>
      <trd lng="es">mancha</trd>
      <trdgrp lng="hu">
        <trd>folt</trd>,
        <trd>szepl&odblac;</trd>,
      </trdgrp>
      <trd lng="id">bintik</trd>
      <trd lng="nl">vlek</trd>
      <trd lng="pl">plama</trd>
    </subsnc>
  <trd lng="be">&c_p;&c_l;&c_ja;&c_m;&c_a;</trd>
  </snc>
  <snc mrk="makul.0o.FIG">
    <uzo tip="stl">FIG</uzo>
    <dif>
      Malbona, difektita punkto:
      <ekz>
        tio &jcirc;etas <tld/>on sur lian karakteron kaj elmetas lin al puno
        <fnt>
          <bib>Marta</bib>
        </fnt>;
      </ekz>
      <ekz>
        tio estis <klr>[&#x2026;]</klr> respekto al &scirc;ia sen<tld/>a pureco kaj nobla animo
        <fnt>
          <bib>IK</bib>
        </fnt>;
      </ekz>
      <ekz>
        oni metis <tld/>on en mian kalkulon
        <fnt>
          <bib>PrV</bib>
        </fnt>;
      </ekz>
      <ekz>
        &gcirc;i estas por mi <tld/>o en la okulo
        <klr>(<ref cel="gxen.0a">&gcirc;eno</ref>,
        ofendeto, <ref tip="vid" cel="ost.0o">osto</ref>)</klr>
        <fnt><bib>PrV</bib></fnt>;
      </ekz>
      <ekz>
        neniu sanktulo estas sen <tld/>o
        <fnt><bib>PrV</bib></fnt>.
      </ekz>
    </dif>
    <refgrp tip="sin">
      <ref cel="difekt.0o">difekto</ref>,
      <ref cel="mank.0o.difekto">manko<sncref/></ref>,
      <ref cel="mis.0ajxo">miso</ref>
    </refgrp>
    <trdgrp lng="be">
      <trd>&c_p;&c_l;&c_ja;&c_m;&c_a; <klr>(&c_p;&c_je;&c_r;&c_a;&c_n;.)</klr></trd>,
      <trd>&c_g;&c_a;&c_n;&c_mol;&c_b;&c_a;</trd>,
      <trd>&c_z;&c_mol;&c_n;&c_ja;&c_v;&c_a;&c_g;&c_a;</trd>
    </trdgrp>
    <trd lng="br">tarch</trd>
    <trdgrp lng="de">
      <trd>Schaden</trd>,
      <trd>Makel</trd>
    </trdgrp>
    <trdgrp lng="en">
      <trd>spot</trd>,
      <trd>stain</trd>
    </trdgrp>
    <trdgrp lng="hu">
      <trd>folt</trd>,
      <trd>makula</trd>
    </trdgrp>
    <trdgrp lng="id">
      <trd>aib</trd>,
      <trd>cacat</trd>,
      <trd>cela</trd>,
      <trd><baz>kurang</baz>kekurangan</trd>
    </trdgrp>
    <trd lng="nl">smet</trd>
    <trd lng="pl">skaza</trd>
  </snc>
  <snc mrk="makul.0o.MED">
    <uzo tip="fak">MED</uzo>
    <dif>
      Loka <ref tip="super" cel="makul.hauxt0o">ha&ubreve;t<tld/>o</ref>, sen reliefo nek penetrado,
      rezultanta el simpla
      modifi&gcirc;o de la ha&ubreve;ta koloro:
      <ekz>
        efelidoj estas etaj pigmentaj <tld/>oj
        <fnt>
          <aut>Vikipedio</aut>,
          <vrk><url ref="&Viki;/Efelido">Efelido</url></vrk>
        </fnt>.
      </ekz>
    </dif>
    <refgrp tip="vid">
       <ref cel="efelid.0o">efelido</ref>,
       <ref cel="hematom.0o">hematomo</ref>,
       <ref cel="lentug.0o.MED">lentugo</ref>,
       <ref cel="sang.0umo">sangumo</ref>
    </refgrp>
    <trd lng="be">&c_p;&c_l;&c_ja;&c_m;&c_a;</trd>
    <trd lng="de">Macula</trd>
    <trd lng="en">macule</trd>
    <trd lng="fr">macule</trd>
    <trd lng="id">makula</trd>
    <trd lng="pl">plama</trd>
  </snc>
  <trd lng="bg">&c_p;&c_je;&c_t;&c_n;&c_o;</trd>
  <trd lng="cs">skvrna, ka&ncaron;ka</trd>
  <trd lng="fa">&a_l;&f_k;&a_h;</trd>
  <trd lng="fr">tache</trd>
  <trdgrp lng="ja">
    <trd>&#x3057;&#x307F;</trd>,
    <trd>&#x3088;&#x3054;&#x308C;</trd>,
    <trd>&#x6591;&#x70B9;  <pr>&#x306F;&#x3093;&#x3066;&#x3093;</pr></trd>,
    <trd>&#x6591;&#x7D0B;  <pr>&#x306F;&#x3093;&#x3082;&#x3093;</pr></trd>,
    <trd>&#x3076;&#x3061;</trd>,
    <trd>&#x6C5A;&#x70B9;  <pr>&#x304A;&#x3066;&#x3093;</pr></trd>
  </trdgrp>
  <trd lng="ne">&#x938;&#x94D;&#x925;&#x93E;&#x928;</trd>
  <trdgrp lng="pl">
    <trd>plama</trd>,
    <trd>skaza</trd>,
    <trd>zaka&lstroke;a</trd>
  </trdgrp>
  <trdgrp lng="pt">
    <trd>mancha</trd>,
    <trd>n&oacute;doa</trd>,
    <trd>m&aacute;cula</trd>
  </trdgrp>
  <trdgrp lng="ro">
    <trd>pat&abreve;</trd>,
    <trd>defect</trd>
  </trdgrp>
  <trd lng="ru">&c_p;&c_ja;&c_t;&c_n;&c_o;</trd>
  <trdgrp lng="sk">
    <trd>f&lcaron;ak</trd>,
    <trd>machu&lcaron;a</trd>,
    <trd>&scaron;kvrna</trd>
  </trdgrp>
  <trd lng="sv">fl&auml;ck</trd>
  <trd lng="tr">leke</trd>
  <trd lng="uk">&c_p;&c_l;&c_ja;&c_m;&c_a;</trd>
  <trdgrp lng="zh">
    <trd>&#x6591; <pr>b&amacron;n</pr></trd>,
    <trd>&#x6591;&#x70B9; <pr>b&amacron;ndi&#x1CE;n</pr></trd>,
    <trd>&#x6591;&#x9EDE; <pr>b&amacron;ndi&#x1CE;n</pr></trd>,
    <trd>&#x73B7; <pr>di&agrave;n</pr></trd>,
    <trd>&#x7455; <pr>xi&aacute;</pr></trd>,
    <trd>&#x75B5; <pr>c&imacron;</pr></trd>,
    <trd>&#x8272;&#x6591; <pr>s&egrave;b&amacron;n</pr></trd>
  </trdgrp>
</drv>

<drv mrk="makul.0i">
  <kap><tld/>i</kap>
  <gra><vspec>tr</vspec></gra>
  <snc mrk="makul.0i.KOMUNE">
    <dif>
      Fari <tld/>ojn sur io:
      <ekz>
        iliaj vestoj estis dis&scirc;iritaj, <tld/>itaj de la strata koto
        <fnt>
          <bib>Marta</bib>
        </fnt>;
      </ekz>
      <ekz>
        miajn manojn ne <tld/>is sango
        <fnt>
          <bib>Far1</bib>
          <lok>&Ccirc;apitro XX</lok>
        </fnt>;
      </ekz>
      <ekz>
        <uzo tip="stl">FIG</uzo>
        ne <tld/>u vian filan koron
        <fnt>
          <bib>Hamlet</bib>
        </fnt>;
      </ekz>
      <ekz>
        ruzo kaj prudento <klr>[ne]</klr> &parsl; <tld lit="M"/>as viron, kiu sin dedi&ccirc;is &parsl; Al
        plenumado de kura&gcirc;aj faroj
        <fnt>
          <bib>Ifigenio</bib>
        </fnt>;
      </ekz>
      <ekz>
        <uzo tip="stl">FIG</uzo>
        se kalumnio ne brulas, &gcirc;i almena&ubreve; <tld/>as
        <fnt><bib>PrV</bib></fnt>.
      </ekz>
    </dif>
  </snc>
  <trdgrp lng="be">
    <trd>&c_z;&c_a;&c_p;&c_l;&c_ja;&c_m;&c_ib;&c_c;&c_mol;</trd>,
    <trd>&c_s;&c_p;&c_l;&c_ja;&c_m;&c_ib;&c_c;&c_mol;</trd>
  </trdgrp>
  <trd lng="br">tarcha&ntilde;</trd>
  <trdgrp lng="cs">
    <trd>poskvrnit</trd>,
    <trd>zamazat</trd>
  </trdgrp>
  <trdgrp lng="de">
    <trd>beflecken</trd>,
    <trd>besch&auml;digen</trd>
  </trdgrp>
  <trd lng="en">stain</trd>
  <trdgrp lng="es">
    <trd>manchar</trd>,
    <trd>ensuciar</trd>
  </trdgrp>
  <trd lng="fa">&a_l;&f_k;&a_h;&zwnj;&a_d;&a_A;&a_r; &f_k;&a_r;&a_d;&a_n;</trd>
  <trd lng="fr">tacher</trd>
  <trdgrp lng="hu">
    <trd>foltot ejt</trd>,
    <trd>bepiszkol</trd>,
    <trd>pettyez</trd>
  </trdgrp>
  <trdgrp lng="id">
    <trd><baz>bercak</baz>membercaki</trd>,
    <trd><baz>kotor</baz>mengotori<klr tip="amb"> (dgn bercak)</klr></trd>,
    <trd><baz>noda</baz>menodai</trd>
  </trdgrp>
  <trdgrp lng="ja">
    <trd>&#x3088;&#x3054;&#x3059;</trd>,
    <trd>&#x3057;&#x307F;&#x3092;&#x3064;&#x3051;&#x308B;</trd>,
    <trd>&#x3051;&#x304C;&#x3059;</trd>
  </trdgrp>
  <trd lng="nl">bevlekken</trd>
  <trdgrp lng="pl">
    <trd>brudzi&cacute;</trd>,
    <trd>plami&cacute;</trd>,
    <trd>bruka&cacute;</trd>,
    <trd>plugawi&cacute;</trd>,
    <trd>ska&zdot;a&cacute;</trd>,
    <trd>szarga&cacute;</trd>
  </trdgrp>
  <trdgrp lng="ro">
    <trd>murdar</trd>,
    <trd>poluat</trd>,
    <trd>contaminat</trd>,
    <trd>spurca</trd>,
    <trd>p&abreve;ta</trd>,
    <trd>m&acirc;nji</trd>
  </trdgrp>
  <trdgrp lng="ru">
    <trd>&c_p;&c_o;&c_s;&c_a;&c_d;&c_i;&c_t;&c_mol; &c_p;&c_ja;&c_t;&c_n;&c_o;</trd>,
    <trd>&c_z;&c_a;&c_p;&c_ja;&c_t;&c_n;&c_a;&c_t;&c_mol;</trd>,
    <trd>&c_p;&c_ja;&c_t;&c_n;&c_a;&c_t;&c_mol;</trd>
  </trdgrp>
  <trd lng="sk">po&scaron;kvrni&tcaron;</trd>
  <trd lng="tr">lekelemek</trd>
  <trdgrp lng="uk">
    <trd>&c_l;&c_i;&c_sh;&c_a;&c_t;&c_i; &c_p;&c_l;&c_ja;&c_m;&c_u;</trd>,
    <trd>&c_p;&c_l;&c_ja;&c_m;&c_i;&c_t;&c_i;</trd>,
    <trd>&c_p;&c_l;&c_ja;&c_m;&c_u;&c_v;&c_a;&c_t;&c_i;</trd>
  </trdgrp>
  <trd lng="zh">&#x7455;&#x75B5; <pr>xi&aacute;c&imacron;</pr></trd>
</drv>

<drv mrk="makul.0eto">
  <kap>
    <tld/>eto
  </kap>
  <snc>
    <dif>
      Malgranda <tld/>o:
      <ekz>
        rigardante lian viza&gcirc;on <klr>[&#x2026;]</klr> kovritan de bluaj <tld/>etoj
        <fnt>
          <bib>Mizero</bib>
          <lok>III</lok>
        </fnt>;
      </ekz>
      <ekz>
        la malmultaj &scirc;ipoj sur la horizonto similis malgrandajn <tld/>etojn
        <fnt>
          <bib>IdO</bib>
          <lok>Unua Parto</lok>
        </fnt>;
      </ekz>
      <ekz>
        la subiranta suno <klr>[&#x2026;]</klr> ludas per blanka <tld/>eto super ne&gcirc;kolora lito
        <fnt>
          <bib>Metrop</bib>
        </fnt>;
      </ekz>
      <ekz>
        la rozo <klr>[&#x2026;]</klr> havis iujn <tld/>etojn, kvaza&ubreve; &gcirc;i havus lentugojn
        <fnt>
          <bib>OIP</bib>
          <lok>Ombro sur interna pejza&gcirc;o</lok>
        </fnt>;
      </ekz>
      <ekz>
        <uzo tip="stl">FIG</uzo>
        &gcirc;ena epizodeto enigis la unuan <tld/>eton en tiun perfektan amor-rilaton
        <fnt>
          <bib>Monato</bib>
          <aut>Julia Sigmond kaj Sen Rodin</aut>
          <vrk><url ref="&Monato;/2010/009988.php"
              >La mal&jcirc;aluzo de Klorinda</url></vrk>
          <lok>2010</lok>
        </fnt>;
      </ekz>
      <ekz>
        <uzo tip="stl">FIG</uzo>
        malgra&ubreve; la pluraj <tld/>etoj la leksikono estas bona kaj a&ccirc;etinda
        <fnt>
          <bib>LOdE</bib>
          <lok>2003, &#x2116; 1</lok>
        </fnt>.
      </ekz>
    </dif>
    <ref tip="sin" cel="punkt.0o.makuleto">punkto<sncref/></ref>
  </snc>
  <trdgrp lng="de">
    <trd>T&uuml;pfelchen</trd>,
    <trd>Punkt <klr>(T&uuml;pfel)</klr></trd>,
    <trd>Fleckchen</trd>,
    <trd>Kleckschen</trd>
  </trdgrp>
  <trdgrp lng="en">
    <trd>tittle</trd>,
    <trd>dot</trd>
  </trdgrp>
  <trd lng="fr">point</trd>
</drv>

<drv mrk="makul.0ita">
  <kap>
    <tld/>ita
  </kap>
  <snc>
    <dif>
      Havanta <tld/>ojn; <tld/>forme mikskolora (<ref tip="sub" cel="ruan.0a">ruana</ref> ks):
      <ekz>
        sang<tld/>ita glavo
        <fnt>
          <bib>Rabistoj</bib>
          <lok>Akto Kvara</lok>
        </fnt>;
      </ekz>
      <ekz>
        apartigu <klr>[&#x2026;]</klr> &ccirc;iun &scirc;afon mikskoloran kaj <tld/>itan
        <fnt>
          <bib>MT</bib>
          <lok>Genezo 30:32</lok>
        </fnt>;
      </ekz>
      <ekz>
        li apartigis en tiu tago la virkaprojn striitajn kaj <tld/>itajn
        <fnt>
          <bib>MT</bib>
          <lok>Genezo 30:35</lok>
        </fnt>;
      </ekz>
      <ekz>
        li havis <tld/>itan tunikon kaj perukon el &scirc;afa felo
        <fnt>
          <bib>Far1</bib>
          <lok>&Ccirc;apitro XII</lok>
        </fnt>;
      </ekz>
      <ekz>
        mevoj &scirc;vebis super la maro por kapti nutra&jcirc;on kaj <klr>[&#x2026;]</klr> mi balda&ubreve; venos
        por forpreni la grandajn blue <tld/>itajn ovojn en la dunoj
        <fnt>
          <bib>IdO</bib>
          <lok>Unua Parto</lok>
        </fnt>.
      </ekz>
    </dif>
  </snc>
  <trdgrp lng="be">
    <trd>&c_z;&c_a;&c_p;&c_l;&c_ja;&c_m;&c_l;&c_je;&c_n;&c_y;</trd>,
    <trd>&c_p;&c_l;&c_ja;&c_m;&c_ib;&c_s;&c_t;&c_y;</trd>
  </trdgrp>
  <trdgrp lng="de">
    <trd>gefleckt</trd>,
    <trd>befleckt</trd>,
    <trd>gesprenkelt</trd>,
    <trd>fleckig</trd>,
    <trd>get&uuml;pfelt</trd>
  </trdgrp>
<trdgrp lng="id">
  <trd><baz>bercak</baz>bebercak</trd>,
  <trd><baz>bintik</baz>berbintik</trd>,
  <trd><baz>bintik</baz>berbintik-bintik</trd>,
  <trd><baz>kotor</baz>terkotori<klr tip="amb"> (dgn bercak)</klr></trd>,
  <trd><baz>noda</baz>bernoda</trd>,
  <trd><baz>noda</baz>ternodai</trd>,
  <trd><baz>titik</baz>bertitik</trd>
</trdgrp>
</drv>

<drv mrk="makul.sen0a">
  <kap>sen<tld/>a</kap>
  <snc mrk="makul.sen0a.KOMUNE">
    <dif>
      Nehavanta <tld/>on materian a&ubreve; moralan:
      <ekz>
