<drv mrk="makul.bat0o">
  <kap>bat<tld/>o</kap>
  <snc mrk="makul.bat0o.MED">
    <uzo tip="fak">MED</uzo>
    <dif>
      <ref tip="super" cel="makul.hauxt0o.MED">Ha&ubreve;tmakulo</ref>
      sekvanta
      baton, ofte i&gcirc;anta <ref tip="vid" cel="blu.0ajxo.MED">blua&jcirc;o</ref>:
      <ekz>
        la malpli forta knabo eliris kun kelkaj bluaj bat<tld/>oj kaj
        &scirc;vela&jcirc;oj
        <fnt><aut>H. Sienkiewicz, trad. M. Sygnarski</aut>, <vrk><url
        ref="http://esperanto.pl/page.php?tid=200000">Tra dezerto kaj
        praarbaro</url></vrk>, <lok>Varsovio, 1978</lok></fnt>;
      </ekz>
      <ekz>
        la kompatinda havas ian fre&scirc;an bat<tld/>on, pro kiu &scirc;i mem kaj &scirc;ia vesta&jcirc;o estis
        makulitaj per sango
        <fnt>
          <bib>Monato</bib>
          <aut>Dmitrij Cibulevskij</aut>
          <vrk><url ref="&Monato;/2012/010614.php"
              >&Ccirc;u sorto ...</url></vrk>
          <lok>2012</lok>
        </fnt>.
      </ekz>
    </dif>
    <refgrp tip="super">
