<?xml version="1.0"?>
<!DOCTYPE vortaro SYSTEM "../dtd/vokoxml.dtd">
<vortaro>
<art mrk="$Id: jak.xml,v 1.40 2026/07/13 21:13:19 revo Exp $">
<kap>
  <ofc>*</ofc>
  <rad>jak</rad>/o
<fnt><bib>UV</bib></fnt></kap>
<drv mrk="jak.0o">
  <kap><ofc>*</ofc><tld/>o</kap>
  <snc mrk="jak.0o.TEKS">
    <uzo tip="fak">TEKS</uzo>
    <dif>
      Ekstera <ref tip="lst" lst="voko:vesta&jcirc;oj" cel="vest.0o">vesto</ref>,
      malfermi&gcirc;anta &ccirc;e ia anta&ubreve;a parto,
      manikhava, kovranta la korpon ekde la &scirc;ultroj &gcirc;is
      proksimume la koksoj:
      <ekz>
	la <tld/>o estas la ordinara senceremonia vesto de la
	okcidentaj e&ubreve;ropanoj;
      </ekz>
      <ekz>
        el la felo faru <tld/>on
        <fnt>
          <bib>ElektFab</bib>
          <lok>Ha&ccirc;jo kaj Grenjo</lok>
        </fnt>;
      </ekz>
      <ekz>
        indi&gcirc;enoj <klr>[&#8230;]</klr> en siaj vilaj peltaj <tld/>oj prezentis strangan vida&jcirc;on
        <fnt>
          <bib>Fab3</bib>
          <lok>&Ccirc;e la plej ekstrema maro</lok>
        </fnt>;
      </ekz>
      <ekz>
        nun ni povas havi &scirc;afan lakton, &scirc;afan froma&gcirc;on kaj lanajn &scirc;trumpojn, e&ccirc; lanajn
        noktajn <tld/>ojn
        <fnt>
          <bib>Fab4</bib>
          <lok>Kion la patro faras, estas &ccirc;iam &gcirc;usta</lok>
        </fnt>;
      </ekz>
      <ekz>
        post la trumpetistoj rajdis dekkelko da asiriaj kavaliroj, en pintaj &ccirc;apoj,
        <tld/>oj kaj malvastaj pantalonoj
        <fnt>
          <bib>Far2</bib>
          <lok>&Ccirc;apitro X</lok>
        </fnt>;
      </ekz>
      <ekz>
        <tld lit="J"/>o, ve&scirc;to, e&ccirc; kalsono // &Gcirc;enus viajn movojn, dum &#8208; // Sendepende de l' sezono
        &#8208; // Ta&ubreve;gas nur l' Adam-kostum'
        <fnt>
          <aut>Raymond Schwartz</aut>
          <vrk><url ref="&Steloj;butiko">La Stranga Butiko</url></vrk>
          <lok>&Ccirc;astemulino</lok>
        </fnt>!
      </ekz>
    </dif>
    <refgrp tip="vid">
      <ref cel="kamizo.0o">kamizolo</ref>,
      <ref cel="vesxt.0o">ve&scirc;to</ref>
    </refgrp>
  </snc>
  <trdgrp lng="be">
    <trd>&c_p;&c_ib;&c_n;&c_zh;&c_a;&c_k;</trd>,
    <trd>&c_k;&c_u;&c_r;&c_t;&c_k;&c_a;</trd>,
    <trd>&c_t;&c_u;&c_zh;&c_u;&c_r;&c_k;&c_a;</trd>
  </trdgrp>
  <trd lng="bo">&t_sa;&t_tata;&t_naro;&t_da;&t_tsheg;&t_tha;&t_shabchu;&t_nga;&t_tsheg;</trd>
  <trdgrp lng="ca">
    <trd>jaqueta</trd>,
    <trd>jaca</trd>,
    <trd>americana</trd>
  </trdgrp>
  <trdgrp lng="cs">
    <trd>kab&aacute;t</trd>,
    <trd>kr&aacute;tk&yacute; kab&aacute;t</trd>,
    <trd>sako</trd>
  </trdgrp>
  <trdgrp lng="de">
    <trd>Jacke</trd>,
    <trd>Jackett</trd>,
    <trd>Sakko</trd>
  </trdgrp>
  <trd lng="en">jacket</trd>
  <trd lng="es">chaqueta</trd>
  <trdgrp lng="fr">
    <trd>veste<klr tip="ind"> (d'homme)</klr></trd>,
    <trd>veston</trd>
  </trdgrp>
  <trd lng="hu">zak&oacute;</trd>
  <trd lng="id">jaket</trd>
  <trdgrp lng="it">
      <trd>giacca</trd>,
      <trd>giubba</trd>,
      <trd>giubbotto</trd>
    </trdgrp>
  <trdgrp lng="ja">
    <trd>&#32972;&#24195;  <pr>&#12379;&#12403;&#12429;</pr></trd>,
    <trd>&#12472;&#12515;&#12465;&#12483;&#12488;  <pr>&#12376;&#12419;&#12369;&#12387;&#12392;</pr></trd>,
    <trd>&#19978;&#30528;  <pr>&#12358;&#12431;&#12366;</pr></trd>
  </trdgrp>
  <trd lng="nl">jas</trd>
  <trdgrp lng="pl">
    <trd>kurtka</trd>,
    <trd>kamizelka</trd>
  </trdgrp>
  <trdgrp lng="pt">
    <trd>palet&oacute;<klr tip="amb"> (de homem)</klr></trd>,
    <trd>casaco<klr tip="amb"> (de homem)</klr></trd>,
    <trd>jaquet&atilde;o</trd>,
    <trd>japona</trd>,
    <trd>v&eacute;stia</trd>,
  </trdgrp>
  <trdgrp lng="ru">
    <trd>&c_p;&c_i;&c_d;&c_zh;&c_a;&c_k;</trd>,
    <trd>&c_k;&c_u;&c_r;&c_t;&c_k;&c_a;</trd>,
    <trd>&c_t;&c_u;&c_zh;&c_u;&c_r;&c_k;&c_a;</trd>
  </trdgrp>
  <trdgrp lng="sk">
    <trd>kab&aacute;t</trd>,
    <trd>sako</trd>
  </trdgrp>
  <trd lng="sv">jacka</trd>
  <trdgrp lng="uk">
    <trd>&c_k;&c_u;&c_r;&c_t;&c_k;&c_a;</trd>,
    <trd>&c_t;&c_u;&c_zh;&c_u;&c_r;&c_k;&c_a;</trd>,
    <trd>&c_p;&c_ib;&c_d;&c_zh;&c_a;&c_k;</trd>
  </trdgrp>
  <trdgrp lng="zh">
    <trd>&#19978;&#34915; <pr>sh&agrave;ngy&imacron;</pr></trd>,
    <trd>&#22841;&#20811; <pr>ji&amacron;k&egrave;</pr></trd>,
    <trd>&#34948; <pr>&#462;o</pr></trd>,
    <trd>&#22806;&#34915; <pr>w&agrave;iy&imacron;</pr></trd>
  </trdgrp>
</drv>

<drv mrk="jak.0eto">
  <kap><tld/>eto</kap>
  <snc mrk="jak.0eto.TEKS">
    <uzo tip="fak">TEKS</uzo>
    <dif>
      Mallonga <tld/>o:
      <ekz>
	&scirc;i sin returnis kaj ekvidis belan junan fra&ubreve;lineton, kiu,
	bone kovrante sin per varma <tld/>eto, kuris al &scirc;i
	<fnt><bib>Marta</bib></fnt>;
      </ekz>
      <ekz>
	<klr>[kamarado]</klr> en blanka &ccirc;emizo sub mallonga
	griza <tld/>eto, kareseme rigardis &scirc;in
	<fnt><bib>Metrop</bib><lok>&ccirc;ap. 3</lok></fnt>;
      </ekz>
      <ekz>
	<tld/>eto de kelnero.
      </ekz>
    </dif>
    <ref tip="vid" cel="jxaket.0o">&jcirc;aketo</ref>
    <trd lng="be">&c_zh;&c_a;&c_k;&c_je;&c_t;</trd>
    <trd lng="ca">jaqueta curta</trd>
    <trd lng="hu">koszt&uuml;mkab&aacute;t</trd>
    <trdgrp lng="fr">
      <trd>veste<klr tip="ind"> (courte)</klr></trd>,
      <trd>blouson</trd>,
      <trd>pourpoint</trd>
    </trdgrp>
    <trd lng="id"><ind>jaket</ind> kecil</trd>
    <trd lng="pl">&zdot;akiet</trd>
    <trd lng="ru">&c_zh;&c_a;&c_k;&c_je;&c_t;</trd>
    <trdgrp lng="it">
      <trd>giacchetta</trd>,
      <trd>giubbetto</trd>,
      <trd>giubba</trd>
    </trdgrp>
  </snc>
  <snc mrk="jak.0eto.TIP">
    <uzo tip="fak">TIP</uzo>
    <dif>
      Deprenebla, ne algluita papera kovrilo de bindita a&ubreve;
      bro&scirc;urita libro, ofte kun kolora ilustra&jcirc;o.
    </dif>
    <trd lng="be">
&c_s;&c_u;&c_p;&c_e;&c_r;&c_v;&c_o;&c_k;&c_l;&c_a;&c_d;&c_k;&c_a;
</trd>
    <trd lng="ca">cobertes<klr tip="amb"> (d'un llibre)</klr></trd>
    <trdgrp lng="fr">
      <trd>jaquette<klr tip="ind"> (de livre)</klr></trd>,
      <trd>couverture<klr tip="ind"> (jaquette)</klr></trd>
    </trdgrp>
    <trd lng="id"><ind>jaket</ind> buku</trd>
    <trd lng="pl">ok&lstroke;adka</trd>
    <trd lng="ru">
&c_s;&c_u;&c_p;&c_je;&c_r;&c_o;&c_b;&c_l;&c_o;&c_zh;&c_k;&c_a;</trd>
    <trdgrp lng="it">
      <trd>copertina</trd>,
      <trd>sovracoperta</trd>
    </trdgrp>
  </snc>
  <trdgrp lng="cs">
    <trd>kab&aacute;tek</trd>,
    <trd>kazajka</trd>,
    <trd>s&aacute;&ccaron;ko</trd>,
    <trd>&zcaron;aket</trd>
  </trdgrp>
  <trd lng="en">jacket</trd>
  <trd lng="hu">k&ouml;nyvbor&iacute;t&oacute;</trd>
  <trdgrp lng="ja">
    <trd>&#12472;&#12515;&#12465;&#12483;&#12488;  <pr>&#12376;&#12419;&#12369;&#12387;&#12392;</pr></trd>,
    <trd>&#12459;&#12496;&#12540;  <pr>&#12363;&#12400;&#12540;</pr></trd>
  </trdgrp>
  <trd lng="nl">jasje</trd>
  <trd lng="pt">sobrecapa</trd>
  <trdgrp lng="sk">
    <trd>kab&aacute;tik</trd>,
    <trd>&zcaron;aket</trd>
  </trdgrp>
  <trd lng="uk">&c_zh;&c_a;&c_k;&c_je;&c_t;</trd>
  <trdgrp lng="zh">
    <trd>&#22806;&#22871; <pr>w&agrave;it&agrave;o</pr></trd>,
    <trd>&#34948; <pr>&#462;o</pr></trd>,
    <trd>&#34948;&#23376; <pr>&#462;ozi</pr></trd>,
    <trd>&#35174; <pr>r&uacute;</pr></trd>
  </trdgrp>
</drv>

<drv mrk="jak.trikita_0o">
  <kap>
    trik<tld/>o, <var><kap>trikita <tld/>o</kap></var>
  </kap>
  <snc>
    <dif>
      <tld lit="J"/>o trikita el lano, kotono ks, portata super &ccirc;emizo a&ubreve; bluzo:
      <ekz>
        &scirc;i ofte estis &jcirc;etanta sur liajn &scirc;ultrojn sian lanugan kaptukon, a&ubreve; la malnovan
        trikitan jakon
        <fnt>
          <bib>Metrop</bib>
        </fnt>;
      </ekz>
      <ekz>
        &scirc;i tute ne bezonis eliri tage tiel al la arbaro <klr>[&#8230;]</klr> vestita en longa
        trikita <tld/>eto kaj &scirc;alo kaj malnovaj, duon&ccirc;ifonaj ne&gcirc;&scirc;uoj
        <fnt>
          <bib>VRA</bib>
        </fnt>.
      </ekz>
    </dif>
    <refgrp tip="vid">
       <ref cel="pulover.0o">pulovero</ref>,
       <ref cel="sveter.0o">svetero</ref>
    </refgrp>
  </snc>
  <trdgrp lng="be">
    <trd>&c_k;&c_o;&c_f;&c_t;&c_a;</trd>,
    <trd>&c_v;&c_ja;&c_z;&c_a;&c_n;&c_k;&c_a;</trd>
  </trdgrp>
  <trd lng="ca">rebeca</trd>
  <trd lng="de">Strickjacke</trd>
  <trd lng="en">cardigan</trd>
  <trd lng="fr">cardigan</trd>
  <trd lng="id">kardigan</trd>
  <trd lng="pl">&zdot;akiet dziany</trd>
  <trd lng="ru">&c_k;&c_o;&c_f;&c_t;&c_a;</trd>
  <trdgrp lng="zh">
    <trd>&#24320;&#35167;&#34923; <pr>k&amacron;ij&imacron;nsh&amacron;n</pr></trd>,
    <trd>&#27611;&#34915; <pr>m&aacute;oy&imacron;</pr></trd>,
    <trd>&#24320;&#35167;&#32650;&#27611;&#34923; <pr>k&amacron;ij&imacron;ny&aacute;ngm&aacute;osh&amacron;n</pr></trd>
  </trdgrp>
</drv>
</art>
