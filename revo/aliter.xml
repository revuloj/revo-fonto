<?xml version="1.0"?>
<!DOCTYPE vortaro SYSTEM "../dtd/vokoxml.dtd">
<vortaro>
<art mrk="$Id: aliter.xml,v 1.26 2026/06/14 12:12:45 revo Exp $">
<kap>
  <rad>aliteraci</rad>/o
<fnt><bib>PVEF</bib></fnt></kap>
<drv mrk="aliter.0o">
  <kap><tld/>o</kap>
  <uzo tip="fak">POE</uzo>
  <snc>
    <dif>
      Efekta ripetado de sama a&ubreve; parenca konsonanto &ccirc;e la komenco
      de vortoj a&ubreve; de silaboj, ekzemple:
        <em>ord</em>o bezonas <em>ord</em>onon;
        lukti <em>f</em>irme, <em>f</em>orte, <em>f</em>ajre;
        samaj a<em>sp</em>iroj kaj e<em>sp</em>eroj;
        <em>v</em>ibras <em>v</em>ok' en <em>v</em>aga <em>v</em>ento:
      <ekz>
        &scirc;ajnis al mi pla&ccirc;a vortolirlado, rimoj kaj superrimoj foje belaj, trafaj
        vortludoj, indaj <tld/>oj kaj anka&ubreve; etaj dozoj da poeta intimeco
        <fnt>
          <bib>Monato</bib>
          <aut>Antonio Val&eacute;n</aut>
          <vrk><url ref="&Monato;/2005/008499.php">&Ccirc;u Ertl provizore stilekzercas?</url></vrk>
        </fnt>;
      </ekz>
      <ekz>
        <tld/>o estas uzata kune kun regula ritmo kaj rimo: &leftquot;tamen restas ta&ubreve;ga vojo de
        taktiko: / trudi penson en esprimon / taktofirman kaj en rimon&#x2026;&rightquot;
        <fnt>
          <bib>Monato</bib>
          <aut>Luiza Carol</aut>
          <vrk><url ref="&Monato;/2011/010287.php">Inter videbleco kaj nevidebleco</url></vrk>
        </fnt>.
      </ekz>
    </dif>
    <ref tip="vid" cel="rim.0o.efekto">rimo</ref>
    <rim>
      La&ubreve; <fnt><bib>BL</bib></fnt>: Prefere diru <ke>vortkomenca (son)ripet(ad)o</ke>,
      <ke>komencosona ripet(ad)</ke>, <ke>sonripet(ad)o</ke>, <ke>komenckonsonanta ripet(ad)o</ke>.
    </rim>
  </snc>
  <trd lng="be">&c_a;&c_l;&c_ib;&c_t;&c_e;&c_r;&c_a;&c_c;&c_y;&c_ja;</trd>
  <trd lng="ca">al&middot;literaci&oacute;</trd>
  <trdgrp lng="de">
    <trd>Alliteration</trd>,
    <trd>Stabreim</trd>
  </trdgrp>
  <trd lng="en">alliteration</trd>
  <trd lng="es">aliteraci&oacute;n</trd>
  <trd lng="fr">allit&eacute;ration<klr tip="ind"> (de consonnes)</klr></trd>
  <trdgrp lng="hu">
    <trd>alliter&aacute;ci&oacute;</trd>,
    <trd>bet&udblac;r&iacute;m</trd>
  </trdgrp>
  <trd lng="ja">&#x982D;&#x97FB;  <pr>&#x3068;&#x3046;&#x3044;&#x3093;</pr></trd>
  <trdgrp lng="nl">
    <trd>alliteratie</trd>,
    <trd>stafrijm</trd>
  </trdgrp>
  <trd lng="pl">aliteracja</trd>
  <trd lng="pt">alitera&ccedil;&atilde;o</trd>
  <trd lng="ro">alitera&tcomma;ie</trd>
  <trd lng="ru">&c_a;&c_l;&c_l;&c_i;&c_t;&c_je;&c_r;&c_a;&c_c;&c_i;&c_ja;</trd>
  <trd lng="sk">aliter&aacute;cia</trd>
  <trd lng="sv">allitteration</trd>
</drv>
</art>
