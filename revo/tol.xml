<?xml version="1.0"?>
<!DOCTYPE vortaro SYSTEM "../dtd/vokoxml.dtd">
<vortaro>
<art mrk="$Id: tol.xml,v 1.36 2026/05/16 08:00:21 revo Exp $">
<kap>
  <ofc>*</ofc>
  <rad>tol</rad>/o
<fnt><bib>UV</bib></fnt></kap>

<drv mrk="tol.0o">
  <kap><ofc>*</ofc><tld/>o</kap>
  <snc mrk="tol.0o.TEKS">
    <uzo tip="fak">TEKS</uzo>
    <dif>
      <ref tip="super" cel="teks.0ajxo.TEKS">Teksa&jcirc;o</ref>
      farita el <ref tip="prt" cel="lin.0o.tolo">lino</ref>
      a&ubreve; <ref cel="kanab.0o">kanabo</ref>:
      <ekz>
        tuniko el delikata <tld/>o
        <fnt>
          <bib>MT</bib>
          <lok>I. Kroniko 15:27</lok>
        </fnt>;
      </ekz>
      <ekz>
        delikata brodita <tld/>o
        <fnt>
          <bib>MT</bib>
          <lok>Je&hcirc;ezkel 27:7</lok>
        </fnt>;
      </ekz>
      <ekz>
        prilaboristoj de lino kombita kaj la teksistoj de blanka <tld/>o
        <fnt>
          <bib>MT</bib>
          <lok>Jesaja 19:9</lok>
        </fnt>;
      </ekz>
      <ekz>
        <klr>[la]</klr> pentristo entrenis <klr>[&#8230;]</klr> grandan pecon da kunrulita
        <tld/>o
        <fnt>
          <bib>Fab1</bib>
          <lok>Kupra porko</lok>
        </fnt>;
      </ekz>
      <ekz>
        <klr>[&scirc;i]</klr> sendis al lia edzino tri pecojn da
        <tld/>o
        <fnt><bib>Revizoro</bib>, <lok>akto 4a, sceno 11a</lok></fnt>;
      </ekz>
      <ekz>
        litoj, kiuj anstata&ubreve; matracoj havis stre&ccirc;itan <tld/>on
        <fnt>
          <bib>Far2</bib>
          <lok>&Ccirc;apitro I</lok>
        </fnt>;
      </ekz>
      <ekz>
        &scirc;i englitis sur la terason kaj singarde disiginte la <tld/>ojn de la tendo,
        elrigardis al Nilo
        <fnt>
          <bib>Far1</bib>
          <lok>&Ccirc;apitro IX</lok>
        </fnt>;
      </ekz>
      <ekz>
        <klr>[la]</klr> tablo <klr>[&#8230;]</klr> estis tute kovrita de tajloraj tabeloj kaj
        de grandaj pecoj da <ref cel="drap.0o">drapo</ref>j, <tld/>oj,
        <ref cel="batist.0o">batisto</ref>j, <ref cel="muslin.0o">muslino</ref>j
        <fnt>
          <bib>Marta</bib>
        </fnt>.
      </ekz>
    </dif>
    <ref tip="vid" cel="koton.0o.lanugo">kotono</ref>
  </snc>
  <trd lng="be">&c_p;&c_a;&c_l;&c_a;&c_t;&c_n;&c_o;</trd>
  <trd lng="bg">&c_l;&c_je;&c_n;</trd>
  <trdgrp lng="ca">
    <trd>tela</trd>,
    <trd>lona</trd>
  </trdgrp>
  <trd lng="cs">pl&aacute;tno</trd>
  <trdgrp lng="de">
    <trd>Leinen</trd>,
    <trd>Leinwand</trd>
  </trdgrp>
  <trdgrp lng="en">
    <trd>linen</trd>,
    <trd>cloth</trd>,
    <trd>sheeting</trd>
  </trdgrp>
  <trd lng="fr">toile</trd>
  <trd lng="hu">v&aacute;szon</trd>
  <trdgrp lng="id">
    <trd>kain</trd>,
    <trd>linen</trd>
  </trdgrp>
  <trdgrp lng="ja">
    <trd>&#12522;&#12531;&#12493;&#12523;</trd>,
    <trd>&#12522;&#12493;&#12531;</trd>,
    <trd>&#20124;&#40635;&#24067;  <pr>&#12354;&#12414;&#12396;&#12398;</pr></trd>,
    <trd>&#40635;&#24067;  <pr>&#12354;&#12373;&#12396;&#12398;</pr></trd>,
    <trd>&#24067;  <pr>&#12398;</pr></trd>,
    <trd>&#12463;&#12525;&#12540;&#12473;</trd>,
    <trd>&#30011;&#24067;  <pr>&#12364;&#12405;</pr></trd>
  </trdgrp>
  <trdgrp lng="nl">
    <trd>linnen</trd>,
    <trd>doek</trd>,
    <trd>lijnwaad</trd>
  </trdgrp>
  <trd lng="pl">p&lstroke;&oacute;tno</trd>
  <trd lng="pt">pano<klr> (de linho ou c&acirc;nhamo)</klr></trd>
  <trdgrp lng="ru">
    <trd>&c_h;&c_o;&c_l;&c_s;&c_t;</trd>,
    <trd>&c_p;&c_o;&c_l;&c_o;&c_t;&c_n;&c_o;</trd>
  </trdgrp>
  <trd lng="sk">pl&aacute;tno</trd>
  <trd lng="uk">&c_p;&c_o;&c_l;&c_o;&c_t;&c_n;&c_o;</trd>
  <trdgrp lng="zh">
    <trd>&#20122;&#40635;&#24067; <pr>y&agrave;m&aacute;b&ugrave;</pr></trd>,
    <trd>&#20126;&#40635;&#24067; <pr>y&agrave;m&aacute;b&ugrave;</pr></trd>
  </trdgrp>
</drv>

<drv mrk="tol.0ajxo">
  <kap><ofc>*</ofc><tld/>a&jcirc;o <fnt><bib>F</bib>, <lok>Universala Vortaro,
  <url ref="&AdE;/fundamento/universala_vortaro.html#av-5230">tol'a&jcirc;'</url></lok></fnt></kap>
  <snc mrk="tol.0ajxo.TEKS">
    <uzo tip="fak">TEKS</uzo>
    <dif>
      Objekto a&ubreve; kolekto el <tld/>o, precipe tiaj vestoj, litotukoj,
      tukoj por mastrumado ks:
      <ekz>
        &ccirc;emizojn, kolumojn, manumojn kaj ceterajn similajn
        objektojn ni nomas <tld/>a&jcirc;o, kvankam ili ne &ccirc;iam estas faritaj
        el <tld/>o
        <fnt><bib>F</bib>, <lok>&FE; 35</lok></fnt>;
      </ekz>
      <ekz>
        mia hararo estis &scirc;vita, ta&ubreve;zita, mia <ind>lito<tld/>a&jcirc;</ind>o
        <klr>(<ref tip="super" cel="tuk.lit0o">litotuko</ref>)</klr>
        malsekega
        <fnt>
          <bib>VaK</bib>
        </fnt>;
        <trd lng="de">Bettzeug <klr>(aus Leinen)</klr></trd>
        <trd lng="id">selimut</trd>
      </ekz>
      <ekz>
        mi donos al vi dote <ind>tablo<tld/>a&jcirc;o</ind>n kaj lita&jcirc;ojn, kiam vi fari&gcirc;os edzino
        <fnt>
          <bib>Fab1</bib>
          <lok>Elinjo-fingreto</lok>
        </fnt>;
        <trd lng="de">Tischdecke <klr>(aus Leinen)</klr></trd>
        <trd lng="id">taplak<klr> (meja)</klr></trd>
      </ekz>
      <ekz>
        &scirc;i amasigis en angulon <klr>[&#8230;]</klr> pastelajn skatolojn, <ind>pentro<tld/>a&jcirc;o</ind>jn kaj
        skizojn
        <fnt>
          <bib>KPr</bib>
        </fnt>.
        <trd lng="de">Leinwand</trd>
        <trd lng="id">kanvas</trd>
      </ekz>
    </dif>
  </snc>
  <trd lng="be">&c_b;&c_ja;&c_l;&c_ib;&c_z;&c_n;&c_a;</trd>
  <trdgrp lng="ca">
    <trd>roba blanca</trd>,
    <trd>llenceria</trd>
  </trdgrp>
  <trd lng="de">W&auml;sche</trd>
  <trd lng="en">linen good</trd>
  <trd lng="fr">linge</trd>
  <trd lng="hu">feh&eacute;rnem&udblac;</trd>
  <trd lng="id">linen</trd>
  <trdgrp lng="ja">
    <trd>&#12522;&#12531;&#12493;&#12523;&#35069;&#21697; 
    <pr>&#12522;&#12531;&#12493;&#12523;&#12379;&#12356;&#12402;&#12435;</pr></trd>,
    <trd>&#24067;&#35069;&#21697;  <pr>&#12396;&#12398;&#12379;&#12356;&#12402;&#12435;</pr></trd>,
    <trd>&#32908;&#30528;  <pr>&#12399;&#12384;&#12366;</pr></trd>,
    <trd>&#19979;&#30528;  <pr>&#12375;&#12383;&#12366;</pr></trd>
  </trdgrp>
  <trd lng="nl">linnengoed</trd>
  <trd lng="pl">bielizna</trd>
  <trd lng="ru">&c_b;&c_je;&c_l;&c_mol;&c_jo;</trd>
  <trdgrp lng="uk">
    <trd>&c_p;&c_o;&c_l;&c_o;&c_t;&c_n;&c_ja;&c_n;&c_i;&c_j; &c_v;&c_i;&c_r;&c_ib;&c_b;</trd>,
    <trd>&c_b;&c_ib;&c_l;&c_i;&c_z;&c_n;&c_a;</trd>
  </trdgrp>
  <trdgrp lng="zh">
    <trd>&#32122; <pr>ch&#299;</pr></trd>,
    <trd>&#20122;&#40635;&#24067; <pr>y&agrave;m&aacute;b&ugrave;</pr></trd>,
    <trd>&#20126;&#40635;&#24067; <pr>y&agrave;m&aacute;b&ugrave;</pr></trd>
  </trdgrp>
</drv>

