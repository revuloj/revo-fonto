<drv mrk="tol.vaks0o">
  <kap><ofc>*</ofc>vaks<tld/>o <fnt><bib>F</bib>, <lok>Universala
  Vortaro, <url
  ref="&AdE;/fundamento/universala_vortaro.html#av-5241">vaks'tol'</url></lok></fnt></kap>
  <snc mrk="tol.vaks0o.TEKS">
    <uzo tip="fak">TEKS</uzo>
    <dif>
      <tld lit="T"/>o &scirc;mirita per vakso a&ubreve; alia substanco nepenetrebla de akvo:
      <ekz>
        apud la muro inter la fenestroj staris kanapo, kovrita per nigra
        sen&scirc;eligita vaks<tld/>o
        <fnt><bib>FK</bib>, <lok>4, rakontoj, Arturo, (rakonto de V.
        Devjatnin), 4</lok></fnt>;
      </ekz>
      <ekz>
        la plafono konsistis el flaveru&gcirc;a vaks<tld/>o, kiu donis al la loko tre agrablan
        lumon
        <fnt>
          <bib>I&scirc;tar</bib>
        </fnt>;
      </ekz>
      <ekz>
        ni sternis vaks<tld/>on sur la tablo
        <fnt>
          <bib>KrM</bib>
        </fnt>.
      </ekz>
    </dif>
    <refgrp tip="vid">
      <ref cel="lin.0oleatolo0oleumo">linoleumo</ref>,
      <ref cel="tapisx">vakstapi&scirc;o</ref>
    </refgrp>
  </snc>
  <trd lng="be">&c_c;&c_y;&c_r;&c_a;&c_t;&c_a;</trd>
  <trdgrp lng="ca">
    <trd>hule</trd>,
    <trd>encerat</trd>
  </trdgrp>
  <trd lng="cs">voskovan&eacute; pl&aacute;tno</trd>
  <trdgrp lng="de">
      <trd>Wachstuch</trd>,
      <trd>Wachsleinwand</trd>
  </trdgrp>
  <trd lng="en">oilcloth</trd>
  <trd lng="fr">toile cir&eacute;e</trd>
  <trd lng="hu">viaszosv&aacute;szon</trd>
  <trd lng="id"><baz>kain</baz>kain minyak</trd>
  <trdgrp lng="ja">
    <trd>&#34635;&#24341;&#24067;  <pr>&#12429;&#12358;&#12402;&#12396;&#12398;</pr></trd>,
    <trd>&#38450;&#27700;&#24067;  <pr>&#12412;&#12358;&#12377;&#12356;&#12405;</pr></trd>
  </trdgrp>
  <trd lng="nl">zeildoek</trd>
  <trd lng="pl">cerata</trd>
  <trd lng="pt">encerado</trd>
  <trd lng="ru">&c_k;&c_l;&c_je;&c_jo;&c_n;&c_k;&c_a;</trd>
  <trd lng="sk">voskov&eacute; pl&aacute;tno</trd>
  <trd lng="uk">&c_k;&c_l;&c_je;&c_j;&c_o;&c_n;&c_k;&c_a;</trd>
</drv>
</art>
