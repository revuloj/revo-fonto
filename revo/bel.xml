<drv mrk="bel.0igajxo">
  <kap><tld/>iga&jcirc;o</kap>
  <snc mrk="bel.0igajxo.KOMUNE">
    <dif>
      Ero intence metita por <tld/>igi tuton:
      <ekz>
        perloj, el kiuj &ccirc;iu sola jam estus efektiva
        <tld/>iga&jcirc;o en la krono de re&gcirc;ino
        <fnt><bib>Fab1</bib>, <lok>la virineto de maro</lok></fnt>;
      </ekz>
      <ekz>
        la knabino pla&ccirc;is al li kaj akiris lian favoron, kaj li rapide donis al &scirc;i &scirc;iajn
        <tld/>iga&jcirc;ojn kaj &scirc;ian destinita&jcirc;on, kaj sep knabinojn elektitajn el la domo
        de la re&gcirc;o
        <fnt>
          <bib>MT</bib>
          <lok>Ester 2:9</lok>
        </fnt>;
      </ekz>
      <ekz>
        paroladoj konvenas en societoj, kie estas necese demonstracii siajn &scirc;aton kaj
        estimon, <klr>[&#x2026;]</klr> sed tie &ccirc;i <klr>[&#x2026;]</klr> tia <tld/>iga&jcirc;o estas
        superflua
        <fnt>
          <bib>HsT</bib>
          <lok>Kuni&gcirc;o</lok>
        </fnt>.
      </ekz>
    </dif>
    <refgrp tip="vid">
      <ref cel="ornam.0ajxo">ornama&jcirc;o</ref>
    </refgrp>
  </snc>
  <trd lng="be">&c_a;&c_z;&c_d;&c_o;&c_b;&c_a;</trd>
