    <trd>&#x6807;&#x81F4; <pr>bi&amacron;ozhi</pr></trd>,
    <trd>&#x534E;&#x4E3D; <pr>hu&aacute;l&igrave;</pr></trd>
  </trdgrp>
</snc>
  <trdgrp lng="be">
