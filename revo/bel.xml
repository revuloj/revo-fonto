<drv mrk="bel.mal0igi">
  <kap>
    mal<tld/>igi
  </kap>
  <snc>
    <dif>
      Fari ion mal<tld/>a:
      <ekz>
        min variolo tute mal<tld/>igis
        <fnt>
          <bib>Marta</bib>
        </fnt>;
      </ekz>
      <ekz>
        la mizero &gcirc;is nun tute ne mal<tld/>igis vin
        <fnt>
          <bib>Marta</bib>
        </fnt>;
      </ekz>
      <ekz>
        eblas tuj eklo&gcirc;i, kaj nek ruboj, nek malordo mal<tld/>igas la &ccirc;irka&ubreve;a&jcirc;on
        <fnt>
          <bib>Monato</bib>
          <aut>Saliko</aut>
          <vrk><url ref="&Monato;/2007/009207.php"
              >Porteblaj hejmoj</url></vrk>
          <lok>2007</lok>
        </fnt>;
      </ekz>
      <ekz>
        la akuzativo estas enkondukita nur el neceso, <klr>[&#x2026;]</klr> sed &gcirc;ia uzado en
        okazo de nebezono pli multe malbeligas la lingvon ol la neuzado en okazo de
        bezono
        <fnt>
          <bib>LR</bib>
          <lok>Dua Parto &ndash; Gramatiko</lok>
        </fnt>.
      </ekz>
    </dif>
  </snc>
  <trdgrp lng="de">
    <trd>verunstalten</trd>,
    <trd>entstellen</trd>,
    <trd>der <ind>Sch&ouml;nheit</ind> berauben</trd>,
    <trd>verunzieren</trd>,
    <trd>verschandeln</trd>
  </trdgrp>
  <trd lng="en">deface</trd>
  <trd lng="fr">d&eacute;parer</trd>
</drv>

<drv mrk="bel.pli0igi">
  <kap>pli<tld/>igi</kap>
  <gra><vspec>tr</vspec></gra>
  <snc mrk="bel.pli0igi.KOMUNE">
    <dif>
      Aran&gcirc;i tiel, ke io aspektu pli <tld/>e:
      <ekz>
        la brilo de &scirc;iaj okuloj pli<tld/>igas ankora&ubreve; &scirc;ian viza&gcirc;on
        <fnt>
          <bib>IdO</bib>
          <lok>Kvina Parto</lok>
        </fnt>;
      </ekz>
      <ekz>
        la trinkkunvenoj ja pli<tld/>igis lian vivon
        <fnt>
          <bib>HsT</bib>
          <lok>Sia propra mastro</lok>
        </fnt>;
      </ekz>
      <ekz>
        figuroj altigas la nivelon de la parolado, tu&scirc;as la korojn, <klr>[&#x2026;]</klr>
        modeste, sed bone uzataj, ili pli<tld/>igas la paroladon
        <fnt>
          <bib>Ret</bib>
          <lok>Dua Parto</lok>
        </fnt>;
      </ekz>
      <ekz>
        niaj komercistoj kolektas la trezorojn el &ccirc;iu parto de la
        mondo por pli<tld/>igi la urbon
        <fnt><bib>SatirRak</bib>, <lok>Pythagoras, 5</lok></fnt>.
      </ekz>
    </dif>
    <ref tip="vid" cel="ornam.0i">ornami</ref>
  </snc>
