<drv mrk="bel.mal0a">
  <kap>mal<tld/>a</kap>
  <snc mrk="bel.mal0a.KOMUNE">
    <dif>
      Ne pla&ccirc;a, ne agrabla al vido, sentumoj, spirito:
      <ekz>
        malgrasaj kaj mal<tld/>aj bovinoj
        <fnt>
          <bib>MT</bib>
          <lok>Genezo 41:20</lok>
        </fnt>;
      </ekz>
      <ekz>
        &scirc;i estis terure mal<tld/>a, &scirc;ia malsupra lipo pendis &gcirc;is la brusto
        <fnt>
          <bib>Fab1</bib>
          <lok>Fajrilo</lok>
        </fnt>;
      </ekz>
      <ekz>
        &leftquot;kelkloke <tld/>a vetero, aliloke mal<tld/>a&rightquot;
        <fnt><bib>SatirRak</bib>, <lok>la fluidumo de la
        &ccirc;iovido</lok></fnt>;
      </ekz>
      <ekz>
        la gardisto fari&gcirc;is denove gardisto, tio estis mal<tld/>a son&gcirc;o! li diris, sed
        sufi&ccirc;e stranga
        <fnt>
          <bib>Fab1</bib>
          <lok>Galo&scirc;oj de feli&ccirc;o</lok>
        </fnt>;
      </ekz>
