<drv mrk="bel.0o">
  <kap><tld/>o</kap>
  <snc mrk="bel.0o.KOMUNE">
    <dif>
      <ref tip="dif" cel="bel.0eco"><tld lit="B"/>eco</ref>:
      <ekz>
        li paroladis al ili pri la <tld/>o, vero kaj bono
        <fnt><bib>Fab3</bib>, <lok>&scirc;tono de la sa&gcirc;uloj</lok>
        </fnt>;
      </ekz>
      <ekz>
        ili estas nomataj pavoj, kaj ili estas la <tld/>o, sed se oni nur iom
        senplumigus ilin, ili aspektus ne alie ol ni &ccirc;iuj
        <fnt>
          <bib>Fab2</bib>
          <lok>Najbaraj familioj</lok>
        </fnt>;
      </ekz>
      <ekz>
        en tiu tago la markoto de la Eternulo estos <tld/>o kaj honoro, kaj la frukto de
        la tero estos majesto kaj ornamo
        <fnt>
          <bib>MT</bib>
          <lok>Jesaja 4:2</lok>
        </fnt>.
      </ekz>
    </dif>
  </snc>
  <rim>
    Cetere <ref tip="hom" cel="bel1.0o">belo</ref> estas anka&ubreve; mezurunuo de sonintenso.
  </rim>
  <trd lng="be">&c_p;&c_r;&c_y;&c_g;&c_a;&c_zh;&c_o;&c_s;&c_mol;&c_c;&c_mol;</trd>
  <trdgrp lng="br">
    <trd>kened</trd>,
    <trd>brav<klr tip="ind"> (ak.)</klr></trd>
  </trdgrp>
  <trdgrp lng="cs">
    <trd>B</trd>,
    <trd>bel</trd>,
    <trd>bell</trd>
  </trdgrp>
  <trd lng="de">das <ind>Sch&ouml;ne</ind></trd>
  <trdgrp lng="en">
    <trd>beauty</trd>,
    <trd>pulchritude</trd>,
    <trd>comeliness</trd>,
    <trd>handsomeness</trd>
  </trdgrp>
  <trdgrp lng="fr">
    <trd>beau<klr tip="amb"> (subst.)</klr></trd>,
    <trd>beaut&eacute;<klr tip="amb"> (la beaut&eacute;,
    propri&eacute;t&eacute;)</klr></trd>
  </trdgrp>
  <trd lng="he">&yod;&vav;&pe;&yod;</trd>
  <trdgrp lng="id">
    <trd><baz>cantik</baz>kecantikan</trd>,
    <trd><baz>indah</baz>keindahan</trd>,
    <trd><baz>tampan</baz>ketampanan</trd>,
    <trd><baz>elok</baz>keelokan</trd>,
    <trd><baz>molek</baz>kemolekan</trd>
  </trdgrp>
  <trd lng="ja">&#x7F8E;  <pr>&#x307F;</pr></trd>
  <trd lng="nl">schoonheid</trd>
  <trdgrp lng="pl">
    <trd>uroda</trd>,
    <trd>krasa</trd>,
    <trd>pi&eogonek;kno</trd>
  </trdgrp>
  <trd lng="ru">&c_k;&c_r;&c_a;&c_s;&c_o;&c_t;&c_a;<klr tip="amb">
  (&c_k;&c_a;&c_ch;&c_je;&c_s;&c_t;&c_v;&c_o;)</klr></trd>
  <trdgrp lng="sk">
    <trd>B</trd>,
    <trd>bel</trd>,
    <trd>bell</trd>
  </trdgrp>
</drv>

<drv mrk="bel.0ajxo">
  <kap><tld/>a&jcirc;o</kap>
  <snc mrk="bel.0ajxo.KOMUNE">
    <dif>
      <tld lit="B"/>a parto a&ubreve; aspekto de io:
      <ekz>
        <klr>[li]</klr> ne mal&scirc;paris siajn la&ubreve;dojn pri la naturaj <tld/>a&jcirc;oj de landoj,
        kiujn li estis trairinta
        <fnt>
          <bib>ChL</bib>
          <lok>&Ccirc;apitro Sesa</lok>
        </fnt>;
      </ekz>
      <ekz>
        bona&jcirc;o kaj <tld/>a&jcirc;o ne forgesi&gcirc;as, &gcirc;i vivas en legendoj kaj kantoj
        <fnt>
          <bib>Fab3</bib>
          <lok>Malnova tomba &scirc;tono</lok>
        </fnt>;
      </ekz>
      <ekz>
        kuris cervoj, kapreoloj kaj leporoj, &dash; &ccirc;io, kion oni povus revi, kiaj <tld/>a&jcirc;oj
        <fnt>
          <bib>ElektFab</bib>
          <lok>Fi&scirc;kaptisto kaj lia edzino</lok>
        </fnt>!
      </ekz>
      <ekz>
        kiel fian&ccirc;on <klr>[li]</klr> sin ornamas per <tld/>a&jcirc;o
        <fnt>
          <bib>MT</bib>
          <lok>Jesaja 61:10</lok>
        </fnt>;
      </ekz>
      <ekz>
        ili nudigos siajn glavojn kontra&ubreve; la <tld/>a&jcirc;ojn de via sa&gcirc;eco kaj malaperigos
        vian brilon
        <fnt>
          <bib>MT</bib>
          <lok>Je&hcirc;ezkel 28:7</lok>
        </fnt>.
      </ekz>
    </dif>
    <ref tip="vid" cel="ornam.0o.ajxo">ornamo<sncref/></ref>
  </snc>
  <trd lng="be">&c_p;&c_r;&c_y;&c_g;&c_a;&c_zh;&c_o;&c_s;&c_mol;&c_c;&c_mol;</trd>
  <trd lng="br">braventez<klr tip="ind"> (tra vrav)</klr></trd>
  <trdgrp lng="de">
    <trd>Sch&ouml;nheit <klr>(Eigenschaft)</klr></trd>,
    <trd>Zier</trd>
  </trdgrp>
  <trdgrp lng="en">
    <trd>beauty</trd>,
    <trd>beautiful things</trd>
  </trdgrp>
  <trd lng="fr">beaut&eacute;<klr tip="amb"> (une beaut&eacute;
  concr&egrave;te)</klr></trd>
  <trd lng="he">&dalet;&bet;&resh; &yod;&pe;&he;</trd>
  <trd lng="nl">iets <ind>moois</ind></trd>
  <trdgrp lng="pl">
    <trd>cacko</trd>,
    <trd>pi&eogonek;kno&sacute;&cacute;</trd>
  </trdgrp>
  <trd lng="ro">frumuse&tcomma;e</trd>
  <trd lng="ru">&c_k;&c_r;&c_a;&c_s;&c_o;&c_t;&c_a;<klr tip="amb">
  (&c_n;&c_je;&c_ch;&c_t;&c_o;
  &c_k;&c_r;&c_a;&c_s;&c_i;&c_v;&c_o;&c_je;)
  </klr></trd>
  <trdgrp lng="uk">
    <trd>&c_k;&c_r;&c_a;&c_s;&c_a;</trd>,
    <trd>&c_p;&c_r;&c_je;&c_k;&c_r;&c_a;&c_s;&c_n;&c_je;&nbsp;(&c_ib;&c_m;.)</trd>,
    <trd>&c_v;&c_r;&c_o;&c_d;&c_a;</trd>
  </trdgrp>
</drv>

