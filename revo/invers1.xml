<?xml version="1.0"?>
<!DOCTYPE vortaro SYSTEM "../dtd/vokoxml.dtd">
<vortaro>
<art mrk="$Id: invers1.xml,v 1.23 2026/06/14 12:12:43 revo Exp $">
<kap>
  <rad>inversi</rad>/o
  <fnt><bib>JED</bib></fnt>
</kap>
<drv mrk="invers1.0o">
  <kap><tld/>o</kap>
  <uzo tip="fak">GRA</uzo>
  <snc>
    <dif>
      Aran&gcirc;o de frazo, kiu ne prezentas la ordinaran ordon:
      <ekz>
        <tld/>o estas ofta en poezia&jcirc;oj;
      </ekz>
      <ekz>
        aliaj ordoj estas tutsimple strangaj: oni ne uzas ilin en konversacio a&ubreve; en
        ordinara prozo, kaj ili okazas nur kiel maloftaj stilefektoj &ndash; <tld/>oj &ndash; en
        la poezio
        <fnt>
          <bib>LAE</bib>
          <lok>4. Sintakso</lok>
        </fnt>;
      </ekz>
      <ekz>
        la stilo <klr>[&#x2026;]</klr> estas fidela pa&ubreve;sa&jcirc;o de la originala islanda
        <klr>[&#x2026;]</klr>: verbo komence de frazo, <tld/>o de vortordo, simplaj frazoj
        sen subordigitaj propozicioj
        <fnt>
          <bib>Monato</bib>
          <aut>Garbhan Macaoidh</aut>
          <vrk><url ref="&Monato;/2004/008323.html"
              >Le&gcirc;oj landon prosperigas</url></vrk>
          <lok>2004</lok>
        </fnt>.
      </ekz>
    </dif>
    <rim>
      La&ubreve; <fnt><bib>BL</bib></fnt>: Prefere diru <ke>inversigo</ke>, <ke>inversiga stilfiguro</ke>.
    </rim>
  </snc>
  <trdgrp lng="be">
    <trd>&c_ib;&c_n;&c_v;&c_e;&c_r;&c_s;&c_ib;&c_ja;</trd>,
    <trd>&c_z;&c_v;&c_a;&c_r;&c_o;&c_t;&c_n;&c_y; &c_p;&c_a;&c_r;&c_a;&c_d;&c_a;&c_k; &c_s;&c_l;&c_o;&c_w;</trd>
  </trdgrp>
  <trd lng="cs">inverze</trd>
  <trdgrp lng="de">
    <trd>Inversion</trd>,
    <trd>Umkehrung der regelm&auml;&szlig;igen Wortfolge</trd>
  </trdgrp>
  <trd lng="en">inversion<klr tip="ind"> (gram.)</klr></trd>
  <trdgrp lng="es">
    <trd>inversi&oacute;n</trd>,
    <trd>hip&eacute;rbaton</trd>
  </trdgrp>
  <trd lng="fa">&a_t;&a_q;&a_d;&f_y;&a_m; &a_w; &a_t;&a_A_hamza_sure;&a_kh;&f_y;&a_r;<klr tip="ind">
  (&a_b;&a_d;&f_y;&a_ayn;)</klr></trd>
  <trd lng="fr">inversion<klr tip="ind"> (gramm.)</klr></trd>
  <trdgrp lng="hu">
    <trd>sz&oacute;rend megford&iacute;t&aacute;sa</trd>,
    <trd>ford&iacute;tott sz&oacute;rend</trd>
  </trdgrp>
  <trdgrp lng="ja">
    <trd>&#x5012;&#x7F6E;  <pr>&#x3068;&#x3046;&#x3061;</pr></trd>,
    <trd>&#x9006;&#x8EE2;  <pr>&#x304E;&#x3083;&#x304F;&#x3066;&#x3093;</pr></trd>
  </trdgrp>
  <trd lng="nl">inversie</trd>
  <trdgrp lng="pl">
    <trd>inwersja</trd>,
    <trd>anastrofa</trd>,
    <trd>przek&lstroke;adnia</trd>
  </trdgrp>
  <trd lng="pt">invers&atilde;o<klr tip="amb"> (gram&aacute;tica)</klr></trd>
  <trdgrp lng="ru">
    <trd>&c_i;&c_n;&c_v;&c_je;&c_r;&c_s;&c_i;&c_ja;</trd>,
    <trd>&c_o;&c_b;&c_r;&c_a;&c_t;&c_n;&c_y;&c_j; &c_p;&c_o;&c_r;&c_ja;&c_d;&c_o;&c_k; &c_s;&c_l;&c_o;&c_v;</trd>
  </trdgrp>
  <trdgrp lng="sk">
    <trd>inverzia</trd>,
    <trd>obr&aacute;ten&yacute; slovosled</trd>
  </trdgrp>
  <trdgrp lng="uk">
    <trd>&c_ib;&c_n;&c_v;&c_je;&c_r;&c_s;&c_ib;&c_ja;</trd>,
    <trd>&c_z;&c_v;&c_o;&c_r;&c_o;&c_t;&c_n;&c_i;&c_j; &c_p;&c_o;&c_r;&c_ja;&c_d;&c_o;&c_k; &c_s;&c_l;&c_ib;&c_v;</trd>
  </trdgrp>
  <trd lng="zh">&#x5012;&#x4F4D; <pr>d&agrave;ow&egrave;i</pr></trd>
</drv>
</art>
