<!DOCTYPE vortaro SYSTEM "../dtd/vokoxml.dtd">
<vortaro>
<art mrk="$Id: seton.xml,v 1.3 2026/03/19 07:14:46 afido Exp $">
<kap>
    <rad>seton</rad>/o <fnt><bib>PIV1</bib></fnt>
</kap>
<drv mrk="seton.0o">
  <kap><tld/>o</kap>
  <snc mrk="seton.0o.MED">
    <uzo tip="fak">MED</uzo>
    <dif>
      Rubando, per kiu oni tenas fistulon malfermita por forfluigo de puso &gcirc;is cikatri&gcirc;o:
      <ekz>
        <tld/>o estas iu speco de drenilo, kies speciala karakterizo estas, ke &gcirc;i dufoje trapasas la
        ha&ubreve;ton
        <fnt>
          <aut>P. Desmet'</aut>
          <vrk>Vortarludoj</vrk>
          <lok>2025</lok>
        </fnt>.
      </ekz>
    </dif>
  </snc>
  <trd lng="be">&c_s;&c_e;&c_t;&c_o;&c_n;-&c_d;&c_r;&c_e;&c_n;&c_a;&c_zh;</trd>
  <trdgrp lng="de">
    <trd>Seton-Einlage</trd>,
    <trd>Fadendrainage</trd>
  </trdgrp>
  <trd lng="fr">s&eacute;ton</trd>
  <trd lng="nl">setacea</trd>
</drv>
</art>

