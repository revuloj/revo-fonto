    <trdgrp lng="be">
      <trd>&c_n;&c_je;&c_p;&c_r;&c_y;&c_ja;&c_z;&c_n;&c_y;</trd>,
      <trd>&c_n;&c_ja;&c_v;&c_je;&c_t;&c_l;&c_ib;&c_v;&c_y;</trd>,
