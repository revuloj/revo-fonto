<drv mrk="afabl.0a">
  <kap><ofc>*</ofc><tld/>a</kap>
  <snc mrk="afabl.0a.KOMUNE">
    <dif>
      Pla&ccirc;a per &gcirc;entileco, akceptemo, agrablaj vortoj,
      komplezo:
      <ekz>
        <tld/>a ridetado
        <fnt>
          <bib>Fab1</bib>
          <lok>La virineto de maro</lok>
        </fnt>;
      </ekz>
      <ekz>
        <tld/>a saluto
        <fnt>
          <bib>Fab4</bib>
          <lok>La vento rakontas pri Valdemaro Doe kaj pri liaj filinoj</lok>
        </fnt>;
      </ekz>
      <ekz>
        malgranda domo, blanka kaj <tld/>aspekta
        <fnt>
          <bib>Fab3</bib>
          <lok>Ib kaj malgranda kristino</lok>
        </fnt>;
      </ekz>
      <ekz>
        <tld/>a vorto pli atingas ol forto
        <fnt><bib>PrV</bib></fnt>;
      </ekz>
      <ekz>
        apud plena man&gcirc;otablo &ccirc;iu estas tre <tld/>a
        <fnt>
          <bib>PrV</bib>
        </fnt>;
      </ekz>
      <ekz>
        kiu agas <tld/>e, vivas agrable
        <fnt>
          <bib>PrV</bib>
        </fnt>;
      </ekz>
      <ekz>
        <nom>David</nom> aliris al tiuj homoj kaj <tld/>e salutis ilin
        <fnt>
          <bib>MT</bib>
          <lok>I. Samuel 30:21</lok>
        </fnt>;
      </ekz>
      <ekz>
        esti <tld/>a al &ccirc;iuj, instruema, tolerema
        <fnt>
          <bib>NT</bib>
          <lok>II. Timoteo 2:24</lok>
        </fnt>;
      </ekz>
      <ekz>
        &ccirc;u vi ne volas esti tiel <tld/>a kaj sidi&gcirc;i
        <fnt>
          <bib>Fab2</bib>
          <lok>Dio de dormo</lok>
        </fnt>?
      </ekz>
      <ekz>
        la virino akceptis ilin amba&ubreve; eksterordinare <tld/>e, kovris longan tablon kaj
        donis al ili grandan pladon da gria&jcirc;o
        <fnt>
          <bib>Fab1</bib>
          <lok>Malgranda Niko kaj granda Niko</lok>
        </fnt>;
      </ekz>
      <ekz>
        <uzo tip="stl">FIG</uzo>
        la suno tre <tld/>e enlumis tra la malgranda fenestro
        <fnt>
          <bib>Fab3</bib>
          <lok>Kvin en unu silikvo</lok>
        </fnt>.
      </ekz>
    </dif>
    <refgrp tip="vid">
