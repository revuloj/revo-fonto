<drv mrk="afabl.ne0a">
  <kap>
    ne<tld/>a
  </kap>
  <snc>
    <dif>
      Ne montranta sin <tld/>a:
      <ekz>
        &leftquot;ne ploru tiom <klr>[&#8230;]</klr>, ekzistas familioj, kiuj havas sole unu
        &ccirc;ambreton&rightquot;, li diris tion malarde kaj ne<tld/>e
        <fnt>
          <aut>Jaroslav Durych</aut>
          <vrk><url ref="https://verkoj.com/dn/inko/114-3.pdf"
              >Tri Dukatoj</url></vrk>
          <lok>&Ccirc;e&hcirc;a kaj slovaka antologio, p. 411</lok>
        </fnt>;
      </ekz>
      <ekz>
        inciton li respondis per ne<tld/>a grimaco kaj iris la&ubreve; sia vojo senvorte
        <fnt>
          <aut>Ign&aacute;t He&rcaron;mann</aut>
          <vrk>&Ccirc;e&hcirc;a kaj slovaka antologio</vrk>
          <lok><url ref="https://eduinf.waw.pl/esp/lern/librejo/0195/0026.php"
              >Mia Kunklasano Ture&ccaron;ek</url></lok>
        </fnt>.
      </ekz>
    </dif>
    <refgrp tip="vid">
      <ref cel="indife.0a.iu">indiferenta<sncref/></ref>
      <ref cel="pasi.sen0a">senpasia</ref>,
      <ref cel="sobr.0a.FIG">sobra<sncref/></ref>
    </refgrp>
  </snc>
  <trd lng="de">ohne <ind>Freundlichkeit</ind></trd>
</drv>

