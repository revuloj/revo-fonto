<drv mrk="afabl.mal0a">
  <kap><ofc>*</ofc>mal<tld/>a <fnt><bib>F</bib>, <lok>Universala
  Vortaro, <url
  ref="&AdE;/fundamento/universala_vortaro.html#av-4967">mal'afabl'</url></lok></fnt></kap>
  <snc mrk="afabl.mal0a.KOMUNE">
    <dif>
      Montranta a&ubreve; esprimanta malbonvolon, malfavoran humoron:
      <ekz>
        lia mal<tld/>a viza&gcirc;o iom glati&gcirc;is
        <fnt>
          <bib>BdV</bib>
        </fnt>;
      </ekz>
      <ekz>
        malgranda homo kun eksterordinare mal<tld/>a kaj malkontenta viza&gcirc;o elvenis
        <fnt>
          <bib>BdV</bib>
        </fnt>;
      </ekz>
      <ekz>
        li havis nur tre mal<tld/>an opinion pri &scirc;ia prudento, &ccirc;ar &scirc;i nur malofte
        zorgadis pri abstraktaj konsideradoj
        <fnt>
          <bib>BdV</bib>
        </fnt>;
      </ekz>
      <ekz>
        <ind>rigardi mal<tld/>e</ind>
        <fnt><bib>PrV</bib></fnt>.
        <trd lng="fr">regarder de <ind>travers</ind></trd>
      </ekz>
      <ekz>
        li &scirc;ajnigis sin fremda al ili kaj parolis kun ili mal<tld/>e
        <fnt>
          <bib>MT</bib>
          <lok>Genezo 42:7</lok>
        </fnt>;
      </ekz>
      <ekz>
        la gardostaranto mal<tld/>e akceptis ilin kaj batis ilin per la pafilo
        <fnt>
          <bib>ElektFab</bib>
          <lok>Du fratoj</lok>
        </fnt>.
      </ekz>
    </dif>
    <refgrp tip="vid">
