<drv mrk="oportu.mal0a">
  <kap>mal<tld/>a</kap>
  <snc mrk="oportu.mal0a.malkonvena">
    <dif>
      Malfacile uzebla; misadaptita al sia destino; <ref cel="lac.0iga">laciga</ref>:
      <ekz>
        tiu &ccirc;i simbola skribado <klr>[&#8230;]</klr> estas tre mal<tld/>a kaj malfacile uzebla
        <fnt>
          <bib>FK</bib>
          <lok>Fundamenta Krestomatio de la lingvo Esperanto</lok>
        </fnt>;
      </ekz>
      <ekz>
        por kio veturigas kun si la homoj tiom da multpeza, mal<tld/>a, grandampleksa
        &scirc;ar&gcirc;o
        <fnt>
          <bib>Metrop</bib>
        </fnt>?
      </ekz>
      <ekz>
        la baso povas bonege ta&ubreve;gi por pezaj, gravaj paroladoj, sed &gcirc;i estas mal<tld/>a
        por <klr>[&#8230;]</klr> aliaj paroladoj
        <fnt>
          <bib>Ret</bib>
          <lok>Dua Parto</lok>
        </fnt>.
      </ekz>
    </dif>
    <refgrp tip="vid">
      <ref cel="komfor.mal0a">malkomforta</ref>
    </refgrp>
    <trdgrp lng="ca">
      <trd>inc&ograve;mode</trd>,
      <trd>gens <ind>pr&agrave;ctic</ind></trd>
    </trdgrp>
    <trdgrp lng="de">
      <trd>unzweckm&auml;&szlig;ig</trd>,
      <trd>ungeeignet</trd>
    </trdgrp>
  <trdgrp lng="id">
    <trd>tidak berguna</trd>,
    <trd>tidak bermanfaat</trd>,
    <trd>tidak berfaedah</trd>,
    <trd>tidak menguntungkan</trd>,
    <trd>tidak praktis</trd>
  </trdgrp>
  </snc>
  <snc mrk="oportu.mal0a.maltrafa">
    <dif>
      &Gcirc;ena pro nekonveneco de la situacio:
      <ekz>
        pro la mal<tld/>a sintenado en kiu li trovi&gcirc;is, li ne povis celi sufi&ccirc;e &gcirc;uste
        <fnt>
          <bib>KPr</bib>
          <lok>&Ccirc;apitro Kvara</lok>
        </fnt>;
      </ekz>
      <ekz>
        mi timis veni al vi en mal<tld/>a horo
        <fnt>
          <bib>IdO</bib>
          <lok>Dua Parto</lok>
        </fnt>;
      </ekz>
      <ekz>
        kiamaniere liberi&gcirc;i de la mal<tld/>aj gastoj
        <fnt>
          <bib>ElektFab</bib>
