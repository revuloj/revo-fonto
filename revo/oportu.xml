<?xml version="1.0"?>
<!DOCTYPE vortaro SYSTEM "../dtd/vokoxml.dtd">
<vortaro>
<art mrk="$Id: oportu.xml,v 1.39 2026/05/30 22:00:22 revo Exp $">
<kap>
  <ofc>*</ofc>
  <rad>oportun</rad>/a <fnt><bib>UV</bib></fnt>
</kap>
<drv mrk="oportu.0a">
  <kap><ofc>*</ofc><tld/>a</kap>
  <snc mrk="oportu.0a.konvena">
    <dif>
      Facile <ref tip="super" cel="uz.0ebla">uzebla</ref>; bone adaptita al sia destino;
      ne laciga:
      <ekz>
        <klr>[la artikolo]</klr> estas <tld/>a sed ne necesa
        <fnt><bib>F</bib>, <lok>&FE; 27</lok></fnt>;
      </ekz>
      <ekz>
        &ccirc;io estas por mi permesata, sed ne &ccirc;io estas <tld/>a
        <fnt>
          <bib>NT</bib>
          <lok>I. Korintanoj 6:12</lok>
        </fnt>;
      </ekz>
      <ekz>
        elkonduku min, mi petas, per pli mallonga kaj pli <tld/>a vojo
        <fnt>
          <bib>Far3</bib>
          <lok>&Ccirc;apitro VII</lok>
        </fnt>;
      </ekz>
      <ekz>
        <klr>[vi]</klr> elrigardis por vi <tld/>an lokon
        <fnt>
          <bib>MT</bib>
          <lok>Jesaja 57:8</lok>
        </fnt>;
      </ekz>
      <ekz>
        la amata kaj amanta edzo meze de la urba bruo aran&gcirc;is por &scirc;i molan, varman kaj
        <tld/>an neston
        <fnt>
          <bib>Marta</bib>
        </fnt>;
      </ekz>
      <ekz>
        estas tre <tld/>a <klr>[&#8230;]</klr>, ke mia fratino kaj mi <klr>[&#8230;]</klr> havas la
        samajn korpmezurojn, unu sola el ni iras en magazenoj, a&ccirc;etas por amba&ubreve;
        <fnt>
          <bib>ChL</bib>
          <lok>Noto De L&#8217; A&ubreve;toro</lok>
        </fnt>;
      </ekz>
      <ekz>
        la efektiva nombro da vortoj, al kiuj oni anstata&ubreve; la formo Esperanta povus doni
        formon pli <tld/>an, prezentas ne pli ol iajn 10%
        <fnt>
          <bib>EE</bib>
          <lok>VII</lok>
        </fnt>.
      </ekz>
    </dif>
    <refgrp tip="vid">
      <ref cel="komfor.0a">komforta</ref>,
      <ref cel="konven.0a">konvena</ref>,
      <ref cel="tauxg.0a">ta&ubreve;ga</ref>,
      <ref cel="util.0a">utila</ref>
    </refgrp>
    <trdgrp lng="ca">
      <trd>c&ograve;mode</trd>,
      <trd>pr&agrave;ctic</trd>,
      <trd>&uacute;til</trd>
    </trdgrp>
    <trdgrp lng="de">
      <trd>zweckm&auml;&szlig;ig</trd>,
      <trd>n&uuml;tzlich</trd>,
      <trd>annehmlich</trd>,
      <trd>geeignet</trd>
    </trdgrp>
    <trd lng="hu">k&eacute;nyelmes</trd>
    <trdgrp lng="id">
      <trd><baz>guna</baz>berguna</trd>,
      <trd><baz>manfaat</baz>bermanfaat</trd>,
      <trd><baz>faedah</baz>berfaedah</trd>,
      <trd><baz>untung</baz>menguntungkan</trd>,
      <trd>praktis</trd>
    </trdgrp>
    <trd lng="oc">aisit</trd>
    <trd lng="ru">&c_u;&c_d;&c_o;&c_b;&c_n;&c_y;&c_j;</trd>
  </snc>
  <snc mrk="oportu.0a.trafa">
    <dif>
      Faciliganta sukceson a&ubreve; prosperon pro sia &gcirc;usta konveneco:
      <ekz>
        vi ne povis veni en pli <tld/>a tempo
        <fnt>
          <bib>FK</bib>
          <lok>Fundamenta Krestomatio de la lingvo Esperanto</lok>
        </fnt>;
      </ekz>
      <ekz>
        mi parolos al vi en tempo pli <tld/>a
        <fnt>
          <bib>Rabistoj</bib>
          <lok>Akto Unua</lok>
        </fnt>;
      </ekz>
      <ekz>
        <klr>[mi]</klr> atendis <tld/>an momenton, por priparoli la aferon kun vi
        <fnt>
          <bib>MrA</bib>
          <lok>&Ccirc;apitro XII</lok>
        </fnt>;
      </ekz>
      <ekz>
        <ind><tld/>a okazo</ind>
        <fnt>
          <bib>I&scirc;tar</bib>
          <lok>&Ccirc;apitro II</lok>
        </fnt>;
        <trd lng="hu">megfelel&odblac; alkalom</trd>
      </ekz>
      <ekz>
        a&gcirc;o maljuna ne estas <tld/>a
        <fnt><bib>PrV</bib></fnt>.
      </ekz>
    </dif>
    <refgrp tip="vid">
      <ref cel="adekva.0a">adekvata</ref>,
      <ref cel="konfor.cel0a">celkonforma</ref>,
      <ref cel="favor.0a">favora</ref>,
      <ref cel="konsen.0ebla">konsentebla</ref>,
      <ref cel="konfor.0a.celkonforma">konforma<sncref/></ref>,
      <ref cel="konven.0a">konvena</ref>
    </refgrp>
    <trdgrp lng="ca">
      <trd>oport&uacute;</trd>,
      <trd>adequat</trd>,
      <trd>indicat</trd>
      <trd>escaient</trd>
    </trdgrp>
    <trdgrp lng="de">
      <trd>angemessen</trd>,
      <trd>angebracht</trd>,
      <trd>g&uuml;nstig</trd>
    </trdgrp>
    <trdgrp lng="hu">
      <trd>alkalmas</trd>,
      <trd>megfelel&odblac;</trd>
    </trdgrp>
    <trdgrp lng="id">
      <trd>cocok</trd>,
      <trd>pantas</trd>,
      <trd>pas</trd>,
      <trd>patut</trd>,
      <trd>tepat</trd>,
      <trd>suai</trd>,
      <trd><baz>suai</baz>sesuai</trd>
    </trdgrp>
    <trdgrp lng="ru">
      <trd>&c_u;&c_d;&c_o;&c_b;&c_n;&c_y;&c_j;</trd>,
      <trd>&c_p;&c_o;&c_d;&c_h;&c_o;&c_d;&c_ja;&c_shch;&c_i;&c_j;</trd>,
      <trd>&c_u;&c_m;&c_je;&c_s;&c_t;&c_n;&c_y;&c_j;</trd>
    </trdgrp>
  </snc>
  <rim>
    La senco de <ref cel="oportu.0a.konvena"><tld/>a<sncref/></ref>
    estas malpli ampleksa ol tiu de
    <em>komforta</em>: estas <tld/>aj nur apartaj simplaj objektoj,
    komfortaj povas esti vivo, aran&gcirc;o ktp. Ekzemple fontoplumo estas
    <tld/>a sed ne komforta. Plie <em><tld/>a</em> estas pli objektiva
    (la <tld/>eco dependas de la pli malpli granda ta&ubreve;geco de la
    objekto), <em>komforta</em> estas pli subjektiva (la komforteco
    dependas de la humoro, de la animstato de la uzanto).
  </rim>
  <trdgrp lng="be">
    <trd>&c_z;&c_r;&c_u;&c_ch;&c_n;&c_y;</trd>,
    <trd>&c_d;&c_a;&c_r;&c_e;&c_ch;&c_n;&c_y;</trd>,
    <trd>&c_z;&c_d;&c_a;&c_t;&c_n;&c_y;</trd>,
    <trd>&c_p;&c_r;&c_y;&c_d;&c_a;&c_t;&c_n;&c_y;</trd>
  </trdgrp>
  <trdgrp lng="cs">
    <trd>oportunn&iacute;</trd>,
    <trd>pohodln&yacute;</trd>,
    <trd>vhodn&yacute;</trd>
  </trdgrp>
  <trd lng="de">opportun</trd>
  <trdgrp lng="es">
      <trd>pr&aacute;ctico</trd>,
      <trd>&uacute;til</trd>
    </trdgrp>
  <trdgrp lng="fr">
    <trd>opportun</trd>,
    <trd>pratique<klr tip="amb"> (adj.)</klr></trd>
  </trdgrp>
  <trdgrp lng="ja">
    <trd>&#20415;&#21033;&#12394;  <pr>&#12409;&#12435;&#12426;&#12394;</pr></trd>,
    <trd>&#20351;&#12356;&#12420;&#12377;&#12356;  <pr>&#12388;&#12363;&#12356;&#12420;&#12377;&#12356;</pr></trd>,
    <trd>&#22909;&#37117;&#21512;&#12394;  <pr>&#12371;&#12358;&#12388;&#12372;&#12358;&#12394;</pr></trd>,
    <trd>&#26178;&#23452;&#12434;&#24471;&#12383;  <pr>&#12376;&#12366;&#12434;&#12360;&#12383;</pr></trd>
  </trdgrp>
  <trdgrp lng="nl">
    <trd>gemakkelijk</trd>,
    <trd>doelmatig</trd>,
    <trd>geschikt</trd>
  </trdgrp>
  <trdgrp lng="pl">
    <trd>dogodny</trd>,
    <trd>wygodny</trd>,
    <trd>sposobny</trd>
  </trdgrp>
  <trdgrp lng="pt">
    <trd>oportuno</trd>,
    <trd>c&ocirc;modo</trd>,
    <trd>confort&aacute;vel</trd>,
    <trd>prop&iacute;cio</trd>,
    <trd>que vem a <ind>prop&oacute;sito</ind></trd>
  </trdgrp>
  <trdgrp lng="ro">
    <trd>&icirc;ndem&acirc;natic</trd>,
    <trd>confortabil</trd>,
    <trd>capabil</trd>
  </trdgrp>
  <trdgrp lng="sk">
    <trd>pohodln&yacute;</trd>,
    <trd>sp&ocirc;sobil&yacute;</trd>,
    <trd>upotrebite&lcaron;n&yacute;</trd>,
    <trd>vhodn&yacute;</trd>,
    <trd>v&yacute;hodn&yacute;</trd>
  </trdgrp>
  <trdgrp lng="uk">
    <trd>&c_z;&c_r;&c_u;&c_ch;&c_n;&c_i;&c_j;</trd>,
    <trd>&c_v;&c_i;&c_g;&c_ib;&c_d;&c_n;&c_i;&c_j;</trd>,
    <trd>&c_s;&c_l;&c_u;&c_sh;&c_n;&c_i;&c_j;</trd>,
    <trd>&c_s;&c_p;&c_r;&c_i;&c_ja;&c_t;&c_l;&c_i;&c_v;&c_i;&c_j;</trd>,
    <trd>&c_p;&c_ib;&c_d;&c_h;&c_o;&c_d;&c_ja;&c_shch;&c_i;&c_j;</trd>
  </trdgrp>
  <trdgrp lng="zh">
    <trd>&#20415;&#23452; <pr>bi&agrave;ny&iacute;</pr></trd>,
    <trd>&#24688;&#24403; <pr>qi&agrave;d&agrave;ng</pr></trd>,
    <trd>&#24688;&#30070; <pr>qi&agrave;d&agrave;ng</pr></trd>,
    <trd>&#36866;&#24403; <pr>sh&igrave;d&agrave;ng</pr></trd>,
    <trd>&#36969;&#30070; <pr>sh&igrave;d&agrave;ng</pr></trd>,
    <trd>&#23454;&#29992; <pr>sh&iacute;y&ograve;ng</pr></trd>,
    <trd>&#23526;&#29992; <pr>sh&iacute;y&ograve;ng</pr></trd>
  </trdgrp>
</drv>

<drv mrk="oportu.0e">
  <kap><ofc>*</ofc><tld/>e</kap>
  <dif>
    La&ubreve; <tld/>a maniero:
  </dif>
  <snc ref="oportu.0a.konvena" mrk="oportu.0e.konvene">
    <ekz>
      subtenante la kru&ccirc;on, por ke la virino povu
      trinki pli <tld/>e
      <fnt><bib>F</bib>, <lok>&FE; 15, la feino (da&ubreve;rigo)</lok></fnt>;
    </ekz>
    <ekz>
      kelkaj faras al si <tld/>e kaj sidi&gcirc;as
      <klr>(komfortigis sin)</klr>
      <fnt>
        <bib>RBa</bib>
        <lok>&Ccirc;apitro II</lok>
      </fnt>;
    </ekz>
    <ekz>
      <nom>Lemuel</nom> faris al si <tld/>e sur mola tapi&scirc;o apud la fajrujo
      <fnt>
        <bib>I&scirc;tar</bib>
        <lok>&Ccirc;apitro VI</lok>
      </fnt>;
    </ekz>
    <ekz>
      volu eniri en la laborejon, tie ni povos pli <tld/>e paroli pri la afero
      <fnt>
        <bib>Marta</bib>
      </fnt>;
    </ekz>
    <ekz>
      persono post persono ekstaris por pli <tld/>e rigardi tiajn artistojn
      <fnt>
        <bib>IdO</bib>
        <lok>Unua Parto</lok>
      </fnt>.
    </ekz>
    <trd lng="be">&c_z;&c_r;&c_u;&c_ch;&c_n;&c_a;</trd>
    <trd lng="ca">c&ograve;modament</trd>
    <trd lng="de">angenehm</trd>
    <trd lng="hu">k&eacute;nyelmesen</trd>
    <trdgrp lng="id">
      <trd><baz>cara</baz>secara berguna</trd>,
      <trd><baz>cara</baz>secara bermanfaat</trd>,
      <trd><baz>cara</baz>secara berfaedah</trd>,
      <trd><baz>cara</baz>secara menguntungkan</trd>,
      <trd><baz>cara</baz>secara praktis</trd>,
      <trd>dengan berguna</trd>,
      <trd>dengan bermanfaat</trd>,
      <trd>dengan berfaedah</trd>,
      <trd>dengan menguntungkan</trd>,
      <trd>dengan praktis</trd>
    </trdgrp>
    <trd lng="ru">&c_u;&c_d;&c_o;&c_b;&c_n;&c_o;</trd>
  </snc>
  <snc ref="oportu.0a.trafa" mrk="oportu.0e.trafe">
    <ekz>
      ne <tld/>e estas en la nuna momento tion priplori
      <fnt>
        <bib>I&scirc;tar</bib>
        <lok>&Ccirc;apitro XII</lok>
      </fnt>;
    </ekz>
    <ekz>
      ne estas <tld/>e fari tiel
      <fnt>
        <bib>MT</bib>
        <lok>Eliro 8:26</lok>
      </fnt>;
    </ekz>
    <ekz>
      se tia estas la rilato de viro al virino, ne estas <tld/>e edzi&gcirc;i
      <fnt>
        <bib>NT</bib>
        <lok>Mateo 19:10</lok>
      </fnt>.
    </ekz>
    <trdgrp lng="be">
      <trd>&c_d;&c_a;&c_r;&c_e;&c_ch;&c_y;</trd>,
      <trd>&c_d;&c_a; &c_m;&c_je;&c_s;&c_c;&c_a;</trd>
    </trdgrp>
    <trdgrp lng="ca">
      <trd>oportunament</trd>,
      <trd>venint al cas</trd>
    </trdgrp>
    <trdgrp lng="de">
      <trd>angemessen</trd>,
      <trd>annehmlich</trd>
    </trdgrp>
    <trdgrp lng="hu">
      <trd>megfelel&odblac;en</trd>,
      <trd>c&eacute;lir&aacute;nyosan</trd>
    </trdgrp>
    <trdgrp lng="id">
      <trd><baz>cara</baz>secara cocok</trd>,
      <trd><baz>cara</baz>secara pantas</trd>,
      <trd><baz>cara</baz>secara pas</trd>,
      <trd><baz>cara</baz>secara patut</trd>,
      <trd><baz>cara</baz>secara tepat</trd>,
      <trd><baz>cara</baz>secara sesuai</trd>,
      <trd>dengan cocok</trd>,
      <trd>dengan pantas</trd>,
      <trd>dengan pas</trd>,
      <trd>dengan patut</trd>,
      <trd>dengan tepat</trd>,
      <trd>dengan sesuai</trd>
    </trdgrp>
    <trd lng="ru">&c_u;&c_m;&c_je;&c_s;&c_t;&c_n;&c_o;</trd>
  </snc>
  <trdgrp lng="cs">
    <trd>pohodln&ecaron;</trd>,
    <trd>vhodn&ecaron;</trd>
  </trdgrp>
  <trdgrp lng="de">
    <trd>opportun</trd>,
    <trd>g&uuml;nstig</trd>
  </trdgrp>
  <trdgrp lng="fr">
    <trd>ais&eacute;ment</trd>,
    <trd>opportun&eacute;ment</trd>
  </trdgrp>
  <trdgrp lng="ja">
    <trd>&#20415;&#21033;&#12395;  <pr>&#12409;&#12435;&#12426;&#12395;</pr></trd>,
    <trd>&#20855;&#21512;&#12424;&#12367;  <pr>&#12368;&#12354;&#12356;&#12424;&#12367;</pr></trd>,
    <trd>&#37117;&#21512;&#12424;&#12367;  <pr>&#12388;&#12372;&#12358;&#12424;&#12367;</pr></trd>
  </trdgrp>
  <trdgrp lng="nl">
    <trd>gemakkelijk</trd>,
    <trd>doelmatig</trd>,
    <trd>geschikt</trd>
  </trdgrp>
  <trdgrp lng="pl">
    <trd>w&lstroke;a&sacute;ciwie</trd>,
    <trd>wygodnie</trd>,
    <trd>na r&eogonek;k&eogonek;</trd>
  </trdgrp>
  <trd lng="pt">oportunamente</trd>
  <trdgrp lng="ro">
    <trd>corect</trd>,
    <trd>confortabil</trd>,
    <trd>pe m&acirc;n&abreve;</trd>
  </trdgrp>
  <trdgrp lng="sk">
    <trd>pohodlne</trd>,
    <trd>vhodne</trd>
  </trdgrp>
  <trdgrp lng="uk">
    <trd>&c_z;&c_r;&c_u;&c_ch;&c_n;&c_o;</trd>,
    <trd>&c_v;&c_i;&c_g;&c_ib;&c_d;&c_n;&c_o;</trd>
  </trdgrp>
</drv>

<drv mrk="oportu.0o">
  <kap><tld/>o</kap>
  <snc mrk="oportu.0o.KOMUNE">
    <dif>
      Facilo, kiu rezultas de favoraj kondi&ccirc;oj:
      <ekz>
        estis multaj venantaj kaj irantaj, kaj ili ne havis <tld/>on e&ccirc;
        por man&gcirc;i
        <fnt><bib>NT</bib>, <lok>&Mar; 6:31</lok></fnt>;
      </ekz>
      <ekz>
        gastejoj establitaj por la <tld/>o de l' komercado
        <fnt>
          <bib>Kandid</bib>
          <lok>&Ccirc;apitro XVII</lok>
        </fnt>;
      </ekz>
      <ekz>
        kial centfoje dum la sama jaro la mar&scirc;rutoj estas &scirc;an&gcirc;ataj? &ccirc;u por <tld/>o de l&#8217;
        publiko
        <fnt>
          <bib>Metrop</bib>
        </fnt>?
      </ekz>
      <ekz>
        li ne surhavis togon, &ccirc;ar la <tld/>o kaj kutimo ordonis demeti togojn por
        festenoj
        <fnt>
          <bib>QuV</bib>
          <lok>&Ccirc;apitro VII</lok>
        </fnt>.
      </ekz>
    </dif>
    <refgrp tip="sin">
      <ref cel="okaz.0o.bonsxanco">okazo<sncref/></ref>,
      <ref cel="sxanc.0o">&scirc;anco</ref>
    </refgrp>
    <refgrp tip="vid">
      <ref cel="komfor.0o">komforto</ref>,
      <ref cel="konven1.0o.gxenerale">konvencio<sncref/></ref>,
      <ref cel="konven.0eco">konveneco</ref>,
      <ref cel="kutim.0o.MOR">kutimo</ref>
    </refgrp>
  </snc>
  <trdgrp lng="be">
    <trd>&c_z;&c_r;&c_u;&c_ch;&c_n;&c_a;&c_s;&c_mol;&c_c;&c_mol;</trd>,
    <trd>&c_z;&c_r;&c_u;&c_ch;&c_n;&c_y; &c_v;&c_y;&c_p;&c_a;&c_d;&c_a;&c_k;</trd>,
    <trd>&c_n;&c_a;&c_g;&c_o;&c_d;&c_a;</trd>
  </trdgrp>
  <trd lng="ca">oportunitat<klr tip="amb"> (circumst&agrave;ncia favorable)</klr></trd>
  <trdgrp lng="cs">
    <trd>pohodl&iacute;</trd>,
    <trd>vhod.p&rcaron;&iacute;le&zcaron;itost</trd>
  </trdgrp>
  <trdgrp lng="de">
    <trd>Gelegenheit</trd>,
    <trd>Gunst <klr>(der Stunde...)</klr></trd>
  </trdgrp>
  <trd lng="en">opportunity</trd>
  <trdgrp lng="fr">
    <trd>aises</trd>,
    <trd>occasion favorable</trd>,
    <trd>opportunit&eacute;</trd>
  </trdgrp>
  <trd lng="hu">megfelel&odblac; alkalom</trd>
  <trdgrp lng="id">
    <trd>kans</trd>,
    <trd><baz>sempat</baz>kesempatan</trd>,
    <trd><baz>luang</baz>peluang</trd>,
    <trd>oportunitas</trd>
  </trdgrp>
  <trdgrp lng="ja">
    <trd>&#22909;&#27231;  <pr>&#12371;&#12358;&#12365;</pr></trd>,
    <trd>&#22909;&#37117;&#21512;  <pr>&#12371;&#12358;&#12388;&#12372;&#12358;</pr></trd>
  </trdgrp>
  <trdgrp lng="pl">
    <trd>wygoda</trd>,
    <trd>okazja</trd>,
    <trd>sprzyjaj&aogonek;ce zdarzenie</trd>
  </trdgrp>
  <trdgrp lng="ro">
    <trd>confort</trd>,
    <trd>oportunitate</trd>,
    <trd>eveniment favorabil</trd>
