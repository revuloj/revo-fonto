<drv mrk="oportu.0ismo">
  <kap><tld/>ismo</kap>
  <snc mrk="oportu.0ismo.POL">
    <uzo tip="fak">POL</uzo>
    <dif>
      Politika a&ubreve; ordinara sinteno, la&ubreve; kiu oni devas atenti la
      cirkonstancajn <tld/>a&jcirc;ojn pli ol la principojn:
      <ekz>
        nomante la gvidantaron de SAT <tld/>isma, nemarksisma, kontra&ubreve;soveta kaj
        etbur&gcirc;a, la sovetaj SAT-anoj kaj iliaj samideanoj alilandaj trovi&gcirc;is sub la
        premo de la decidoj de <nom>Komintern</nom>
        <fnt>
          <bib>EeP</bib>
          <lok>Kvara Parto</lok>
        </fnt>;
      </ekz>
      <ekz>
        pro <tld/>ismo la popolo finfine decidis tiel vo&ccirc;doni, subtenante la flankon,
        kiu aperas pli forta
        <fnt>
          <bib>Monato</bib>
          <aut>Zlatko Ti&scaron;ljar</aut>
          <vrk><url ref="&Monato;/2003/008112.html">Jes al E&ubreve;ropo sed &ccirc;u &scirc;anco perdita?</url></vrk>
          <lok>2003</lok>
        </fnt>;
      </ekz>
      <ekz>
        ekzistas ne nur <tld/>ismo, sed anka&ubreve; &leftquot;politika toleremo&rightquot;
        <fnt>
          <bib>Monato</bib>
          <aut>Wolfgang Guenther</aut>
          <vrk><url ref="&Monato;/2008/009537.php">&Ccirc;u bojkoto? (12)</url></vrk>
          <lok>2008</lok>
        </fnt>;
      </ekz>
      <ekz>
        registaro aganta tiel ne povas eviti ripro&ccirc;on de <tld/>ismo, se subite ne plu
        validas la anta&ubreve;aj argumentoj pri protektado de sano
        <fnt>
          <bib>Monato</bib>
          <aut>Stefan Maul</aut>
          <vrk><url ref="&Monato;/2009/009750.php">Kaspreto-teatro</url></vrk>
          <lok>2009</lok>
        </fnt>.
      </ekz>
    </dif>
    <refgrp tip="vid">
      <ref cel="pragma.0ismo.FIL">pragmatismo</ref>,
      <ref cel="util.0ismo">utilismo</ref>
    </refgrp>
  </snc>
  <trd lng="be">&c_a;&c_p;&c_a;&c_r;&c_t;&c_u;&c_n;&c_ib;&c_z;&c_m;</trd>
