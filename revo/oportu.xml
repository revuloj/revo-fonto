<drv mrk="oportu.0ajxo">
  <kap><tld/>a&jcirc;o</kap>
  <snc mrk="oportu.0ajxo.KOMUNE">
    <dif>
      Faciliga a&jcirc;o a&ubreve; flanko de situacio:
      <ekz>
        posta &ccirc;ambreto <klr>[&#8230;]</klr> ornamita kaj provizita je &ccirc;iuspecaj <tld/>a&jcirc;oj,
        kiujn amaj koroj povis proponi
        <fnt>
          <bib>MrA</bib>
          <lok>&Ccirc;apitro IV</lok>
        </fnt>;
      </ekz>
      <ekz>
        tiuj konsideroj jam sufi&ccirc;e plipezas &ccirc;iujn favorajn <tld/>a&jcirc;ojn, kiuj sin povus
        prezenti hodia&ubreve;
        <fnt>
          <bib>I&scirc;tar</bib>
          <lok>&Ccirc;apitro XV</lok>
        </fnt>;
      </ekz>
      <ekz>
        krom tiuj &ccirc;i naturaj vortfaraj <tld/>a&jcirc;oj, kiujn la lingvo Esperanto havas, vi
        trovos en &gcirc;i ankora&ubreve; apartajn <klr>[&#8230;]</klr> rimedojn, kiuj enkondukas
        grandegan ekonomion &ccirc;e la lernado de la vortoj
        <fnt>
          <bib>EE</bib>
          <lok>V</lok>
        </fnt>;
      </ekz>
      <ekz>
        &Ccirc;inio nepre disponigu grandegajn monsumojn al instruado, publika higieno,
        <klr>[&#8230;]</klr> konstruado de bazaj <tld/>a&jcirc;oj
        <fnt>
          <bib>Monato</bib>
          <aut>Mu Binghua</aut>
          <vrk><url ref="&Monato;/2006/009055.php">Pezaj enlandaj &scirc;ar&gcirc;oj por la
          registaro</url></vrk>
          <lok>2006</lok>
        </fnt>.
      </ekz>
    </dif>
  </snc>
  <trd lng="be">&c_v;&c_y;&c_g;&c_o;&c_d;&c_a;</trd>
  <trdgrp lng="ca">
    <trd>comoditat</trd>,
    <trd>cosa <ind>&uacute;til</ind></trd>
  </trdgrp>
