    <trd><baz>pantas</baz>kepantasan</trd>,
    <trd><baz>patut</baz>kepatutan</trd>,
    <trd><baz>suai</baz>kesesuaian</trd>,
    <trd><baz>tepat</baz>ketepatan</trd>
  </trdgrp>
  </snc>
  <trd lng="be">&c_z;&c_r;&c_u;&c_ch;&c_n;&c_a;&c_s;&c_mol;&c_c;&c_mol;</trd>
