<drv mrk="oportu.mal0ajxo">
  <kap>mal<tld/>a&jcirc;o</kap>
  <snc mrk="oportu.mal0ajxo.KOMUNE">
    <dif>
      Mal<tld/>a afero a&ubreve; kondi&ccirc;o, kiu &gcirc;enas:
      <ekz>
        kian rekompencon oni ricevas pro &ccirc;iuj tiuj mal<tld/>a&jcirc;oj
        <fnt>
          <bib>Fab1</bib>
          <lok>Ligo de amikeco</lok>
        </fnt>?
      </ekz>
      <ekz>
        ni zorge pesu la <tld/>a&jcirc;ojn kaj la mal<tld/>a&jcirc;ojn kaj decidu
        <fnt><bib>I&scirc;tar</bib>, <lok>&ccirc;apitro 15a, Omar fari&gcirc;as
        ventegocentro</lok></fnt>;
      </ekz>
      <ekz>
        ia natura konstanta &ccirc;efo <klr>[&#8230;]</klr> prezentas gravan mal<tld/>a&jcirc;on por nia
        afero, &ccirc;ar &gcirc;i donas al la afero kvaza&ubreve; personan karakteron
        <fnt>
          <bib>Paroloj</bib>
          <vrk>Parolado anta&ubreve; la Oka Kongreso Esperantista en Krakow en la 11a de a&ubreve;gusto 1912</vrk>
        </fnt>;
      </ekz>
      <ekz>
        nia funebra ceremoniaro certigas al la ombro fortojn, gardas &gcirc;in de la
        mal<tld/>a&jcirc;oj kaj de la sopiro al la tero
        <fnt>
          <bib>Far2</bib>
          <lok>&Ccirc;apitro XXII</lok>
        </fnt>;
      </ekz>
      <ekz>
        elturmentita de la multaj mal<tld/>a&jcirc;oj
        <fnt>
          <bib>Marta</bib>
        </fnt>;
      </ekz>
      <ekz>
        por eviti eblajn mal<tld/>a&jcirc;ojn en la okazo, se oni Vin rekonus <klr>[&#8230;]</klr>,
        pli bone ke ni <klr>[&#8230;]</klr> iru en la urbon vespere
        <fnt>
          <bib>BdV</bib>
          <lok>La Batalo de l' Vivo</lok>
        </fnt>;
      </ekz>
      <ekz>
        la plej granda mal<tld/>a&jcirc;o de nia Akademio estas la perdo de &ccirc;iu tria jaro dum
        la okazigo de la elektoj
        <fnt>
          <bib>LOdE</bib>
          <lok>2000, No 3 (65)</lok>
        </fnt>.
      </ekz>
    </dif>
  </snc>
  <trdgrp lng="be">
    <trd>&c_n;&c_ja;&c_z;&c_r;&c_u;&c_ch;&c_n;&c_a;&c_s;&c_mol;&c_c;&c_mol;</trd>,
