<drv mrk="oportu.mal0i">
  <kap>mal<tld/>i</kap>
  <gra><vspec>x</vspec></gra>
  <snc mrk="oportu.mal0i.KOMUNE">
    <dif>
      Esti mal<tld/>a, <ref tip="vid" cel="embara.0i">embarasi</ref>
      iun:
      <ekz>
        tiam mi vin ne pli longe mal<tld/>os
        <fnt><bib>FK</bib>, <lok>4, rakontoj, la porcio da glacia&jcirc;o,
        (rakonto de L. Dilling, tradukita de Eduard Hall el Joensuu
        (Finnlando))</lok></fnt>;
      </ekz>
      <ekz>
        amba&ubreve; estis apartigite kondukataj en &ccirc;ambrojn, kie regis ega fre&scirc;o kaj en kiuj
        la suno neniam mal<tld/>is <klr>(t.e. &ccirc;eloj de malliberejo)</klr>
        <fnt>
          <bib>Kandid</bib>
          <lok>&Ccirc;apitro VI</lok>
        </fnt>;
      </ekz>
      <ekz>
        por la po&scirc;komputilo gravas ke la ekrano estu sufi&ccirc;e granda <klr>[sed]</klr> tiom
        granda po&scirc;telefono tute mal<tld/>as
        <fnt>
          <bib>LOdE</bib>
          <lok>2002, &#8470; 10</lok>
        </fnt>.
      </ekz>
    </dif>
