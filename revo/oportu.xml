<drv mrk="oportu.0eco">
  <kap><tld/>eco</kap>
  <dif>
    Karaktero de io <tld/>a.
  </dif>
  <snc ref="oportu.0a.konvena" mrk="oportu.0eco.konveneco">
    <ekz>
      por <tld/>eco de la vizitantoj, la verando estas disigita en apartaj kabinetoj
      <fnt>
        <bib>Metrop</bib>
      </fnt>;
    </ekz>
    <ekz>
      ricevinte de vi leteron <klr>[&#8230;]</klr> kaj kompreninte &gcirc;in, kvankam
      li la lingvon ne lernis, via adresito vidos praktike la <tld/>econ
      de l' lingvo
        <fnt>
          <bib>DL</bib>
          <lok>Dua Libro de l' Lingvo Internacia</lok>
        </fnt>;
    </ekz>
    <ekz>
      la homoj vidas en la Esperantismo ne sole aferon de egoisma <tld/>eco, sed
      gravan ideon
      <fnt>
        <bib>Paroloj</bib>
        <vrk>Parolado anta&ubreve; la Tria Kongreso Esperantista en Cambridge en la 12a de a&ubreve;gusto
        1907</vrk>
      </fnt>.
    </ekz>
    <trd lng="ca">comoditat</trd>
    <trd lng="hu">k&eacute;nyelmess&eacute;g</trd>
    <trdgrp lng="id">
      <trd><baz>guna</baz>kebergunaan</trd>,
      <trd><baz>manfaat</baz>kebermanfaatan</trd>,
      <trd><baz>faedah</baz>keberfaedahan</trd>,
      <trd><baz>praktis</baz>kepraktisan</trd>
    </trdgrp>
    <trd lng="ru">&c_u;&c_d;&c_o;&c_b;&c_n;&c_o;&c_s;&c_t;&c_mol;</trd>
  </snc>
  <snc ref="oportu.0a.trafa" mrk="oportu.0eco.trafeco">
    <ekz>
      mi ne vidas la <tld/>econ de tiu klopodo, se vi estas certa
      malsukcesi;
    </ekz>
    <ekz>
      pro<tld/>eca cedo
      <fnt>
        <bib>Homaranismo</bib>
        <vrk>Homaranismo</vrk>
      </fnt>;
    </ekz>
    <ekz>
      la temo de la kongreso <klr>[estis]</klr> &leftquot;lingvo, kulturo kaj <tld/>ecoj&rightquot;
      <fnt>
        <bib>LOdE</bib>
        <lok>2002, &#8470; 10</lok>
      </fnt>.
    </ekz>
    <trd lng="ca">oportunitat<klr tip="amb"> (qualitat d'oport&uacute;)</klr></trd>
    <trdgrp lng="hu">
      <trd>alkalmass&aacute;g</trd>,
      <trd>megfelel&odblac;s&eacute;g</trd>
    </trdgrp>
  <trdgrp lng="id">
