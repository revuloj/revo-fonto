<kap>
  <ofc>*</ofc>
  <rad>enigm</rad>/o <fnt><bib>UV</bib></fnt>
</kap>

<drv mrk="enigm.0o">
  <kap><ofc>*</ofc><tld/>o</kap>
  <snc mrk="enigm.0o.SPO">
    <uzo tip="fak">SPO</uzo>
    <dif>
      Malfacila proponata divenota&jcirc;o:
      <ekz>
        klarigi, solvi <tld/>on;
      </ekz>
      <ekz>
        ili ne povis solvi la <tld/>on dum tri tagoj
        <fnt>
          <bib>MT</bib>
          <lok>Ju&gcirc;istoj 14:14</lok>
        </fnt>;
      </ekz>
      <ekz>
        Mi parolas kun li, <klr>[&#8230;]</klr> malka&scirc;e, ne per <tld/>oj
        <fnt>
          <bib>MT</bib>
          <lok>Nombroj 12:8</lok>
        </fnt>;
      </ekz>
      <ekz>
        la <tld/>o simple solvi&gcirc;as
        <fnt>
          <bib>PrV</bib>
        </fnt>.
      </ekz>
    </dif>
    <trdgrp lng="ca">
      <trd>enigma</trd>,
      <trd>endevinalla</trd>
    </trdgrp>
    <trd lng="de">Ratespiel</trd>
    <trd lng="hu">rejtv&eacute;ny</trd>
    <trd lng="pl">zagadka</trd>
  </snc>
  <snc mrk="enigm.0o.FIG">
    <uzo tip="stl">FIG</uzo>
    <dif>
      Malklara, malfacile komprenebla afero:
      <ekz>
        la bela kaj juna viza&gcirc;o de Marta tute ne prezentis malfacile solveblan <tld/>on
        <fnt>
          <bib>Marta</bib>
        </fnt>;
      </ekz>
      <ekz>
        kiaj armiloj de instruiteco, volo a&ubreve; sperto povis servi &scirc;in en la batalo kontra&ubreve;
        la komplika&jcirc;oj de la socia vivo, kontra&ubreve; la mizero, blinda okazo, soleco? en
        &ccirc;i tiuj demandoj ku&scirc;is la <tld/>o de &scirc;ia estonteco
        <fnt>
          <bib>Marta</bib>
        </fnt>;
      </ekz>
      <ekz>
        estis al mi nesolvebla <tld/>o, kiel ili povis suprenveni el tiu abismo
        <fnt>
          <bib>IdO</bib>
          <lok>Unua Parto</lok>
        </fnt>;
      </ekz>
      <ekz>
        Atlantido estas unu el la plej malnovaj <tld/>oj por la
        homaro
        <fnt>
          <aut>A. Cherpillod</aut>,
          <vrk>Atlantido - la perdita kontinento</vrk>,
          <bib>Monato</bib>,
          <lok>1997:7, p. 21a</lok>
        </fnt>.
      </ekz>
    </dif>
    <refgrp tip="vid">
      <ref cel="mister.0o">mistero</ref>
    </refgrp>
    <trd lng="ca">enigma</trd>
    <trd lng="de">Geheimnis</trd>
    <trdgrp lng="hu">
      <trd>rejt&eacute;ly</trd>,
      <trd>rejtv&eacute;ny <klr tip="amb">(&aacute;tv.)</klr></trd>
    </trdgrp>
    <trdgrp lng="pl">
      <trd>zagadka</trd>,
      <trd>enigma</trd>,
      <trd>tajemnica</trd>
    </trdgrp>
  </snc>
  <trdgrp lng="be">
    <trd>&c_z;&c_a;&c_g;&c_a;&c_d;&c_k;&c_a;</trd>,
    <trd>&c_e;&c_n;&c_ib;&c_g;&c_m;&c_a;</trd>
  </trdgrp>
  <trdgrp lng="cs">
    <trd>enigma</trd>,
    <trd>h&aacute;danka</trd>,
    <trd>taj</trd>,
    <trd>z&aacute;hada</trd>
  </trdgrp>
  <trd lng="de">R&auml;tsel</trd>
  <trdgrp lng="en">
    <trd>enigma</trd>,
    <trd>puzzle</trd>,
    <trd>riddle</trd>
  </trdgrp>
  <trdgrp lng="es">
    <trd>enigma</trd>,
    <trd>adivinanza</trd>
  </trdgrp>
  <trdgrp lng="fr">
    <trd>devinette</trd>,
    <trd>&eacute;nigme</trd>
  </trdgrp>
  <trdgrp lng="id">
    <trd>teka-teki</trd>,
    <trd>enigma</trd>,
    <trd>cangkriman</trd>
  </trdgrp>
  <trdgrp lng="ja">
    <trd>&#35598;  <pr>&#12394;&#12382;</pr></trd>,
    <trd>&#19981;&#21487;&#35299;&#12394;&#12418;&#12398; 
    <pr>&#12405;&#12363;&#12363;&#12356;&#12394;&#12418;&#12398;</pr></trd>
  </trdgrp>
  <trd lng="nl">raadsel</trd>
  <trdgrp lng="pt">
    <trd>enigma</trd>,
    <trd>advinha&ccedil;&atilde;o</trd>
  </trdgrp>
  <trd lng="ru">&c_z;&c_a;&c_g;&c_a;&c_d;&c_k;&c_a;</trd>
  <trdgrp lng="sk">
    <trd>h&aacute;danka</trd>,
    <trd>z&aacute;hada</trd>
  </trdgrp>
  <trd lng="uk">&c_z;&c_a;&c_g;&c_a;&c_d;&c_k;&c_a;</trd>
  <trdgrp lng="zh">
    <trd>&#35598;&#35486; <pr>m&iacute;y&#468;</pr></trd>,
    <trd>&#35598;&#22296; <pr>m&iacute;tu&aacute;n</pr></trd>,
    <trd>&#36855;&#38988; <pr>m&iacute;t&iacute;</pr></trd>,
    <trd>&#26234;&#21147;&#28216;&#25103; <pr>zh&igrave;l&igrave;y&oacute;ux&igrave;</pr></trd>,
    <trd>&#21713;&#35868; <pr>y&#462;m&iacute;</pr></trd>,
    <trd>&#35598; <pr>m&iacute;</pr></trd>,
    <trd>&#36855;&#23467; <pr>m&iacute;g&#333;ng</pr></trd>,
    <trd>&#35598;&#38988; <pr>m&iacute;t&iacute;</pr></trd>
  </trdgrp>
</drv>

<drv mrk="enigm.0a">
  <kap><tld/>a</kap>
  <snc mrk="enigm.0a.nekomprenebla">
    <dif>
      Malfacile komprenebla:
      <ekz>
        <tld/>a vorto, rigardo, frazo;
      </ekz>
      <ekz>
        tiu Sfinkso! abomena statuo, <tld/>a
        <fnt>
          <bib>Far2</bib>
          <lok>&Ccirc;apitro XXIV</lok>
        </fnt>;
      </ekz>
      <ekz>
        la vivo, &ccirc;i giganta, <tld/>a karusel'
        <fnt>
          <bib>LSB</bib>
          <lok>Al Paul Verlaine</lok>
        </fnt>;
      </ekz>
      <ekz>
        io <tld/>a kaj alloga estis en &scirc;ia rideto kaj en &scirc;ia
        mola varma rigardo
        <fnt>
          <aut>J. Modest</aut>,
          <vrk>Vetiha</vrk>,
          <bib>Monato</bib>,
          <lok>2001:2, p. 26a</lok>
        </fnt>;
      </ekz>
      <ekz>
        tiu peto sin turnas al tiu, por kiu &gcirc;i estas destinita, respondis la juna virino
        per <tld/>a tono
        <fnt>
          <bib>ChL</bib>
          <lok>&Ccirc;apitro Deka</lok>
        </fnt>;
      </ekz>
      <ekz>
        ricevinte tiun <tld/>an kaj ne subskribitan leteron, sinjorino de Prelongo
        sentis impreson de neesprimebla kortu&scirc;eco
        <fnt>
          <bib>KPr</bib>
          <lok>&Ccirc;apitro Deksesa</lok>
        </fnt>.
      </ekz>
    </dif>
    <refgrp tip="vid">
      <ref cel="sfinks.0a">sfinksa</ref>
    </refgrp>
  </snc>
  <trd lng="be">&c_z;&c_a;&c_g;&c_a;&c_d;&c_k;&c_a;&c_v;&c_y;</trd>
  <trdgrp lng="ca">
    <trd>enigm&agrave;tic</trd>,
    <trd>sibil&middot;l&iacute;</trd>
  </trdgrp>
  <trdgrp lng="cs">
    <trd>enigmatick&yacute;</trd>,
    <trd>h&aacute;dankov&yacute;</trd>,
    <trd>nesnadno srozumiteln&yacute;</trd>,
    <trd>tajemn&yacute;</trd>,
    <trd>t&ecaron;&zcaron;ko vysv&ecaron;tliteln&yacute;</trd>,
    <trd>z&aacute;hadn&yacute;</trd>
  </trdgrp>
  <trdgrp lng="de">
    <trd>r&auml;tselhaft</trd>,
    <trd>schleierhaft</trd>,
    <trd>geheimnisvoll</trd>
  </trdgrp>
  <trd lng="en">enigmatic</trd>
  <trd lng="es">enigm&aacute;tico</trd>
  <trdgrp lng="fr">
    <trd>&eacute;nigmatique</trd>,
    <trd>myst&eacute;rieux</trd>,
    <trd>sibyllin</trd>
  </trdgrp>
  <trd lng="he">&het;&yod;&dalet;&tav;&yod;</trd>
  <trdgrp lng="hu">
    <trd>rejt&eacute;lyes</trd>,
    <trd>titokzatos</trd>
  </trdgrp>
  <trdgrp lng="id">
    <trd>enigmatik</trd>,
    <trd>misterius</trd>,
    <trd>penuh teka-teki</trd>
  </trdgrp>
  <trdgrp lng="ja">
    <trd>&#35598;&#12398;  <pr>&#12394;&#12382;&#12398;</pr></trd>,
    <trd>&#35598;&#12417;&#12356;&#12383;  <pr>&#12394;&#12382;&#12417;&#12356;&#12383;</pr></trd>,
    <trd>&#19981;&#21487;&#35299;&#12394;  <pr>&#12405;&#12363;&#12363;&#12356;&#12394;</pr></trd>
  </trdgrp>
  <trd lng="nl">raadselachtig</trd>
  <trdgrp lng="pl">
    <trd>zagadkowy</trd>,
    <trd>enigmatyczny</trd>,
    <trd>tajemniczy</trd>
  </trdgrp>
  <trd lng="ru">&c_z;&c_a;&c_g;&c_a;&c_d;&c_o;&c_ch;&c_n;&c_y;&c_j;</trd>
  <trd lng="sk">z&aacute;hadn&yacute;</trd>
  <trdgrp lng="uk">
    <trd>&c_z;&c_a;&c_g;&c_a;&c_d;&c_k;&c_o;&c_v;&c_i;&c_j;</trd>,
    <trd>&c_t;&c_a;&c_jeu;&c_m;&c_n;&c_i;&c_ch;&c_i;&c_j;</trd>
  </trdgrp>
  <trdgrp lng="zh">
    <trd>&#24847;&#20041;&#28145;&#36828; <pr>y&igrave;y&igrave;sh&emacron;nyu&#462;n</pr></trd>,
    <trd>&#33707;&#26126;&#20854;&#22937; <pr>m&ograve;m&iacute;ngq&iacute;mi&agrave;o</pr></trd>,
    <trd>&#33707;&#27979;&#39640;&#28145; <pr>m&ograve;c&egrave;g&amacron;osh&emacron;n</pr></trd>,
    <trd>&#36094; <pr>z&eacute;</pr></trd>,
    <trd>&#33707;&#21517;&#20854;&#22937;&#30340; <pr>m&ograve;m&iacute;ngq&iacute;mi&agrave;ode</pr></trd>,
    <trd>&#22823;&#24785;&#19981;&#35299;&#30340; <pr>d&agrave;hu&ograve;b&ugrave;ji&ecaron;de</pr></trd>,
    <trd>&#31070;&#31192;&#33707;&#27979; <pr>sh&eacute;nm&igrave;m&ograve;c&egrave;</pr></trd>,
    <trd>&#26497;&#28145; <pr>j&iacute;sh&emacron;n</pr></trd>,
    <trd>&#33707;&#21517;&#20854;&#22937; <pr>m&ograve;m&iacute;ngq&iacute;mi&agrave;o</pr></trd>,
    <trd>&#31070;&#31192; <pr>sh&eacute;nm&igrave;</pr></trd>,
    <trd>&#22914;&#35598; <pr>r&uacute;m&iacute;</pr></trd>,
    <trd>&#22885; <pr>&agrave;o</pr></trd>,
    <trd>&#26080;&#27861;&#35299;&#37322; <pr>w&uacute;f&#462;ji&ecaron;sh&igrave;</pr></trd>,
    <trd>&#29572;&#22937; <pr>xu&aacute;nmi&agrave;o</pr></trd>
  </trdgrp>
</drv>

<drv mrk="enigm.krucvort0o">
  <kap>krucvort<tld/>o, <var><kap>vortkruc<tld/>o</kap></var></kap>
  <snc mrk="enigm.krucvort0o.SPO">
    <uzo tip="fak">SPO</uzo>
    <dif>
      Surpapera ludo, en kiu oni plenigas kradon per literoj,
      horizontale kaj vertikale skribante vortojn respondajn al
      difinoj:
      <ekz>
        &gcirc;ustan solvon de la vortkruc<tld/>o el la pasinta numero
        <klr>[&#8230;]</klr> sendis <nom>Nora</nom>
        <fnt>
        <aut>J. Tom&iacute;&scaron;ek</aut>,
          <vrk>okdirekta enigmo</vrk>,
          <lok><url ref="http://www.esperanto.sk/informiloj/eslovaka/ES-2004-2.pdf">
          Esperantisto slovaka, 2004-02</url></lok>
        </fnt>.
      </ekz>
    </dif>
  </snc>
  <trdgrp lng="be">
    <trd>&c_k;&c_r;&c_y;&c_zh;&c_a;&c_v;&c_a;&c_n;&c_k;&c_a;</trd>,
    <trd>&c_k;&c_r;&c_a;&c_s;&c_v;&c_o;&c_r;&c_d;</trd>
  </trdgrp>
  <trd lng="ca">mots encreuats</trd>
  <trd lng="cs">k&rcaron;&iacute;&zcaron;ovka</trd>
  <trd lng="de">Kreuzwortr&auml;tsel</trd>
  <trd lng="en">crossword puzzle</trd>
  <trd lng="es">crucigrama</trd>
  <trd lng="fr">mot-crois&eacute;</trd>
  <trd lng="hu">keresztrejtv&eacute;ny</trd>
  <trd lng="id">teka-teki silang</trd>
  <trd
  lng="ja">&#12463;&#12525;&#12473;&#12527;&#12540;&#12489;&#12539;&#12497;&#12474;&#12523;</trd>
  <trd lng="nl">kruiswoordraadsel</trd>
  <trd lng="pl">krzy&zdot;&oacute;wka</trd>
  <trd lng="sk">kr&iacute;&zcaron;ovka</trd>
  <trd lng="sv">korsord</trd>
  <trdgrp lng="zh">
    <trd>&#22635;&#23383;&#28216;&#25103; <pr>ti&aacute;nz&igrave;y&oacute;ux&igrave;</pr></trd>,
    <trd>&#22635;&#23383;&#28216;&#25103; <pr>ti&aacute;nz&igrave;y&oacute;ux&igrave;</pr></trd>
