<?xml version="1.0"?>
<!DOCTYPE vortaro SYSTEM "../dtd/vokoxml.dtd">

<vortaro>
  <art mrk="$Id: konvekt.xml,v 1.3 2026/07/16 14:36:29 afido Exp $">
    <kap>
      <rad>konvekt</rad>/i
      <fnt><bib>PIV1</bib></fnt>
    </kap>

<drv mrk="konvekt.0i">
  <kap><tld/>i</kap>
  <uzo tip="fak">FIZ</uzo>
  <snc mrk="konvekt.0i.FIZ">
    <gra><vspec>tr</vspec></gra>
    <dif>
      (pri fluo) Transporti kun si fizikan grandon (varmo, impulso, elektra &scirc;argo k.a.):
      <ekz>
        varma gaso <tld/>as <klr>[&#x2026;]</klr> la energion &gcirc;is la suna supra&jcirc;o
        <fnt>
          <bib>Viki</bib>
          <lok><url ref="https://eo.wikipedia.org/?curid=187"
              >Astronomio</url></lok>
        </fnt>.
      </ekz>
    </dif>
    <trdgrp lng="de">
      <trd>konvektieren</trd>,
      <trd>durch Str&ouml;mung transportieren</trd>
    </trdgrp>
  </snc>
</drv>

<drv mrk="konvekt.0o">
  <kap>
    <tld/>o, <var><kap><tld/>ado</kap></var>
  </kap>
  <snc mrk="konvekt.0o.FIZ">
    <uzo tip="fak">FIZ</uzo>
    <dif>
      Transporto de fizika grando kun fluo:
      <ekz>
        <ind>varmtranstransporto per kondukado</ind>,
        <klr>[&#x2026;]</klr> <tld/>o, radiado
        <fnt>
          <aut>Fabien van Mook</aut>
          <vrk><url ref="http://fabien.galerio.org/kofo/cirkuleroj/kofo12provizora.pdf"
              >Provizora inventaro de konstrufizikaj terminoj pri mastransporto kaj
              varmtransporto</url></vrk>
          <lok>p. 3</lok>
        </fnt>.
        <trd lng="de">W&auml;rmeleitung</trd>
      </ekz>
    </dif>
  </snc>
  <rim>
      En geosciencoj oni uzas terminojn <em>konvekcio</em> por relative vertikala kaj <em>advekcio</em>
      por horizontala fluo
      <fnt>
          <aut>Maurice Lewin</aut>
          <vrk><url ref="https://www.eventoj.hu/steb/vortaroj/meteologio/terminaro_ak.html"
              >Meteologia terminaro</url></vrk>
        </fnt>.
    </rim>
  <trdgrp lng="de">
    <trd>Konvektion <klr>(Physik)</klr></trd>,
    <trd>Str&ouml;mungstransport</trd>
  </trdgrp>
  <trd lng="en">convection</trd>
  <trd lng="fr">convection</trd>
</drv>

  </art>

