<?xml version="1.0"?>
<!DOCTYPE vortaro SYSTEM "../dtd/vokoxml.dtd">
<vortaro>
<art mrk="$Id: graviol.xml,v 1.9 2026/05/17 12:00:21 revo Exp $">
<kap>
  <rad>graviol</rad>/o <fnt><bib>PIV1</bib></fnt>
</kap>
<drv mrk="graviol.0o">
  <kap><tld/>o</kap>
  <snc mrk="graviol.0o.KUI">
    <uzo tip="fak">KUI</uzo>
    <dif>
      Man&gcirc;ebla <ref tip="super" cel="frukt.0o.KUI">frukto</ref> de
      <tld/>arbo, granda (15 &gcirc;is 30 centimetrojn longa) kun blanka,
      acideta karno:
      <ekz>
        ni gustumas glacia&jcirc;on je <tld/>o, planto el
        Amazon<klr>[i]</klr>o kun pruvita efiko kontra&ubreve; kancero
        <fnt>
          <aut>C. Pinardon. R. Sanz</aut>,
          <vrk>Du Bicikloj je la Horizonto</vrk>,
          <lok><url ref="http://www.horizonto.net/rakontoj/34-brazilo.html">
          Brazilo</url>, 2011</lok>
        </fnt>.
      </ekz>
    </dif>
  </snc>
  <trd lng="be">&c_a;&c_n;&c_o;&c_n;&c_a; &c_k;&c_a;&c_l;&c_ju;&c_ch;&c_a;&c_ja;</trd>
  <trd lng="ca">guan&agrave;bana</trd>
  <trd lng="de">Sauersack</trd>
  <trd lng="en">soursop</trd>
  <trd lng="fr">corossol</trd>
  <trd lng="pl">graviola</trd>
  <trdgrp lng="uk">
    <trd>&c_a;&c_n;&c_o;&c_n;&c_a; &c_k;&c_o;&c_l;&c_ju;&c_ch;&c_a;</trd>,
    <trd>&c_ja;&c_g;&c_o;&c_d;&c_a; &c_a;&c_n;&c_o;&c_n;&c_i; &c_k;&c_o;&c_l;&c_ju;&c_ch;&c_o;&c_ji;</trd>,
    <trd>&c_s;&c_m;&c_je;&c_t;&c_a;&c_n;&c_n;&c_je;&nbsp;&c_ja;&c_b;&c_l;&c_u;&c_k;&c_o;</trd>
  </trdgrp>
</drv>

<drv mrk="graviol.0arbo">
  <kap><tld/>arbo, <var><kap><tld/>ujo</kap></var></kap>
  <snc mrk="graviol.0arbo.BOT">
    <uzo tip="fak">BOT</uzo>
    <dif>
      Arbeto de tropika Sudameriko kun man&gcirc;eblaj fruktoj,
      kun folioj uzataj kiel trankviliga kuracilo,
      <ref tip="lst" lst="voko:botanikaj_specioj" cel="speci.0o.BIO">specio</ref>
      el familio <ref tip="malprt" cel="anonac.0oj">anonacoj</ref>
      (<trd lng="la">Annona muricata</trd>).
    </dif>
    <bld lok="&WCU;/thumb/6/6d/Annona_muricata_1.jpg/330px-Annona_muricata_1.jpg" prm="CC BY
    2.0"><tld/>o &ccirc;e <tld/>ujo, Botanika &Gcirc;ardeno, Saint-Gilles les Bains, Reunio
        <fnt>
          <aut>Damien Boilley el Parizo</aut>
          <lok><url
          ref="&WCW;/File:Annona_muricata_1.jpg">&WCW;/File:Annona_muricata_1.jpg</url></lok>
        </fnt>
    </bld>
  </snc>
  <trdgrp lng="be">
    <trd>&c_a;&c_n;&c_o;&c_n;&c_a; <klr>(&c_p;&c_l;&c_o;&c_d;)</klr></trd>,
    <trd>&c_g;&c_r;&c_a;&c_v;&c_ib;&c_jo;&c_l;&c_a;</trd>
  </trdgrp>
  <trd lng="ca">guanabaner</trd>
  <trdgrp lng="de">
    <trd>Stachelannone</trd>,
  </trdgrp>
  <trd lng="fr">corossolier</trd>
  <trdgrp lng="pl">
    <trd>flaszowiec mi&eogonek;kkociernisty</trd>,
    <trd>graviola</trd>
  </trdgrp>
  <trd lng="zh">&#21050;&#26524;&#30058;&#33620;&#26525; <pr>c&igrave;gu&#466;f&amacron;nl&igrave;zh&#299;</pr></trd>
</drv>
</art>

