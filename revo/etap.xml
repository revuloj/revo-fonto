<?xml version="1.0"?>
<!DOCTYPE vortaro SYSTEM "../dtd/vokoxml.dtd">
<vortaro>
<art mrk="$Id: etap.xml,v 1.28 2026/06/03 18:00:22 revo Exp $">
<kap>
  <ofc>8</ofc>
  <rad>etap</rad>/o <fnt><bib>PVEF</bib></fnt>
</kap>

<drv mrk="etap.0o">
  <kap><tld/>o</kap>
  <snc mrk="etap.0o.TRA">
    <dif>
      Parto de <ref tip="malprt" cel="vojagx.0o">voja&gcirc;o</ref>
      inter du haltejoj, precipe tia tuttaga parto:
      <ekz>
        la regimento faris hodia&ubreve; longan <tld/>on;
      </ekz>
      <ekz>
        oni veturas montbicikle la&ubreve; la tuta longeco de &leftquot;<nom>Alpentour</nom>&rightquot;
        a&ubreve; la&ubreve; parto de &gcirc;i,
        tio signifas tage en <tld/>o pasigi inter 50 kaj 120 km
        <fnt>
          <aut>E. Georgiev</aut>
          <vrk>900 km tra montbicikla paradizo</vrk>
          <lok>Monato, 2000-12, p. 20a</lok>
        </fnt>;
      </ekz>
    </dif>
  <trd lng="de">Tagesmarsch</trd>
  <trdgrp lng="en">
    <trd>distance covered</trd>,
    <trd>lap</trd>,
    <trd>length covered</trd>
  </trdgrp>
  <trdgrp lng="hu">
    <trd>menetszakasz</trd>,
    <trd>&uacute;tszakasz</trd>,
    <trd>etap</trd>
  </trdgrp>
  <trd lng="pl">etap</trd>
  <trd lng="pt">etapa</trd>
  <trd lng="ro">etap&abreve;</trd>
  </snc>
  <snc mrk="etap.0o.haltejo">
    <dif>
      Portempa halto, <ref tip="vid" cel="halt.0ejo">haltejo</ref> en voja&gcirc;o:
      <ekz>
        tiutempe ofte okazis, ke letero transiris plurajn landojn kaj ricevis stampon en
        &ccirc;iu <tld/>o
        <fnt>
          <aut>W. Klag</aut>
          <vrk>VIPE 2000, a&ubreve; &ccirc;u la po&scirc;tmarkoj malaperos?</vrk>
          <lok>Monato, 2000-09, p. 18a</lok>
        </fnt>.
      </ekz>
    </dif>
    <trdgrp lng="de">
     <trd>Rastplatz</trd>,
     <trd>Etappenort</trd>,
     <trd>Etappenziel</trd>,
     <trd>Etappe</trd>
    </trdgrp>
      <trdgrp lng="en">
      <trd>halting place</trd>,
      <trd>stopover</trd>
    </trdgrp>
    <trd lng="hu">pihen&odblac;hely</trd>
    <trd lng="pl">etap</trd>
    <trd lng="pt">etapa</trd>
    <trd lng="ro">etap&abreve;</trd>
  </snc>
  <snc mrk="etap.0o.stadio">
    <dif>
      Iu el la stabilaj statoj de pli vasta evoluo,
      <ref cel="stadi.0o.fazo">stadio<sncref/></ref>:
      <ekz>
        dum dormado sin sekvas pluraj <tld/>oj
        <fnt>
          <aut>P. S. Viana</aut>
          <vrk><url ref="https://www.lingq.com/lesson/bona-dormado-sana-cerbo-1181564/">Bona
          dormado, sana cerbo </url></vrk>
          <lok>Esperanta Retradio, 2014</lok>
        </fnt>.
      </ekz>
    </dif>
    <trd lng="de">Etappe</trd>
    <trdgrp lng="en">
      <trd>stage</trd>,
      <trd>period</trd>,
      <trd>phase</trd>
    </trdgrp>
    <trd lng="hu">szakasz</trd>
    <trdgrp lng="zh">
    <trd>&#31354;&#38291;&#27573; <pr>k&#333;ngji&#257;ndu&agrave;n</pr></trd>,
    <trd>&#26102;&#38388;&#27573; <pr>sh&iacute;ji&#257;ndu&agrave;n</pr></trd>,
    <trd>&#32102;&#39178;&#31449; <pr>g&ecaron;iy&#462;ngzh&agrave;n</pr></trd>,
    <trd>&#21333;&#36275;&#36339; <pr>d&#257;nz&uacute;ti&agrave;o</pr></trd>,
    <trd>&#38454;&#27573; <pr>ji&#275;du&agrave;n</pr></trd>
  </trdgrp>
</snc>
  <trdgrp lng="be">
    <trd>&c_e;&c_t;&c_a;&c_p;</trd>,
    <trd>&c_s;&c_t;&c_a;&c_d;&c_y;&c_ja;</trd>
  </trdgrp>
  <trdgrp lng="bg">
    <trd>&c_je;&c_t;&c_a;&c_p;</trd>,
    <trd>&c_s;&c_t;&c_a;&c_d;&c_i;&c_j;</trd>
  </trdgrp>
  <trd lng="ca">etapa</trd>
  <trdgrp lng="cs">
    <trd>b&ecaron;h</trd>,
    <trd>b&ecaron;h</trd>,
    <trd>etapa</trd>,
    <trd>f&aacute;ze</trd>,
    <trd>kolo z&aacute;vodu</trd>,
    <trd>st&aacute;dium</trd>,
    <trd>turnus</trd>,
    <trd>&uacute;sek cesty</trd>,
    <trd>&ccaron;&aacute;st z&aacute;vodu</trd>
  </trdgrp>
  <trd lng="es">etapa</trd>
  <trd lng="fr">&eacute;tape</trd>
  <trdgrp lng="ja">
    <trd>&#23487;&#21942;&#22320;  <pr>&#12375;&#12421;&#12367;&#12360;&#12356;&#12385;</pr></trd>,
    <trd>&#20241;&#25001;&#22320;  <pr>&#12365;&#12421;&#12358;&#12369;&#12356;&#12385;</pr></trd>,
    <trd>&#34892;&#31243;  <pr>&#12371;&#12358;&#12390;&#12356;</pr></trd>,
    <trd>&#36208;&#34892;&#21306;&#38291;  <pr>&#12381;&#12358;&#12371;&#12358;&#12367;&#12363;&#12435;</pr></trd>,
    <trd>&#27573;&#38542;  <pr>&#12365;&#12374;&#12399;&#12375;</pr></trd>
  </trdgrp>
  <trdgrp lng="nl">
    <trd>stadium</trd>,
    <trd>etappe</trd>
  </trdgrp>
  <trd lng="pl">etap</trd>
  <trd lng="pt">etapa</trd>
  <trd lng="ro">etap&abreve;</trd>
  <trdgrp lng="ru">
  <trd>&c_e;&c_t;&c_a;&c_p;</trd>,
  <trd>&c_s;&c_t;&c_a;&c_d;&c_i;&c_ja;</trd>
</trdgrp>
  <trdgrp lng="sk">
    <trd>f&aacute;za</trd>,
    <trd>&uacute;sek</trd>
  </trdgrp>
  <trdgrp lng="uk">
    <trd>&c_je;&c_t;&c_a;&c_p;</trd>,
    <trd>&c_s;&c_t;&c_a;&c_d;&c_ib;&c_ja;</trd>
  </trdgrp>
</drv>
</art>
