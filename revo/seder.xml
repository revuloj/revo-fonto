<?xml version="1.0"?>
<!DOCTYPE vortaro SYSTEM "../dtd/vokoxml.dtd">

<vortaro>
  <art mrk="$Id: seder.xml,v 1.3 2026/04/10 22:55:36 afido Exp $">
    <kap>
      <rad>Seder</rad>/o
    </kap>

<drv mrk="seder.0o">
  <kap><tld/>o</kap>
  <snc mrk="seder.0o.juda_festo">
    <uzo tip="fak">REL</uzo>
    <dif>
      Juda festo en la vespero de la dekkvara tago de
      <ref tip="prt" cel="nisan.0o">Nisano</ref>,  t.e.
      la vespero anta&ubreve; <ref tip="malprt" cel="pask.0o.hebrea">Pasko</ref>:
      <ekz>
        la rakonto <klr>(la Rabeno de Ba&hcirc;ara&hcirc;)</klr>
        komenci&gcirc;as &ccirc;e <tld/>o je la juda festo de Pesa&hcirc;o
        <fnt>
          <bib>Viki</bib>
          <lok><url ref="https://eo.wikipedia.org/?curid=845027"
              >La Rabeno de Ba&hcirc;ara&hcirc;</url></lok>
        </fnt>;
      </ekz>
      <ekz>
        &ccirc;e la paska man&gcirc;o, la <tld/>o, judoj kantas <nac>la'&scirc;ana ha'baa biru&scirc;alajim</nac> &leftquot;&gcirc;is la
        venonta jaro en Jerusalemo&rightquot;
        <fnt>
          <bib>Monato</bib>
          <vrk>La influo de la hebrea lingvo sur Esperanto</vrk>
        </fnt>.
      </ekz>
    </dif>
    <trd lng="de">Sederabend</trd>
    <trd lng="en">Passover Seder</trd>
    <trd lng="fr">s&eacute;der de Pessa'h</trd>
    <trd lng="he">&lamed;&#x5B5;&yod;&lamed; &he;&#x5B7;&samekh;&#x5B5;&#x5BC;&dalet;&#x5B6;&resh;</trd>
    <trd lng="pl">Seder</trd>
  </snc>
<trd lng="be">&c_s;&c_e;&c_d;&c_e;&c_r;</trd>
</drv>

  </art>

