<?xml version="1.0"?>
<!DOCTYPE vortaro SYSTEM "../dtd/vokoxml.dtd">
<vortaro>
<art mrk="$Id: liauxning.xml,v 1.2 2026/07/15 14:06:19 afido Exp $">
<kap>
    <rad>Lia&ubreve;ning</rad>/o <fnt><bib>LanLin</bib></fnt>,
    <var><kap><rad var="lj">Lja&ubreve;ning</rad>/o <fnt><bib>PIV2</bib></fnt></kap></var>
</kap>
<drv mrk="liauxning.0o">
  <kap><tld/>o,
  <var><kap><tld var="lj"/>o</kap></var></kap>
  <snc mrk="liauxning.0o.GEOG">
    <uzo tip="fak">GEOG</uzo>
    <uzo tip="fak">POL</uzo>
    <dif>
      Provinco en la nord-orienta parto de <ref tip="malprt" cel="cxin.CX0ujo">&Ccirc;inujo</ref> kun la
      &ccirc;efurbo <ref tip="prt" cel="sxenjang.0o">&Scirc;enjango</ref>:
      <ekz>
        nova&jcirc;oj pri la &ccirc;ina <klr>[&#x2026;]</klr> provinco <tld/>o
        <fnt>
          <aut>-</aut>
          <vrk><url ref="https://eo.wikinews.org/wiki/Kategorio:Lia%C5%ADningo">
          Kategorio: Lia&ubreve;ningo</url></vrk>
          <lok>Vikinova&jcirc;oj, 2015-01-04</lok>
        </fnt>;
      </ekz>
      <ekz>
        al &Scirc;enjango en la provinco <tld var="lj"/>o <klr>[&#x2026;]</klr> ni transmovi&gcirc;is per vagonaro
        <fnt>
          <aut>E. Miyoshi, trad. &Scirc;. Maeda</aut>
          <vrk><url ref="https://fr.scribd.com/document/1000007059/Mia-Poliomjelito-Esperanto">
          Mia poliomjelito mal&scirc;losis pordon al da&ubreve;ripova paco</url></vrk>
          <lok>2022</lok>
        </fnt>.
      </ekz>
    </dif>
  </snc>
  <trd lng="de">Liaoning</trd>
  <trd lng="fr">Liaoning</trd>
  <trdgrp lng="zh">
    <trd>&#x907C;&#x5BE7; <pr>Li&aacute;on&iacute;ng</pr></trd>,
    <trd>&#x8FBD;&#x5B81; <pr>Li&aacute;on&iacute;ng</pr></trd>
  </trdgrp>
</drv>
</art>

