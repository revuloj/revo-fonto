<?xml version="1.0"?>
<!DOCTYPE vortaro SYSTEM "../dtd/vokoxml.dtd">
<vortaro>
<art mrk="$Id: kaskad.xml,v 1.26 2026/07/02 16:16:43 revo Exp $">
<kap>
  <rad>kaskad</rad>/o <fnt><bib>JED</bib></fnt>
</kap>

<drv mrk="kaskad.0o">
  <kap><tld/>o</kap>
  <snc>
    <dif>
      Plur&scirc;tupa akvofalo.
    </dif>
    <trdgrp lng="ca">
      <trd>cascada</trd>,
      <trd>salt d&#8217;aigua</trd>,
      <trd>saltant</trd>,
      <trd>sallent</trd>
    </trdgrp>
    <trdgrp lng="de">
      <trd>Kaskade</trd>,
      <trd>Stufenwasserfall</trd>
    </trdgrp>
    <trdgrp lng="hu">
      <trd>l&eacute;pcs&odblac;s v&iacute;zes&eacute;s</trd>,
      <trd>zuhatag</trd>
    </trdgrp>
  </snc>
  <snc>
    <uzo tip="stl">FIG</uzo>
    <dif>
      Rapida, neretenebla fluo de io:
      <ekz>
        senfina <tld/>o da demandoj.
      </ekz>
    </dif>
    <trdgrp lng="ca">
      <trd>cascada</trd>,
      <trd>allau</trd>,
      <trd>reguitzell</trd>,
      <trd>tirallonga</trd>
    </trdgrp>
    <trdgrp lng="de">
      <trd>Kaskade</trd>,
      <trd>Schwall</trd>
    </trdgrp>
    <trdgrp lng="hu">
      <trd>&ouml;z&ouml;n</trd>,
      <trd>zuhatag</trd>
    </trdgrp>
  </snc>
  <snc>
    <uzo tip="fak">TEK</uzo>
    <dif>
      Grupo de sinsekve kunligitaj samtipaj aparatoj a&ubreve; konstrua&jcirc;oj:
      <ekz>
        <ind><tld/>a</ind> sistemo,
        <trd lng="ca">en <ind>cascada</ind></trd>
        <trdgrp lng="fr">
          <trd>de <ind>cascade</ind></trd>,
          <trd>en <ind>cascade</ind></trd>,
          <trd>cascad&eacute;</trd>
        </trdgrp>
      </ekz>
      <ekz>
        <tld/>a konekto,
      </ekz>
      <ekz>
        <tld/>a amplifilo.
      </ekz>
    </dif>
    <trdgrp lng="de">
      <trd>Kaskade</trd>,
      <trd>Batterie</trd>
    </trdgrp>
    <trd lng="hu">kaszk&aacute;d</trd>
  </snc>
  <rim>
    La&ubreve; <fnt><bib>BL</bib></fnt>: (la&ubreve; la senco) prefere diru <ke>akvofalo</ke>, <ke>serio</ke>.
  </rim>

  <adm>
    Sxajnas al mi, ke la senco TEK koncernas nur la adjektivon.
    <aut>MB</aut>
  </adm>
  <trd lng="be">&c_k;&c_a;&c_s;&c_k;&c_a;&c_d;</trd>
  <trd lng="bg">&c_k;&c_a;&c_s;&c_k;&c_a;&c_d;&c_a;</trd>
  <trd lng="bo">&t_ba;&t_ba;&t_sa;&t_tsheg;&t_cha;&t_shabchu;&t_tsheg;</trd>
  <trd lng="en">cascade</trd>
  <trd lng="es">cascada</trd>
  <trdgrp lng="fr">
    <trd>cascade</trd>,
    <trd>avalanche<klr tip="ind"> (suite ininterrompue)</klr></trd>,
    <trd>chapelet<klr tip="ind"> (suite ininterrompue)</klr></trd>,
    <trd>d&eacute;luge<klr tip="ind"> (suite ininterrompue)</klr></trd>,
    <trd>kyrielle<klr tip="ind"> (suite ininterrompue)</klr></trd>,
    <trd>ribambelle<klr tip="ind"> (suite ininterrompue)</klr></trd>,
    <trd>succession<klr tip="ind"> (suite ininterrompue)</klr></trd>,
    <trd>suite ininterrompue</trd>,
    <trd>torrent<klr tip="ind"> (suite ininterrompue)</klr></trd>
  </trdgrp>
  <trd lng="de">Kaskade</trd>
  <trdgrp lng="ja">
    <trd>&#28381;  <pr>&#12383;&#12365;</pr></trd>,
    <trd>&#27425;&#12293;&#12392;&#36215;&#12371;&#12427;&#12371;&#12392;  <pr>&#12388;&#12366;&#12388;&#12366;&#12392;&#12362;&#12371;&#12427;&#12371;&#12392;</pr></trd>
  </trdgrp>
  <trd lng="nl">cascade</trd>
  <trd lng="pl">kaskada</trd>
  <trd lng="ro">cascad&abreve;</trd>
  <trd lng="ru">&c_k;&c_a;&c_s;&c_k;&c_a;&c_d;</trd>
  <trdgrp lng="sk">
    <trd>kask&aacute;da</trd>,
    <trd>perej</trd>
  </trdgrp>
  <trdgrp lng="cs">
    <trd>kask&aacute;da</trd>,
    <trd>pe&rcaron;ej</trd>,
    <trd>slap</trd>,
    <trd>vodop&aacute;d</trd>
  </trdgrp>
  <trdgrp lng="uk">
    <trd>&c_k;&c_a;&c_s;&c_k;&c_a;&c_d;</trd>,
    <trd>&c_v;&c_o;&c_d;&c_o;&c_s;&c_p;&c_a;&c_d;</trd>,
    <trd>&c_p;&c_o;&c_r;&c_o;&c_g;&c_i; (&c_r;&c_ib;&c_ch;&c_k;&c_o;&c_v;&c_ib;)</trd>
  </trdgrp>
  <trdgrp lng="zh">
    <trd>&#23567;&#28689;&#24067; <pr>xi&#462;op&ugrave;b&ugrave;</pr></trd>,
    <trd>&#32026;&#32879; <pr>j&iacute;li&aacute;n</pr></trd>
  </trdgrp>
</drv>
</art>
