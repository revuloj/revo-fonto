<?xml version="1.0"?>
<!DOCTYPE vortaro SYSTEM "../dtd/vokoxml.dtd">
<vortaro>
<art mrk="$Id: akaricid.xml,v 1.1 2026/05/24 17:17:12 afido Exp $">
<kap>
    <rad>akaricid</rad>/o
</kap>
<drv mrk="akaricid.0o">
  <kap><tld/>o</kap>
  <snc mrk="akaricid.0o.AGR">
    <uzo tip="fak">AGR</uzo>
    <dif>
      <ref tip="super" cel="pesticid.0o.AGR">Pesticido</ref> per kiu oni mortigas akarojn:
      <ekz>
          kiam ni renkontas lin, <nom>Habib</nom> estas dis&scirc;pruciganta <tld/>on
          <fnt>
            <aut>P. Daum, trad. T. Tailhades</aut>
            <vrk><url ref="https://eo.mondediplo.com/2016/05/article2357">
            Al&gcirc;eria Saharo : Eldorado de tomatoj</url></vrk>
            <lok>Le Monde diplomatique, 2016-06</lok>
          </fnt>;
      </ekz>
      <ekz>
          por kontra&ubreve;batali akarojn <nom>Varroa</nom>, abelujoj anka&ubreve; devas esti traktitaj unu-du
          fojojn &ccirc;iujare
          per sintezaj <tld/>oj kiel &#8218;<esc>amitraz</esc>&#8216;, oksalata acido, formiata acido, kaj
          vegeta&jcirc;aj esencoj
          <fnt>
            <aut>R. Guill&eacute;n, trad. M. Leon</aut>
            <vrk><url ref="https://eo.mondediplo.com/2017/12/article2588">
            Kion abeloj flustras en homajn orelojn</url></vrk>
            <lok>Le Monde diplomatique, 2017-12</lok>
          </fnt>.
      </ekz>
    </dif>
  </snc>
  <trd lng="de">Akarizid</trd>
  <trd lng="en">acaricide</trd>
  <trd lng="fr">acaricide</trd>
  <trd lng="it">acaricida</trd>
</drv>
</art>

