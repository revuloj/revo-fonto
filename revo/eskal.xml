<?xml version="1.0"?>
<!DOCTYPE vortaro SYSTEM "../dtd/vokoxml.dtd">
<vortaro>
<art mrk="$Id: eskal.xml,v 1.18 2026/03/06 08:00:21 revo Exp $">
<kap>
  <rad>eskal</rad>/o <fnt><bib>SPV</bib></fnt>
</kap>

<drv mrk="eskal.0o">
  <kap><tld/>o</kap>
  <uzo tip="stl">RAR</uzo>
  <snc mrk="eskal.0o.sxtupetaro">
    <dif>
      <ref tip="dif" cel="sxtup.0etaro">&Scirc;tupetaro</ref>:
      <ekz>
        la hidalgo supriris la &ccirc;efan <tld/>on
        <fnt><bib>DonKihxoto</bib>, <lok>parto 2a, &ccirc;apitro 63a, p.
        757a</lok></fnt>;
      </ekz>
      <ekz>
        mi eniris brokantejon por &ccirc;efe trovi se&gcirc;on a&ubreve; almena&ubreve; &scirc;tupon de <tld/>o, sur kiu
        mi povus ripozi kelkajn minutojn
        <fnt>
          <bib>Monato</bib>
          <aut>Bernhard Pabst</aut>
          <vrk><url ref="&Monato;/2008/009376.php">Inter libroj posttagmeze</url></vrk>
          <lok>2008</lok>
        </fnt>;
      </ekz>
      <ekz>
        mi trovi&gcirc;is sur <tld/>o, refoje provante trovi kaj elpreni la &scirc;losilon el la
        subtegmenta fluejo
        <fnt>
          <bib>Monato</bib>
          <aut>Garvan Makaj</aut>
          <vrk><url ref="&Monato;/2009/009779.php">&Scirc;losila teorio</url></vrk>
          <lok>2009</lok>
        </fnt>;
      </ekz>
      <ekz>
        la domoj estas ligataj inter si per &scirc;tuparetoj, <ind>&scirc;nur<tld/>o</ind>j kaj glitvojoj
        <fnt>
          <aut>Michael Ende, trad. Wolfram Diestel</aut>
          <vrk>La Sen&ccirc;esa Rakonto</vrk>
          <lok>Fantaziujo en Dan&gcirc;ero</lok>
        </fnt>.
        <trd lng="ca">escala de corda</trd>
        <trd lng="de">Strickleiter</trd>
      </ekz>
    </dif>
    <trd lng="be">&c_d;&c_r;&c_a;&c_b;&c_ib;&c_n;&c_y;</trd>
    <trd lng="bg">&c_s;&c_t;&c_malmol;&c_l;&c_b;&c_a;</trd>
    <trdgrp lng="ca">
      <trd>escaleta</trd>,
      <trd>escala<klr tip="amb"> (port&agrave;til, de m&agrave;, de corda)</klr></trd>
    </trdgrp>
    <trd lng="cs">&zcaron;eb&rcaron;&iacute;k</trd>
    <trd lng="de">Leiter</trd>
    <trd lng="en">ladder</trd>
    <trd lng="es">escalerilla</trd>
    <trd lng="hu">l&eacute;tra</trd>
    <trd lng="nl">ladder</trd>
    <trd lng="pl">drabina</trd>
    <trd lng="pt">escada <klr tip="amb">(de m&atilde;o)</klr></trd>
    <trdgrp lng="ru">
      <trd>&c_l;&c_je;&c_s;&c_t;&c_n;&c_i;&c_c;&c_a;
      <klr>(&c_p;&c_r;&c_i;&c_s;&c_t;&c_a;&c_v;&c_n;&c_a;&c_ja;)</klr></trd>,
      <trd>&c_s;&c_t;&c_r;&c_je;&c_m;&c_ja;&c_n;&c_k;&c_a;</trd>
    </trdgrp>
    <trd lng="sk">rebr&iacute;k</trd>
    <trd lng="sv">stege</trd>
  </snc>
  <snc mrk="eskal.0o.FIG">
    <uzo tip="stl">FIG</uzo>
    <dif>
      <ref tip="dif" cel="hierar.0o">Hierar&hcirc;io</ref>:
      <ekz>
        organika&jcirc;oj kiuj estas malsuperaj sur la <tld/>o
        de la naturo estas pli variemaj
        <fnt><bib>OriginoDeSpecioj</bib>, <lok>&ccirc;apitro 5a</lok></fnt>;
      </ekz>
      <ekz>
        miaj gepatroj restis kiel eble for de renkonti&gcirc;oj de tiuj
        &ccirc;e la bazo de la socia <tld/>o
        <fnt>
          <aut>T. Steele</aut>,
          <vrk>La unua bildo</vrk>,
          <lok><url
          ref="http://mirmekobo.com/http___www.mirmekobo.com/Mirmekobo_files/Mirmekobo%206.pdf">
          Mirmekobo, 2009-09 (6)</url></lok>
        </fnt>.
      </ekz>
    </dif>
    <trd lng="be">&c_l;&c_je;&c_s;&c_mol;&c_v;&c_ib;&c_c;&c_a; <klr
    tip="amb">(&c_g;&c_ib;&c_je;&c_r;&c_a;&c_r;&c_h;&c_ib;&c_ch;&c_n;&c_a;&c_ja;)</klr></trd>
    <trd lng="ca">escala</trd>
    <trdgrp lng="de">
      <trd>Hierarchie</trd>,
      <trd>Leiter</trd>,
      <trd>Karriereleiter</trd>,
      <trd>Nahrungspyramide</trd>
    </trdgrp>
    <trd lng="pl">hierarchia</trd>
    <trd lng="zh">&#26799; <pr>t&#299;</pr></trd>
</snc>
  <trd lng="cs">pu&scaron;t&ecaron;n&eacute; o&ccaron;ko na pun&ccaron;o&scaron;e</trd>
  <trd lng="fr">&eacute;chelle</trd>
  <trdgrp lng="ja">
    <trd>&#12399;&#12375;&#12372;</trd>,
    <trd>&#20253;&#32218;  <pr>&#12391;&#12435;&#12379;&#12435;</pr></trd>
  </trdgrp>
  <trd lng="sk">pusten&eacute; o&ccaron;ko na pan&ccaron;uche</trd>
  <trdgrp lng="uk">
    <trd>&c_d;&c_r;&c_a;&c_b;&c_i;&c_n;&c_a; (&c_t;&c_zh; &c_ja;&c_k; &c_b;&c_ib;&c_ch;&c_n;&c_a;
    &c_s;&c_t;&c_ib;&c_n;&c_k;&c_a; &c_u; &c_v;&c_o;&c_z;&c_ib;)</trd>,
    <trd>&c_p;&c_je;&c_t;&c_l;&c_ib;</trd>,
    <trd>&c_shch;&c_o; &c_r;&c_o;&c_z;&c_ib;&c_j;&c_sh;&c_l;&c_i;&c_s;&c_ja; (&c_u; &c_p;&c_a;&c_n;&c_ch;&c_o;&c_s;&c_ib;</trd>,
    <trd>&c_v;&#8217;&c_ja;&c_z;&c_a;&c_n;&c_i;&c_h; &c_v;&c_i;&c_r;&c_o;&c_b;&c_a;&c_h;)</trd>
  </trdgrp>
</drv>
</art>

