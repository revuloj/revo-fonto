<?xml version="1.0"?>
<!DOCTYPE vortaro SYSTEM "../dtd/vokoxml.dtd">
<vortaro>
<art mrk="$Id: sterto.xml,v 1.24 2026/05/14 14:38:07 revo Exp $">
<kap>
  <ofc>*</ofc>
  <rad>stertor</rad>/o <fnt><bib>UV</bib></fnt>
</kap>
<drv mrk="sterto.0o">
  <kap><ofc>*</ofc><tld/>o</kap>
  <snc mrk="sterto.0o.SON">
    <dif>
      Ra&ubreve;ka <ref tip="lst" cel="son.0o" lst="voko:sonoj">sono</ref>,
      kiun a&ubreve;digas mortonto pro malfacila spirado:
      <ekz>
        tie kaj tie estis a&ubreve;deblaj la <tld/>oj de agonio
        <fnt><aut>A. Kivi, trad. I. Ekstr&ouml;m</aut>, <vrk>Sep
        fratoj</vrk>, <lok>1947</lok></fnt>;
      </ekz>
      <ekz>
        la bu&scirc;on kovras blanka &scirc;a&ubreve;mo kaj <klr>[ellasas]</klr>
        ra&ubreve;kan penetrantan <tld/>on kvaza&ubreve; de bu&ccirc;ata bovo
        <fnt>
          <bib>IdO</bib>
          <lok>Dua Parto</lok>
        </fnt>.
      </ekz>
    </dif>
    <refgrp tip="vid">
      <ref cel="rasl.0o">raslo</ref>,
      <ref cel="singul1.0i">singulto</ref>
    </refgrp>
  </snc>
  <trd lng="be">&c_h;&c_r;&c_y;&c_p;</trd>
  <trd lng="cs">chropt&ecaron;n&iacute; um&iacute;raj&iacute;c&iacute;ho</trd>
  <trdgrp lng="de">
    <trd>Stertor</trd>,
    <trd>R&ouml;cheln</trd>
  </trdgrp>
  <trdgrp lng="en">
    <trd>rattle in the throat</trd>,
    <trd>death rattle</trd>,
    <trd>stertorous breathing</trd>
  </trdgrp>
  <trd lng="fr">r&acirc;le</trd>
  <trd lng="hu">h&ouml;rg&eacute;s</trd>
  <trdgrp lng="ja">
    <trd>&#x30BC;&#x30A4;&#x30BC;&#x30A4;&#x97F3;
    <pr>&#x30BC;&#x30A4;&#x30BC;&#x30A4;&#x304A;&#x3068;</pr></trd>,
    <trd>&#x3042;&#x3048;&#x304E;&#x58F0;  <pr>&#x3042;&#x3048;&#x304E;&#x3054;&#x3048;</pr></trd>,
    <trd>&#x5598;&#x9CF4;  <pr>&#x305C;&#x3093;&#x3081;&#x3044;</pr></trd>
  </trdgrp>
  <trdgrp lng="nl">
    <trd>gerochel</trd>,
    <trd>gereutel</trd>
  </trdgrp>
  <trd lng="pl">rz&eogonek;&zdot;enie</trd>
  <trd lng="ru">&c_h;&c_r;&c_i;&c_p;</trd>
  <trdgrp lng="sk">
    <trd>chr&ccaron;anie <klr>(ranen&yacute;ch, umieraj&uacute;cich)</klr></trd>,
    <trd>chr&ccaron;anie <klr>(ranen&yacute;ch| umieraj&uacute;cich)</klr></trd>
  </trdgrp>
  <trdgrp lng="uk">
    <trd>&c_h;&c_r;&c_i;&c_p;</trd>,
    <trd>&c_h;&c_r;&c_i;&c_p;&c_i;</trd>,
    <trd>&c_h;&c_r;&c_i;&c_p;&c_ib;&c_n;&c_n;&c_ja;</trd>,
    <trd>&c_h;&c_a;&c_r;&c_ch;&c_a;&c_n;&c_n;&c_ja;</trd>
  </trdgrp>
</drv>

<drv mrk="sterto.0i">
  <kap>
    <tld/>i
  </kap>
  <snc>
    <dif>
      A&ubreve;digi <tld/>on:
      <ekz>
        <tld/>ante li elspiris la lastan spiron
        <fnt>
          <bib>IdO</bib>
          <lok>Tria Parto</lok>
        </fnt>;
      </ekz>
      <ekz>
        &scirc;i tiregis la puntojn de sia korsa&jcirc;o, <tld/>ante: &ndash; mi sufoki&gcirc;as
        <fnt>
          <bib>ChL</bib>
          <lok>&Ccirc;apitro Dua</lok>
        </fnt>!
      </ekz>
      <ekz>
        lia kontra&ubreve;ulo komencis spiri &ccirc;iam pli rapide, poste <tld/>i, poste lia viza&gcirc;o
        i&gcirc;is ru&gcirc;eblua
        <fnt>
          <bib>QuV</bib>
          <lok>&Ccirc;apitro VII</lok>
        </fnt>.
      </ekz>
    </dif>
  </snc>
  <trd lng="de">r&ouml;cheln</trd>
  <trd lng="en">breathe stertorously</trd>
  <trd lng="fr">r&acirc;ler</trd>
</drv>

</art>
