<?xml version="1.0"?>
<!DOCTYPE vortaro SYSTEM "../dtd/vokoxml.dtd">
<vortaro>
<art mrk="$Id: mikro.xml,v 1.19 2026/06/11 10:59:50 revo Exp $">
<kap>
  <rad>mikro</rad>- <fnt><bib>SPV</bib></fnt>
</kap>

<drv mrk="mikro.0">
  <kap><tld/>-</kap>
  <mlg>&#181;</mlg>
  <gra><vspec>prefikso</vspec></gra>
  <snc mrk="mikro.0.MEZ">
    <dif>
      &leftquot;Milionono da&rightquot; (10<sup>-6</sup> = 0,000001)
      en la Internacia Sistemo de unuoj (SI):
      <ekz>
        la ek&scirc;alta tempo estas malpli ol 1 <ind><tld/>sekundo</ind>
        <fnt>
          <aut>Krist&aacute;ly T.</aut>,
          <vrk><url ref="&STEB;ingxenierado/elektro/musx-reflektoro.htm">
          Mu&scirc;okula reflektoro</url></vrk>,
          <lok>[vidita en 2010]</lok>
        </fnt>.
        <trd lng="de">Mikrosekunde</trd>
      </ekz>
    </dif>
  </snc>
  <snc mrk="mikro.0.KOMUNE">
    <dif>
      Tre malgranda:
    </dif>
    <subsnc mrk="mikro.0.SCI">
      <uzo tip="fak">SCI</uzo>
      <dif>
        Koncernanta malgrandegajn a&jcirc;ojn, ne observeblajn okule
        sed nur per arta rimedo:
        <ekz>
          <ind><tld/>polvo</ind> <klr>(<ref cel="aerosol.0o">aerosolo</ref>)</klr>
          <fnt>
            <bib>Monato</bib>
            <aut>Stefan Maul</aut>
            <vrk><url ref="&Monato;/2005/008633.php">Polvo</url></vrk>
          </fnt>;
          <trd lng="de">Feinstaub</trd>
          <trd lng="en">particulates</trd>
          <trd lng="fr">particules en suspension</trd>
        </ekz>
        <ekz>
          <ind><tld/>&hcirc;irurgia</ind>
          <fnt>
            <bib>Viki</bib>
            <lok><url ref="https://eo.wikipedia.org/?curid=42235">Endoskopio</url></lok>
          </fnt>;
         <trd lng="de">mikrochirurgisch</trd>
        </ekz>
        <ekz>
          <ref tip="vid" cel="mikrovivajx.0o"><tld/>viva&jcirc;o</ref>.
        </ekz>
      </dif>
    </subsnc>
    <subsnc mrk="mikro.0.ANA">
      <uzo tip="fak">ANA</uzo>
      <dif>
        Malnormale malgranda:
        <ekz>
          <tld/>hepateco
          <fnt>
            <aut>-</aut>,
            <vrk><url ref="http://vortareto.free.fr/dictionnaire/esp-fr/m.htm">
            Lexique et dictionnaire m&eacute;dical
            fran&ccedil;ais-esp&eacute;ranto</url></vrk>,
            <lok>2005</lok>
          </fnt>.
        </ekz>
      </dif>
    </subsnc>
    <subsnc mrk="mikro.0.mini">
      <uzo tip="stl">FIG</uzo>
      <dif>
        <ref tip="dif" cel="mini1.0o.KOMUNE">Mini-</ref>:
        <ekz>
          <ind><tld/>komputilo</ind>
          <fnt>
            <vrk><url ref="&STEB;ingxenierado/komputado/f871-p31.htm">Mikrokomputilo</url></vrk>
          </fnt>.
          <trd lng="de">Mikrocomputer</trd>
        </ekz>
      </dif>
    </subsnc>
    <rim>
      La&ubreve; <fnt><bib>BL</bib></fnt>: Prefere diru <ke>et-</ke>, <ke>eta</ke>, <ke>malgranda</ke>,
      <ke>malgrandskala</ke>.
    </rim>
  <trd lng="de">Kleinst-</trd>
  </snc>
  <trd lng="be">&c_m;&c_ib;&c_k;&c_r;&c_a;-</trd>
  <trd lng="bg">&c_m;&c_i;&c_k;&c_r;&c_o;-</trd>
  <trd lng="ca">micro-</trd>
  <trd lng="de">Mikro-</trd>
  <trd lng="en">micro-</trd>
  <trd lng="es">micro-</trd>
  <trd lng="fa">&a_m;&f_y;&f_k;&a_r;&a_w;</trd>
  <trd lng="fr">micro-</trd>
  <trd lng="hu">mikro-</trd>
  <trd lng="it">micro-</trd>
  <trd lng="ja">&#12510;&#12452;&#12463;&#12525;&#65374;</trd>
  <trd lng="nl">micro-</trd>
  <trd lng="no">mikro-</trd>
  <trd lng="pl">mikro-</trd>
  <trd lng="pt">micro-</trd>
  <trd lng="ru">&c_m;&c_i;&c_k;&c_r;&c_o;-</trd>
  <trd lng="sv">mikro-</trd>
  <trd lng="uk">&c_m;&c_ib;&c_k;&c_r;&c_o;&#8230;</trd>
  <trdgrp lng="zh">
    <trd>&#26174;&#24494; <pr>xi&#462;nw&emacron;i</pr></trd>,
    <trd>&#39023;&#24494; <pr>xi&#462;nw&emacron;i</pr></trd>
  </trdgrp>
</drv>
</art>

