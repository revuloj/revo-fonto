<?xml version="1.0"?>
<!DOCTYPE vortaro SYSTEM "../dtd/vokoxml.dtd">
<vortaro>
<art mrk="$Id: silvestr.xml,v 1.15 2026/06/04 21:53:01 revo Exp $">
<kap>
  <rad>Silvestr</rad>/o <fnt><bib>PIV1</bib></fnt>
</kap>
<drv mrk="silvestr.0o">
  <kap><tld/>o</kap>
  <snc mrk="silvestr.0o.NOM">
    <uzo tip="fak">NOM</uzo>
    <dif>
      Vira <ref tip="lst" cel="nom.antaux0o" lst="voko:personaj_nomoj">anta&ubreve;nomo</ref> latindevena:
      <ekz>
        tio estis la lasta vespero en la jaro, vespero de <tld/>o
        <fnt><bib>Fab2</bib>, <lok>knabineto kun alumetoj</lok></fnt>.
      </ekz>
    </dif>
    <trd lng="be">&c_D;&c_z;&c_je;&c_n;&c_mol; &c_S;&c_mol;&c_v;&c_ja;&c_t;&c_o;&c_g;&c_a; &c_S;&c_y;&c_l;&c_mol;&c_v;&c_e;&c_s;&c_t;&c_r;&c_a;</trd>
  </snc>
  <snc mrk="silvestr.0o.tago">
    <uzo tip="fak">KAL</uzo>
    <dif>
      La lasta tago de la jaro, je kiu oni memoras sanktan <tld/>on
      (papo <tld/>o Ia):
      <ekz>
        dum la vintraj monatoj (je Kristnasko kaj <tld/>o) multaj homoj el meza kaj
        norda E&ubreve;ropo <klr>[&#x2026;]</klr> fu&gcirc;as al sunaj marbordoj
        <fnt>
          <bib>Monato</bib>
          <aut>Stefan Maul</aut>
          <vrk><url ref="&Monato;/2005/008551.php"
              >Ondego da helpemo</url></vrk>
          <lok>2005</lok>
        </fnt>.
      </ekz>
    </dif>
  </snc>
  <rim>
    en la senco de <tld/>a festo, la&ubreve; <fnt><bib>BL</bib></fnt>: eblas diri <ke>jarfino</ke>,
    <ke>jarfina festo</ke>, <ke>jarfina nokto</ke>.
  </rim>
  <ref tip="lst" cel="fest.0o" lst="voko:festoj">festo</ref>
  <trd lng="be">&c_P;&c_ja;&c_r;&c_e;&c_d;&c_a;&c_d;&c_n;&c_je; &c_N;&c_o;&c_v;&c_a;&c_g;&c_a; &c_g;&c_o;&c_d;&c_a;</trd>
  <trd lng="de">Silvester</trd>
  <trdgrp lng="en">
    <trd>Sylvester</trd>,
    <trd>New Year's Eve</trd>
  </trdgrp>
  <trd lng="fr">Sylvestre</trd>
  <trd lng="it">Silvestro</trd>
  <trdgrp lng="ja">
    <trd>&#x30B7;&#x30EB;&#x30D9;&#x30B9;&#x30C6;&#x30EB;</trd>,
    <trd>&#x30B7;&#x30EB;&#x30D9;&#x30B9;&#x30BF;&#x30FC;</trd>,
    <trd>&#x30B7;&#x30EB;&#x30A6;&#x30A7;&#x30B9;&#x30C6;&#x30EB;</trd>
  </trdgrp>
  <trd lng="nl">Silvester</trd>
  <trd lng="pl">Sylwester</trd>
  <trd lng="ru">&c_S;&c_i;&c_l;&c_mol;&c_v;&c_je;&c_s;&c_t;&c_r;</trd>
  <trd lng="uk">&c_S;&c_i;&c_l;&c_mol;&c_v;&c_je;&c_s;&c_t;&c_r;</trd>
  <trdgrp lng="zh">
    <trd>&#x8DE8;&#x5E74; <pr>ku&agrave;ni&aacute;n</pr></trd>,
    <trd>&#x65B0;&#x5E74;&#x524D;&#x5915; <pr>x&imacron;nni&aacute;nqi&aacute;nx&imacron;</pr></trd>
  </trdgrp>
</drv>

<drv mrk="silvestr.0a">
  <kap><tld lit="s"/>a</kap>
  <snc mrk="silvestr.0a.KAL">
  <uzo tip="fak">KAL</uzo>
    <dif>
       Rilatanta al <tld/>o a&ubreve; al ties festo (la 31a de decembro):
       <ekz>
         <ind><tld lit="s"/>a vespero</ind>;
         <trd lng="nl">oudejaarsavond</trd>
       </ekz>
       <ekz>
        ni komune festis la <tld lit="s"/>an nokton
        <fnt>
          <bib>LOdE</bib>
          <lok>2003, &#x2116; 2 (100)</lok>
        </fnt>;
      </ekz>
       <ekz>
         per <ind><tld lit="s"/>a bufedo</ind>, &ccirc;ampano kaj balo oni
         gaje transpa&scirc;is al la nova jaro
         <fnt>
           <aut>Marija Belo&scaron;evi&cacute; </aut>,
           <bib>LOdE</bib>
         </fnt>;
         <trd lng="nl">oudejaarsbuffet</trd>
       </ekz>
       <ekz>
        Internacia <tld/>a Balo
        <fnt>
          <bib>LOdE</bib>
          <lok>1999, No 10 (60)</lok>
        </fnt>.
      </ekz>
    </dif>
  </snc>
  <trdgrp lng="be">
    <trd>&c_d;&c_a;&c_t;&c_y;&c_ch;&c_n;&c_y; &c_P;&c_ja;&c_r;&c_e;&c_d;&c_a;&c_d;&c_n;&c_ja; &c_N;&c_o;&c_v;&c_a;&c_g;&c_a; &c_g;&c_o;&c_d;&c_a;</trd>,
    <trd>&c_p;&c_je;&c_r;&c_a;&c_d;&c_n;&c_a;&c_v;&c_a;&c_g;&c_o;&c_d;&c_n;&c_ib;</trd>
  </trdgrp>
  <trd lng="de">Silvester-</trd>
  <trd lng="it">di San <ind>Silvestro</ind></trd>
  <trdgrp lng="nl">
    <trd>Silvester-</trd>,
    <trd>oudejaars-</trd>
  </trdgrp>
</drv>
</art>

