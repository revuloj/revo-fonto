<?xml version="1.0"?>
<!DOCTYPE vortaro SYSTEM "../dtd/vokoxml.dtd">

<vortaro>
  <art mrk="$Id: fraktur.xml,v 1.2 2026/07/16 20:00:22 afido Exp $">
    <kap>
      <rad>fraktur</rad>/o
      <fnt><bib>PIV1</bib></fnt>
    </kap>

<drv mrk="fraktur.0o">
  <kap><tld/>o</kap>
  <snc mrk="fraktur.0o.MED">
    <uzo tip="fak">MED</uzo>
    <dif>
      Rompi&gcirc;o de osto:
      <ekz>
        pavianaj kranioj, <tld/>itaj per malakra objekto, estas trovitaj proksime de
        kelkaj el tiuj fosilioj
        <fnt>
          <bib>Ret</bib>
          <lok>Unua Parto</lok>
        </fnt>;
      </ekz>
      <ekz>
        <uzo tip="stl">FIG</uzo>
        estas formi&gcirc;anta <tld/>o inter la mondo de la planedaj estraroj kaj la novaj
        generacioj
        <fnt>
          <aut>Greta Thunberg, trad. Filippo Franceschi</aut>
          <vrk><url ref="https://libro.ee/file.php?id=2905"
              >Parolado &ccirc;e Unui&gcirc;intaj Nacioj, 22-09-2019</url></vrk>
        </fnt>.
      </ekz>
    </dif>
    <trdgrp lng="de">
      <trd>Fraktur</trd>,
      <trd>Knochenbruch</trd>
    </trdgrp>
    <trd lng="en">fracture</trd>
    <trd lng="fr">fracture</trd>
  </snc>
  <trd lng="ca">fractura</trd>
  <trd lng="es">fractura</trd>
</drv>

<drv mrk="fraktur.F0o">
  <kap>
    Frakturo
  </kap>
  <snc mrk="fraktur.F0o.TIP">
    <uzo tip="fak">TIP</uzo>
    <dif>
      Gotika <ref tip="super" cel="tip.0aro">tiparo</ref>:
      <ekz>
        <tld/>o <klr>[estas]</klr> angulplena skribo, kutime uzata de germanaj presistoj
        anta&ubreve; la unua mondmilito
        <fnt>
          <aut>Sergio Pokrovskij </aut>
          <vrk><url ref="https://bertilow.com/div/komputada_leksikono/F.html"
              >Komputada leksikono</url></vrk>
          <lok>frakturo</lok>
        </fnt>.
      </ekz>
    </dif>
  </snc>
  <trd lng="ca">escriptura g&ograve;tica</trd>
  <trd lng="de">Frakturschrift</trd>
  <trd lng="en">Gothic print</trd>
  <trd lng="es">escritura g&oacute;tica</trd>
  <trd lng="fr">&eacute;criture gothique</trd>
</drv>

  </art>

