<?xml version="1.0"?>
<!DOCTYPE vortaro SYSTEM "../dtd/vokoxml.dtd">
<vortaro>
<art mrk="$Id: tonik.xml,v 1.26 2026/07/13 14:00:20 revo Exp $">
<kap>
  <rad>tonik</rad>/o <fnt><bib>SPV</bib></fnt>
</kap>
<drv mrk="tonik.0o">
  <kap><tld/>o</kap>
  <snc mrk="tonik.0o.MED">
    <uzo tip="fak">MED</uzo>
    <dif>
      <ref tip="super" cel="medika1.0o">Medikamento</ref> kun vigliga,
      fortiga efiko, kontra&ubreve; korpa malforto:
      <ekz>
        mi donu al &scirc;i <tld/>on por &scirc;in refortigi
        <fnt><bib>RugxDom</bib>, <lok>&ccirc;apitro 74a, volumo 2a, p.
        567a</lok></fnt>;
      </ekz>
      <ekz>
        aprezata delonge kiel spirita <tld/>o, priskribata kiel fonto de juneco
        <klr>[&#8230;]</klr>, mielo estas vaste uzata de homoj
        <fnt>
        <aut>Juan Carlos Montero Medina</aut>
          <vrk><url ref="&Monato;/2018/012258.php">Mielo &#8208; Utiloj
          kaj ecoj de vera panaceo</url></vrk>
          <bib>Monato</bib>
          <lok>2018/10, p. 22</lok>
        </fnt>.
      </ekz>
    </dif>
    <trdgrp lng="be">
      <trd>&c_t;&c_o;&c_n;&c_ib;&c_k;</trd>,
      <trd>&c_t;&c_a;&c_n;&c_ib;&c_z;&c_u;&c_ju;&c_ch;&c_y;
  &c_s;&c_r;&c_o;&c_d;&c_a;&c_k;</trd>
    </trdgrp>
    <trdgrp lng="ca">
      <trd>tonificant</trd>,
      <trd>t&ograve;nic</trd>
    </trdgrp>
    <trdgrp lng="de">
      <trd>Tonikum</trd>
    </trdgrp>
    <trd lng="fr">tonique<klr> (vira subst.)</klr><klr tip="ind">
    (subst.)</klr></trd>
    <trdgrp lng="hu">
      <trd>er&odblac;s&iacute;t&odblac;(szer)</trd>,
      <trd>toniz&aacute;l&oacute;(szer)</trd>
    </trdgrp>
    <trd lng="it">tonico<klr> (sost.)</klr></trd>
    <trd lng="nl">tonicum</trd>
    <trd lng="pl">tonik</trd>
    <trd lng="pt">t&ocirc;nico</trd>
    <trdgrp lng="ru">
      <trd>&c_t;&c_o;&c_n;&c_i;&c_k;</trd>, 
      <trd>&c_t;&c_o;&c_n;&c_i;&c_z;&c_i;&c_r;&c_u;&c_ju;&c_shch;&c_je;&c_je;
  &c_s;&c_r;&c_je;&c_d;&c_s;&c_t;&c_v;&c_o;</trd>
    </trdgrp>
  </snc>
  <snc mrk="tonik.0o.KUI">
    <uzo tip="fak">KUI</uzo>
    <dif>
      Refre&scirc;iga &hcirc;ininhava amara klara <ref tip="super" cel="limona.0o">limonado</ref>:
      <ekz>
        mi iras al taverno kaj drinkas tekilon, a&ubreve; &gcirc;inon sen <tld/>o
        <fnt>
          <aut>Grigori L. Arosev</aut>
          <vrk><url ref="&Monato;/2001/007399.html">Nerekonebla</url></vrk>
           <bib>Monato</bib>
           <lok>2001/05, p. 26</lok>
        </fnt>.
      </ekz>
    </dif>
    <trd lng="be">&c_t;&c_o;&c_n;&c_ib;&c_k; <klr>(&c_n;&c_a;&c_p;&c_ib;&c_t;&c_a;&c_k;)</klr></trd>
    <trdgrp lng="ca">
      <trd>t&ograve;nica</trd>,
      <trd>aigua t&ograve;nica</trd>
    </trdgrp>
    <trd lng="de">Tonicwasser</trd>
    <trd lng="en">tonic water</trd>
    <trdgrp lng="zh">
    <trd>&#27748;&#21147;&#27700; <pr>t&#257;ngl&igrave;shu&#464;</pr></trd>,
    <trd>&#28271;&#21147;&#27700; <pr>t&#257;ngl&igrave;shu&#464;</pr></trd>,
    <trd>&#28363;&#34917;&#21697; <pr>z&#299;b&#468;p&#464;n</pr></trd>,
    <trd>&#28363;&#35036;&#21697; <pr>z&#299;b&#468;p&#464;n</pr></trd>
  </trdgrp>
</snc>
  <ref tip="hom" cel="tonik1.0o.MUZ">toniko (muziko)</ref>
  <trd lng="cs">t&oacute;nika</trd>
  <trdgrp lng="ja">
    <trd>&#20027;&#38899;  <pr>&#12375;&#12421;&#12362;&#12435;</pr></trd>,
    <trd>&#12461;&#12540;&#12494;&#12540;&#12488;</trd>,
    <trd>&#24375;&#22766;&#21092;  <pr>&#12365;&#12423;&#12358;&#12381;&#12358;&#12374;&#12356;</pr></trd>
  </trdgrp>
  <trd lng="sk">tonikum</trd>
  <trdgrp lng="uk">
    <trd>&c_t;&c_o;&c_n;&c_ib;&c_k;&c_a;</trd>,
    <trd>&c_o;&c_s;&c_n;&c_o;&c_v;&c_n;&c_i;&c_j; &c_t;&c_o;&c_n;</trd>,
    <trd>&c_o;&c_s;&c_n;&c_o;&c_v;&c_n;&c_a; &c_ch;&c_a;&c_s;&c_t;&c_o;&c_t;&c_a;</trd>,
    <trd>&c_t;&c_o;&c_n;&c_ib;&c_z;&c_u;&c_ju;&c_ch;&c_a; &c_r;&c_je;&c_ch;&c_o;&c_v;&c_i;&c_n;&c_a;</trd>,
    <trd>&c_t;&c_o;&c_n;&c_ib;&c_z;&c_u;&c_ju;&c_ch;&c_i;&c_j; &c_z;&c_a;&c_s;&c_ib;&c_b;</trd>,
    <trd>&c_t;&c_o;&c_n;&c_ib;&c_k; (&c_n;&c_a;&c_p;&c_ib;&c_j;)</trd>
  </trdgrp>
</drv>

<drv mrk="tonik.0a">
  <kap><tld/>a</kap>
  <snc mrk="tonik.0a.MED">
    <uzo tip="fak">MED</uzo>
    <dif>
      <ref tip="sin" cel="vigl.0iga">Vigliga</ref>, refortiga.
    </dif>
    <trd lng="be">&c_t;&c_a;&c_n;&c_ib;&c_z;&c_u;&c_ju;&c_ch;&c_y;</trd>
    <trd lng="de">tonisch</trd>
    <trdgrp lng="hu">
      <trd>er&odblac;s&iacute;t&odblac;</trd>,
      <trd>toniz&aacute;l&oacute;</trd>
    </trdgrp>
    <trdgrp lng="nl">
      <trd>tonisch</trd>,
      <trd>versterkend</trd>,
      <trd>opwekkend</trd>
    </trdgrp>
    <trd lng="pl">tonizuj&aogonek;cy</trd>
    <trd lng="pt">tonificante</trd>
    <trd lng="ru">
    &c_t;&c_o;&c_n;&c_i;&c_z;&c_i;&c_r;&c_u;&c_ju;&c_shch;&c_i;&c_j;
    </trd>
  </snc>
  <trdgrp lng="ca">
    <trd>tonificant</trd>,
    <trd>t&ograve;nic</trd>
  </trdgrp>
  <trd lng="fr">tonique<klr tip="ind"> (adj.)</klr></trd>
  <trd lng="it">tonico<klr> (agg.)</klr></trd>
    <trdgrp lng="ja">
    <trd>&#20027;&#38899;&#12398;  <pr>&#12354;&#12427;&#12376;&#12362;&#12392;&#12398;</pr></trd>,
    <trd>&#24375;&#22766;&#12395;&#12377;&#12427;  <pr>&#12365;&#12423;&#12358;&#12381;&#12358;&#12395;&#12377;&#12427;</pr></trd>
  </trdgrp>
  <trdgrp lng="zh">
    <trd>&#34917;&#21697; <pr>b&#468;p&#464;n</pr></trd>,
    <trd>&#35036;&#21697; <pr>b&#468;p&#464;n</pr></trd>
  </trdgrp>
</drv>
</art>
