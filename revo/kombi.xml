<?xml version="1.0"?>
<!DOCTYPE vortaro SYSTEM "../dtd/vokoxml.dtd">

<vortaro>
  <art mrk="$Id: kombi.xml,v 1.1 2026/06/13 14:22:55 afido Exp $">
    <kap>
      <rad>kombi</rad>/o
      <fnt><aut>P. Desmet', J. Horvath</aut> <vrk>Bildvortaro, 2012</vrk></fnt>
    </kap>

<drv mrk="kombi.0o">
  <kap><tld/>o</kap>
  <snc>
    <uzo tip="fak">AUT</uzo>
    <dif>
      Karoseria formo de
      <ref cel="auxt.kombi0o">pluruza a&ubreve;to, kombina&ubreve;to, biena&ubreve;to</ref>;
      tia a&ubreve;to:
      <ekz>
        la lastajn 20 km ni veturas per <tld/>o kaj atingas la terenon tra akvo, polvo,
        truoj
        <fnt>
          <aut>E. Kruse</aut>
          <vrk><url ref="http://ifef.free.fr/bultenoj/IF%201978-5.pdf"
              >Brazilo, ne imagebla lando</url></vrk>
          <lok>Internacia fervojisto, sept./otk. 1978 p. 67</lok>
        </fnt>;
      </ekz>
      <ekz>
        la a&ubreve;tofamilio <esc>LADA 110</esc> <klr>[&#x2026;]</klr> inkluzivis anka&ubreve; <tld/>a&ubreve;ton <esc>VAZ-2111</esc>
        <fnt>
          <aut>-</aut>
          <vrk><url ref="https://eo.wikibooks.org/wiki/La_rusa_lingvo_en_vivo/%C5%9Cofori_en_Rusio">
          La rusa lingvo en vivo - &scirc;ofori en Rusio</url></vrk>
          <lok>Vikilibroj, 2024</lok>
        </fnt>.
      </ekz>
    </dif>
    <trd lng="de">Kombi</trd>
    <trd lng="en">station wagon</trd>
    <trd lng="fr">break <klr>(voiture)</klr></trd>
  </snc>
</drv>

  </art>

