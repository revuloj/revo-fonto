<?xml version="1.0"?>
<!DOCTYPE vortaro SYSTEM "../dtd/vokoxml.dtd">
<vortaro>
<art mrk="$Id: impet.xml,v 1.26 2026/03/06 07:06:16 revo Exp $">
<kap>
  <ofc>8</ofc>
  <rad>impet</rad>/i <fnt><bib>PVEF</bib></fnt>
</kap>
<drv mrk="impet.0i">
  <kap><tld/>i</kap>
  <gra><vspec>ntr</vspec></gra>
  <snc mrk="impet.0i.alkuri">
    <dif>
      Forte kaj vive sin &jcirc;eti anta&ubreve;en:
      <ekz>
	la ondoj <tld/>as kontra&ubreve; la bordo;
      </ekz>
      <ekz>
        &scirc;i <tld/>is al mi por min kisi
        <fnt>
          <bib>MkM</bib>
          <lok>13</lok>
        </fnt>;
      </ekz>
      <ekz>
        hirundo <tld/>is en la portikon, flugis unu rondon tuj sub la ora plafono
        <klr>[&#x2026;]</klr> kaj malaperis en kapitelo
        <fnt>
          <bib>MkM</bib>
          <lok>2</lok>
        </fnt>;
      </ekz>
      <ekz>
        la stevardino <tld/>as al la pilotejo, sed maljuna pasa&gcirc;erino haltigas &scirc;in
        <fnt>
          <bib>KrB</bib>
          <lok>Excelsior!</lok>
        </fnt>.
      </ekz>
    </dif>
    <refgrp tip="vid">
      <ref cel="kur.al0i">alkuri</ref>,
      <ref cel="atak.0i.batali">ataki</ref>,
      <ref cel="sving.kur0igxi">kursvingi&gcirc;i</ref>,
      <ref cel="penetr.0i.enigxi">penetri</ref>,
      <ref cel="sturm.0i">sturmi</ref>
    </refgrp>
    <trdgrp lng="de">
     <trd>vorst&uuml;rzen</trd>,
     <trd>mit Schwung <ind>anpacken</ind></trd>
    </trdgrp>
    <trdgrp lng="en">
     <trd>be impetuous</trd>,
     <trd>bound</trd>,
     <trd>dash</trd>,
     <trd>leap</trd>,
     <trd>spring</trd>
    </trdgrp>
    <trdgrp lng="hu">
     <trd>nekiiramodik</trd>,
     <trd>nekilend&uuml;l</trd>
    </trdgrp>
    <trd lng="nl">voorwaarts <ind>stormen</ind></trd>
  </snc>
  <snc mrk="impet.0i.FIG">
    <uzo tip="stl">FIG</uzo>
    <dif>
      Arde, fervore aspiri al iu celo:
      <ekz>
        mi tro <tld/>is aludante pri &gcirc;i, mi timas, ke mi jam ofendis la honorulojn
        <fnt>
          <bib>Ret</bib>
          <lok>Aldono</lok>
        </fnt>;
      </ekz>
      <ekz>
        <klr>[li]</klr> kun la forto de la malespero <tld/>as kontra&ubreve; la baroj, kiuj
        malhelpas la homaran progreson
        <fnt>
          <bib>EeP</bib>
          <lok>Dua Parto</lok>
        </fnt>;
      </ekz>
      <ekz>
        <nom>Mattos</nom> estas pasia poeto: lia animbrulo <tld/>as el &ccirc;iu verko
        <fnt>
          <bib>EeP</bib>
          <lok>Dua Parto</lok>
        </fnt>.
      </ekz>
    </dif>
    <trdgrp lng="de">
      <trd>leidenschaftlich <ind>verlangen</ind></trd>,
      <trd>sich <ind>werfen</ind> auf</trd>
    </trdgrp>
    <trd lng="en">to be impelled</trd>
    <trdgrp lng="hu">
     <trd>v&aacute;gyik</trd>,
     <trd>t&ouml;rekszik</trd>
    </trdgrp>
    <trd lng="nl">zich <ind>werpen</ind> op</trd>
  </snc>
  <trdgrp lng="be">
    <trd>&c_ib;&c_m;&c_k;&c_n;&c_u;&c_c;&c_c;&c_a;</trd>,
    <trd>&c_ib;&c_r;&c_v;&c_a;&c_c;&c_c;&c_a; <klr>(&c_d;&c_a; &c_ch;&c_a;&c_g;&c_o;&c_s;&c_mol;&c_c;&c_ib;)</klr></trd>
  </trdgrp>
  <trdgrp lng="cs">
    <trd>nal&eacute;hat</trd>,
    <trd>vrhat se vp&rcaron;ed</trd>,
    <trd>vynucovat</trd>,
    <trd>&uacute;to&ccaron;it</trd>
  </trdgrp>
  <trdgrp lng="fr">
    <trd>s'<ind>&eacute;lancer</ind></trd>,
    <trd>se <ind>jeter</ind><klr tip="ind"> (sur qc)</klr></trd>,
    <trd>se <ind>pr&eacute;cipiter</ind><klr tip="ind"> (sur qc)</klr></trd>,
    <trd>se <ind>ruer</ind><klr tip="ind"> (sur qc)</klr></trd>,
    <trd>aspirer</trd>,
    <trd>tendre<klr tip="ind"> (aspirer &agrave;)</klr></trd>
  </trdgrp>
  <trdgrp lng="ja">
    <trd>&#x7A81;&#x9032;&#x3059;&#x308B;  <pr>&#x3068;&#x3063;&#x3057;&#x3093;&#x3059;&#x308B;</pr></trd>,
    <trd>&#x98DB;&#x3073;&#x304B;&#x304B;&#x308B;  <pr>&#x3068;&#x3073;&#x304B;&#x304B;&#x308B;</pr></trd>,
    <trd>&#x7A81;&#x304D;&#x9032;&#x3080;  <pr>&#x3064;&#x304D;&#x3059;&#x3059;&#x3080;</pr></trd>
  </trdgrp>
  <trdgrp lng="pt">
   <trd>arrojar-se</trd>,
   <trd>atirar-se impetuosamente</trd>
  </trdgrp>
  <trdgrp lng="ru">
    <trd>&c_u;&c_s;&c_t;&c_r;&c_je;&c_m;&c_i;&c_t;&c_mol;&c_s;&c_ja;</trd>,
    <trd>&c_u;&c_s;&c_t;&c_r;&c_je;&c_m;&c_l;&c_ja;&c_t;&c_mol;&c_s;&c_ja;</trd>
  </trdgrp>
  <trdgrp lng="sk">
    <trd>dravo t&uacute;&zcaron;i&tcaron; za nie&ccaron;&iacute;m</trd>,
    <trd>hna&tcaron; sa</trd>,
    <trd>r&uacute;ti&tcaron; sa</trd>,
    <trd>&uacute;silne smerova&tcaron;</trd>
  </trdgrp>
  <trdgrp lng="uk">
    <trd>&c_k;&c_i;&c_d;&c_a;&c_t;&c_i;&c_s;&c_ja; &c_v;&c_p;&c_je;&c_r;&c_je;&c_d;</trd>,
    <trd>&c_p;&c_o;&c_r;&c_i;&c_v;&c_a;&c_t;&c_i;&c_s;&c_ja;</trd>,
    <trd>&c_s;&c_p;&c_r;&c_ja;&c_m;&c_o;&c_v;&c_u;&c_v;&c_a;&c_t;&c_i;&c_s;&c_ja;</trd>
  </trdgrp>
</drv>

<drv mrk="impet.0o">
  <kap><tld/>o</kap>
  <snc mrk="impet.0o.alkuro">
    <dif>
      Forta kaj viva anta&ubreve;en&jcirc;eti&gcirc;o; eksalto:
      <ekz>
        oni malfermis alian kradon kaj sur la arenon enkuris kun sova&gcirc;a <tld/>o kaj
        bojado tutaj aroj da hundoj
        <fnt>
          <bib>QuV</bib>
          <lok>&Ccirc;apitro LVI</lok>
        </fnt>.
      </ekz>
    </dif>
    <refgrp tip="vid">
      <ref cel="sving">eksvingo</ref>
    </refgrp>
    <trdgrp lng="de">
      <trd>Ungst&uuml;m</trd>,
      <trd>Heftigkeit</trd>,
      <trd>Vorw&auml;rtsst&uuml;rzen</trd>
    </trdgrp>
    <trdgrp lng="hu">
     <trd>iram</trd>,
     <trd>lend&uuml;let</trd>
    </trdgrp>
    <trd lng="nl">het voorwaarts <ind>stormen</ind></trd>
    <trdgrp lng="ru">
      <trd>&c_n;&c_a;&c_p;&c_o;&c_r;</trd>,
      <trd>&c_p;&c_o;&c_r;&c_y;&c_v;</trd>
    </trdgrp>
  </snc>
  <snc mrk="impet.0o.FIG">
    <uzo tip="stl">FIG</uzo>
    <dif>
      Fervorego; arda aspiro al iu celo:
      <ekz>
	ataki, paroli kun <tld/>o;
      </ekz>
      <ekz>
	la <tld/>oj de nobla animo.
      </ekz>
    </dif>
    <refgrp tip="vid">
      <ref cel="impuls.0o">impulso</ref>,
      <ref cel="torent">torenteco</ref>,
      <ref cel="verv.0o">vervo</ref>
    </refgrp>
    <trdgrp lng="de">
      <trd>leidenschaftlicher <ind>Drang</ind></trd>,
      <trd>Heftigkeit</trd>,
      <trd>Feuer</trd>
    </trdgrp>
    <trdgrp lng="hu">
     <trd>v&aacute;gy</trd>,
     <trd>h&eacute;v</trd>
    </trdgrp>
    <trd lng="nl">ontstuimigheid</trd>
    <trdgrp lng="ru">
      <trd>&c_p;&c_o;&c_r;&c_y;&c_v;</trd>,
      <trd>&c_u;&c_s;&c_t;&c_r;&c_je;&c_m;&c_l;&c_je;&c_n;&c_i;&c_je;</trd>,
      <trd>&c_i;&c_m;&c_p;&c_u;&c_l;&c_mol;&c_s;</trd>
    </trdgrp>
  </snc>
    <trdgrp lng="be">
      <trd>&c_ib;&c_m;&c_p;&c_e;&c_t;</trd>,
      <trd>&c_ib;&c_m;&c_p;&c_u;&c_l;&c_mol;&c_s;</trd>,
      <trd>&c_p;&c_a;&c_m;&c_k;&c_n;&c_je;&c_n;&c_mol;&c_n;&c_je;</trd>
    </trdgrp>
  <trdgrp lng="cs">
    <trd>hnac&iacute; s&iacute;la</trd>,
    <trd>popud</trd>
  </trdgrp>
  <trdgrp lng="en">
    <trd>impetus</trd>,
    <trd>rush</trd>,
    <trd>impulse</trd>
  </trdgrp>
  <trd lng="es">&iacute;mpetu</trd>
  <trdgrp lng="fr">
    <trd>&eacute;lan</trd>,
    <trd>fougue</trd>,
    <trd>impulsion</trd>,
    <trd>lanc&eacute;e</trd>,
    <trd>aspiration</trd>
  </trdgrp>
  <trdgrp lng="ja">
    <trd>&#x7A81;&#x9032;  <pr>&#x3068;&#x3063;&#x3057;&#x3093;</pr></trd>,
    <trd>&#x52E2;&#x3044;  <pr>&#x3044;&#x304D;&#x304A;&#x3044;</pr></trd>,
    <trd>&#x306F;&#x305A;&#x307F;</trd>,
    <trd>&#x71B1;&#x610F;  <pr>&#x306D;&#x3064;&#x3044;</pr></trd>,
    <trd>&#x885D;&#x52D5;  <pr>&#x3057;&#x3087;&#x3046;&#x3069;&#x3046;</pr></trd>
  </trdgrp>
  <trd lng="pt">&iacute;mpeto</trd>
  <trdgrp lng="sk">
    <trd>dravos&tcaron;</trd>,
    <trd>drav&aacute; t&uacute;&zcaron;ba</trd>,
    <trd>n&aacute;por</trd>,
    <trd>&uacute;silie</trd>
  </trdgrp>
  <trdgrp lng="uk">
    <trd>&c_p;&c_o;&c_r;&c_i;&c_v;</trd>,
    <trd>&c_u;&c_s;&c_t;&c_r;&c_je;&c_m;&c_l;&c_ib;&c_n;&c_n;&c_ja;</trd>
  </trdgrp>
  <trdgrp lng="zh">
    <trd>&#x52BF;&#x5934; <pr>sh&igrave;t&oacute;u</pr></trd>,
    <trd>&#x52A8;&#x529B; <pr>d&ograve;ngl&igrave;</pr></trd>,
    <trd>&#x58F0;&#x52BF; <pr>sh&emacron;ngsh&igrave;</pr></trd>
  </trdgrp>
</drv>

<drv mrk="impet.0a">
  <kap><tld/>a</kap>
  <snc>
    <dif>
      Karakterizata per <tld/>o:
      <ekz>
        al mi &scirc;ajnas, ke <nom>Otto</nom> estas tro <tld/>a
        <fnt>
          <bib>Metrop</bib>
        </fnt>!
      </ekz>
      <ekz>
        la proko per kelkaj <tld/>aj pa&scirc;oj saltis al mi
        <fnt>
          <bib>VaK</bib>
          <lok>Dekunua &Ccirc;apitro</lok>
        </fnt>;
      </ekz>
      <ekz>
        la manoj &ndash; akompanante la fortigon kaj altigon de la vo&ccirc;o &ndash; pro la &ccirc;iam pli
        <tld/>a argumentado levi&gcirc;as iom post iom &gcirc;is ili atingas, en la plej kulmina
        momento, la plej altan pozicion
        <fnt>
          <bib>Ret</bib>
          <lok>Dua Parto</lok>
        </fnt>.
      </ekz>
    </dif>
  </snc>
  <trdgrp lng="be">
    <trd>&c_ib;&c_m;&c_p;&c_e;&c_t;&c_n;&c_y;</trd>,
    <trd>&c_ib;&c_m;&c_k;&c_l;&c_ib;&c_v;&c_y;</trd>
  </trdgrp>
  <trdgrp lng="cs">
    <trd>prudk&yacute;</trd>,
    <trd>rychl&yacute;</trd>
  </trdgrp>
  <trdgrp lng="de">
      <trd>ungest&uuml;m</trd>,
      <trd>feurig</trd>
    </trdgrp>
  <trd lng="en">impetuous</trd>
  <trd lng="es">impetuoso</trd>
  <trdgrp lng="fr">
    <trd>dynamique</trd>,
    <trd>nerveux</trd>,
    <trd>vigoureux</trd>
  </trdgrp>
  <trd lng="hu">heves</trd>
  <trdgrp lng="ja">
    <trd>&#x52E2;&#x3044;&#x306E;&#x3042;&#x308B;  <pr>&#x3044;&#x304D;&#x304A;&#x3044;&#x306E;&#x3042;&#x308B;</pr></trd>,
    <trd>&#x885D;&#x52D5;&#x7684;&#x306A;  <pr>&#x3057;&#x3087;&#x3046;&#x3069;&#x3046;&#x3066;&#x304D;&#x306A;</pr></trd>
  </trdgrp>
  <trd lng="nl">ontstuimig</trd>
  <trd lng="pt">impetuoso<klr tip="ind"> (adj.)</klr></trd>
  <trdgrp lng="ru">
    <trd>&c_s;&c_t;&c_r;&c_je;&c_m;&c_i;&c_t;&c_je;&c_l;&c_mol;&c_n;&c_y;&c_j;</trd>,
    <trd>&c_p;&c_o;&c_r;&c_y;&c_v;&c_i;&c_s;&c_t;&c_y;&c_j;</trd>,
    <trd>&c_b;&c_u;&c_r;&c_n;&c_y;&c_j;</trd>,
    <trd>&c_b;&c_u;&c_j;&c_n;&c_y;&c_j;</trd>
  </trdgrp>
  <trdgrp lng="sk">
    <trd>prudk&yacute;</trd>,
    <trd>r&yacute;chly</trd>
  </trdgrp>
  <trdgrp lng="uk">
    <trd>&c_s;&c_t;&c_r;&c_ib;&c_m;&c_k;&c_i;&c_j;</trd>,
    <trd>&c_r;&c_v;&c_u;&c_ch;&c_k;&c_i;&c_j;</trd>,
    <trd>&c_b;&c_u;&c_r;&c_h;&c_l;&c_i;&c_v;&c_i;&c_j;</trd>,
    <trd>&c_b;&c_u;&c_j;&c_n;&c_i;&c_j;</trd>
  </trdgrp>
  <trdgrp lng="zh">
    <trd>&#x72C2;&#x8E81; <pr>ku&aacute;ngz&agrave;o</pr></trd>,
    <trd>&#x5927;&#x529B; <pr>d&agrave;l&igrave;</pr></trd>,
    <trd>&#x52C3;&#x52C3; <pr>b&oacute;b&oacute;</pr></trd>,
    <trd>&#x5306;&#x907D; <pr>c&omacron;ngj&ugrave;</pr></trd>,
    <trd>&#x5982;&#x706B; <pr>r&uacute;hu&#x1D2;</pr></trd>
  </trdgrp>
</drv>

<drv mrk="impet.0ega">
  <kap><tld/>ega</kap>
  <snc>
    <dif>
      Perforte <tld/>a:
      <ekz>
	<tld/>ega torento, vento, kolero, karaktero;
      </ekz>
      <ekz>
	<tld/>ege protesti.
      </ekz>
    </dif>
  </snc>
  <trdgrp lng="be">
    <trd>&c_b;&c_u;&c_ja;&c_n;&c_y;</trd>,
    <trd>&c_g;&c_v;&c_a;&c_l;&c_t;&c_o;&c_w;&c_n;&c_y;</trd>,
    <trd>&c_n;&c_ja;&c_s;&c_t;&c_r;&c_y;&c_m;&c_n;&c_y;</trd>
  </trdgrp>
  <trd lng="cs">n&aacute;tlakov&yacute;</trd>
  <trdgrp lng="de">
      <trd>st&uuml;rmisch</trd>,
      <trd>heftig</trd>
  </trdgrp>
  <trd lng="en">driving <klr>(a driving rain)</klr></trd>
  <trdgrp lng="fr">
    <trd>imp&eacute;tueux</trd>,
    <trd>fougueux</trd>,
    <trd>violent</trd>
  </trdgrp>
  <trd lng="hu">viharos</trd>
  <trdgrp lng="ja">
    <trd>&#x6FC0;&#x3057;&#x3044;  <pr>&#x306F;&#x3052;&#x3057;&#x3044;</pr></trd>,
    <trd>&#x731B;&#x70C8;&#x306A;  <pr>&#x3082;&#x3046;&#x308C;&#x3064;&#x306A;</pr></trd>
  </trdgrp>
  <trd lng="nl">woest</trd>
  <trd lng="pt">agressivamente <ind>impetuoso</ind><klr tip="ind">
(adj.)</klr></trd>
  <trdgrp lng="ru">
    <trd>&c_b;&c_u;&c_r;&c_n;&c_y;&c_j;</trd>,
    <trd>&c_b;&c_u;&c_j;&c_n;&c_y;&c_j;</trd>,
    <trd>&c_n;&c_je;&c_u;&c_d;&c_je;&c_r;&c_zh;&c_i;&c_m;&c_y;&c_j;</trd>
  </trdgrp>
  <trd lng="sk">n&aacute;tlakov&yacute;</trd>
  <trdgrp lng="uk">
    <trd>&c_b;&c_u;&c_r;&c_h;&c_l;&c_i;&c_v;&c_i;&c_j;</trd>,
    <trd>&c_n;&c_je;&c_s;&c_t;&c_r;&c_i;&c_m;&c_n;&c_i;&c_j;</trd>
  </trdgrp>
  <trdgrp lng="zh">
    <trd>&#x6FC0;&#x70C8; <pr>j&imacron;li&egrave;</pr></trd>,
    <trd>&#x76ED; <pr>l&igrave;</pr></trd>
  </trdgrp>
</drv>
</art>
