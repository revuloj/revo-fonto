<kap><rad>tortilj</rad>/o</kap>
<drv mrk="tortilj.0o">
  <kap><tld/>o</kap>
  <snc>
    <uzo tip="fak">KUI</uzo>
    <dif>
      Plata, maldika, ronda, kresposimila pano, fabrikata el maizfaruno,
      kaj kiu estas la bazo de multaj man&gcirc;a&jcirc;oj de la
      Mezamerika kuirado:
      <ekz>
        <tld/>o kun fazeoloj.
      </ekz>
    </dif>
  <ref tip="vid" cel="pan.maiz0o">maizpano</ref>
  </snc>
  <trd lng="be">&c_t;&c_a;&c_r;&c_t;&c_y;&c_l;&c_mol;&c_ja;</trd>
  <trd lng="ca">tortilla<klr> (coca)</klr></trd>
  <trd lng="cs">chlebov&aacute; placka</trd>
  <trd lng="de">Tortilla</trd>
  <trd lng="en">tortilla</trd>
  <trd lng="es">tortilla<klr tip="amb"> (pan plano de ma&iacute;z)</klr></trd>
  <trd lng="fr">tortilla</trd>
  <trd lng="ia">tortilla</trd>
  <trd lng="it">tortilla</trd>
  <trd lng="ja">&#x30C8;&#x30EB;&#x30C6;&#x30A3;&#x30FC;&#x30E4;</trd>
  <trd lng="ko">&#53664;&#47476;&#54000;&#50556;</trd>
  <trd lng="lfn">tortilia</trd>
  <trd lng="nl">tortilla</trd>
  <trd lng="pl">tortilla<klr> (nie istnieje polskie t&lstroke;umaczenie -
  przyj&eogonek;to oryginaln&aogonek; pisowni&eogonek;)</klr></trd>
  <trdgrp lng="pt">
    <trd>tortilha</trd>,
    <trd>tortilla</trd>
  </trdgrp>
  <trd lng="sk">chlebov&aacute; placka</trd>
  <trdgrp lng="sv">
    <trd>tortilla</trd>,
    <trd>tortillabr&ouml;d</trd>
  </trdgrp>
  <trdgrp lng="uk">
    <trd>&c_t;&#x43E;&c_r;&c_t;&c_i;&#x43B;&#x44C;&#x44F; (&#x43C;&c_je;&#x43A;&c_s;&c_i;&#x43A;&c_a;&#x43D;&c_s;&#x44C;&#x43A;&c_i;&c_j;
    &c_h;&#x43B;&c_ib;&c_b;</trd>,
    <trd>&#x43A;&#x43E;&c_r;&c_zh;)</trd>
  </trdgrp>
  <trd lng="zh">&#22696;&#35199;&#21733;&#34180;&#39292; <pr>M&ograve;x&imacron;g&emacron; b&aacute;ob&#464;ng</pr></trd>
</drv>
