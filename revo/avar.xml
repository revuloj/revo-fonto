    <trd>&#x3051;&#x3061;&#x308B;</trd>,
    <trd>&#x51FA;&#x3057;&#x60DC;&#x3057;&#x3080;  <pr>&#x3060;&#x3057;&#x304A;&#x3057;&#x3080;</pr></trd>
  </trdgrp>
  <trd lng="nl">karig zijn met</trd>
  <trdgrp lng="pl">
    <trd>sk&aogonek;pi&cacute;</trd>,
    <trd>&zdot;a&lstroke;owa&cacute;</trd>,
    <trd>szcz&eogonek;dzi&cacute;</trd>
  </trdgrp>
  <trdgrp lng="ru">
