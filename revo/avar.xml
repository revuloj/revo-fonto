</drv>

<drv mrk="avar.0i">
  <kap><tld/>i</kap>
  <gra><vspec>tr</vspec></gra>
  <snc mrk="avar.0i.elspezi">
    <dif>
      Esti <tld/>a pri, agi <tld/>e pri elspezo:
      <ekz>
        unu disdonas, kaj ri&ccirc;i&gcirc;as &ccirc;iam pli, alia tro <tld/>as, kaj tamen nur malri&ccirc;i&gcirc;as
        <fnt>
          <bib>MT</bib>
          <lok>Sentencoj 11:24</lok>
        </fnt>;
      </ekz>
      <ekz>
        ho Izido, neniam mi <tld/>is al vi oferojn, sed hodia&ubreve; mi donas la plej grandan
        <fnt>
          <bib>Far3</bib>
          <lok>&Ccirc;apitro I</lok>
        </fnt>;
      </ekz>
      <ekz>
        li decidis <tld/>i por tio nek monon, nek homojn
        <fnt>
          <bib>QuV</bib>
          <lok>&Ccirc;apitro LI</lok>
        </fnt>;
      </ekz>
      <ekz>
        onklo nenion por eduk&#x2019; <tld/>is
        <fnt>
          <bib>SrT</bib>
          <lok>Libro I.</lok>
        </fnt>;
      </ekz>
      <ekz>
        patroj <tld/>as, infanoj mal&scirc;paras
        <fnt><bib>PrV</bib></fnt>.
      </ekz>
    </dif>
    <refgrp tip="sin">
      <ref cel="domagx.0i.avari">doma&gcirc;i</ref>,
      <ref cel="sxpar.0i.moderi">&scirc;pari</ref>
    </refgrp>
    <ref tip="vid" cel="avid.0i">avidi</ref>
  </snc>
  <snc mrk="avar.0i.FIG">
    <dif>
      Esti <tld/>a pri io nemateria:
      <ekz>
        se la sango bolas, tiam lango &parsl; La &jcirc;urojn ne <tld/>as
        <fnt>
          <bib>Hamlet</bib>
          <lok>Hamleto</lok>
        </fnt>;
      </ekz>
      <ekz>
        anta&ubreve; nelonge ili dronis, nur por vidi la viza&gcirc;on de lia sankteco, kaj hodia&ubreve;
        ili <tld/>as la kriojn
        <fnt>
          <bib>Far3</bib>
          <lok>&Ccirc;apitro XIII</lok>
        </fnt>;
      </ekz>
      <ekz>
        li ne <tld/>is la&ubreve;dojn
        <fnt>
          <bib>QuV</bib>
          <lok>&Ccirc;apitro XXXI</lok>
        </fnt>;
      </ekz>
      <ekz>
        <nom>Petronius</nom> sciis tamen ne <tld/>i la punojn, al kiuj ilin subigis la &gcirc;enerala moro
        <fnt>
          <bib>QuV</bib>
          <lok>&Ccirc;apitro XII</lok>
        </fnt>.
      </ekz>
    </dif>
  </snc>
  <trdgrp lng="be">
    <trd>&c_s;&c_k;&c_u;&c_p;&c_ib;&c_c;&c_c;&c_a;</trd>,
    <trd>&c_s;&c_k;&c_n;&c_a;&c_r;&c_y;&c_c;&c_c;&c_a;</trd>,
    <trd>&c_p;&c_r;&c_a;&c_g;&c_n;&c_u;&c_c;&c_mol;</trd>
  </trdgrp>
  <trdgrp lng="br">
    <trd>beza&ntilde; <ind>pizh</ind></trd>,
    <trd>beza&ntilde; <ind>skragn</ind></trd>
  </trdgrp>
  <trd lng="de">geizen</trd>
  <trdgrp lng="en">
    <trd>be <ind>greedy</ind></trd>,
    <trd>stint</trd>,
    <trd>penny-pinch</trd>
  </trdgrp>
  <trdgrp lng="fr">
    <trd>&ecirc;tre <ind>avare</ind> (de)</trd>,
    <trd>rationner<klr tip="ind"> (par avarice)</klr></trd>
  </trdgrp>
  <trdgrp lng="hu">
