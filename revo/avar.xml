    <trd>&c_sh;&c_k;&c_o;&c_d;&c_u;&c_v;&c_a;&c_t;&c_i;&nbsp;(&c_ch;&c_o;&c_g;&c_o;-&c_n;.)</trd>
  </trdgrp>
</drv>

<drv mrk="avar.0ulo">
  <kap><ofc>*</ofc><tld/>ulo</kap>
  <snc>
    <dif>
      Homo, kiu avaras:
      <ekz>
        pri <tld/>ulo oni ne plu diros, ke li estas bonfaranto
        <fnt>
          <bib>MT</bib>
          <lok>Jesaja 32:5</lok>
        </fnt>;
      </ekz>
      <ekz>
        ili flugis internen de la kvar nudaj muroj de <tld/>ulo, kie, tute malgrasa,
        tremanta de malvarmo, malsata kaj soifa, la maljunulo per &ccirc;iuj siaj pensoj
        kaj meditoj alkro&ccirc;i&gcirc;is al sia mono
        <fnt>
          <bib>Fab3</bib>
          <lok>Historio</lok>
        </fnt>;
      </ekz>
      <ekz>
        kion vi nomas honesta? depreni al ri&ccirc;aj <tld/>uloj de ilia kolo trionon de la
        zorgoj,
        <fnt>
          <bib>Rabistoj</bib>
          <lok>Akto Unua</lok>
        </fnt>;
      </ekz>
      <ekz>
        <tld/>ulo, elirante el la pre&gcirc;ejo, kie la pastro parolis pri bonfarado, diris: &mdash;
        la prediko tiel min tu&scirc;is, ke mi mem estas preta peti almozojn
        <fnt>
          <bib>FK</bib>
          <lok>Fundamenta Krestomatio de la lingvo Esperanto</lok>
        </fnt>;
      </ekz>
      <ekz>
        mal&scirc;parulo &gcirc;uas nelonge, <tld/>ulo neniam
        <fnt><bib>PrV</bib></fnt>.
      </ekz>
    </dif>
  </snc>
  <trdgrp lng="be">
    <trd>&c_s;&c_k;&c_n;&c_a;&c_r;&c_a;</trd>,
    <trd>&c_s;&c_k;&c_u;&c_p;&c_ja;&c_n;&c_d;&c_a;</trd>,
    <trd>&c_zh;&c_m;&c_ib;&c_n;&c_d;&c_a;</trd>,
    <trd>&c_h;&c_c;&c_ib;&c_v;&c_je;&c_c;</trd>,
    <trd>&c_z;&c_a;&c_c;&c_ib;&c_s;&c_k;&c_a;&c_j;&c_l;&c_a;</trd>
  </trdgrp>
  <trdgrp lng="de">
    <trd>Geizhals</trd>,
    <trd>Knauser</trd>
  </trdgrp>
  <trdgrp lng="en">
    <trd>miser</trd>,
    <trd>covetous person</trd>,
  </trdgrp>
  <trd lng="fr">avare<klr> (subst.)</klr></trd>
  <trd lng="he">&qof;&#x5B7;&mem;&tsadi;&#x5B8;&fnun;</trd>
  <trdgrp lng="id">
    <trd><baz>orang</baz>orang kedekut</trd>,
    <trd><baz>orang</baz>orang kikir</trd>,
    <trd><baz>orang</baz>orang koret</trd>,
    <trd><baz>orang</baz>orang lokek</trd>,
    <trd><baz>orang</baz>orang medit</trd>,
    <trd><baz>orang</baz>orang pelit</trd>
  </trdgrp>
  <trdgrp lng="ja">
    <trd>&#x3051;&#x3061;&#x3093;&#x574A;  <pr>&#x3051;&#x3061;&#x3093;&#x307C;&#x3046;</pr></trd>,
    <trd>&#x5B88;&#x92AD;&#x5974;  <pr>&#x3057;&#x3085;&#x305B;&#x3093;&#x3069;</pr></trd>
  </trdgrp>
  <trd lng="pl">sknera</trd>
  <trdgrp lng="ro">
    <trd>avar</trd>,
    <trd>zg&acirc;rcit</trd>
  </trdgrp>
  <trdgrp lng="uk">
    <trd>&c_s;&c_k;&c_u;&c_p;&c_a;&c_r;</trd>,
    <trd>&c_s;&c_k;&c_u;&c_p;&c_je;&c_r;&c_d;&c_ja;&c_g;&c_a;</trd>,
    <trd>&c_s;&c_k;&c_n;&c_a;&c_r;&c_a;</trd>
  </trdgrp>
