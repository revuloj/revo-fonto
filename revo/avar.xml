<drv mrk="avar.mal0a">
  <kap>mal<tld/>a</kap>
  <snc>
    <dif>
      Facile donanta:
      <ekz>
        amikoj <klr>[&#x2026;]</klr> per mal<tld/>a fondo de la Centra Oficejo donis fortikan
        fundamenton por &ccirc;iuj plej gravaj laboroj
        <fnt>
          <bib>Paroloj</bib>
          <vrk>Parolado anta&ubreve; la Dua Kongreso Esperantista en Gen&egrave;ve en la 28a de a&ubreve;gusto 1906</vrk>
        </fnt>;
      </ekz>
      <ekz>
        la faraono faris al la dioj mal<tld/>ajn oferojn kaj konstruis templojn
        <fnt>
          <bib>Far1</bib>
          <lok>Anta&ubreve;parolo</lok>
        </fnt>;
      </ekz>
      <ekz>
        tre pla&ccirc;is al li <klr>[&#x2026;]</klr> ilia mal<tld/>a la&ubreve;dado kaj preska&ubreve; adorado
        <fnt>
          <bib>MrA</bib>
          <lok>&Ccirc;apitro V</lok>
        </fnt>;
      </ekz>
      <ekz>
        viroj, junaj kaj maljunaj, tributis al la beleco kaj la lerteco de la
        dancistinoj la plej mal<tld/>an admiron
        <fnt>
          <bib>I&scirc;tar</bib>
          <lok>&Ccirc;apitro XIII</lok>
        </fnt>;
      </ekz>
      <ekz>
        pri havo najbara <klr>(de najbaro)</klr> oni estas mal<tld/>a
        <fnt><bib>PrV</bib></fnt>.
      </ekz>
    </dif>
    <ref tip="sin" cel="don.0ema">donema</ref>
    <refgrp tip="vid">
      <ref cel="donac.0ema">donacema</ref>,
      <ref cel="spez.el0ema">elspezema</ref>
    </refgrp>
  </snc>
  <trd lng="be">&c_sh;&c_ch;&c_o;&c_d;&c_r;&c_y;</trd>
  <trd lng="bg">&c_shch;&c_je;&c_d;&c_malmol;&c_r;</trd>
  <trd lng="bo">&t_la;&t_ga;&t_tsheg;&t_pa;&t_tsheg;&t_sha;&t_naro;&t_ga;&t_tsheg;&t_pa;&t_naro;&t_tsheg;</trd>
  <trd lng="br">brokus</trd>
  <trd lng="cs">&scaron;t&ecaron;dr&yacute;</trd>
  <trdgrp lng="de">
    <trd>freigiebig</trd>,
    <trd>gener&ouml;s</trd>,
    <trd>spendabel</trd>
  </trdgrp>
  <trd lng="en">generous</trd>
  <trd lng="es">generoso</trd>
  <trdgrp lng="fr">
    <trd>g&eacute;n&eacute;reux</trd>,
    <trd>large<klr tip="ind"> (g&eacute;n&eacute;reux)</klr></trd>,
    <trd>prodigue</trd>
  </trdgrp>
  <trdgrp lng="hu">
    <trd>b&odblac;kez&udblac;</trd>,
    <trd>adakoz&oacute;</trd>,
    <trd>t&eacute;kozl&oacute;</trd>
  </trdgrp>
  <trdgrp lng="id">
    <trd>dermawan</trd>,
    <trd>karim</trd>,
    <trd>murah</trd>,
    <trd><baz>murah</baz>murah hati</trd>
  </trdgrp>
  <trdgrp lng="it">
    <trd>generoso</trd>,
    <trd>prodigo</trd>,
    <trd>munifico</trd>
  </trdgrp>
