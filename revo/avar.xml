  </trdgrp>
  <trd lng="it">avaro</trd>
  <trdgrp lng="ja">
    <trd>&#x6B32;&#x306E;&#x6DF1;&#x3044;  <pr>&#x3088;&#x304F;&#x306E;&#x3075;&#x304B;&#x3044;</pr></trd>,
    <trd>&#x3051;&#x3061;&#x306A;</trd>
  </trdgrp>
  <trd lng="nl">gierig</trd>
  <trd lng="pl">sk&aogonek;py</trd>
  <trd lng="pt">avarento</trd>
  <trd lng="ro">zg&acirc;rcit</trd>
