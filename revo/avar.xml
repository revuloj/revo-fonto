    <trd>miserly</trd>,
    <trd>stingy</trd>,
    <trd>niggardly</trd>,
    <trd>greedy</trd>
  </trdgrp>
  <trd lng="es">avaro</trd>
  <trd lng="fr">avare<klr> (adj.)</klr></trd>
  <trd lng="he">&qof;&mem;&tsadi;&fnun;</trd>
  <trdgrp lng="hu">
