    <trd>&c_s;&c_t;&c_i;&c_s;&c_n;&c_a;&c_t;</trd>
  </trdgrp>
  <trdgrp lng="br">
    <trd>pizh<klr tip="ind"> (na foran ket)</klr></trd>,
    <trd>skragn</trd>
  </trdgrp>
  <trdgrp lng="cs">
