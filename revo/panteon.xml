<!DOCTYPE vortaro SYSTEM "../dtd/vokoxml.dtd">

<vortaro>
  <art mrk="$Id: panteon.xml,v 1.5 2026/06/13 23:22:51 afido Exp $">
    <kap>
      <rad>panteon</rad>/o
    </kap>

<drv mrk="panteon.0o">
  <kap><tld/>o</kap>
  <uzo tip="fak">HIS</uzo><uzo tip="fak">REL</uzo>
  <snc>
    <dif>
      Antikva <ref tip="super" cel="sankt.0ejo">sanktejo</ref>
      konsekrita al &ccirc;iuj dioj:
      <ekz>
        grandaj maketoj de kelkaj belegaj monumentoj:
        la baziliko de Sankta Petro en
        Romo, la katedraloj de Ankono kaj de Florenco,
        <tld lit="P"/>o en Romo,
        Partenono
        <fnt>
          <aut>Aldo Grassini</aut>
          <vrk><url ref="&Monato;/2006/008997.php"
              >Arto videbla anka&ubreve; por blinduloj</url></vrk>
              <bib>Monato</bib>
          <lok>2006/10, p. 20</lok>
        </fnt>;
      </ekz>
      <ekz>
        <uzo tip="stl">FIG</uzo>
        komence de junio 1951 okazis ina&ubreve;guro
        de <tld lit="P"/>o por la pioniroj de la
        mondlingva ideo
        <fnt>
          <bib>EeP</bib>
          <lok>Kvara Parto</lok>
        </fnt>;
      </ekz>
      <ekz>
        <uzo tip="stl">FIG</uzo>
        apud li en tiu <tld/>o egale rangas eble nur
        <nom>Arthur Conan Doyle</nom> kaj <nom>Agatha
        Christie</nom>
        <fnt>
          <aut>Donald Broadribb</aut>
          <vrk><url ref="&Monato;/2008/009400.php"
              >Nova Maigret-romano</url></vrk>
              <bib>Monato</bib>
          <lok>2008/04, p. 24</lok>
        </fnt>.
      </ekz>
    </dif>
    <rim>
      La&ubreve; <fnt><bib>BL</bib></fnt>: Prefere diru <ke>diara templo</ke>, <ke>templo al &ccirc;iuj
      dioj</ke>, (pri la dioj mem) <ke>diaro</ke>.
    </rim>
    <trd lng="de">Pantheon</trd>
    <trd lng="en">pantheon</trd>
    <trd lng="fr">Panth&eacute;on</trd>
    <trd lng="nl">pantheon</trd>
    <trd lng="pl">panteon</trd>
    <trdgrp lng="zh">
      <trd>&#19975;&#31070;&#27583;</trd>,
      <trd>&#33836;&#31070;&#27583;</trd>,
      <trd>&#28504;&#25552;&#32705;</trd>,
      <trd>&#31070;&#31995;</trd>
    </trdgrp>
  </snc>
     <trd lng="be">&c_p;&c_a;&c_n;&c_t;&c_e;&c_o;&c_n;</trd>
 </drv>
</art>

