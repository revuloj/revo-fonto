<?xml version="1.0"?>
<!DOCTYPE vortaro SYSTEM "../dtd/vokoxml.dtd">
<vortaro>
<art mrk="$Id: cxemiz.xml,v 1.43 2026/03/03 08:00:25 revo Exp $">
<kap>
  <ofc>*</ofc>
  <rad>&ccirc;emiz</rad>/o <fnt><bib>UV</bib></fnt>
</kap>

<drv mrk="cxemiz.0o">
  <kap><ofc>*</ofc><tld/>o</kap>
  <snc mrk="cxemiz.0o.TEKS">
    <uzo tip="fak">TEKS</uzo>
    <dif>
      Maldika sur- a&ubreve; sub<ref tip="lst" lst="voko:vesta&jcirc;oj" cel="vest.0o.TEKS">vesto</ref>
      kovranta la trunkon, parte a&ubreve; tute la brakojn:
      <ekz>
        la sud-tirolano iras kun malbutonumita <tld/>o kaj kun tibeta
        &ccirc;eneto &ccirc;irka&ubreve; la kolo
        <fnt>
        <aut>E. Georgiev</aut>,
        <vrk>Reinhold Messner - Alpisto, revanto, e&ubreve;ropa deputito
        </vrk>,
        <bib>Monato</bib>,
        <lok>2002:8, p. 26a</lok>
        </fnt>.
      </ekz>
    </dif>
  </snc>
  <trd lng="be">&c_k;&c_a;&c_sh;&c_u;&c_l;&c_ja;</trd>
  <trd lng="bo">&#3936;&#3964;&#3906;&#3851;&#3936;&#3911;&#3956;&#3906;&#3851;</trd>
  <trdgrp lng="el">
    <trd>&pi;&omikron;&ypsilon;&kappa;&alfa_ton;&my;&jota;&sigma;&omikron;</trd>,
    <trd>&ypsilon;&pi;&omikron;&kappa;&alfa_ton;&my;&jota;&sigma;&omikron;</trd>
  </trdgrp>
  <trd lng="bg">&c_r;&c_i;&c_z;&c_a;</trd>
  <trd lng="ca">camisa</trd>
  <trd lng="de">Hemd</trd>
  <trd lng="cs">ko&scaron;ile</trd>
  <trd lng="en">shirt</trd>
  <trd lng="es">camisa</trd>
  <trd lng="fr">chemise</trd>
  <trd lng="he">&het;&vav;&lamed;&tsadi;&he;</trd>
  <trd lng="id">kemeja</trd>
  <trdgrp lng="ja">
    <trd>&#12471;&#12515;&#12484;  <pr>&#12375;&#12419;&#12388;</pr></trd>,
    <trd>&#12527;&#12452;&#12471;&#12515;&#12484;</trd>,
    <trd>&#12471;&#12517;&#12511;&#12540;&#12474;</trd>
  </trdgrp>
  <trd lng="nl">hemd</trd>
  <trd lng="pt">camisa</trd>
  <trd lng="pl">koszula</trd>
  <trd lng="ro">c&abreve;ma&#537;&abreve;</trd>
  <trdgrp lng="ru">
    <trd>&c_r;&c_u;&c_b;&c_a;&c_h;&c_a;</trd>,
    <trd>&c_r;&c_u;&c_b;&c_a;&c_sh;&c_k;&c_a;</trd>,
    <trd>&c_s;&c_o;&c_r;&c_o;&c_ch;&c_k;&c_a;</trd>
  </trdgrp>
  <trd lng="sgn" kod="M541x531S2ff00481x483S36d00479x527S1da02512x515S1da0a459x515">P@43*</trd>
  <trd lng="tr">g&ouml;mlek</trd>
  <trd lng="it">camicia</trd>
  <trd lng="uk">&c_s;&c_o;&c_r;&c_o;&c_ch;&c_k;&c_a;</trd>
  <trdgrp lng="zh">
    <trd>&#34923; <pr>sh&amacron;n</pr></trd>,
    <trd>&#34924;&#34923; <pr>ch&egrave;nsh&amacron;n</pr></trd>
  </trdgrp>
</drv>

<drv mrk="cxemiz.nokto0o">
  <kap>nokto<tld/>o</kap>
  <snc mrk="cxemiz.nokto0o.TEKS">
    <uzo tip="fak">TEKS</uzo>
    <dif>
      <ref tip="lst" lst="voko:vesta&jcirc;oj" cel="vest.nokto0o.TEKS">Noktovesto</ref>
      en formo de vasta kaj longa <tld/>o:
      <ekz>
        sur la bildo estas bela an&gcirc;elo kun longaj, lumaj
        haroj kaj blanka nokto<tld/>o
        <fnt>
          <aut>A. Lindgren, trad. I. Krotova</aut>,
          <vrk>La infanoj che la strato Brufarantoj</vrk>,
          <lok>[sen dato]</lok>
        </fnt>.
      </ekz>
    </dif>
  </snc>
  <trd lng="be">&c_n;&c_a;&c_ch;&c_n;&c_a;&c_ja; <ind>&c_k;&c_a;&c_sh;&c_u;&c_l;&c_ja;</ind></trd>
  <trd lng="ca">camisa de dormir</trd>
  <trd lng="fr">chemise de nuit</trd>
  <trd lng="id"><ind>kemeja</ind> malam</trd>
  <trdgrp lng="ja">
    <trd>&#23517;&#38291;&#30528;  <pr>&#12397;&#12414;&#12365;</pr></trd>,
    <trd>&#12493;&#12464;&#12522;&#12472;&#12455;</trd>
  </trdgrp>
  <trdgrp lng="uk">
    <trd>&c_n;&c_ib;&c_ch;&c_n;&c_a; &c_s;&c_o;&c_r;&c_o;&c_ch;&c_k;&c_a;</trd>,
    <trd>&c_s;&c_p;&c_a;&c_l;&c_mol;&c_n;&c_a; &c_s;&c_o;&c_r;&c_o;&c_ch;&c_k;&c_a;</trd>
  </trdgrp>
</drv>

<drv mrk="cxemiz.polo0o">
  <kap>polo<tld/>o</kap>
  <snc mrk="cxemiz.polo0o.TEKS">
    <uzo tip="fak">TEKS</uzo>
    <dif>
      <ref tip="lst" lst="voko:vesta&jcirc;oj" cel="cxemiz.0o.TEKS"><tld lit="&Ccirc;"/>o</ref>
      el trikita, &scirc;vitabsorba &scirc;tofo, kun kolumo kaj mallongaj manikoj,
      origine portata por teniso, poloo, golfo kaj aliaj eksterdomaj
      sportoj:
      <ekz>
        mi produktigos &scirc;vit- kaj polo<tld/>ojn en unuaklasa kvalito
        <fnt>
          <aut>P. Weide</aut>,
          <vrk>&Ccirc;u vi &scirc;atus krei atenton...</vrk>,
          <lok><url ref="http://dvd.ikso.net/revuo/Revuo_Esperanto/2006/11.pdf">
          Esperanto, 2006:11</url></lok>
        </fnt>.
      </ekz>
    </dif>
  </snc>
  <trd lng="be">&c_p;&c_o;&c_l;&c_a; <klr tip="amb">(&c_k;&c_a;&c_sh;&c_u;&c_l;&c_ja;)</klr></trd>
  <trd lng="ca">polo<klr tip="amb"> (samarreta)</klr></trd>
  <trd lng="fr">chemise <ind>polo</ind></trd>
  <trdgrp lng="id">
    <trd><ind>kemeja</ind> polo</trd>,
    <trd>polo</trd>
  </trdgrp>
  <trd lng="ja">&#12509;&#12525;&#12471;&#12515;&#12484;</trd>
</drv>

<drv mrk="cxemiz.to0o">
  <kap>to-<tld/>o</kap>
  <snc mrk="cxemiz.to0o.TEKS">
    <uzo tip="fak">TEKS</uzo>
    <dif>
      Neformala T-forma <ref tip="lst" lst="voko:vesta&jcirc;oj" cel="cxemiz.0o.TEKS"><tld/>o</ref>
      kun mallongaj manikoj &gcirc;is mezo de supra brako,
      portata sub- a&ubreve; sol-veste:
      <ekz>
        li kreis T-<tld/>ojn kaj po&scirc;tkartojn
        <fnt>
        <aut>J. G. Champlin</aut>, <vrk>Kiel pentri demokration?</vrk>,
        <bib>Monato</bib>, <lok>2001:12, p.
        20a</lok>
        </fnt>.
      </ekz>
    </dif>
  </snc>
  <trdgrp lng="be">
    <trd>&c_m;&c_a;&c_j;&c_k;&c_a;</trd>,
    <trd>&c_f;&c_u;&c_t;&c_b;&c_o;&c_l;&c_k;&c_a;</trd>
  </trdgrp>
  <trd lng="bg">&c_t;&c_je;&c_n;&c_i;&c_s;&c_k;&c_a;</trd>
  <trd lng="ca">samarreta</trd>
  <trd lng="de">T-Shirt</trd>
  <trdgrp lng="en">
    <trd>tee-shirt</trd>,
    <trd>T-shirt</trd>
  </trdgrp>
  <trd lng="es">camiseta</trd>
  <trd lng="fr">tee-shirt</trd>
  <trd lng="id"><ind>kaus</ind> oblong</trd>
  <trdgrp lng="it">
    <trd>T-shirt</trd>,
    <trd>maglietta</trd>
  </trdgrp>
  <trd lng="nl">T-shirt</trd>
  <trdgrp lng="pl">
    <trd>T-shirt</trd>,
    <trd>koszulka</trd>,
    <trd>podkoszulek<klr> {m.}</klr></trd>,
    <trd>podkoszulka<klr> {f.}</klr></trd>
  </trdgrp>
  <trdgrp lng="pt">
    <trd>camisola</trd>,
    <trd>camiseta<klr> (bras.)</klr></trd>
  </trdgrp>
  <trdgrp lng="ru">
    <trd>&c_m;&c_a;&c_j;&c_k;&c_a;</trd>,
    <trd>&c_f;&c_u;&c_t;&c_b;&c_o;&c_l;&c_k;&c_a;</trd>
  </trdgrp>
  <trdgrp lng="uk">
    <trd>&c_f;&c_u;&c_t;&c_b;&c_o;&c_l;&c_k;&c_a;</trd>,
    <trd>&c_b;&c_je;&c_z;&c_r;&c_u;&c_k;&c_a;&c_v;&c_k;&c_a;</trd>
  </trdgrp>
  <trdgrp lng="zh">
    <trd>&#30701;&#34966;&#22278;&#39046;&#34923; <pr>du&#462;nxi&ugrave;yu&aacute;nl&#464;ngsh&amacron;n</pr></trd>,
    <trd>&#20307;&#24676;&#34923; <pr>t&#464;x&ugrave;sh&amacron;n</pr></trd>,
    <trd>&#27735;&#34923; <pr>h&agrave;nsh&amacron;n</pr></trd>
  </trdgrp>
</drv>
</art>
