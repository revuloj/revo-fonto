<?xml version="1.0"?>
<!DOCTYPE vortaro SYSTEM "../dtd/vokoxml.dtd">
<vortaro>
<art mrk="$Id: migdal.xml,v 1.35 2026/04/03 07:26:58 revo Exp $">
<kap>
  <ofc>*</ofc>
  <rad>migdal</rad>/o <fnt><bib>UV</bib></fnt>
</kap>
<drv mrk="migdal.0o">
  <kap><ofc>*</ofc><tld/>o</kap>
  <snc mrk="migdal.0o.KUI">
    <uzo tip="fak">KUI</uzo>
    <dif>
      <ref tip="super" cel="kern.0o.BOT">Kerno</ref>
      de la frukto de
      <ref tip="malprt" cel="migdal.0arbo.BOT"><tld/>arbo</ref>,
      kies interna grajno estas man&gcirc;ebla:
      <ekz>
        alportu al la homo donacon: iom da balzamo kaj iom da mielo, aroma&jcirc;on kaj
        mirhon, pistakojn kaj <tld/>ojn
        <fnt>
          <bib>MT</bib>
          <lok>Genezo 43:11</lok>
        </fnt>;
      </ekz>
      <ekz>
        li alportis zorgplene envolvitajn en papero kelkajn <tld/>ojn kaj sekvinberojn
        <fnt>
          <aut>Robindra Nath Tagore, trad. I. J. Sorabji </aut>
          <vrk>La Kabulano</vrk>
          <lok>en: Orienta Almanako, 1913</lok>
        </fnt>;
      </ekz>
      <ekz>
        <tld/>formaj okuloj
        <fnt>
          <bib>ChB</bib>
          <lok>5</lok>
        </fnt>;
      </ekz>
      <ekz>
        maldol&ccirc;a <tld/>o
        <fnt>
          <bib>Fab3</bib>
          <lok>Sub la saliko</lok>
        </fnt>.
      </ekz>
    </dif>
  </snc>
  <ref tip="hom" cel="migdal1.0o">migdalo <klr>(de cerbo)</klr></ref>
  <trd lng="be">&c_m;&c_ib;&c_n;&c_d;&c_a;&c_l;&c_mol; <klr>(&c_a;&c_r;&c_e;&c_h;)</klr></trd>
  <trd lng="bg">&c_b;&c_a;&c_d;&c_je;&c_m;</trd>
  <trd lng="br">alamandezenn<klr tip="ind"> (frouezhenn)</klr></trd>
  <trd lng="ca">ametlla</trd>
  <trd lng="cs">mandle <klr>(po&zcaron;iv.)</klr></trd>
  <trd lng="de">Mandel</trd>
  <trd lng="en">almond</trd>
  <trd lng="es">almendra</trd>
  <trd lng="fr">amande</trd>
  <trd lng="hu">mandula</trd>
  <trd lng="ja">&#x30A2;&#x30FC;&#x30E2;&#x30F3;&#x30C9;</trd>
  <trd lng="nl">amandel<klr tip="ind"> (noot)</klr></trd>
  <trd lng="no">mandel<klr tip="amb"> (n&oslash;tt)</klr></trd>
  <trd lng="pl">migda&lstroke;</trd>
  <trd lng="pt">am&ecirc;ndoa</trd>
  <trd lng="ru">&c_m;&c_i;&c_n;&c_d;&c_a;&c_l;&c_mol; <klr>(&c_o;&c_r;&c_je;&c_h;)</klr></trd>
  <trd lng="sk">mand&lcaron;a <klr>(ovocie)</klr></trd>
  <trd lng="uk">&c_m;&c_i;&c_g;&c_d;&c_a;&c_l;&c_mol; (&c_p;&c_l;&c_ib;&c_d;)</trd>
  <trdgrp lng="zh">
    <trd>&#x674F;&#x4EC1; <pr>x&igrave;ngr&eacute;n</pr></trd>,
    <trd>&#25153;&#26691; <pr>bi&#x1CE;nt&aacute;o</pr></trd>,
    <trd>&#x5DF4;&#x65E6;&#26408; <pr>b&amacron;d&agrave;nm&ugrave;</pr></trd>,
    <trd>&#x5DF4;&#x8FBE;&#26408; <pr>b&amacron;d&aacute;m&ugrave;</pr></trd>,
    <trd>&#x5DF4;&#36948;&#26408; <pr>b&amacron;d&aacute;m&ugrave;</pr></trd>
  </trdgrp>
</drv>

<drv mrk="migdal.0a">
  <kap>
    <tld/>a
  </kap>
  <snc>
    <dif>
      De, kun <tld/>oj:
      <ekz>
        <tld/>a &scirc;elo
        <fnt>
          <bib>QuV</bib>
          <lok>&Ccirc;apitro XIII</lok>
        </fnt>;
      </ekz>
      <ekz>
        fari <tld/>an torton
        <fnt>
          <bib>Monato</bib>
          <aut>Istv&aacute;n Ertl</aut>
          <vrk><url ref="&Monato;/2013/010910.php"
              >Dobos Delight</url></vrk>
          <lok>2013</lok>
        </fnt>;
      </ekz>
      <ekz>
        <nom>Marika</nom> diris ke <tld/>a&jcirc;o tiel rapide ne eblas
        <fnt>
          <bib>Monato</bib>
          <aut>Istv&aacute;n Ertl</aut>
          <vrk><url ref="&Monato;/2013/010910.php"
              >Dobos Delight</url></vrk>
          <lok>2013</lok>
        </fnt>.
      </ekz>
    </dif>
  </snc>
  <trdgrp lng="be">
    <trd>&c_m;&c_ib;&c_n;&c_d;&c_a;&c_l;&c_je;&c_v;&c_y;</trd>,
    <trd>&c_m;&c_ib;&c_n;&c_d;&c_a;&c_l;&c_mol;&c_n;&c_y;</trd>,
    <trd>&c_m;&c_ib;&c_n;&c_d;&c_a;&c_l;&c_je;&c_p;&c_a;&c_d;&c_o;&c_b;&c_n;&c_y;</trd>
  </trdgrp>
  <trd lng="de">Mandel-</trd>
</drv>

<drv mrk="migdal.suker0o">
  <kap>suker<tld/>o</kap>
  <snc mrk="migdal.suker0o.KUI">
    <uzo tip="fak">KUI</uzo>
    <dif>
      <ref tip="super" cel="frand.0ajxo.KUI">Franda&jcirc;o</ref> farita
      el migdalgrajno en sukera tega&jcirc;o:
      <ekz>
        fratino Rosalio pli ol unu fojon alportis suker<tld/>ojn
        <fnt><aut>J. B. Gresset, trad. C. Rousseau</aut>,
        <vrk>Ver-vert</vrk>, <lok>Esperantista Centra Librejo,
        [1914?]</lok></fnt>.
      </ekz>
    </dif>
  </snc>
  <trd lng="be">&c_m;&c_ib;&c_n;&c_d;&c_a;&c_l;&c_mol; &c_u; &c_c;&c_u;&c_k;&c_r;&c_o;&c_v;&c_a;&c_j; &c_g;&c_l;&c_a;&c_z;&c_u;&c_r;&c_y;</trd>
  <trd lng="ca">ametlla ensucrada</trd>
  <trd lng="de">gebrannte <ind>Mandel</ind></trd>
  <trd lng="fr">drag&eacute;e</trd>
</drv>

<drv mrk="migdal.0arbo">
  <kap><tld/>arbo, <var><kap><tld/>ujo</kap></var></kap>
  <snc mrk="migdal.0arbo.BOT">
    <uzo tip="fak">BOT</uzo>
    <dif>
      Arbo el Okcidentazio kaj mediteraneaj landoj,
      fruprintempe floranta, kultivata anka&ubreve; en Ameriko;
      <ref tip="lst" cel="speci.0o.BIO" lst="voko:botanikaj_specioj">specio</ref> de <ref
      tip="super" cel="prunus.0o">prunuso</ref>
      (<trd lng="la">Prunus dulcis</trd>):
      <ekz>
        &gcirc;ardenrandaj junaj <tld/>arboj
        <fnt>
          <aut>J. Dorosmai, trad. J. Dorosmai jun. kaj J. Horvath</aut>
          <vrk>Fabloj kaj Aforismoj</vrk>
          <lok>2002a</lok>
        </fnt>;
      </ekz>
      <ekz>
        <nom>Jakob</nom> prenis al si bastonojn el verdaj poploj, <tld/>arboj, kaj platanarboj, kaj
        sen&scirc;eligis sur ili blankajn striojn
        <fnt>
          <bib>MT</bib>
          <lok>Genezo 30:37</lok>
        </fnt>.
      </ekz>
    </dif>
  </snc>
  <trd lng="be">&c_m;&c_ib;&c_n;&c_d;&c_a;&c_l;&c_mol;
  <klr>(&c_r;&c_a;&c_s;&c_mol;&c_l;&c_ib;&c_n;&c_a;)</klr></trd>
  <trdgrp lng="br">
    <trd>alamandezenn<klr tip="ind"> (gwezenn)</klr></trd>,
    <trd>gwezenn-alamandez</trd>
  </trdgrp>
  <trd lng="ca">ametller</trd>
  <trd lng="cs">mandlovn&iacute;k</trd>
  <trd lng="de">Mandelbaum</trd>
  <trdgrp lng="en">
    <trd>almond</trd>,
    <trd>almond tree</trd>
  </trdgrp>
  <trd lng="es">almendro</trd>
  <trd lng="fr">amandier</trd>
  <trd lng="hu">mandulafa</trd>
  <trdgrp lng="ja">
    <trd>&#x30A2;&#x30FC;&#x30E2;&#x30F3;&#x30C9;</trd>,
    <trd>&#x30D8;&#x30F3;&#x30C8;&#x30A6;</trd>,
    <trd>&#x30CF;&#x30BF;&#x30F3;&#x30AD;&#x30E7;&#x30A6;</trd>
  </trdgrp>
  <trd lng="nl">amandelboom</trd>
  <trd lng="no">mandeltre</trd>
  <trd lng="pl">migda&lstroke;owiec<klr> zwyczajny</klr></trd>
  <trd lng="ru">&c_m;&c_i;&c_n;&c_d;&c_a;&c_l;&c_mol; <klr>(&c_r;&c_a;&c_s;&c_t;&c_je;&c_n;&c_i;&c_je;)</klr></trd>
  <trd lng="sk">mand&lcaron;ovn&iacute;k</trd>
  <trd lng="uk">&c_m;&c_i;&c_g;&c_d;&c_a;&c_l;&c_mol; (&c_d;&c_je;&c_r;&c_je;&c_v;&c_o;)</trd>
  <trd lng="zh">&#x5DF4;&#x65E6;&#x674F; <pr>b&amacron;d&agrave;nx&igrave;ng</pr></trd>
</drv>
</art>
