<?xml version="1.0"?>
<!DOCTYPE vortaro SYSTEM "../dtd/vokoxml.dtd">
<vortaro>
<art mrk="$Id: mes.xml,v 1.27 2026/04/29 14:41:47 revo Exp $">
<kap>
  <ofc>*</ofc>
  <rad>mes</rad>/o
<fnt><bib>UV</bib></fnt></kap>
<drv mrk="mes.0o">
  <kap><ofc>*</ofc><tld/>o</kap>
  <snc mrk="mes.0o.KAT">
    <uzo tip="fak">KAT</uzo>
    <dif>
      <ref tip="super" cel="liturg.0o.KRI">Liturgio</ref>
      en Roma katolikismo kaj kelkaj aliaj okcident-kristanaj
      konfesioj:
      <ekz>
        la granda pre&gcirc;ejo estis malluma, preska&ubreve; malplena, nur unu pastro diris sian
        <tld/>on en flanka kapelo
        <fnt>
          <bib>KPr</bib>
          <lok>&Ccirc;apitro Deka</lok>
        </fnt>;
      </ekz>
      <ekz>
        la kunveno decidis sendi monon en la urbeton por funebra <tld/>o
        <fnt>
          <bib>Mizero</bib>
          <lok>XII</lok>
        </fnt>;
      </ekz>
      <ekz>
        farinte <tld/>on, li &ccirc;eestas nun la paradon
        <fnt>
          <bib>Kandid</bib>
          <lok>&Ccirc;apitro XIV</lok>
        </fnt>;
      </ekz>
      <ekz>
        tradicie &ccirc;i tie katolikaj <tld/>oj okazadis en la
        germana lingvo &gcirc;is la jaro 1940
        <fnt><aut>Last</aut>:
          <vrk>Pre&gcirc;eja jubileo</vrk>,
          <bib>Monato</bib>
          <lok>jaro 2002a, numero 2a, p. 17a</lok>
        </fnt>;
      </ekz>
      <ekz>
        bro&scirc;ureto por sekvi la katolikan <tld/>on (Sankta <tld lit="M"/>o) aperis en
        1966 kun originala muziko de <nom>Kurt Schweizer</nom>
        <fnt>
          <bib>EeP</bib>
          <lok>Dua Parto</lok>
        </fnt>.
      </ekz>
    </dif>
    <ref tip="super" cel="serv.Di0o">diservo</ref>
    <ref tip="vid" cel="misi.0o.KRI">misio<sncref/></ref>
  </snc>
  <trdgrp lng="be">
    <trd>&c_ib;&c_m;&c_sh;&c_a;</trd>,
    <trd>&c_b;&c_a;&c_g;&c_a;&c_s;&c_l;&c_u;&c_zh;&c_b;&c_a;</trd>
  </trdgrp>
  <trd lng="br">oferenn</trd>
  <trdgrp lng="ca">
    <trd>missa</trd>,
    <trd>ofici</trd>
  </trdgrp>
  <trd lng="cs">okru&zcaron;&iacute;  <klr>(kone&ccaron;n&iacute;ku| vejcovodu)</klr></trd>
  <trdgrp lng="de">
    <trd>Messe</trd>,
    <trd><klr>(katholischer)</klr> Gottesdienst</trd>
  </trdgrp>
  <trd lng="en">mass<klr tip="ind"> (religious)</klr></trd>
  <trd lng="es">misa</trd>
  <trdgrp lng="fr">
    <trd>messe</trd>
  </trdgrp>
  <trdgrp lng="hu">
    <trd>mise</trd>,
    <trd>istentisztelet</trd>
  </trdgrp>
  <trdgrp lng="it">
    <trd>messa<klr> (celebrazione eucaristica)</klr></trd>,
    <trd><ind>celebrazione</ind> eucaristica</trd>
  </trdgrp>
  <trdgrp lng="ja">
    <trd>&#x30DF;&#x30B5;</trd>,
    <trd>&#x8056;&#x796D;  <pr>&#x305B;&#x3044;&#x3055;&#x3044;</pr></trd>,
    <trd>&#x30DF;&#x30B5;&#x66F2;  <pr>&#x30DF;&#x30B5;&#x304D;&#x3087;&#x304F;</pr></trd>
  </trdgrp>
  <trd lng="nl">mis<klr tip="ind"> (kath.)</klr></trd>
  <trd lng="pl">msza</trd>
  <trd lng="pt">missa</trd>
  <trdgrp lng="ro">
    <trd>liturghie</trd>
    <trd>slujb&abreve;</trd>
  </trdgrp>
  <trdgrp lng="ru">
    <trd>&c_m;&c_je;&c_s;&c_s;&c_a;</trd>,
    <trd>&c_o;&c_b;&c_je;&c_d;&c_n;&c_ja;</trd>
  </trdgrp>
  <trdgrp lng="sk">
    <trd>okru&zcaron;ie</trd>,
    <trd>om&scaron;a</trd>
  </trdgrp>
  <trdgrp lng="uk">
    <trd>&c_m;&c_je;&c_s;&c_a;</trd>,
    <trd>&c_S;&c_l;&c_u;&c_zh;&c_b;&c_a; &c_B;&c_o;&c_zh;&c_a;</trd>,
    <trd>&c_l;&c_ib;&c_t;&c_u;&c_r;&c_g;&c_ib;&c_ja;</trd>
  </trdgrp>
  <trdgrp lng="zh">
    <trd>&#x793C;&#x62DC; <pr>l&#x1D0;b&agrave;i</pr></trd>,
    <trd>&#x79AE;&#x62DC; <pr>l&#x1D0;b&agrave;i</pr></trd>
  </trdgrp>
</drv>
</art>
