<?xml version="1.0"?>
<!DOCTYPE vortaro SYSTEM "../dtd/vokoxml.dtd">
<vortaro>
<art mrk="$Id: bolt.xml,v 1.30 2026/05/11 16:42:23 revo Exp $">
<kap>
  <rad>bolt</rad>/o <fnt><bib>JED</bib></fnt>
</kap>
<drv mrk="bolt.0o">
  <kap><tld/>o</kap>
  <snc mrk="bolt.0o.TEK">
    <uzo tip="fak">TEK</uzo>
    <dif>
      Cilindra peco uzata por kunfiksi du objektojn,
      kutime fiksebla per <tld/>ingo a&ubreve; stifto kaj tiel facile forigebla:
      <ekz>
        &gcirc;i eltiris la feran <tld/>on el la fermita plankpordo kaj &scirc;telece malsupreniris
        al la malliberulo
        <fnt>
          <bib>Fab4</bib>
          <lok>Filino de la mar&ccirc;a re&gcirc;o</lok>
        </fnt>;
      </ekz>
      <ekz>
        la hejtisto <klr>[&#x2026;]</klr> tiris nun ardantan dikan <tld/>on el la fajro kaj
        metis &gcirc;in en sitelon da fre&scirc;a akvo
        <fnt>
          <bib>Mortul&Scirc;ip</bib>
          <lok>&Ccirc;apitro 30</lok>
        </fnt>;
      </ekz>
      <ekz>
        se li ne tuj forlasos la kaldronejon, ne nur martelon, sed anka&ubreve; stre&ccirc;<tld/>on
        <klr>[mi]</klr> &jcirc;etos al lia kranio
        <fnt>
          <bib>Mortul&Scirc;ip</bib>
          <lok>&Ccirc;apitro 32</lok>
        </fnt>;
      </ekz>
      <ekz>
        en la okcipito de la mortinto, sub la hartorda&jcirc;o, trovi&gcirc;is fortika, sescola
        fer<tld/>o, &gcirc;i estis enbatita rekte en la cerbon
        <fnt>
          <aut>Johannes Linnankoski, trad. Vilho Set&auml;l&auml;</aut>
          <vrk><url ref="https://eo.wikisource.org/wiki/Batalo_pri_la_Domo_Heikkil%C3%A4/II"
              >Batalo pri la Domo Heikkil&auml;</url></vrk>
          <lok>p. 54</lok>
        </fnt>;
      </ekz>
      <ekz>
        post veno de la nokto la butikisto &scirc;losis la pordon elinterne per <tld/>o
        <fnt>
          <aut>Aleksandro Grin, trad. Jurij Finkel</aut>
          <vrk><url ref="https://www.esperanto.mv.ru/Grin/vojo_2_07.html"
              >La vojo nenien</url></vrk>
          <lok>&Ccirc;apitro VII</lok>
        </fnt>.
      </ekz>
    </dif>
    <bld
      lok="&WCU;/thumb/0/00/SPLINTgebogen.jpg/330px-SPLINTgebogen.jpg"
      prm="CC BY-SA 3.0"
      >&scirc;ra&ubreve;b<tld/>o fiksita per <tld/>ingo kaj aldona fendostifto
        <fnt>
          <aut>StromBer, propra foto</aut>
          <lok><url ref="&WCW;/File:SPLINTgebogen.jpg"
              >https://commons.wikimedia.org/wiki/File:SPLINTgebogen.jpg</url></lok>
        </fnt>
    </bld>
    <trdgrp lng="zh">
      <trd>&#x87BA;&#x8F2A;&#x6C7D;&#x8239; <pr>lu&oacute;l&uacute;nq&igrave;chu&aacute;n</pr></trd>,
      <trd>&#x87BA;&#x65CB;&#x5F62;&#x7684;&#x4E1C;&#x897F;
      <pr>lu&oacute;xu&aacute;nx&iacute;ngded&omacron;ngxi</pr></trd>
    </trdgrp>
  </snc>
  <rim>
      Ial <fnt><bib>PIV2</bib></fnt> malgra&ubreve; la &gcirc;istiama uzo, redifinis &leftquot;bolto&rightquot;
      kiel kaphavan &scirc;ra&ubreve;bon kun &scirc;ra&ubreve;bingo.
    </rim>
  <trd lng="be">&c_sh;&c_r;&c_u;&c_b;&c_a;</trd>
  <trd lng="ca">pern</trd>
  <trdgrp lng="cs">
    <trd>&scaron;roub s matic&iacute;</trd>,
    <trd>svorn&iacute;k</trd>
  </trdgrp>
  <trdgrp lng="de">
    <trd>Bolzen</trd>
  </trdgrp>
  <trdgrp lng="en">
    <trd><klr>(clevis)</klr> pin</trd>,
    <trd>bolt</trd>
  </trdgrp>
  <trd lng="es">tornillo</trd>
  <trdgrp lng="fr">
    <trd>boulon <klr tip="ind">(vis cylindrique)</klr></trd>,
    <trd>rivet</trd>
  </trdgrp>
  <trd lng="he">&bet;&vav;&resh;&#x2137;</trd>
  <trd lng="hu">f&eacute;mcsavar</trd>
  <trd lng="ja">&#x30DC;&#x30EB;&#x30C8;</trd>
  <trd lng="pl">&sacute;ruba</trd>
  <trd lng="ru">&c_b;&c_o;&c_l;&c_t;</trd>
  <trd lng="sk">svorn&iacute;k</trd>
  <trd lng="sv">bult</trd>
  <trdgrp lng="uk">
    <trd>&c_o;&c_l;&c_t;</trd>,
    <trd>&c_gu;&c_v;&c_i;&c_n;&c_t;</trd>,
    <trd>&c_sh;&c_v;&c_o;&c_r;&c_ib;&c_n;&c_mol;</trd>
  </trdgrp>
</drv>

<drv mrk="bolt.0i">
  <kap><tld/>i</kap>
  <gra><vspec>tr</vspec></gra>
  <snc mrk="bolt.0i.TEK">
    <uzo tip="fak">TEK</uzo>
    <dif>
      Kunligi per <tld/>oj.
    </dif>
    <trd lng="zh">&#x62E7;&#x7D27;&#x87BA;&#x4E1D; <pr>n&iacute;ngj&#x1D0;nlu&oacute;s&imacron;</pr></trd>
</snc>
  <trd lng="be">&c_sh;&c_r;&c_u;&c_b;&c_a;&c_v;&c_a;&c_c;&c_mol;</trd>
  <trd lng="ca">empernar</trd>
  <trd lng="cs">se&scaron;roubovat</trd>
  <trdgrp lng="de">
    <trd>mit <ind>Bolzen</ind> verbinden</trd>,
    <trd>verschrauben</trd>
  </trdgrp>
  <trd lng="en">bolt</trd>
  <trd lng="es">atornillar</trd>
  <trd lng="fr">boulonner</trd>
  <trd lng="he">&lamed;&het;&bet;&resh; &bet;&bet;&vav;&resh;&#x2137;</trd>
  <trd lng="hu">&ouml;sszecsavaroz</trd>
  <trd lng="ja">&#x30DC;&#x30EB;&#x30C8;&#x3067;&#x7DE0;&#x3081;&#x308B;
  <pr>&#x307C;&#x308B;&#x3068;&#x3067;&#x3057;&#x3081;&#x308B;</pr></trd>
  <trdgrp lng="pl">
    <trd>ze&sacute;rubowywa&cacute;</trd>,
    <trd>ze&sacute;rubowa&cacute;</trd>,
    <trd>przy&sacute;rubowywa&cacute;</trd>,
    <trd>przy&sacute;rubowa&cacute;</trd>,
    <trd>po&lstroke;&aogonek;czy&cacute;
    <ind>&sacute;rub&aogonek;</ind></trd>,
    <trd>po&lstroke;&aogonek;czy&cacute;
    <ind>&sacute;rubami</ind></trd>,
    <trd>skr&eogonek;ci&cacute; <ind>&sacute;rub&aogonek;</ind></trd>,
    <trd>skr&eogonek;ci&cacute; <ind>&sacute;rubami</ind></trd>
  </trdgrp>
  <trd lng="ru">&c_s;&c_o;&c_je;&c_d;&c_i;&c_n;&c_ja;&c_t;&c_mol;
  &c_b;&c_o;&c_l;&c_t;&c_a;&c_m;&c_i;</trd>
  <trd lng="sk">spoji&tcaron; svorn&iacute;kmi</trd>
  <trd lng="uk">&c_z;&#x2019;&c_jeu;&c_d;&c_n;&c_u;&c_v;&c_a;&c_t;&c_i;
  &c_b;&c_o;&c_l;&c_t;&c_a;&c_m;&c_i;</trd>
</drv>

<drv mrk="bolt.0ingo">
  <kap><tld/>ingo</kap>
  <snc mrk="bolt.0ingo.TEK">
    <uzo tip="fak">TEK</uzo>
    <dif>
      Spirale truita metalpeco, kiun oni &scirc;ra&ubreve;bas sur la
      <tld/>o por &gcirc;in alfiksi.
    </dif>
    <ref tip="super" cel="sxraux.0ingo">&scirc;ra&ubreve;bingo</ref>
    <trdgrp lng="zh">
      <trd>&#x57AB;&#x5708; <pr>di&agrave;nju&agrave;n</pr></trd>,
      <trd>&#x57AB;&#x7247; <pr>di&agrave;npi&agrave;n</pr></trd>
    </trdgrp>
  </snc>
  <trd lng="be">&c_g;&c_a;&c_j;&c_k;&c_a;</trd>
  <trd lng="ca">femella</trd>
  <trdgrp lng="cs">
    <trd>matice</trd>,
    <trd>matka<klr> (&scaron;roubu)</klr></trd>
  </trdgrp>
  <trdgrp lng="de">
    <trd>Schraubenmutter</trd>,
    <trd>Mutter <klr>(Schraube)</klr></trd>
  </trdgrp>
  <trd lng="en">nut</trd>
  <trd lng="es">tuerca</trd>
  <trd lng="fr">&eacute;crou</trd>
  <trd lng="he">&tet;&bet;&ayin;&tav; &nun;&#x5B0;&ayin;&#x5B4;&yod;&lamed;&#x5B8;&he;</trd>
  <trd lng="hu">csavaranya</trd>
  <trd lng="ja">&#x30CA;&#x30C3;&#x30C8;</trd>
  <trd lng="pl">nakr&eogonek;tka</trd>
  <trd lng="ru">&c_g;&c_a;&c_j;&c_k;&c_a;</trd>
  <trd lng="sk">matica</trd>
  <trd lng="uk">&c_g;&c_a;&c_j;&c_k;&c_a;</trd>
</drv>

<drv mrk="bolt.mal0i">
  <kap>mal<tld/>i</kap>
  <gra><vspec>tr</vspec></gra>
  <snc mrk="bolt.mal0i.TEK">
    <uzo tip="fak">TEK</uzo>
    <dif>
      Forigi <tld/>ojn, malfiksi, malmunti:
      <ekz>
        oni fanfaronis pri nenio alia ol mal<tld/>i la
        norvegan feran vapor&scirc;ipon
        <fnt>
          <aut>A. Allais, trad. CERL klubanoj</aut>,
          <vrk><url ref="http://www.ipernity.com/blog/53089/167409">
          Mismanovro</url></vrk>,
          <lok>2009</lok>
        </fnt>.
      </ekz>
    </dif>
  </snc>
  <trdgrp lng="be">
    <trd>&c_a;&c_d;&c_sh;&c_r;&c_u;&c_b;&c_o;&c_w;&c_v;&c_a;&c_c;&c_mol;</trd>,
    <trd>&c_a;&c_d;&c_m;&c_a;&c_c;&c_o;&c_w;&c_v;&c_a;&c_c;&c_mol;
    <klr>(&c_z;&c_a;&c_sh;&c_r;&c_u;&c_b;&c_a;&c_v;&c_a;&c_n;&c_a;&c_je;)</klr></trd>
  </trdgrp>
  <trd lng="ca">desempernar</trd>
  <trd lng="cs">od&scaron;roubovat</trd>
  <trdgrp lng="de">
    <trd><ind>Bolzen</ind> l&ouml;sen</trd>,
    <trd>aufschrauben</trd>
  </trdgrp>
  <trd lng="en">unbolt</trd>
  <trd lng="fr">d&eacute;boulonner</trd>
  <trd lng="ja">&#x53D6;&#x308A;&#x5916;&#x3059;  <pr>&#x3068;&#x308A;&#x306F;&#x305A;&#x3059;</pr></trd>
  <trdgrp lng="sk">
    <trd>odskrutkova&tcaron;</trd>,
    <trd>uvo&lcaron;ni&tcaron; skrutky</trd>
  </trdgrp>
  <trdgrp lng="uk">
    <trd>&c_z;&c_n;&c_ib;&c_m;&c_a;&c_t;&c_i;/&c_v;&c_ib;&c_d;&c_k;&c_r;&c_u;&c_ch;&c_u;&c_v;&c_a;&c_t;&c_i;
    &c_b;&c_o;&c_l;&c_t;</trd>,
    <trd>&c_r;&c_o;&c_z;&c_b;&c_i;&c_r;&c_a;&c_t;&c_i;</trd>
  </trdgrp>
</drv>
</art>
