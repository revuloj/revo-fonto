<drv mrk="kuk.0o">
  <kap><ofc>*</ofc><tld/>o</kap>
  <snc mrk="kuk.0o.KUI">
    <uzo tip="fak">KUI</uzo>
    <dif>
      Franda <ref tip="lst" cel="bak.0ajxo.KUI" lst="voko:man&gcirc;a&jcirc;oj">baka&jcirc;o</ref> el
      diversspeca pasto kun sukero:
      <ekz>
        mi trinkis teon kun <tld/>o kaj konfita&jcirc;o
        <fnt>
          <bib>F</bib>
          <lok>&FE; 35</lok>
        </fnt>;
      </ekz>
      <ekz>
        kazea <tld/>o
        <fnt>
          <bib>VaK</bib>
          <lok>Na&ubreve;a &Ccirc;apitro</lok>
        </fnt>;
        <trd lng="de">Quarkkuchen</trd>
      </ekz>
      <ekz>
        <ind>vinber<tld/>o</ind>
        <fnt>
          <bib>MT</bib>
          <lok>&Alt; 2:5</lok>
        </fnt>;
        <trd lng="de">Rosinenkuchen</trd>
      </ekz>
      <ekz>
        prenu tri mezurojn da plej bona faruno, knedu, kaj faru <tld/>ojn
        <fnt>
          <bib>MT</bib>
          <lok>&Gen; 18:6</lok>
        </fnt>;
      </ekz>
      <ekz>
        li prenis unu macan <tld/>on kaj unu <tld/>on kun oleo kaj unu flanon
        <fnt>
          <bib>MT</bib>
          <lok>&Lev; 8:26</lok>
        </fnt>;
      </ekz>
      <ekz>
        li preferas la mizeran soldatan bieron kaj sekan platan <tld/>on, frotitan per
        ajlo
        <fnt>
          <bib>Far1</bib>
          <lok>&Ccirc;apitro 14a</lok>
        </fnt>;
      </ekz>
      <ekz>
        tablon ornamas ne tuko sed <tld/>o
        <fnt><bib>PrV</bib></fnt>;
      </ekz>
      <ekz>
        de pli da suko ne malboni&gcirc;as la <tld/>o
        <klr>(tro da bono ne &gcirc;enas)</klr>
        <fnt><bib>PrV</bib></fnt>;
      </ekz>
      <ekz>
        e&ccirc; per dol&ccirc;a <tld/>o vi min ne allogos
        <fnt>
          <bib>PrV</bib>
        </fnt>.
      </ekz>
    </dif>
  </snc>
  <trdgrp lng="be">
    <trd>&c_p;&c_ib;&c_r;&c_o;&c_g;</trd>,
    <trd>&c_p;&c_ib;&c_r;&c_a;&c_zh;&c_o;&c_k;</trd>,
    <trd>&c_k;&c_je;&c_k;&c_s;</trd>
  </trdgrp>
  <trdgrp lng="cs">
    <trd>kol&aacute;&ccaron;</trd>,
    <trd>kus pe&ccaron;iva</trd>
  </trdgrp>
  <trd lng="de">Kuchen</trd>
  <trd lng="en">cake</trd>
  <trd lng="es">pastel</trd>
  <trd lng="fr">g&acirc;teau</trd>
  <trdgrp lng="hu">
    <trd>s&uuml;tem&eacute;ny</trd>,
    <trd>kal&aacute;cs</trd>
  </trdgrp>
  <trd lng="id">kue</trd>
  <trdgrp lng="ja">
    <trd>&#x83D3;&#x5B50;  <pr>&#x304B;&#x3057;</pr></trd>,
    <trd>&#x713C;&#x83D3;&#x5B50;  <pr>&#x3084;&#x304D;&#x304C;&#x3057;</pr></trd>,
    <trd>&#x30B1;&#x30FC;&#x30AD;  <pr>&#x3051;&#x30FC;&#x304D;</pr></trd>
  </trdgrp>
  <trd lng="nl">koek</trd>
  <trdgrp lng="pl">
    <trd>ciasto</trd>,
    <trd>ciastko</trd>
  </trdgrp>
  <trd lng="pt">bolo</trd>
  <trdgrp lng="ru">
    <trd>&c_p;&c_i;&c_r;&c_o;&c_g;
    <klr>(&c_s;&c_l;&c_a;&c_d;&c_k;&c_i;&c_j;)</klr></trd>,
    <trd>&c_p;&c_i;&c_r;&c_o;&c_zh;&c_o;&c_k;</trd>,
    <trd>&c_l;&c_je;&c_p;&c_jo;&c_sh;&c_k;&c_a;</trd>,
    <trd>&c_k;&c_je;&c_k;&c_s;</trd>,
    <trd>&c_p;&c_i;&c_r;&c_o;&c_zh;&c_n;&c_o;&c_je;</trd>,
    <trd>&c_k;&c_o;&c_n;&c_d;&c_i;&c_t;&c_je;&c_r;&c_s;&c_k;&c_o;&c_je;
    &c_i;&c_z;&c_d;&c_je;&c_l;&c_i;&c_je; <klr>&c_i;
    &c_t;.&c_p;.</klr></trd>
  </trdgrp>
  <trd lng="sk">kol&aacute;&ccaron;</trd>
  <trd lng="sv">kaka</trd>
  <trd lng="uk"><klr>(&c_s;&c_o;&c_l;&c_o;&c_d;&c_k;&c_i;&c_j;)</klr> &c_p;&c_i;&c_r;&c_ib;&c_g;</trd>
