<drv mrk="kuk.0eto">
  <kap><tld/>eto</kap>
  <snc mrk="kuk.0eto.KOMP">
    <uzo tip="fak">KOMP</uzo>
    <dif>
      Dosiero kiu konservas en la komputilo de la uzanto
      informojn pri lia lasta konekti&gcirc;o al difinita retejo:
      <ekz>
        ni uzas <tld/>etojn por plibonigi la funkciadon
        de la retejo
        <fnt>
          <aut>-</aut>
          <vrk>[bonveniga mesa&gcirc;o]</vrk>
          <lok><url ref="https://www.liberafolio.org/">
          libera folio</url>, 2018</lok>
        </fnt>.
      </ekz>
    </dif>
    <trd lng="de">Cookie</trd>
    <trdgrp lng="fr">
      <trd>cookie<klr> (informatique)</klr></trd>,
      <trd>t&eacute;moin de connexion</trd>
    </trdgrp>
    <trd lng="id">kuki</trd>
  </snc>
  <trd lng="be">&c_k;&c_u;&c_k;&c_ib;</trd>
  <trd lng="en">cookie<klr> (web)</klr></trd>
  <trd lng="ja">&#x30AF;&#x30C3;&#x30AD;&#x30FC;</trd>
  <trd lng="pl">ciasteczko <klr>(plik)</klr></trd>
  <trdgrp lng="zh">
    <trd>&#x9905;&#x5E79; <pr>b&#x1D0;ngg&amacron;n</pr></trd>,
    <trd>&#x997C;&#x5E72; <pr>b&#x1D0;ngg&amacron;n</pr></trd>
  </trdgrp>
</drv>

<drv mrk="kuk.miel0o">
