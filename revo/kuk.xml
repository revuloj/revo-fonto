    <trd>pala&ccaron;inka</trd>,
    <trd>sv&iacute;tek</trd>
  </trdgrp>
  <trdgrp lng="de">
    <trd>Pfannkuchen<klr tip="amb"> (flach)</klr></trd>,
    <trd>Eierkuchen</trd>
  </trdgrp>
  <trdgrp lng="en">
