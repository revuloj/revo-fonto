    <trd>griddle cake</trd>
  </trdgrp>
  <trd lng="fr">cr&ecirc;pe</trd>
  <trd lng="hu">palacsinta</trd>
  <trdgrp lng="id">
    <trd>krep</trd>,
    <trd>krepes</trd>
  </trdgrp>
  <trd lng="ja">&#x30DB;&#x30C3;&#x30C8;&#x30B1;&#x30FC;&#x30AD;</trd>
  <trd lng="nl">pannenkoek</trd>
  <trd lng="pl">nale&sacute;nik</trd>
  <trdgrp lng="ru">
    <trd>&c_b;&c_l;&c_i;&c_n;</trd>,
    <trd>&c_o;&c_l;&c_a;&c_d;&c_mol;&c_ja;</trd>
  </trdgrp>
  <trd lng="sk">palacinka</trd>
