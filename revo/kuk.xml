<drv mrk="kuk.mol0o">
  <kap>
    mol<tld/>o, <var><kap>spongo<tld/>o</kap></var>
  </kap>
  <snc>
    <dif>
      Tre mola, spongeca <tld/>o el flua pasto de faruno, graso, ovo, sukero, lakto,
      eventuale amelo, bakpulvoro:
      <ekz>
        &ccirc;okolada mol<tld/>o, <klr>[&#x2026;]</klr> citrona spongo<tld/>o (savoj<tld/>o)
        <fnt>
          <vrk><url ref="https://esperanto-gironde.fr/wp-content/uploads/LEGI158.pdf"
              >Kunveno en Cenon Palmer la 21an de Marto 2019</url></vrk>
          <lok>La Esperanto-Gironde-Informilo, 04/2019 p.8</lok>
        </fnt>;
      </ekz>
      <ekz>
        Nigra-arbara &ccirc;eriz<tld/>o <klr>[el]</klr> du tavoloj de &ccirc;okoladaj spongo<tld/>oj
        gustigitaj per &ccirc;erizobrando, aroma konfita&jcirc;o el erigitaj &ccirc;erizoj
        <klr>[&#x2026;]</klr> batita kremo <klr>[&#x2026;]</klr> kaj raspita &ccirc;okolado
        <fnt>
          <bib>Viki</bib>
          <lok><url ref="https://eo.wikipedia.org/?curid=670454"
              >Nigra-arbara &ccirc;erizkuko</url></lok>
        </fnt>.
      </ekz>
    </dif>
  </snc>
  <trd lng="be">&c_k;&c_je;&c_k;&c_s;</trd>
  <trd lng="de">R&uuml;hrkuchen</trd>
  <trd lng="pl">keks</trd>
  <trd lng="ru">&c_k;&c_je;&c_k;&c_s;</trd>
  <trd lng="tr">rikwato</trd>
</drv>

<drv mrk="kuk.pan0o">
  <kap>
    pan<tld/>o
  </kap>
  <snc>
    <uzo tip="fak">KUI</uzo>
    <dif>
      Malnova pano (a&ubreve; bulko), trempita en lakto eventuale kun ovo, sukero, fruktoj
      kaj fritita a&ubreve; bakita:
      <ekz>
        malfre&scirc;a bulko a&ubreve; pano, trempita en lakto kaj fritita &gcirc;isbrune <klr>[jen]</klr>
        pankuko
        <fnt>
          <aut>Francisko Lorrain</aut>
          <vrk><url ref="https://www.esperanto.qc.ca/riverego/Riverego124-125.pdf"
              >Malpli oftaj fundamentaj vortoj 5</url></vrk>
          <lok>La Riverego, n-ro 124/125, Somero-a&ubreve;tuno 2016, p. 24</lok>
        </fnt>;
      </ekz>
      <ekz>
        pan<tld/>o: <klr>[&#x2026;]</klr> la pano restu &ccirc;. 24 horojn en la lakto, bone miksu &gcirc;in, aldonante
        ovojn, sukeron gustiga&jcirc;ojn ... baku ... &ccirc;. 30 minutojn
        <fnt>
          <bib>Monato</bib>
          <aut>Henri Lassere</aut>
          <vrk>Kiel uzi pan-restojn</vrk>
        </fnt>.
      </ekz>
    </dif>
  </snc>
  <trd lng="de">Arme Ritter</trd>
  <trd lng="en">french toast</trd>
  <trd lng="el">&alfa;&beta;&gamma;&omikron_ton;&psi;&omega;&my;&omikron;</trd>
  <trd lng="es">torrija</trd>
  <trd lng="fr">pain perdu</trd>
  <trd lng="hu">bund&aacute;s keny&eacute;r</trd>
  <trd lng="nl">wentelteefje</trd>
  <trd lng="tr">ekmek bal&inodot;&gbreve;&inodot;</trd>
  <trd lng="ru">&c_g;&c_r;&c_je;&c_n;&c_k;&c_i;</trd>
  <trd lng="uk">&c_g;&c_r;&c_ib;&c_n;&c_k;&c_i;</trd>
</drv>

<drv mrk="kuk.pat0o">
  <kap>pat<tld/>o</kap>
  <snc mrk="kuk.pat0o.KUI">
    <uzo tip="fak">KUI</uzo>
    <dif>
      Maldika <ref tip="super" cel="kuk.0o.KUI"><tld/>o</ref> kuirita
      en pato:
      <ekz>
        ni scias, kiu havos dol&ccirc;an supon kaj pat<tld/>on
        <fnt>
          <bib>Fab2</bib>
          <lok>Pa&scirc;tisto de porkoj</lok>
        </fnt>!
      </ekz>
      <ekz>
        la nederlanda pat<tld/>o vere estas farita en pato, kaj estas
        granda, plata kaj ronda
        <fnt>
          <aut>P. Peeraerts</aut>,
          <vrk>Re: Ich bin ein Berliner</vrk>,
          <lok><url ref="&SCE;">soc.culture.esperanto</url>,
          2003-09-24</lok>
        </fnt>.
      </ekz>
    </dif>
    <refgrp tip="sin">
      <ref cel="kresp.0o">krespo</ref>
    </refgrp>
  </snc>
  <trdgrp lng="be">
    <trd>&c_b;&c_l;&c_ib;&c_n;&c_je;&c_c;</trd>,
    <trd>&c_a;&c_l;&c_a;&c_d;&c_k;&c_a;</trd>,
    <trd>&c_s;&c_k;&c_a;&c_v;&c_a;&c_r;&c_o;&c_d;&c_n;&c_ib;&c_k;</trd>
  </trdgrp>
  <trdgrp lng="cs">
