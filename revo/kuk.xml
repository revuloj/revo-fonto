  <trdgrp lng="uk">
    <trd>&c_n;&c_a;&c_l;&c_i;&c_s;&c_n;&c_i;&c_k;</trd>,
    <trd>&c_m;&c_l;&c_i;&c_n;&c_je;&c_c;&c_mol;</trd>
  </trdgrp>
  <trdgrp lng="zh">
    <trd>&#x8584;&#x70E4;&#x9905; <pr>b&oacute;k&#x1CE;ob&#x1D0;ng</pr></trd>,
    <trd>&#x8584;&#x70E4;&#x997C; <pr>b&oacute;k&#x1CE;ob&#x1D0;ng</pr></trd>,
    <trd>&#x6D3B;&#x529B;&#x86CB;&#x9905; <pr>hu&oacute;l&igrave;d&agrave;nb&#x1D0;ng</pr></trd>
  </trdgrp>
</drv>

<drv mrk="kuk.plat0o">
  <kap>
    plat<tld/>o
  </kap>
  <snc>
    <dif>
      Plata <tld/>o, bakita sur &scirc;tono, bakpleto k.s.:
      <ekz>
        hordeaj plat<tld/>oj
        <fnt>
          <bib>MT</bib>
          <lok>&Jeh; 4:12</lok>
        </fnt>;
      </ekz>
      <ekz>
        mi plore rifuzadis man&gcirc;i plat<tld/>ojn
        <fnt>
          <bib>SkandalJozef</bib>
          <lok>Plendoj de Jozefo arestita</lok>
        </fnt>.
      </ekz>
    </dif>
    <refgrp tip="vid">
      <ref cel="flan.0o">flano</ref>,
      <ref cel="pic.0o">pico</ref>
    </refgrp>
  </snc>
