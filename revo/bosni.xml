<?xml version="1.0"?>
<!DOCTYPE vortaro SYSTEM "../dtd/vokoxml.dtd">
<vortaro>
<art mrk="$Id: bosni.xml,v 1.19 2026/06/21 16:00:23 revo Exp $">
<kap>
  <rad>Bosni</rad>/o
</kap>

<drv mrk="bosni.B0o">
  <kap>
    <tld lit="B"/>o
    <fnt><bib>RLN</bib></fnt>
  </kap>
  <snc mrk="bosni.B0o.GEOG">
    <uzo tip="fak">GEOG</uzo>
    <uzo tip="fak">POL</uzo>
    <dif>
      <ref tip="dif" cel="bosn.B0ujo.GEOG">Bosnujo</ref>:
      <ekz>
        la milito en <tld/>o, komenci&gcirc;inta en 1991, ka&ubreve;zis tragediojn al centmiloj da
        homoj
        <fnt>

          <aut>Bardhyl Selimi</aut>
          <vrk><url ref="&Monato;/2004/008328.html">Sekvoj de la milito</url></vrk>
          <bib>Monato</bib>
          <lok>2004/06, p. 14</lok>
        </fnt>;
      </ekz>
      <ekz>
        la nombro de serboj, pereintaj en Kroatio kaj <tld/>o dum tiu epoko, &ccirc;irka&ubreve;as
        tricent mil tricent tridek mil, la&ubreve; la similaj rezultoj de la du historiistoj
        <fnt>
        <aut>Michel Duc Goninaz</aut>
        <vrk><url ref="&Monato;/2000/006947.html">Eks-Jugoslavio: kiu kiun mistifikas?</url></vrk>
        <bib>Monato</bib>
        <lok>2000/06, p. 8</lok>
        </fnt>;
              </ekz>
      <ekz>
        en <tld/>o vivas <tld lit="b"/>anoj
        <fnt>
        <aut>Michel Duc Goninaz</aut>
        <vrk><url ref="&Monato;/2000/006947.html">Eks-Jugoslavio: kiu kiun mistifikas?</url></vrk>
          <bib>Monato</bib>
          <lok>2000/06, p. 8</lok>
        </fnt>.
      </ekz>
    </dif>
  </snc>
  <trd lng="be">&c_B;&c_o;&c_s;&c_mol;&c_n;&c_ib;&c_ja;</trd>
  <trd lng="bg">&c_B;&c_o;&c_s;&c_n;&c_a;</trd>
  <trd lng="ca">B&ograve;snia</trd>
  <trd lng="de">Bosnien</trd>
  <trd lng="en">Bosnia</trd>
  <trd lng="es">Bosnia</trd>
  <trd lng="fr">Bosnie</trd>
  <trd lng="he">&bet;&vav;&samekh;&nun;&yod;&he;</trd>
  <trd lng="id">Bosnia</trd>
  <trd lng="ja">&#12508;&#12473;&#12491;&#12450;&#22320;&#26041; 
  <pr>&#12412;&#12377;&#12395;&#12354;&#12385;&#12411;&#12358;</pr></trd>
  <trdgrp lng="pl">
    <trd>Bo&sacute;nia</trd>
  </trdgrp>
  <trd lng="nl">Bosni&euml;</trd>
  <trd lng="uk">&c_B;&c_o;&c_s;&c_n;&c_ib;&c_ja;&nbsp;(&c_r;&c_je;&c_gu;&c_ib;&c_o;&c_n;)</trd>
</drv>

<drv mrk="bosni.B0oHercegovino">
  <kap>
    <tld lit="B"/>o kaj Hercegovino
    <fnt><bib>RLN</bib></fnt>
  </kap>
  <snc mrk="bosni.B0oHercegovino.sxtato">
    <uzo tip="fak">GEOG</uzo>
    <uzo tip="fak">POL</uzo>
    <dif>
       <ref tip="dif" cel="bosn.B0ujoHercegovino.sxtato">Bosnujo kaj
      Hercegovino</ref>:
      <ekz>
        koncerne <tld/>on-Hercegovinon kiu poste tiom suferis pro la serba kaj kroata
        agresoj la opinienketo de majo 1990 kaj la manifestacio de julio 1991 en
        Sarajevo kontra&ubreve; la militdan&gcirc;ero montris, ke ties popolo ne deziris la disi&gcirc;on
        <fnt><aut>Michel Duc Goninaz</aut>,
        <vrk><url ref="&Monato;/2000/006947.html">Eks-Jugoslavio: kiu kiun mistifikas?</url></vrk>,
        <bib>Monato</bib>,
        <lok>2000/06, p. 8</lok>
        </fnt>.
      </ekz>
    </dif>
  </snc>
  <trd lng="be">&c_B;&c_o;&c_s;&c_mol;&c_n;&c_ib;&c_ja; &c_ib;
  &c_G;&c_je;&c_r;&c_c;&c_a;&c_g;&c_a;&c_v;&c_ib;&c_n;&c_a;</trd>
  <trd lng="bg">&c_B;&c_o;&c_s;&c_n;&c_a; &c_i;
  &c_H;&c_je;&c_r;&c_c;&c_je;&c_g;&c_o;&c_v;&c_i;&c_n;&c_a;</trd>
  <trd lng="ca">B&ograve;snia i Hercegovina</trd>
  <trd lng="de">Bosnien und Herzegowina</trd>
  <trd lng="en">Bosnia and Herzegovina</trd>
  <trd lng="es">Bosnia y Herzegovina</trd>
  <trd lng="fr">Bosnie-Herz&eacute;govine</trd>
  <trd lng="id">Bosnia Herzegovina</trd>
  <trd
  lng="ja">&#12508;&#12473;&#12491;&#12450;&#12539;&#12504;&#12523;&#12484;&#12455;&#12468;&#12499;&#12490;
   <pr>&#12412;&#12377;&#12395;&#12354;&#12539;&#12408;&#12427;&#12388;&#12359;&#12372;&#12403;&#12394;</pr></trd>
  <trd lng="nl">Bosni&euml; en Herzegovina</trd>
  <trd lng="pl">Bo&sacute;nia i Hercogowina</trd>
</drv>

</art>

