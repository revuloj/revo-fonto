<?xml version="1.0"?>
<!DOCTYPE vortaro SYSTEM "../dtd/vokoxml.dtd">
<vortaro>
<art mrk="$Id: asiri.xml,v 1.16 2026/05/28 10:00:21 revo Exp $">
<kap><ofc>10</ofc>
  <rad>Asiri</rad>/o <fnt><bib>PIV1</bib></fnt>
</kap>
<drv mrk="asiri.A0o">
  <kap><tld/>o</kap>
  <snc mrk="asiri.A0o.GEOG">
    <uzo tip="fak">GEOG</uzo>
    <uzo tip="fak">HIS</uzo>
    <dif>
      Antikva regno en la norda parto de <ref tip="malprt" cel="mezopotami.M0o">Mezopotamio</ref>
      plurfoje centro de
      memstara,
      potenca regno inter 1500 kaj 600 a. K.:
      <ekz>
        Li venigos la re&gcirc;on de <tld/>o
        <fnt><bib>MT</bib>, <lok>&Jes; 7:17</lok></fnt>.
      </ekz>
    </dif>
    <trdgrp lng="zh">
    <trd>&#20122;&#35199;&#21033;&#20122;&#20154; <pr>y&agrave;x&#299;l&igrave;y&agrave;r&eacute;n</pr></trd>,
    <trd>&#20126;&#35199;&#21033;&#20126;&#20154; <pr>y&agrave;x&#299;l&igrave;y&agrave;r&eacute;n</pr></trd>,
    <trd>&#20122;&#36848;&#20154; <pr>y&agrave;sh&ugrave;r&eacute;n</pr></trd>,
    <trd>&#20126;&#36848;&#20154; <pr>y&agrave;sh&ugrave;r&eacute;n</pr></trd>,
    <trd>&#20122;&#35199;&#21033;&#20122; <pr>y&agrave;x&#299;l&igrave;y&agrave;</pr></trd>,
    <trd>&#20126;&#35199;&#21033;&#20126; <pr>y&agrave;x&#299;l&igrave;y&agrave;</pr></trd>,
    <trd>&#20122;&#36848; <pr>y&agrave;sh&ugrave;</pr></trd>,
    <trd>&#20126;&#36848; <pr>y&agrave;sh&ugrave;</pr></trd>,
    <trd>&#22312;&#23427;&#30340;&#24375;&#30427;&#26178;&#26399; <pr>z&agrave;it&#257;d&igrave;qi&aacute;ngsh&egrave;ngsh&iacute;q&#299;</pr></trd>,
    <trd>&#22312;&#23427;&#30340;&#24378;&#30427;&#26102;&#26399; <pr>z&agrave;it&#257;d&igrave;qi&aacute;ngsh&egrave;ngsh&iacute;q&#299;</pr></trd>
  </trdgrp>
</snc>
  <trd lng="be">&c_A;&c_s;&c_y;&c_r;&c_y;&c_ja;</trd>
  <trd lng="bg">&c_A;&c_s;&c_i;&c_r;&c_i;&c_ja;</trd>
  <trd lng="ca">Ass&iacute;ria</trd>
  <trd lng="de">Assyrien</trd>
  <trd lng="en">Assyria</trd>
  <trd lng="fa">&a_A_madda;&a_sh;&a_w;&a_r;</trd>
  <trd lng="fr">Assyrie</trd>
  <trd lng="he">&alef;&#1463;&shin;&#1473;&vav;&#1468;&resh;</trd>
  <trd lng="it">Assiria</trd>
  <trd lng="ja">&#12450;&#12483;&#12471;&#12522;&#12450;</trd>
  <trd lng="pl">Asyria</trd>
  <trd lng="ru">&c_A;&c_s;&c_s;&c_i;&c_r;&c_i;&c_ja;</trd>
</drv>

<drv mrk="asiri.0a">
  <kap><ofc>10</ofc><tld lit="a"/>a</kap>
  <snc>
    <dif>
      Rilata al <tld/>o, &gcirc;iaj lo&gcirc;antoj, historio, kulturo:
      <ekz>
        elegante vestitaj <tld/>aj sinjoroj portis la donacojn por la
        princo
        <fnt><bib>Far2</bib>, <lok>&ccirc;apitro 10a</lok></fnt>.
      </ekz>
    </dif>
  </snc>
  <trd lng="be">&c_a;&c_s;&c_y;&c_r;&c_y;&c_j;&c_s;&c_k;&c_ib;</trd>
  <trdgrp lng="ca">
    <trd>assiri</trd>,
    <trd>assiri&agrave;</trd>
  </trdgrp>
  <trd lng="de">assyrisch</trd>
  <trd lng="en">Assyrian</trd>
  <trd lng="fa">&a_A_madda;&a_sh;&a_w;&a_r;&f_y;</trd>
  <trd lng="fr">assyrien<klr tip="amb"> (adj.)</klr></trd>
  <trd lng="it">assiro<klr> (agg.)</klr></trd>
  <trd lng="pl">asyryjski</trd>
  <trd lng="ru">&c_a;&c_s;&c_s;&c_i;&c_r;&c_i;&c_j;&c_s;&c_k;&c_i;&c_j;</trd>
</drv>

<drv mrk="asiri.0ano">
  <kap><ofc>10</ofc><tld lit="a"/>ano</kap>
  <snc>
    <dif>
      Regnano de <tld/>o:
      <ekz>
        al la <klr>...</klr> <tld/>anoj I&scirc;tar estas diino de la
        milito kaj de la &ccirc;asado
        <fnt><bib>I&scirc;tar</bib>, <lok>&ccirc;apitro 3a, Lemuel da&ubreve;rigas sian
        esploron</lok></fnt>.
      </ekz>
    </dif>
  </snc>
  <trd lng="be">&c_a;&c_s;&c_y;&c_r;&c_y;&c_je;&c_c;</trd>
  <trdgrp lng="ca">
    <trd>assiri</trd>,
    <trd>assiri&agrave;</trd>
  </trdgrp>
  <trd lng="de">Assyrer</trd>
  <trd lng="en">Assyrian</trd>
  <trd lng="fa">&a_A_madda;&a_sh;&a_w;&a_r;&f_y;</trd>
  <trd lng="fr">Assyrien<klr tip="amb"> (subst.)</klr></trd>
  <trd lng="it">assiro<klr> (sost.)</klr></trd>
  <trd lng="pl">Asyryjczyk</trd>
  <trd lng="ru">&c_a;&c_s;&c_s;&c_i;&c_r;&c_i;&c_je;&c_c;</trd>
  <trd lng="uk">&c_a;&c_s;&c_s;&c_i;&c_r;&c_ib;&c_jeu;&c_c;&c_mol;</trd>
</drv>
</art>

