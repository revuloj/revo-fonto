<?xml version="1.0"?>
<!DOCTYPE vortaro SYSTEM "../dtd/vokoxml.dtd">

<vortaro>
  <art mrk="$Id: amok.xml,v 1.2 2026/05/04 04:07:18 afido Exp $">
    <kap>
      <rad>amok</rad>/o
      <fnt><bib>PIV1</bib></fnt>
    </kap>

<drv mrk="amok.0o">
  <kap><tld/>o</kap>
  <snc>
    <dif>
      Blinda murdemo de unuopulo(j) pro psikaj a&ubreve; teroraj motivoj:
      <ekz>
        pro masakro la 11an de marto en urbeto proksime de Stuttgart (suda Germanio),
        kie 17-jarulo murdis 15 homojn, precipe lernantojn, politikistoj diskutis pri
        konsekvencoj, post simila <tld/>o-kuro en orienta Germanio anta&ubreve; du jaroj oni
        jam diskutis pri malpermeso de pafiloj
        <fnt>
          <bib>Monato</bib>
          <aut>Stefan Maul</aut>
          <vrk>Kia konsekvenco!</vrk>
          <lok>2009</lok>
        </fnt>.
      </ekz>
    </dif>
    <refgrp tip="vid">
      <ref cel="murd.amas0o">amasmurdo</ref>,
      <ref cel="masakr.0o">masakro</ref>
    </refgrp>
    <trd lng="de">Amok</trd>
    <trd lng="en">amok</trd>
    <trd lng="fr">amok</trd>
    <trd lng="ru">&c_a;&c_m;&c_o;&c_k;</trd>
  </snc>
<trd lng="id">amuk<klr> (sindrom)</klr></trd>
</drv>

  </art>

