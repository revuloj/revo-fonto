    <trd>&#x52DE; <pr>l&aacute;o</pr></trd>,
    <trd>&#x529F;&#x52B3; <pr>g&omacron;ngl&aacute;o</pr></trd>,
    <trd>&#x529F;&#x52DE; <pr>g&omacron;ngl&aacute;o</pr></trd>,
    <trd>&#x7E3E; <pr>j&igrave;</pr></trd>,
    <trd>&#x7EE9; <pr>j&igrave;</pr></trd>,
    <trd>&#x4F18;&#x70B9; <pr>y&omacron;udi&#x1CE;n</pr></trd>,
    <trd>&#x512A;&#x9EDE; <pr>y&omacron;udi&#x1CE;n</pr></trd>,
    <trd>&#x529F;&#x7E3E; <pr>g&omacron;ngj&igrave;</pr></trd>,
    <trd>&#x529F;&#x7EE9; <pr>g&omacron;ngj&igrave;</pr></trd>,
    <trd>&#x5927;&#x529F; <pr>d&agrave;g&omacron;ng</pr></trd>
  </trdgrp>
</drv>

<drv mrk="merit.0a">
  <kap><tld/>a</kap>
  <snc mrk="merit.0a.KOMUNE">
    <dif>
      <tld lit="M"/>oplena, mult<tld/>a:
      <ekz>
        en tiu revuo li estis kunlaboranto <klr>[&#x2026;]</klr> <tld/>a kaj alte estimata
        <fnt>
          <bib>Marta</bib>
        </fnt>;
      </ekz>
      <ekz>
        mi prenis vin por iu pli <tld/>a
        <fnt>
          <bib>Hamlet</bib>
          <lok>Hamleto</lok>
        </fnt>;
      </ekz>
      <ekz>
        lia plej <tld/>a agado estis sur la traduka kaj lernolibra kampoj
        <fnt>
          <bib>EeP</bib>
          <lok>Dua Parto</lok>
        </fnt>;
      </ekz>
      <ekz>
        kelkaj drametoj iom <tld/>aj <klr>[&#x2026;]</klr> ka&scirc;i&gcirc;as &gcirc;is nun en gazetoj
        <fnt>
          <bib>Plumamikoj</bib>
          <lok>Dramoj en esperanto</lok>
        </fnt>;
      </ekz>
      <ekz>
        servo ne petita, ne estas <tld/>a
        <fnt><bib>PrV</bib></fnt>.
      </ekz>
    </dif>
    <refgrp tip="vid">
      <ref cel="dign.0a">digna</ref>,
      <ref cel="eminen1.0a">eminenta</ref>
    </refgrp>
    <trdgrp lng="be">
      <trd>&c_z;&c_a;&c_s;&c_l;&c_u;&c_zh;&c_a;&c_n;&c_y;</trd>,
      <trd>&c_v;&c_a;&c_r;&c_t;&c_y;</trd>
    </trdgrp>
    <trdgrp lng="ca">
      <trd>meritori</trd>,
      <trd>merit&oacute;s</trd>
    </trdgrp>
    <trd lng="de">verdienstvoll</trd>
    <trd lng="es">meritorio</trd>
    <trd lng="fr">m&eacute;ritant</trd>
    <trdgrp lng="hu">
      <trd>&eacute;rdemes</trd>,
      <trd>m&eacute;lt&oacute;</trd>
    </trdgrp>
    <trdgrp lng="id">
      <trd><baz>faedah</baz>berfaedah</trd>,
      <trd><baz>guna</baz>berguna</trd>,
      <trd><baz>jasa</baz>berjasa</trd>,
      <trd><baz>manfaat</baz>bermanfaat</trd>,
      <trd><baz>maslahat</baz>bermaslahat</trd>
    </trdgrp>
    <trd lng="nl">verdienstelijk</trd>
    <trdgrp lng="zh">
      <trd>&#x6709;&#x8CA2;&#x737B; <pr>y&#x1D2;ug&ograve;ngxi&agrave;n</pr></trd>,
      <trd>&#x6709;&#x8D21;&#x732E; <pr>y&#x1D2;ug&ograve;ngxi&agrave;n</pr></trd>
    </trdgrp>
  </snc>
  <snc mrk="merit.0a.meritita">
    <dif>
      <tld lit="M"/>ita:
      <ekz>
        <nom>Zamenhof</nom> ricevas &gcirc;ustan kaj <tld/>an takson &ccirc;e tiuj rondoj
        <fnt>
          <bib>Zam</bib>
          <lok>Rolo de Zamenhof en la internacilingva movado</lok>
        </fnt>;
      </ekz>
      <ekz>
        laboro finita, ripozo <tld/>a
        <fnt><bib>PrV</bib></fnt>.
      </ekz>
    </dif>
    <ref tip="vid" cel="pek.mortomerita0o">mortomerita peko</ref>
    <trd lng="be">&c_z;&c_a;&c_s;&c_l;&c_u;&c_zh;&c_a;&c_n;&c_y;</trd>
    <trd lng="ca">merescut</trd>
    <trdgrp lng="de">
      <trd>verdient</trd>,
      <trd>wohlverdient</trd>
    </trdgrp>
    <trd lng="fr">m&eacute;rit&eacute;</trd>
    <trd lng="hu">meg&eacute;rdemelt</trd>
    <trd lng="nl">verdiend</trd>
    <trd lng="es">merecido</trd>
  <trdgrp lng="id">
    <trd><baz>banding</baz>sebanding</trd>,
    <trd><baz>imbang</baz>seimbang</trd>,
    <trd><baz>layak</baz>selayaknya</trd>,
    <trd><baz>suai</baz>sesuai</trd>,
    <trd><baz>padan</baz>sepadan</trd>,
    <trd><baz>pantas</baz>sepantasnya</trd>,
    <trd><baz>patut</baz>sepatutnya</trd>,
    <trd><baz>timpal</baz>setimpal</trd>,
    <trd>layak</trd>
  </trdgrp>
  </snc>
  <trdgrp lng="cs">
    <trd>zaslou&zcaron;il&yacute;</trd>,
    <trd>z&aacute;slu&zcaron;n&yacute;</trd>
  </trdgrp>
  <trdgrp lng="en">
    <trd>meritorious</trd>,
    <trd>worthy</trd>
  </trdgrp>
  <trdgrp lng="ja">
    <trd>&#x529F;&#x7E3E;&#x306E;&#x3042;&#x308B;  <pr>&#x3053;&#x3046;&#x305B;&#x304D;&#x306E;&#x3042;&#x308B;</pr></trd>,
    <trd>&#x79F0;&#x8CDB;&#x306B;&#x5024;&#x3059;&#x308B;  <pr>&#x3057;&#x3087;&#x3046;&#x3055;&#x3093;&#x306B;&#x3042;&#x305F;&#x3044;&#x3059;&#x308B;</pr></trd>,
    <trd>&#x5F53;&#x7136;&#x53D7;&#x3051;&#x308B;&#x3079;&#x304D;  <pr>&#x3068;&#x3046;&#x305C;&#x3093;&#x3046;&#x3051;&#x308B;&#x3079;&#x304D;</pr></trd>,
    <trd>&#x3075;&#x3055;&#x308F;&#x3057;&#x3044;</trd>
  </trdgrp>
  <trdgrp lng="pl">
    <trd>godny</trd>
    <trd>zas&lstroke;u&zdot;ony</trd>
  </trdgrp>
  <trdgrp lng="ro">
    <trd>demn</trd>
    <trd>meritat</trd>
  </trdgrp>
  <trd lng="ru">&c_z;&c_a;&c_s;&c_l;&c_u;&c_zh;&c_je;&c_n;&c_n;&c_y;&c_j;</trd>
  <trdgrp lng="sk">
    <trd>zasl&uacute;&zcaron;il&yacute;</trd>,
    <trd>z&aacute;slu&zcaron;n&yacute;</trd>
  </trdgrp>
  <trd lng="uk">&c_z;&c_a;&c_s;&c_l;&c_u;&c_zh;&c_je;&c_n;&c_i;&c_j;</trd>
  <trdgrp lng="zh">
    <trd>&#x914D;&#x79F0; <pr>p&egrave;ich&egrave;n</pr></trd>,
    <trd>&#x914D;&#x7A31; <pr>p&egrave;ich&egrave;n</pr></trd>
  </trdgrp>
</drv>

<drv mrk="merit.0ajxo">
  <kap><tld/>a&jcirc;o</kap>
  <snc mrk="merit.0ajxo.KOMUNE">
    <dif>
      Tio, kion oni <tld/>is:
      <ekz>
        redonu la <tld/>a&jcirc;on al la fieruloj
        <fnt>
          <bib>MT</bib>
          <lok>Psalmaro 94:2</lok>
        </fnt>;
      </ekz>
      <ekz>
        li sentis sin honorigita per tiu unika, tipe bicikla <tld/>a&jcirc;o, kiu havas
        eksterordinare belan aspekton
        <fnt>
          <aut>Peter Zilvar</aut>
          <vrk><url ref="https://www.esperanto.de/sites/default/files/esperanto.de/ea-archiv/Esperanto%20aktuell%202024-1.pdf"
              >Artisma biciklistmemora&jcirc;o</url></vrk>
          <lok>Esperanto aktuell, 1/2024, n-ro 283</lok>
        </fnt>;
      </ekz>
      <ekz>
        feli&ccirc;o kiun la sama&gcirc;ulinoj de &scirc;ia filino ju&gcirc;is ilia <tld/>a&jcirc;o
        <fnt>
          <aut>Edith Wharton, trad. Edwin Grobe</aut>
          <vrk><url ref="https://eduinf.waw.pl/esp/lern/librejo/0223/0003.php"
              >Aliaj Tempoj</url></vrk>
          <lok>&ccirc;ap. III</lok>
        </fnt>.
      </ekz>
    </dif>
    <refgrp tip="vid">
      <ref cel="distin.0o.pro_merito">distingo<sncref/></ref>,
      <ref cel="premi.0o">premio</ref>,
      <ref cel="rekomp.0o">rekompenco</ref>,
      <ref cel="vengx.0o">ven&gcirc;o</ref>
    </refgrp>
  </snc>
  <trd lng="be">&c_u;&c_z;&c_n;&c_a;&c_g;&c_a;&c_r;&c_o;&c_d;&c_a;
  <klr>(&c_n;&c_je;&c_sh;&c_t;&c_a;
  &c_z;&c_a;&c_s;&c_l;&c_u;&c_zh;&c_a;&c_n;&c_a;&c_je;)</klr></trd>
  <trdgrp lng="ca">
    <trd>premi</trd>,
    <trd>gratificaci&oacute;</trd>,
    <trd>all&ograve; merescut</trd>
