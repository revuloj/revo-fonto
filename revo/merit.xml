<drv mrk="merit.0i">
  <kap><ofc>*</ofc><tld/>i</kap>
  <gra><vspec>tr</vspec></gra>
  <snc mrk="merit.0i.KOMUNE">
    <dif>
      Havi pro sia konduto a&ubreve; pro siaj ecoj rajton pri justa rekompenco
      a&ubreve; puno; esti inda je:
      <ekz>
        &scirc;i <tld/>is &ccirc;ian la&ubreve;don, la plej multe &ccirc;ar &scirc;i montris la plej grandan zorgecon
        <fnt>
          <bib>Fab1</bib>
          <lok>La virineto de maro</lok>
        </fnt>;
      </ekz>
      <ekz>
        mi estas tute laca, kaj mi bone <tld/>is ripozon
        <fnt>
          <bib>Fab1</bib>
          <lok>Vojkamarado</lok>
        </fnt>;
      </ekz>
      <ekz>
        teruran malnobla&jcirc;on li faris, <klr>[&#x2026;]</klr> li <tld/>as punon
        <fnt>
          <bib>Fab1</bib>
          <lok>Malgranda Niko kaj granda Niko</lok>
        </fnt>;
      </ekz>
      <ekz>
        redonu al ili, kion ili <tld/>as
        <fnt>
          <bib>MT</bib>
          <lok>Psalmaro 28:4</lok>
        </fnt>;
      </ekz>
      <ekz>
        la kulpulo <tld/>as batojn
        <fnt>
          <bib>MT</bib>
          <lok>Readmono 25:2</lok>
        </fnt>;
      </ekz>
      <ekz>
        la laboristo <tld/>as sian salajron
        <fnt>
          <bib>NT</bib>
          <lok>I. Timoteo 5:18</lok>
        </fnt>;
      </ekz>
      <ekz>
        mi jam ne <tld/>as esti nomata via filo
        <fnt>
          <bib>NT</bib>
          <lok>Luko 15:19</lok>
        </fnt>;
      </ekz>
      <ekz>
        per kio ni <tld/>is la koleron de nia <klr>[&#x2026;]</klr> protektanto
        <fnt>
          <bib>Far2</bib>
          <lok>&Ccirc;apitro XII</lok>
        </fnt>?
      </ekz>
      <ekz>
        tiuj ostoj <tld/>is nenion alian, ol ke oni ludu per ili
        keglojn
        <fnt>
          <bib>Hamlet</bib>
          <lok>Hamleto</lok>
        </fnt>;
      </ekz>
      <ekz>
        &ccirc;iuj rigardantoj apla&ubreve;dis min, anstata&ubreve; la aktoron, kiu fakte estis <tld/>inta
        tiujn apla&ubreve;dojn
        <fnt>
          <bib>IdO</bib>
          <lok>Unua Parto</lok>
        </fnt>;
      </ekz>
      <ekz>
        kiel li <tld/>is, tiel li profitis
        <fnt><bib>PrV</bib></fnt>.
      </ekz>
    </dif>
  </snc>
  <trdgrp lng="be">
    <trd>&c_z;&c_a;&c_s;&c_l;&c_u;&c_g;&c_o;&c_w;&c_v;&c_a;&c_c;&c_mol;</trd>,
    <trd>&c_b;&c_y;&c_c;&c_mol;
    <ind>&c_v;&c_a;&c_r;&c_t;&c_y;&c_m;</ind></trd>
  </trdgrp>
  <trdgrp lng="ca">
    <trd>mer&egrave;ixer</trd>,
    <trd>meritar</trd>
  </trdgrp>
  <trdgrp lng="cs">
    <trd>zasluhovat</trd>,
    <trd>zaslou&zcaron;it</trd>,
    <trd>zaslou&zcaron;it si</trd>
  </trdgrp>
  <trd lng="de">verdienen</trd>
  <trdgrp lng="en">
    <trd>merit</trd>,
    <trd>deserve</trd>
  </trdgrp>
  <trdgrp lng="es">
    <trd>merecerse<klr> (algo)</klr></trd>,
    <trd>merecer<klr> (algo)</klr></trd>,
    <trd>tener m&eacute;ritos de</trd>,
    <trd>hacer m&eacute;ritos para</trd>
  </trdgrp>
  <trd lng="fr">m&eacute;riter</trd>
  <trdgrp lng="hu">
    <trd>meg&eacute;rdemel</trd>,
    <trd>ki&eacute;rdemel</trd>
  </trdgrp>
  <trdgrp lng="id">
    <trd>berhak<klr tip="amb"> (mendapat/menerima)</klr></trd>,
    <trd>layak<klr tip="amb"> (mendapat/menerima)</klr></trd>,
    <trd>pantas<klr tip="amb"> (mendapat/menerima)</klr></trd>,
    <trd>patut<klr tip="amb"> (mendapat/menerima)</klr></trd>
  </trdgrp>
  <trdgrp lng="ja">
    <trd>&#x4FA1;&#x3059;&#x308B;  <pr>&#x3042;&#x305F;&#x3044;&#x3059;&#x308B;</pr></trd>,
    <trd>&#x3075;&#x3055;&#x308F;&#x3057;&#x3044;</trd>,
    <trd>&#x5F53;&#x7136;&#x3067;&#x3042;&#x308B;  <pr>&#x3068;&#x3046;&#x305C;&#x3093;&#x3067;&#x3042;&#x308B;</pr></trd>
  </trdgrp>
  <trdgrp lng="nl">
    <trd>verdienen<klr tip="ind"> (waardig zijn)</klr></trd>,
    <trd>waardig zijn</trd>
  </trdgrp>
  <trd lng="pl">zas&lstroke;u&zdot;y&cacute;</trd>
  <trdgrp lng="pt">
    <trd>merecer</trd>,
    <trd>ser <ind>digno</ind> de</trd>,
    <trd>fazer <ind>jus</ind> a</trd>,
    <trd>valer</trd>
  </trdgrp>
  <trdgrp lng="ro">
    <trd>merita</trd>
    <trd>cuveni</trd>
  </trdgrp>
  <trdgrp lng="ru">
    <trd>&c_z;&c_a;&c_s;&c_l;&c_u;&c_zh;&c_i;&c_v;&c_a;&c_t;&c_mol;</trd>,
    <trd>&c_z;&c_a;&c_s;&c_l;&c_u;&c_zh;&c_i;&c_t;&c_mol;</trd>,
    <trd>&c_b;&c_y;&c_t;&c_mol;
    &c_d;&c_o;&c_s;&c_t;&c_o;&c_j;&c_n;&c_y;&c_m;</trd>
  </trdgrp>
  <trd lng="sk">zasl&uacute;&zcaron;i&tcaron; si</trd>
  <trdgrp lng="uk">
    <trd>&c_z;&c_a;&c_s;&c_l;&c_u;&c_g;&c_o;&c_v;&c_u;&c_v;&c_a;&c_t;&c_i;</trd>,
    <trd>&c_v;&c_a;&c_r;&c_t;&c_u;&c_v;&c_a;&c_t;&c_i;</trd>,
    <trd>&c_b;&c_u;&c_t;&c_i; &c_v;&c_a;&c_r;&c_t;&c_i;&c_m;</trd>
  </trdgrp>
  <trdgrp lng="zh">
    <trd>&#x5E94;&#x5F97; <pr>y&imacron;ngd&eacute;</pr></trd>,
    <trd>&#x61C9;&#x5F97; <pr>y&imacron;ngd&eacute;</pr></trd>
  </trdgrp>
</drv>

<drv mrk="merit.0o">
  <kap><tld/>o</kap>
  <snc mrk="merit.0o.KOMUNE">
    <dif>
      Ago, eco danke al kiu oni <tld/>as ion:
      <ekz>
        ne trograndigu miajn <tld/>ojn
        <fnt>
          <bib>Far2</bib>
          <lok>&Ccirc;apitro II</lok>
        </fnt>;
      </ekz>
      <ekz>
        la&ubreve; la <tld/>o de siaj manoj homo ricevas redonon
        <fnt>
          <bib>MT</bib>
          <lok>Sentencoj 12:14</lok>
        </fnt>;
      </ekz>
      <ekz>
        feraj &ccirc;enoj <klr>[&#x2026;]</klr> atestas pri tio, kiel la mondo kaj la samtempuloj
        povoscias taksi <tld/>ojn
        <fnt>
          <bib>Fab3</bib>
          <lok>Dorna vojo de la honoro</lok>
        </fnt>;
      </ekz>
      <ekz>
        se ili neniam restas sen rimedoj, tio estas la <tld/>o de ilia modera vivo
        <fnt>
          <bib>Far2</bib>
          <lok>&Ccirc;apitro XV</lok>
        </fnt>;
      </ekz>
      <ekz>
        la laboroj kaj <tld/>oj de sinjoro <nom>Schleyer</nom> estis tre grandaj
        <fnt>
          <bib>Paroloj</bib>
          <vrk>Parolado anta&ubreve; la Unua Kongreso Esperantista en Boulogne sur Mer en la 5a de a&ubreve;gusto
          1905</vrk>
        </fnt>;
      </ekz>
      <ekz>
        &ccirc;iuj enterigitoj estas plenaj de <tld/>oj
        <fnt><bib>PrV</bib></fnt>;
      </ekz>
      <ekz>
        prave punite la&ubreve;<tld/>e
        <fnt><bib>PrV</bib></fnt>.
      </ekz>
    </dif>
    <refgrp tip="vid">
      <ref cel="agnosk.0o">agnosko</ref>,
      <ref cel="kon.re0o.agnosko">rekono<sncref/></ref>
    </refgrp>
  </snc>
  <trd lng="be">&c_z;&c_a;&c_s;&c_l;&c_u;&c_g;&c_a;</trd>
  <trd lng="bo">&t_da;&t_ga;&t_drengbu;&t_tsheg;&t_ba;&t_tsheg;</trd>
  <trd lng="ca">m&egrave;rit</trd>
  <trd lng="cs">z&aacute;sluha</trd>
  <trd lng="de">Verdienst</trd>
  <trdgrp lng="en">
    <trd>merit</trd>,
    <trd>worth</trd>
  </trdgrp>
  <trd lng="es">m&eacute;rito(s)</trd>
  <trd lng="fr">m&eacute;rite</trd>
  <trd lng="hu">&eacute;rdem</trd>
  <trdgrp lng="id">
    <trd><baz>berhak</baz>keberhakan</trd>,
    <trd><baz>layak</baz>kelayakan</trd>,
    <trd><baz>pantas</baz>kepantasan</trd>,
    <trd><baz>patut</baz>kepatutan</trd>
  </trdgrp>
  <trdgrp lng="ja">
    <trd>&#x529F;&#x7E3E;  <pr>&#x3053;&#x3046;&#x305B;&#x304D;</pr></trd>,
    <trd>&#x624B;&#x67C4;  <pr>&#x3066;&#x304C;&#x3089;</pr></trd>,
    <trd>&#x53D6;&#x308A;&#x67C4;  <pr>&#x3068;&#x308A;&#x3048;</pr></trd>,
    <trd>&#x9577;&#x6240;  <pr>&#x3061;&#x3087;&#x3046;&#x3057;&#x3087;</pr></trd>,
    <trd>&#x4FA1;&#x5024;  <pr>&#x304B;&#x3061;</pr></trd>,
    <trd>&#x529F;&#x7F6A;  <pr>&#x3053;&#x3046;&#x3056;&#x3044;</pr></trd>,
    <trd>&#x529F;&#x5FB3;  <pr>&#x304F;&#x3069;&#x304F;</pr></trd>
  </trdgrp>
  <trd lng="nl">verdienste</trd>
  <trd lng="pl">godno&sacute;&cacute; <klr>(zas&lstroke;uga)</klr></trd>
  <trd lng="ro">demnitate <klr>(merit)</klr></trd>
