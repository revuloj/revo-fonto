<?xml version="1.0"?>
<!DOCTYPE vortaro SYSTEM "../dtd/vokoxml.dtd">
<vortaro>
<art mrk="$Id: mering.xml,v 1.20 2026/05/06 15:15:19 revo Exp $">
<kap>
  <rad>mering</rad>/o
  <fnt><bib>PV</bib></fnt>
</kap>
<drv mrk="mering.0o">
  <kap><tld/>o</kap>
  <uzo tip="fak">KUI</uzo>
  <snc>
    <dif>
      Malpeza <ref tip="super" cel="kuk.0o">kuko</ref> farita el
      &scirc;a&ubreve;mkirlita ovblanko kaj sukero:
      <ekz>
        oni ofte uzas <tld/>ojn kiel dekora&jcirc;ojn de tortoj kaj desertoj
        <fnt>
          <bib>Viki</bib>
          <lok><url ref="https://eo.wikipedia.org/?curid=490622"
              >Meringo</url></lok>
        </fnt>;
      </ekz>
      <ekz>
        kiam vi preparas kikerojn, <klr>[&#x2026;]</klr> konservu la likvon! <klr>[&gcirc;i]</klr>
        estas utila por anstata&ubreve;igi ovojn en <klr>[&#x2026;]</klr> e&ccirc; en makarono kaj
        meringo kaj similaj &scirc;a&ubreve;mdesertoj
        <fnt>
          <aut>Lode Van de Velde</aut>
          <vrk><url ref="https://tempa.bitarkivo.org/gazetoj/EsperantistaVegetarano/EsperantistaVegetarano_2022_n01.pdf"
              >Akvo faba</url></vrk>
          <lok>Esperantista Vegetarano, 2022/1, p. 24</lok>
        </fnt>.
      </ekz>
    </dif>
  </snc>
  <trd lng="be">&c_m;&c_e;&c_r;&c_e;&c_n;&c_g;&c_a;</trd>
  <trd lng="ca">merenga</trd>
  <trdgrp lng="cs">
    <trd>p&ecaron;nov&eacute; pe&ccaron;ivo</trd>,
    <trd>sn&ecaron;hov&aacute; pusinka</trd>
  </trdgrp>
  <trd lng="de">Baiser</trd>
  <trd lng="en">meringue</trd>
  <trd lng="fr">meringue</trd>
  <trd lng="hu">habcs&oacute;k</trd>
  <trd lng="ja">&#x30E1;&#x30EC;&#x30F3;&#x30B2;</trd>
  <trdgrp lng="nl">
    <trd>schuimpje</trd>,
    <trd>schuimgebakje</trd>,
    <trd>meringue</trd>
  </trdgrp>
  <trd lng="pl">beza</trd>
  <trdgrp lng="pt">
    <trd>merengue <klr tip="amb">(cul.)</klr></trd>,
    <trd>suspiro <klr tip="amb">(cul.)</klr></trd>
  </trdgrp>
  <trdgrp lng="ru">
    <trd>&c_m;&c_je;&c_r;&c_je;&c_n;&c_g;&c_a;</trd>,
    <trd>&c_b;&c_je;&c_z;&c_je;</trd>
  </trdgrp>
  <trd lng="sk">snehov&aacute; pusinka</trd>
  <trdgrp lng="uk">
    <trd>&c_m;&c_je;&c_r;&c_je;&c_n;&c_gu;&c_a;</trd>,
    <trd>&c_b;&c_je;&c_z;&c_je; (&c_s;&c_o;&c_r;&c_t; &c_t;&c_ib;&c_s;&c_t;&c_je;&c_ch;&c_k;&c_a;)</trd>
  </trdgrp>
  <trdgrp lng="zh">
    <trd>&#x4EE5;&#x53CA;&#x505A;&#x6210;&#x7684;&#x7CD5;&#x9905;
    <pr>y&#x1D0;j&iacute;zu&ograve;ch&eacute;ngdeg&amacron;ob&#x1D0;ng</pr></trd>,
    <trd>&#x4EE5;&#x53CA;&#x505A;&#x6210;&#x7684;&#x7CD5;&#x997C;
    <pr>y&#x1D0;j&iacute;zu&ograve;ch&eacute;ngdeg&amacron;ob&#x1D0;ng</pr></trd>
  </trdgrp>
</drv>

<drv mrk="mering.0i">
  <kap><tld/>i</kap>
  <gra><vspec>tr</vspec></gra>
  <snc>
    <dif>
      &Scirc;miri per <tld/>a pasto:
      <ekz>
        <tld/>ita citrontorto.
      </ekz>
    </dif>
  </snc>
  <trd lng="be">&c_p;&c_a;&c_k;&c_r;&c_y;&c_v;&c_a;&c_c;&c_mol; <ind>&c_m;&c_e;&c_r;&c_e;&c_n;&c_g;&c_a;&c_j;</ind></trd>
  <trd lng="ca">cobrir amb <ind>merenga</ind></trd>
  <trd lng="cs">pot&rcaron;&iacute;t sn&ecaron;hovou p&ecaron;nou</trd>
  <trd lng="fr">meringuer</trd>
  <trd lng="hu">cukros toj&aacute;shabbal von be</trd>
  <trd lng="ja">&#x30E1;&#x30EC;&#x30F3;&#x30B2;&#x3092;&#x306E;&#x305B;&#x308B;</trd>
  <trd lng="pl">smarowa&cacute; kremem <ind>bezowym</ind></trd>
  <trd lng="sk">potrie&tcaron; snehovou penou</trd>
</drv>
</art>
