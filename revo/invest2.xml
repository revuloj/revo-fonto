<?xml version="1.0"?>
<!DOCTYPE vortaro SYSTEM "../dtd/vokoxml.dtd">
<vortaro>
  <art mrk="$Id: invest2.xml,v 1.8 2026/06/28 19:46:18 revo Exp $">
    <kap>
      <rad>invest</rad>/i
      <fnt>VdE</fnt>
    </kap>

<drv mrk="invest2.0i">
  <kap><tld/>i</kap>
  <gra><vspec>tr</vspec></gra>
  <snc mrk="invest2.0i.enoficigi">
    <uzo tip="stl">ARK</uzo>
    <uzo tip="stl">RAR</uzo>
    <dif>
      <refgrp tip="dif">
        <ref cel="invest1.0i">Investituri</ref>,
        <ref cel="posten.en0igi">enpostenigi</ref>,
        <ref cel="ofic.en0igi">enoficigi</ref>
      </refgrp>:
      <ekz>
        <tld/>i ambasadoron
        <fnt><bib>PV</bib></fnt>;
      </ekz>
      <ekz>
        la papo <klr>[&#8230;]</klr> <tld/>is amba&ubreve; episkopojn
        <fnt>
          <bib>Viki</bib>
          <lok><url ref="https://eo.wikipedia.org/?curid=251464"
              >Konrado la 1-a (Bohemio)</url></lok>
        </fnt>;
      </ekz>
      <ekz>
        &ccirc;efministro de Japanio <klr>[...]</klr> estas nomumata de parlamenta rezolucio, <tld/>ata de
        la imperiestro
        <fnt>
          <bib>Viki</bib>
          <lok><url ref="https://eo.wikipedia.org/?curid=17408">&Ccirc;efministro de Japanio</url></lok>
        </fnt>.
      </ekz>
    </dif>
    <trdgrp lng="de">
      <trd>einf&uuml;hren <klr>(in ein Amt)</klr></trd>,
      <trd>benennen <klr>(f&uuml;r ein Amt)</klr></trd>
    </trdgrp>
    <trdgrp lng="fr">
      <trd>investir<klr tip="ind"> (mettre &agrave; un poste)</klr></trd>,
      <trd>introniser<klr tip="ind"> (mettre &agrave; un
      poste)</klr></trd>,
      <trd>donner l'<ind>investiture</ind> (&agrave;)<klr tip="ind">
      (mettre &agrave; un poste)</klr></trd>
    </trdgrp>
    <trd lng="hu">beiktat</trd>
    <trd lng="nl">inhuldigen</trd>
    <trd lng="pl">mianowa&cacute; uroczy&sacute;cie na urz&aogonek;d</trd>
    <trd lng="pt">investir<klr tip="amb"> (dar posse
    solene)</klr></trd>
    <trdgrp lng="ru">
      <trd>&c_n;&c_a;&c_d;&c_je;&c_l;&c_ja;&c_t;&c_mol;
        &c_p;&c_o;&c_l;&c_n;&c_o;&c_m;&c_o;&c_ch;&c_i;&c_ja;&c_m;&c_i;</trd>,
      <trd>&c_o;&c_b;&c_l;&c_je;&c_k;&c_a;&c_t;&c_mol;
        &c_v;&c_l;&c_a;&c_s;&c_t;&c_mol;&c_ju;</trd>,
      <trd>&c_v;&c_o;&c_z;&c_l;&c_a;&c_g;&c_a;&c_t;&c_mol;
        &c_o;&c_b;&c_ja;&c_z;&c_a;&c_n;&c_n;&c_o;&c_s;&c_t;&c_i;</trd>
    </trdgrp>
  </snc>
  <ref tip="hom" cel="invest.0i.EKON">investi<sncref/> <klr>(monon)</klr></ref>
  <trdgrp lng="cs">
    <trd>investovat</trd>,
    <trd>uv&eacute;st do &uacute;&rcaron;adu</trd>
  </trdgrp>
  <trd lng="en">invest</trd>
  <trd lng="ja">&#25237;&#x8CC7;&#12377;&#x308B;  <pr>&#12392;&#12358;&#12375;&#12377;&#x308B;</pr></trd>
  <trd lng="sk">investova&tcaron; kapit&aacute;l</trd>
</drv>

<drv mrk="invest2.0o">
  <kap><tld/>o, <var><kap><tld/>ado</kap></var></kap>
  <snc mrk="invest2.0o.enoficigo">
    <uzo tip="stl">ARK</uzo>
    <dif>
      <ref tip="dif" cel="invest1.0o">Investituro</ref>:
      <ekz>
        <nac>Legatus a latere</nac> <klr>[&#8230;]</klr> estas konfidita al la plej altaj ranguloj de la
        sacerdota grupo, nome al kardinaloj, temas pri ekstraordinara <tld/>ado kiel
        <nac>alter ego</nac> (kiel li, kiel la papo mem) kaj kiel tia li posedas plenajn povojn
        <fnt>
          <bib>Viki</bib>
          <lok><url ref="https://eo.wikipedia.org/?curid=422641"
              >Papa legato</url></lok>
        </fnt>.
      </ekz>
    </dif>
    <trd lng="de"><klr>(Amts-)</klr>Einf&uuml;hrung</trd>
    <trd lng="fr">investiture</trd>
    <trd lng="pl">inwestytura</trd>
  </snc>
  <refgrp tip="hom">
    <ref cel="invest.0o.ajxo"><klr>(mon-)</klr>investo<sncref/></ref>,
    <ref cel="invest.0ado">(mon-)investado</ref>
  </refgrp>
  <trd lng="cs">investov&aacute;n&iacute;</trd>
  <trd lng="en">investment</trd>
  <trdgrp lng="ja">
    <trd>&#x4EFB;&#x547D;  <pr>&#x306B;&#12435;&#12417;&#12356;</pr></trd>,
    <trd>&#x53D9;&#x4EFB;  <pr>&#12376;&#12423;&#x306B;&#12435;</pr></trd>,
    <trd>&#25237;&#x8CC7;  <pr>&#12392;&#12358;&#12375;</pr></trd>
  </trdgrp>
  <trd lng="sk">investovanie</trd>
  <trdgrp lng="uk">
    <trd>&c_d;&c_a;&c_r;&c_u;&c_v;&c_a;&c_n;&c_n;&c_ja;</trd>,
    <trd>&c_n;&c_a;&c_d;&c_ib;&c_l;&c_je;&c_n;&c_n;&c_ja;</trd>,
    <trd>&c_ib;&c_n;&c_v;&c_je;&c_s;&c_t;&c_i;&c_c;&c_ib;&c_ja;</trd>,
    <trd>&c_ib;&c_n;&c_v;&c_je;&c_s;&c_t;&c_u;&c_v;&c_a;&c_n;&c_n;&c_ja;</trd>,
    <trd>&c_v;&c_k;&c_l;&c_a;&c_d;&c_je;&c_n;&c_n;&c_ja; &c_g;&c_r;&c_o;&c_sh;&c_je;&c_j;/&c_k;&c_a;&c_p;&c_ib;&c_t;&c_a;&c_l;&c_u;</trd>
  </trdgrp>
</drv>

</art>

