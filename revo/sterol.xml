<?xml version="1.0"?>
<!DOCTYPE vortaro SYSTEM "../dtd/vokoxml.dtd">

<vortaro>
  <art mrk="$Id: sterol.xml,v 1.1 2026/03/09 06:35:20 afido Exp $">
    <kap>
      <rad>sterol</rad>/o <fnt><bib>PIV1</bib></fnt>,
      <var><kap><rad var="in">sterin</rad>/o</kap></var>
    </kap>

<drv mrk="sterol.0o">
  <kap><tld/>o, <var><kap><tld var="in"/>o</kap></var></kap>
  <uzo tip="fak">KEM</uzo>
  <snc>
    <dif>
      Iu el grupo de lipidoj <ref tip="super" cel="steroid.0o">steroido</ref>
      en la &ccirc;elmembranoj de organismoj, organika substanco kun ordinare kvar karboncikloj kaj hidroksila grupo:
      <ekz>
        lakta&jcirc;oj ri&ccirc;igitaj je vegetalaj <tld/>oj
        <fnt>
          <bib>Monato</bib>
          <aut>Roberto Pigro</aut>
          <vrk><url ref="&Monato;/2013/011124.php"
              >Atentu la koron</url></vrk>
          <lok>2013</lok>
        </fnt>;
      </ekz>
      <ekz>
        vitamino D <klr>[&#x2026;]</klr> esti&gcirc;as el <tld/>oj trovi&gcirc;antaj en la ha&ubreve;to per efiko
        de ultraviola radiado, el tiuj <tld var="in"/>oj gravas la 7-dehidrokolesterolo
        <fnt>
          <bib>Viki</bib>
          <lok><url ref="https://eo.wikipedia.org/?curid=137035"
              >Vitamino D</url></lok>
        </fnt>.
      </ekz>
    </dif>
    <bld
      lok="&WCU;/a/a5/Sterol.svg"
      prm="PD"
      lrg="320"
      >strukturformulo de <tld/>o
        <fnt>
          <aut>Roland Mattern, Roland1952</aut>
          <lok><url ref="&WCW;/File:Sterol.svg"
              >https://commons.wikimedia.org/wiki/File:Sterol.svg</url></lok>
        </fnt>
    </bld>
    <trd lng="de">Sterin</trd>
    <trd lng="en">sterol</trd>
    <trd lng="fr">st&eacute;rol</trd>
  </snc>
</drv>

  </art>

