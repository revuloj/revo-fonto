<?xml version="1.0"?>
<!DOCTYPE vortaro SYSTEM "../dtd/vokoxml.dtd">
<vortaro>
<art mrk="$Id: sxpin.xml,v 1.40 2026/03/17 22:00:20 revo Exp $">
<kap>
  <ofc>*</ofc>
  <rad>&scirc;pin</rad>/i <fnt><bib>UV</bib></fnt>
</kap>
<drv mrk="sxpin.0i">
  <kap><ofc>*</ofc><tld/>i</kap>
  <gra><vspec>tr</vspec></gra>
  <snc mrk="sxpin.0i.TEKS">
    <uzo tip="fak">TEKS</uzo>
    <dif>
      <ref tip="super" cel="tir.0i.FIG_longigi">Tiri</ref> <ref cel="faden.0o.TEKS">fadeno</ref>n
      el maldensa provizo da fibroj (lano, kotono, lino k.a.)
      kuntordante ilin:
      <ekz>
        <tld/>i kapran lanon
        <fnt>
          <bib>MT</bib>
          <lok>Eliro 35:26</lok>
        </fnt>;
      </ekz>
      <ekz>
        &ccirc;iu virino, kiu havis ian kompetentecon, <tld/>is kaj alportis <tld/>itan lanon
        bluan kaj purpuran kaj ru&gcirc;an kaj bisinon
        <fnt>
          <bib>MT</bib>
          <lok>Eliro 35:25</lok>
        </fnt>;
      </ekz>
      <ekz>
        la mastrino kun siaj servistinoj kaj <tld/>adis lanon kaj linon
        <fnt>
          <bib>Fab3</bib>
        </fnt>;
      </ekz>
      <ekz>
        <klr>[la]</klr> <tld/>fasko<klr>[n&#8230;]</klr> &scirc;i premis en sia mano <klr>[&#8230;]</klr>,
        &scirc;i sen&ccirc;ese <tld/>adis, la fadeno sur &scirc;ia <tld/>ilo estis pli delikata ol
        aranea&jcirc;o
        <fnt>
          <bib>Fab3</bib>
          <lok>&Scirc;tono de la sa&gcirc;uloj</lok>
        </fnt>;
      </ekz>
      <ekz>
        sur la planko ku&scirc;is la fasko <klr>[&#8230;]</klr> kiun &scirc;i estis <tld/>inta el la
        urtikoj
        <fnt>
          <bib>Fab1</bib>
          <lok>Sova&gcirc;aj cignoj</lok>
        </fnt>.
      </ekz>
    </dif>
    <trd lng="es">hilar</trd>
    <trd lng="fr">filer<klr tip="amb"> (faire un fil)</klr></trd>
    <trd lng="hu">fon</trd>
    <trd lng="it">filare</trd>
    <trdgrp lng="ca">
      <trd>filar</trd>,
      <trd>teixir</trd>
    </trdgrp>
    <trdgrp lng="ru">
      <trd>&c_p;&c_r;&c_ja;&c_s;&c_t;&c_mol;</trd>,
      <trd>&c_s;&c_u;&c_ch;&c_i;&c_t;&c_mol;</trd>
    </trdgrp>
  </snc>
  <snc mrk="sxpin.0i.BIO">
    <uzo tip="fak">BIO</uzo><uzo tip="fak">KEM</uzo>
    <dif>
      Produkti <ref cel="silk.0o">silk</ref>fadenon per sekreciado kiel
      faras <ref cel="arane.0o">araneo</ref>, kelkaj ra&ubreve;poj a&ubreve;
      filamenton (<ref cel="viskoz.0o">viskozo</ref> kc) el flua&jcirc;o per sinteza procezo:
      <ekz>
        malgranda araneo <klr>[&#8230;]</klr> laboreme <tld/>adis super li sian teksa&jcirc;on
        <fnt>
          <bib>Fab3</bib>
          <lok>Nokta &ccirc;apo de fra&ubreve;lo</lok>
        </fnt>.
      </ekz>
    </dif>
    <refgrp tip="vid">
       <ref cel="strecx.0i">stre&ccirc;i</ref>
    </refgrp>
    <trdgrp lng="ca">
      <trd>filar</trd>,
      <trd>teixir<klr tip="amb"> (una aranya, un cuc de seda)</klr></trd>
    </trdgrp>
  </snc>
  <snc mrk="sxpin.0i.SON">
    <uzo tip="stl">FIG</uzo>
    <dif>
      <ref tip="super" cel="murmur.0i.brui">Murmuri</ref>
      kun <ref tip="lst" cel="son.0o" lst="voko:sonoj">sono</ref>
      simila al tiu de rad<tld/>ilo, <ref tip="vid" cel="ronron.0i.SON">ronroni</ref>:
      <ekz>
        la kato komencis <tld/>i
        <fnt><bib>Fab2</bib>, <lok>Malbela anasido</lok></fnt>.
      </ekz>
    </dif>
    <trd lng="ca">roncar<klr tip="amb"> (un gat)</klr></trd>
  </snc>
  <snc mrk="sxpin.0i.FIG">
    <uzo tip="stl">FIG</uzo>
    <dif>
      <ref tip="super" cel="pens.el0i">Elpensi</ref> <ref cel="faden.0o.FIG">fadenon</ref>
      de rakonto, plano ks:
      <ekz>
        <klr>[li]</klr> <tld/>is la pensfadenon, kiu nun kuras de lando al lando
        <fnt>
          <bib>Fab3</bib>
          <lok>Cigna nesto</lok>
        </fnt>;
      </ekz>
      <ekz>
        la pastroj tute ne suspektas, <klr>[&#8230;]</klr> kiajn planojn li <tld/>is en sia
        kapo
        <fnt>
          <bib>Far2</bib>
          <lok>&Ccirc;apitro VI</lok>
        </fnt>;
      </ekz>
      <ekz>
        &scirc;ia bu&scirc;o <tld/>is la longajn fadenojn de fantaziaj
        rakontoj
        <fnt><bib>Marta</bib></fnt>.
      </ekz>
      <ekz>
        el tiuj vortoj <tld/>i&gcirc;is longa vico da oraj revoj
        <fnt>
          <bib>Marta</bib>
        </fnt>.
      </ekz>
    </dif>
    <trd lng="ca">rumiar</trd>
    <trd lng="fr">ourdir</trd>
    <trdgrp lng="hu">
      <trd>sz&odblac;<klr tip="amb"> (pl. terveket)</klr></trd>,
      <trd>k&ouml;lt<klr tip="amb"> (pl. legend&aacute;kat)</klr></trd>
    </trdgrp>
    <trd lng="it">tessere<klr> (fig.)</klr></trd>
    <trdgrp lng="ru">
      <trd>&c_p;&c_l;&c_je;&c_s;&c_t;&c_i;</trd>,
      <trd>&c_s;&c_p;&c_l;&c_je;&c_t;&c_a;&c_t;&c_mol;</trd>
    </trdgrp>
  </snc>
  <refgrp tip="vid">
    <ref cel="plekt.0i">plekti</ref>,
    <ref cel="teks.0i">teksi</ref>,
    <ref cel="trik.0i">triki</ref>
  </refgrp>
  <trdgrp lng="be">
    <trd>&c_p;&c_r;&c_a;&c_s;&c_mol;&c_c;&c_ib;</trd>,
    <trd>&c_s;&c_u;&c_k;&c_a;&c_c;&c_mol;</trd>,
    <trd>&c_p;&c_l;&c_je;&c_s;&c_mol;&c_c;&c_ib;</trd>,
    <trd>&c_s;&c_p;&c_l;&c_ja;&c_t;&c_a;&c_c;&c_mol;</trd>
  </trdgrp>
  <trd lng="de">spinnen</trd>
  <trd lng="en">spin</trd>
  <trdgrp lng="ja">
    <trd>&#32033;&#12368;  <pr>&#12388;&#12416;&#12368;</pr></trd>,
    <trd>&#21520;&#12367;  <pr>&#12399;&#12367;</pr></trd>,
    <trd>&#12388;&#12367;&#12427;</trd>,
    <trd>&#32340;&#12426;&#12394;&#12377;  <pr>&#12362;&#12426;&#12394;&#12377;</pr></trd>,
    <trd>&#20316;&#12426;&#19978;&#12370;&#12427;  <pr>&#12388;&#12367;&#12426;&#12354;&#12370;&#12427;</pr></trd>
  </trdgrp>
  <trd lng="nl">spinnen</trd>
  <trdgrp lng="pl">
    <trd>dzierga&cacute;</trd>,
    <trd>prz&aogonek;&sacute;&cacute;</trd>,
    <trd>snu&cacute;</trd>
  </trdgrp>
  <trd lng="pt">fiar</trd>
  <trdgrp lng="uk">
    <trd>&c_p;&c_r;&c_ja;&c_s;&c_t;&c_i;</trd>,
    <trd>&c_s;&c_u;&c_k;&c_a;&c_t;&c_i;</trd>,
    <trd>&c_p;&c_l;&c_je;&c_s;&c_t;&c_i; (&c_p;&c_a;&c_v;&c_u;&c_t;&c_i;&c_n;&c_u;)</trd>
  </trdgrp>
  <trdgrp lng="zh">
    <trd>&#34523; <pr>zh&#363;</pr></trd>,
    <trd>&#32033;&#32023; <pr>f&#462;ngsh&amacron;</pr></trd>,
    <trd>&#32442;&#32433; <pr>f&#462;ngsh&amacron;</pr></trd>,
    <trd>&#21520;&#19997; <pr>t&ugrave;s&#299;</pr></trd>,
    <trd>&#21520;&#32114; <pr>t&ugrave;s&#299;</pr></trd>,
    <trd>&#22270;&#35851; <pr>t&uacute;m&oacute;u</pr></trd>,
    <trd>&#22294;&#35584; <pr>t&uacute;m&oacute;u</pr></trd>,
    <trd>&#32080;&#32178; <pr>ji&eacute;w&#462;ng</pr></trd>,
    <trd>&#32467;&#32593; <pr>ji&eacute;w&#462;ng</pr></trd>,
    <trd>&#34850;&#35441; <pr>ch&#468;nhu&agrave;</pr></trd>,
    <trd>&#34850;&#35805; <pr>ch&#468;nhu&agrave;</pr></trd>,
    <trd>&#35498;&#20123;&#28961;&#32842;&#30340;&#35441; <pr>shu&#333;xi&emacron;w&uacute;li&aacute;odehu&agrave;</pr></trd>,
    <trd>&#35828;&#20123;&#26080;&#32842;&#30340;&#35805;
    <pr>shu&#333;xi&emacron;w&uacute;li&aacute;odehu&agrave;</pr></trd>
  </trdgrp>
</drv>

<drv mrk="sxpin.0ajxo">
  <kap>
    <tld/>a&jcirc;o
  </kap>
  <snc mrk="sxpin.0ajxo.TEKS">
    <dif>
      Io <tld/>ita, la rezulto de <tld/>ado:
      <ekz>
        araneo en <klr>[s]</klr>ia <tld/>a&jcirc;o
        <fnt>
          <bib>Fab4</bib>
          <lok>La vento rakontas pri Valdemaro Doe kaj pri liaj filinoj</lok>
        </fnt>;
      </ekz>
      <ekz>
        volvi &ccirc;irka&ubreve; <klr>[la diletanteco]</klr> <tld/>a&jcirc;on de spirito
        <fnt>
          <bib>Marta</bib>
        </fnt>.
      </ekz>
    </dif>
  </snc>
  <trdgrp lng="be">
    <trd>&c_p;&c_r;&c_a;&c_d;&c_z;&c_ib;&c_v;&c_a;</trd>,
    <trd>&c_p;&c_r;&c_a;&c_zh;&c_a;</trd>,
    <trd>&c_k;&c_u;&c_d;&c_z;&c_je;&c_l;&c_ja;</trd>,
    <trd>&c_p;&c_a;&c_v;&c_u;&c_c;&c_ib;&c_n;&c_a;</trd>,
    <trd>&c_p;&c_a;&c_v;&c_u;&c_ch;&c_y;&c_n;&c_mol;&c_n;&c_je;</trd>
  </trdgrp>
  <trd lng="ca">filat<klr tip="amb"> (cosa filada)</klr></trd>
  <trd lng="de">Gespinst</trd>
  <trdgrp lng="ja">
    <trd>&#32033;&#31992;  <pr>&#12412;&#12358;&#12375;</pr></trd>,
    <trd>&#12463;&#12514;&#12398;&#24035;  <pr>&#12367;&#12418;&#12398;&#12377;</pr></trd>,
    <trd>&#12459;&#12452;&#12467;&#12398;&#32365;
    <pr>&#12459;&#12452;&#12467;&#12398;&#12414;&#12422;</pr></trd>
  </trdgrp>
  <trdgrp lng="pl">
    <trd>k&aogonek;dziel</trd>,
    <trd>prz&eogonek;dza</trd>
  </trdgrp>
  <trdgrp lng="uk">
    <trd>&c_p;&c_r;&c_ja;&c_d;&c_i;&c_v;&c_o;</trd>,
    <trd>&c_p;&c_a;&c_v;&c_u;&c_t;&c_i;&c_n;&c_a;</trd>
  </trdgrp>
</drv>

<drv mrk="sxpin.0ejo">
  <kap>
    <tld/>ejo
  </kap>
  <snc mrk="sxpin.0ejo.TEKS">
    <dif>
      Loko, verkejo, fabriko kie oni <tld/>as:
      <ekz>
        iun matenon, ili iris por vendi kokonojn al la <tld/>ejo
        <fnt>
          <aut>E. About, trad. G. Moch</aut>
          <vrk><url ref="&Gutenberg;files/65835/65835-0.txt">La Re&gcirc;o de la Montoj</url></vrk>
          <lok>1909</lok>
        </fnt>;
      </ekz>
    </dif>
  </snc>
  <trdgrp lng="be">
    <trd>&c_p;&c_r;&c_a;&c_d;&c_z;&c_ib;&c_l;&c_mol;&c_n;&c_ja;</trd>,
    <trd>&c_p;&c_r;&c_a;&c_d;&c_z;&c_ib;&c_l;&c_mol;&c_n;&c_y; <ind>&c_c;&c_e;&c_h;</ind></trd>
  </trdgrp>
  <trdgrp lng="ca">
    <trd>rac&oacute; de filar</trd>,
    <trd>cambra de filar</trd>,
    <trd>filatura</trd>
  </trdgrp>
  <trd lng="fr">filature</trd>
  <trdgrp lng="ja">
    <trd>&#35069;&#31992;&#24037;&#22580;  <pr>&#12379;&#12356;&#12375;&#12371;&#12358;&#12376;&#12423;&#12358;</pr></trd>,
    <trd>&#32033;&#32318;&#24037;&#22580;  <pr>&#12412;&#12358;&#12379;&#12365;&#12371;&#12358;&#12376;&#12423;&#12358;</pr></trd>
  </trdgrp>
  <trd lng="pl">prz&eogonek;dzalnia</trd>
</drv>

<drv mrk="sxpin.0ilo">
  <kap><tld/>ilo</kap>
  <snc mrk="sxpin.0ilo.TEKS">
    <uzo tip="fak">TEKS</uzo>
    <dif>
      &Ccirc;ia aparato por &scirc;pini:
      <ekz>
        &scirc;iaj servistinoj <klr>[&#8230;]</klr> turnas la <tld/>ilon
        <fnt>
          <bib>Fab4</bib>
          <lok>La vento rakontas pri Valdemaro Doe kaj pri liaj filinoj</lok>
        </fnt>;
      </ekz>
      <ekz>
        la fadeno sur &scirc;ia <tld/>ilo estis pli delikata ol aranea&jcirc;o
        <fnt>
          <bib>Fab3</bib>
          <lok>&Scirc;tono de la sa&gcirc;uloj</lok>
        </fnt>;
      </ekz>
      <ekz>
        greka <tld/>ilo konsistis el stango kiu &ccirc;e la kapo estis hokforma, proksima al
        la malsupro estis peza bovloforma ronda&jcirc;o
        <klr>(vd <ref cel="sxpin.0turnilo">&scirc;pinturnilo</ref>)</klr>,
        tra kies mezo iris la stango
        <fnt>
          <bib>Rsp</bib>
        </fnt>;
      </ekz>
      <ekz>
        murmuri kiel <tld/>ilo
        <fnt><bib>ElektFab</bib>, <lok>La bremenaj
        muzikistoj</lok></fnt>.
      </ekz>
    </dif>
    <ref tip="prt" cel="spinde.0o">spindelo</ref>
    <bld
    lok="&WCU;/thumb/9/98/Noraduz_-_Armenia_(2921901759).jpg/330px-Noraduz_-_Armenia_(2921901759).jpg"
    prm="CC BY 2.0">armenino <tld/>ante lanon per tradicia <tld/>ilo
        <fnt>
          <aut>Rita Willaert from 9890 Gavere, Belgium, Flickr Noraduz - Armenia</aut>
          <lok><url
          ref="&WCW;/File:Noraduz_-_Armenia_(2921901759).jpg">&WCW;/File:Noraduz_-_Armenia_(2921901759).jpg</url></lok>
        </fnt>
    </bld>
  </snc>
  <trdgrp lng="be">
    <trd>&c_v;&c_je;&c_r;&c_a;&c_c;&c_ja;&c_n;&c_o;</trd>,
    <trd>&c_p;&c_r;&c_a;&c_d;&c_z;&c_ib;&c_l;&c_mol;&c_n;&c_y;
    <ind>&c_s;&c_t;&c_a;&c_n;&c_o;&c_k;</ind></trd>
  </trdgrp>
  <trdgrp lng="de">
    <trd>Handspindel</trd>,
    <trd>Spinnrad</trd>
  </trdgrp>
  <trdgrp lng="es">
    <trd>hiladora</trd>,
    <trd>m&aacute;quina de hilar</trd>
  </trdgrp>
  <trdgrp lng="fr">
    <trd>m&eacute;tier &agrave; tisser</trd>,
    <trd>m&eacute;tier &agrave; filer</trd>
  </trdgrp>
  <trdgrp lng="it">
      <trd>fuso<klr tip="amb"> (tess. e mecc.)</klr></trd>,
      <trd>filatoio<klr tip="amb"> (attrezzo)</klr></trd>,
      <trd>filatrice<klr tip="amb"> (macchina)</klr></trd>,
      <trd>rocca<klr tip="amb"> (tess.)</klr></trd>
    </trdgrp>
    <trdgrp lng="ca">
    <trd>filadora</trd>,
    <trd>m&agrave;quina de filar</trd>
  </trdgrp>
  <trdgrp lng="ja">
    <trd>&#32033;&#37656;  <pr>&#12412;&#12358;&#12377;&#12356;</pr></trd>,
    <trd>&#37656;  <pr>&#12356;&#12431;</pr></trd>
  </trdgrp>
  <trdgrp lng="pl">
    <trd>wrzeciono</trd>,
    <trd>prz&eogonek;&sacute;lica</trd>
  </trdgrp>
  <trdgrp lng="uk">
    <trd>&c_v;&c_je;&c_r;&c_je;&c_t;&c_je;&c_n;&c_o;</trd>,
    <trd>&c_p;&c_r;&c_ja;&c_d;&c_k;&c_a;</trd>
  </trdgrp>
  <trdgrp lng="zh">
    <trd>&#32033;&#36554; <pr>f&#462;ngch&emacron;</pr></trd>,
    <trd>&#32442;&#36710; <pr>f&#462;ngch&emacron;</pr></trd>
  </trdgrp>
</drv>

<drv mrk="sxpin.rad0ilo">
  <kap>rad<tld/>ilo</kap>
  <snc mrk="sxpin.rad0ilo.TEKS">
    <uzo tip="fak">TEKS</uzo>
    <dif>
      <ref tip="super" cel="sxpin.0ilo.TEKS">&Scirc;pinilo</ref> pelata
      de rado, kiun oni movas per pedalo:
      <ekz>
        granda kiel rad<tld/>ilo
        <fnt><bib>Fab2</bib>, <lok>Ne&gcirc;a re&gcirc;ino</lok></fnt>;
      </ekz>
      <ekz>
        la rad<tld/>ilo balda&ubreve; estis aldonita al la flago de la Kongresa Partio de Hindio
        <fnt>
          <bib>Viki</bib>
          <lok><url ref="https://eo.wikipedia.org/?curid=32107">Mohandas Karamchand
          Gandhi</url></lok>
        </fnt>.
      </ekz>
    </dif>
    <ref tip="prt" cel="rad.sxpin0o"><tld/>rado</ref>
    <bld
    lok="&WCU;/thumb/a/ab/Textilmuseum_Bocholt_Spinnrad.jpg/500px-Textilmuseum_Bocholt_Spinnrad.jpg"
    prm="CC-BY-SA-3.0">rad<tld/>ilo, teksa&jcirc;a muzeo en Bocholt
        <fnt>
          <aut>Stahlkocher, propra foto</aut>
          <lok><url
          ref="&WCW;/File:Textilmuseum_Bocholt_Spinnrad.jpg">&WCW;/File:Textilmuseum_Bocholt_Spinnrad.jpg</url></lok>
        </fnt>
    </bld>
  </snc>
  <trd lng="be">&c_k;&c_a;&c_l;&c_a;&c_w;&c_r;&c_o;&c_t;</trd>
  <trd lng="ca">torn de filar</trd>
  <trdgrp lng="es">
    <trd>torno de hilar</trd>,
    <trd>rueca</trd>
  </trdgrp>
  <trd lng="fr">rouet</trd>
  <trd lng="hu">rokka</trd>
  <trdgrp lng="it">
    <trd>filatoio<klr tip="amb"> (attrezzo)</klr></trd>,
    <trd>arcolaio</trd>
  </trdgrp>
  <trdgrp lng="ja">
    <trd>&#32033;&#12366;&#36554;  <pr>&#12388;&#12416;&#12366;&#12375;&#12419;</pr></trd>,
    <trd>&#31992;&#32368;&#36554;  <pr>&#12356;&#12392;&#12367;&#12426;&#12368;&#12427;&#12414;</pr></trd>,
    <trd>&#31992;&#36554;  <pr>&#12356;&#12392;&#12368;&#12427;&#12414;</pr></trd>
  </trdgrp>
  <trd lng="nl">spinnewiel</trd>
  <trd lng="pl">ko&lstroke;owrotek</trd>
  <trdgrp lng="pt">
    <trd>roca</trd>,
    <trd>fuso</trd>
  </trdgrp>
  <trd lng="ru">&c_p;&c_r;&c_ja;&c_l;&c_k;&c_a;</trd>
  <trd lng="zh">&#36566; <pr>ku&aacute;ng</pr></trd>
</drv>

<drv mrk="sxpin.0turnilo">
  <kap><tld/>turnilo</kap>
  <snc mrk="sxpin.0turnilo.TEKS">
    <uzo tip="fak">TEKS</uzo>
    <dif>
      Parto de <ref tip="malprt" cel="sxpin.0ilo.TEKS"><tld/>ilo</ref>
      per kiu oni &gcirc;in turnimpetas:
      <ekz>
        &scirc;i etendas sian manon al la <tld/>ilo, kaj &scirc;iaj fingroj tenas la <tld/>turnilon
        <fnt>
          <bib>MT</bib>
          <lok>Sentencoj 31:19</lok>
        </fnt>.
      </ekz>
    </dif>
    <bld lok="&WCU;/thumb/b/b8/Drop_spindles_from_Mexico.jpg/330px-Drop_spindles_from_Mexico.jpg"
    prm="CC BY-SA 3.0">ringaj <tld/>turniloj de aztekoj, Meksiko
        <fnt>
          <aut>Peter van der Sluijs, propra verko</aut>
          <lok><url
          ref="&WCW;/File:Drop_spindles_from_Mexico.jpg">&WCW;/File:Drop_spindles_from_Mexico.jpg</url></lok>
        </fnt>
