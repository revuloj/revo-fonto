<!DOCTYPE vortaro SYSTEM "../dtd/vokoxml.dtd">
<vortaro>
<art mrk="$Id: kreten.xml,v 1.23 2026/05/02 20:00:22 revo Exp $">
<kap>
  <rad>kreten</rad>/o
  <fnt><bib>JED</bib></fnt>
</kap>
<drv mrk="kreten.0o">
  <kap>
    <tld/>o
  </kap>
  <snc mrk="kreten.0o.malsanulo">
    <dif>
      Homo suferanta de denaska manko de <ref cel="tiroid.0o">tiroida</ref>
      hormono, kio kune kun manko de jodo en la nutra&jcirc;o ka&ubreve;zas gravajn simptomojn kiel
      difektita spino, kropon, idiotecon.
    </dif>
    <trd lng="de">Kretin</trd>
    <trd lng="hu">kret&eacute;n</trd>
    <trd lng="nl">cretin</trd>
    <trd lng="pl">kretyn</trd>
  </snc>
  <snc mrk="kreten.0o.FIG">
    <uzo tip="stl">FIG</uzo>
    <dif>
      Malspritegulo:
      <ekz>
        la societo estas miksa, &ccirc;ar re&gcirc;o kaj almozulo, geniulo kaj <tld/>o, sidas apude
        <fnt>
          <bib>Fab4</bib>
          <lok>Turgardisto Ole</lok>
        </fnt>;
      </ekz>
      <ekz>
        kiamaniere vo&ccirc;doni, se ni kredas la reprezentantojn de niaj politikaj partoj se
        ne friponoj do almena&ubreve; <tld/>oj
        <fnt>
          <bib>Monato</bib>
          <aut>Paul Gubbins</aut>
          <vrk><url ref="&Monato;/2012/010797.php">Ne, ne ... N!</url></vrk>
        </fnt>?
      </ekz>
    </dif>
    <trd lng="de">Schwachsinniger</trd>
  </snc>
  <trd lng="be">&c_k;&c_r;&c_e;&c_t;&c_y;&c_n;</trd>
  <trd lng="ca">cret&iacute;</trd>
  <trd lng="en">cretin</trd>
  <trd lng="es">cretino</trd>
  <trd lng="fr">cr&eacute;tin</trd>
  <trdgrp lng="hu">
    <trd>kret&eacute;n</trd>,
    <trd>h&uuml;lye</trd>,
    <trd>idi&oacute;ta</trd>,
    <trd>agyal&aacute;gyult</trd>
  </trdgrp>
  <trdgrp lng="ja">
    <trd>&#12463;&#12524;&#12481;&#12531;&#30149;&#24739;&#32773;  <pr>&#12463;&#12524;&#12481;&#12531;&#12403;&#12423;&#12358;&#12363;&#12435;&#12376;&#12419;</pr></trd>,
    <trd>&#22823;&#12400;&#12363;  <pr>&#12362;&#12362;&#12496;&#12459;</pr></trd>
  </trdgrp>
  <trdgrp lng="nl">
    <trd>zwakzinnige</trd>,
    <trd>idioot</trd>
  </trdgrp>
  <trdgrp lng="pl">
    <trd>kretyn</trd>,
    <trd>dure&nacute;</trd>,
    <trd>idiota</trd>,
    <trd>mato&lstroke;</trd>
  </trdgrp>
  <trd lng="pt">cretino</trd>
  <trd lng="ru">&c_k;&c_r;&c_je;&c_t;&c_i;&c_n;</trd>
  <trdgrp lng="uk">
    <trd>&c_k;&c_r;&c_je;&c_t;&c_i;&c_n;</trd>,
    <trd>&c_ib;&c_d;&c_ib;&c_o;&c_t;</trd>,
    <trd>&c_n;&c_je;&c_d;&c_o;&c_u;&c_m;&c_k;&c_u;&c_v;&c_a;&c_t;&c_i;&c_j;</trd>
  </trdgrp>
  <trdgrp lng="zh">
    <trd>&#21574;&#23376; <pr>d&#257;izi</pr></trd>,
    <trd>&#23569;&#26681;&#31563; <pr>sh&#462;og&#275;nj&#299;n</pr></trd>,
    <trd>&#34928;&#20154; <pr>shu&#257;ir&eacute;n</pr></trd>
  </trdgrp>
</drv>

<drv mrk="kreten.0e">
  <kap>
    <tld/>e
  </kap>
  <snc>
    <dif>
       Stulte, idiote:
      <ekz>
        via vekhorlo&gcirc;' <tld/>e / Ne bruis je la &gcirc;usta hor'
        <fnt>
          <aut>Raymond Schwartz</aut>
          <vrk><url ref="&Steloj;butiko">La Stranga Butiko</url></vrk>
        </fnt>;
      </ekz>
      <ekz>
        <klr>[ili]</klr> <tld/>e konstruigis centralojn en regiono konata pro tertremoj
        <fnt>
          <bib>Monato</bib>
          <aut>Paul Gubbins</aut>
          <vrk><url ref="&Monato;/2011/010345.php">Ne menciu la n-vorton</url></vrk>
        </fnt>;
      </ekz>
      <ekz>
        mi estas devigata alfronti al mia <tld/>eco, al mia selekte limigita klerigado
        <fnt>
          <bib>Monato</bib>
          <aut>Paul Gubbins</aut>
          <vrk><url ref="&Monato;/2013/010996.php">Fama? Ne, dankon.</url></vrk>
        </fnt>.
      </ekz>
    </dif>
  </snc>
  <trdgrp lng="be">
    <trd>&c_n;&c_je;&c_r;&c_a;&c_z;&c_u;&c_m;&c_n;&c_a;</trd>,
    <trd>&c_p;&c_a;-&c_ib;&c_d;&c_y;&c_jo;&c_c;&c_k;&c_u;</trd>
  </trdgrp>
  <trdgrp lng="de">
    <trd>idiotisch</trd>,
    <trd>beschr&auml;nkt</trd>,
    <trd>bescheuert</trd>,
    <trd>schwachsinnig</trd>
  </trdgrp>
</drv>

<drv mrk="kreten.0ajxo">
  <kap>
    <tld/>a&jcirc;o
  </kap>
  <snc>
    <dif>
      <ref tip="dif" cel="stult.0ajxo">Stulta&jcirc;o</ref>, idiota&jcirc;o:
      <ekz>
        misfamigi min, deklarante, ke &leftquot;la a&ubreve;toro, &scirc;ajne, estas &#8218;atisto&#8217;&#8221;,
        <klr>[&#8230;]</klr>
        mi rigardas ne nur kiel <tld/>a&jcirc;on, sed anka&ubreve; kiel simplan insulton
        <fnt>
          <bib>Monato</bib>
          <aut>Andr&eacute; Cherpillod</aut>
          <vrk><url ref="&Monato;/2009/009676.php">Mi ne estas atisto</url></vrk>
        </fnt>;
      </ekz>
      <ekz>
        lia aserto &leftquot;en la unikoda epoko ankora&ubreve; plendi pri iksoj iomete &#8218;ex-modi&gcirc;as&#8217;&#8221;
        estas <klr>[&#8230;]</klr> pura <tld/>a&jcirc;o
        <fnt>
          <bib>Monato</bib>
          <aut>Andr&eacute; Cherpillod</aut>
          <vrk><url ref="&Monato;/2011/010530.php">Pura kretena&jcirc;o</url></vrk>
        </fnt>.
      </ekz>
    </dif>
  </snc>
  <trdgrp lng="be">
    <trd>&c_ib;&c_d;&c_y;&c_jo;&c_c;&c_t;&c_v;&c_a;</trd>,
    <trd>&c_d;&c_u;&c_r;&c_a;&c_s;&c_mol;&c_c;&c_mol;</trd>
  </trdgrp>
  <trdgrp lng="ca">
    <trd>ximpleria</trd>,
    <trd>bajanada</trd>,
    <trd>poca-soltada</trd>,
    <trd>estupidesa</trd>,
    <trd>bestiesa</trd>,
    <trd>rucada</trd>,
    <trd>burrada</trd>,
    <trd>animalada</trd>
  </trdgrp>
  <trdgrp lng="de">
    <trd>Dummheit</trd>,
    <trd>Schwachsinn</trd>
  </trdgrp>
  <trdgrp lng="zh">
    <trd>&#24858;&#34850; <pr>y&uacute;ch&#468;n</pr></trd>,
    <trd>&#24858;&#34850;&#30340;&#34892;&#20026; <pr>y&uacute;ch&#468;ndex&iacute;ngw&eacute;i</pr></trd>,
    <trd>&#24858;&#34850;&#30340;&#34892;&#28858; <pr>y&uacute;ch&#468;ndex&iacute;ngw&eacute;i</pr></trd>,
    <trd>&#21561;&#29275; <pr>chu&#299;ni&uacute;</pr></trd>,
    <trd>&#31946;&#22615;&#20107; <pr>h&uacute;tush&igrave;</pr></trd>,
    <trd>&#31946;&#28034;&#20107; <pr>h&uacute;tush&igrave;</pr></trd>,
    <trd>&#20667;&#21170;&#20799; <pr>sh&#462;j&igrave;nr</pr></trd>,
    <trd>&#20667;&#21185;&#20818; <pr>sh&#462;j&igrave;nr</pr></trd>
  </trdgrp>
</drv>


