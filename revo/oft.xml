<drv mrk="oft.0eco">
  <kap><tld/>eco</kap>
  <snc mrk="oft.0eco.KOMUNE">
    <dif>
      Relativa abundo de okazado:
      <ekz>
        la elipso estas tre <tld/>a, &gcirc;ia <tld/>eco dependas grandparte de la
        &leftquot;familiareco&rightquot; de la temo
        <fnt>
          <bib>Ret</bib>
          <lok>Dua Parto</lok>
        </fnt>;
      </ekz>
      <ekz>
        man&gcirc;kutimo alta je graso, aparte bestdevena graso,
        ligi&gcirc;as kun plia <tld/>eco de arteriosklerozo
        <fnt><aut>K. Ungar</aut>,
          <vrk>Vivu vigle kaj vegetare!</vrk>,
          <bib>Monato</bib>,
          <lok>1995:7, p. 18a</lok>
        </fnt>;
      </ekz>
      <ekz>
        la domanaro jam rimarkis la <ind>mal<tld/>eco</ind>n de liaj vizitoj
        <fnt>
          <bib>I&scirc;tar</bib>
          <lok>&Ccirc;apitro XXIII</lok>
        </fnt>.
        <trdgrp lng="ca">
          <trd>infreq&uuml;&egrave;ncia</trd>,
          <trd>poca <ind>freq&uuml;&egrave;ncia</ind></trd>,
          <trd>raresa</trd>
        </trdgrp>
        <trd lng="de">Seltenheit</trd>
        <trdgrp lng="es">
          <trd>infrecuencia</trd>,
          <trd>rareza<klr> (cualidad)</klr></trd>
        </trdgrp>
        <trd lng="nl">zeldzaamheid<klr tip="ind"> (het schaars
        zijn)</klr></trd>
      </ekz>
    </dif>
    <ref tip="vid" cel="oft.0o"><tld/>o</ref>
  </snc>
  <trd lng="be">&c_ch;&c_a;&c_s;&c_t;&c_a;&c_t;&c_a;</trd>
  <trd lng="br">aliested</trd>
  <trd lng="ca">freq&uuml;&egrave;ncia</trd>
