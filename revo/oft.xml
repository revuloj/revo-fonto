<drv mrk="oft.0e">
  <kap><ofc>*</ofc><tld/>e</kap>
  <gra><vspec>adverbo</vspec></gra>
  <snc mrk="oft.0e.KOMUNE">
    <dif>
      Multe da fojoj:
      <ekz>
        teatramanto <tld/>e vizitas la teatron
        <fnt>
          <bib>F</bib>
          <lok>&FE; 32</lok>
        </fnt>;
      </ekz>
      <ekz>
        li estas tre ekkolerema kaj eksciti&gcirc;as <tld/>e &ccirc;e la plej malgranda bagatelo
        <fnt>
          <bib>F</bib>
          <lok>&FE; 41</lok>
        </fnt>;
      </ekz>
      <ekz>
        <tld/>e amiko estas pli sindona ol frato.
        <fnt>
          <bib>MT</bib>
          <lok>Sentencoj 18:24</lok>
        </fnt>;
      </ekz>
      <ekz>
        <tld/>e nepripensita parolo vundas kiel glavo
        <fnt>
          <bib>MT</bib>
          <lok>Sentencoj 12:18</lok>
        </fnt>;
      </ekz>
      <ekz>
        mi povos &scirc;in <tld/>ege vizitadi en intimeco de familio
        <fnt>
          <bib>ChL</bib>
          <lok>&Ccirc;apitro Oka</lok>
        </fnt>;
      </ekz>
      <ekz>
        post infekta malsano oni <tld/>e bruligas la vestojn de la malsanulo
        <fnt>
          <bib>F</bib>
          <lok>&FE; 39</lok>
        </fnt>;
      </ekz>
      <ekz>
        malsa&gcirc;ulo <tld/>e estas profeto
        <fnt>
          <bib>PrV</bib>
        </fnt>;
      </ekz>
      <ekz>
        inter la mano &gcirc;is la bu&scirc;o <tld/>e disver&scirc;i&gcirc;as la supo
        <fnt>
          <bib>PrV</bib>
        </fnt>.
      </ekz>
    </dif>
  </snc>
