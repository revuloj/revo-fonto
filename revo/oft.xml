<drv mrk="oft.0a">
  <kap><tld/>a</kap>
  <snc mrk="oft.0a.KOMUNE">
    <dif>
      Okazanta a&ubreve; trovebla multe da fojoj:
      <ekz>
        kronika kataro de konjunktivo estas unu el la plej <tld/>aj malsanoj de la okuloj
        <fnt>
          <bib>FK</bib>
          <lok>Fundamenta Krestomatio de la lingvo Esperanto</lok>
        </fnt>;
      </ekz>
      <ekz>
        min tedas la <tld/>a ripetado
        <fnt>
          <bib>MrA</bib>
          <lok>&Ccirc;apitro X</lok>
        </fnt>;
      </ekz>
      <ekz>
        <klr>[li]</klr> anta&ubreve;e estis <tld/>a gasto, kaj li venis <klr>[&#8230;]</klr> preska&ubreve;
        &ccirc;iutage
        <fnt>
          <bib>HsT</bib>
          <lok>Sia propra mastro</lok>
        </fnt>;
      </ekz>
      <ekz>
        lin doloris <tld/>aj krizoj de astmo
        <fnt>
          <bib>KPr</bib>
          <lok>&Ccirc;apitro Dekkvina</lok>
        </fnt>;
      </ekz>
      <ekz>
        <tld/>a ka&ubreve;zo de fatalaj program-eraroj
        <fnt>
          <aut>Klivo</aut>,
          <vrk>Kio estas Javo?</vrk>,
          <bib>Monato</bib>,
          <lok>1998:5, p. 13a</lok>
        </fnt>;
      </ekz>
      <ekz>
        <tld/>a festo &#8208; malplena kesto
        <fnt>
          <bib>PrV</bib>
        </fnt>.
      </ekz>
    </dif>
  </snc>
  <trd lng="be">&c_ch;&c_a;&c_s;&c_t;&c_y;</trd>
  <trd lng="br">stank<klr tip="ind"> (ag. en amzer)</klr></trd>
