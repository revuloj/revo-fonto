<?xml version="1.0"?>
<!DOCTYPE vortaro SYSTEM "../dtd/vokoxml.dtd">
<vortaro>
<art mrk="$Id: orangx.xml,v 1.37 2026/05/17 08:00:21 revo Exp $">
<kap>
  <ofc>*</ofc>
  <rad>oran&gcirc;</rad>/o <fnt><bib>UV</bib></fnt>
</kap>
<drv mrk="orangx.0o">
  <kap><ofc>*</ofc><tld/>o</kap>
  <snc mrk="orangx.0o.KUI">
    <uzo tip="fak">KUI</uzo>
    <dif>
      Frukto de <tld/>ujo, globforma, dol&ccirc;a, parfuma, sukplena, kun dika
      ru&gcirc;flava &scirc;elo:
      <ekz>
        mi havas pomon kaj <tld/>on por vi
        <fnt><bib>Gerda</bib>, <lok>&ccirc;apitro 18a</lok></fnt>.
      </ekz>
      <ekz>
        <ind><tld/>kolora</ind>.
        <trd lng="br">ora&ntilde;jez<klr tip="ind"> (liv)</klr></trd>
        <trd lng="sv">orange</trd>
      </ekz>
    </dif>
  </snc>
  <trd lng="be">&c_a;&c_p;&c_e;&c_l;&c_mol;&c_s;&c_ib;&c_n;</trd>
  <trd lng="bg">&c_p;&c_o;&c_r;&c_t;&c_o;&c_k;&c_a;&c_l;</trd>
  <trd lng="bo">&#3930;&#3851;&#3939;&#3956;&#3851;&#3928;&#3851;</trd>
  <trd lng="br">ora&ntilde;jezenn<klr tip="ind"> (frouezhenn)</klr></trd>
  <trd lng="ca">taronja</trd>
  <trdgrp lng="de">
    <trd>Apfelsine</trd>,
    <trd>Orange</trd>
  </trdgrp>
  <trd lng="el">&pi;&omikron;&rho;&tau;&omikron;&kappa;&alfa_ton;&lambda;&jota;</trd>
  <trd lng="en">orange</trd>
  <trd lng="es">naranja</trd>
  <trd lng="fr">orange</trd>
  <trd lng="fy">sinesappel</trd>
  <trd lng="hu">narancs</trd>
  <trd lng="id">jeruk</trd>
  <trd lng="io">oranjo</trd>
  <trd lng="ja">&#12458;&#12524;&#12531;&#12472; <pr>&#12362;&#12428;&#12435;&#12376;</pr></trd>
  <trdgrp lng="nl">
    <trd>sinaasappel</trd>,
    <trd>appelsien</trd>
  </trdgrp>
  <trd lng="pl">pomara&nacute;cza</trd>
  <trd lng="pt">laranja</trd>
  <trdgrp lng="ro">
    <trd>portocal</trd>,
    <trd>portocal&abreve;</trd>
  </trdgrp>
  <trd lng="ru">&c_a;&c_p;&c_je;&c_l;&c_mol;&c_s;&c_i;&c_n;</trd>
  <trd lng="sv">apelsin</trd>
  <trd lng="tr">portakal</trd>
  <trdgrp lng="uk">
    <trd>&c_p;&c_o;&c_m;&c_je;&c_r;&c_a;&c_n;&c_je;&c_c;&c_mol;</trd>,
    <trd>&c_b;&c_ib;&c_g;&c_a;&c_r;&c_a;&c_d;&c_ib;&c_ja;</trd>
  </trdgrp>
  <trdgrp lng="zh">
    <trd>&#27225; <pr>ch&eacute;ng</pr></trd>,
    <trd>&#27225;&#23376; <pr>ch&eacute;ngzi</pr></trd>,
    <trd>&#26611;&#19969; <pr>li&#468;d&#299;ng</pr></trd>,
    <trd>&#26611;&#27225; <pr>li&#468;ch&eacute;ng</pr></trd>
  </trdgrp>
</drv>

<drv mrk="orangx.0a">
  <kap><tld/>a</kap>
  <snc>
    <dif>
      Rilata al <tld/>o.
    </dif>
    <trd lng="be">&c_a;&c_p;&c_e;&c_l;&c_mol;&c_s;&c_ib;&c_n;&c_a;&c_v;&c_y;</trd>
    <trd lng="fy">sinesappel-</trd>
    <trd lng="id">... <ind>jeruk</ind></trd>
    <trd lng="ja">&#12458;&#12524;&#12531;&#12472;&#12398;
    <pr>&#12362;&#12428;&#12435;&#12376;&#12398;</pr></trd>
    <trdgrp lng="nl">
      <trd>sinaasappel-</trd>,
      <trd>appelsien-</trd>
    </trdgrp>
  </snc>
  <snc>
    <ref tip="dif" cel="orangx.0kolora"><tld/>kolora</ref>
    <trd lng="ca">taronja</trd>
    <trd lng="fy">oranje</trd>
    <trdgrp lng="id">
      <trd>jingga</trd>,
      <trd>oranye</trd>
    </trdgrp>
    <trd lng="io">oranjea</trd>
    <trd lng="ja">&#12458;&#12524;&#12531;&#12472;&#33394;&#12398;
    <pr>&#12362;&#12428;&#12435;&#12376;&#12356;&#12429;&#12398;</pr></trd>
    <trd lng="nl">oranje<klr tip="ind"> (bn.)</klr></trd>
  </snc>
  <trdgrp lng="be">
    <trd>&c_a;&c_r;&c_a;&c_n;&c_zh;&c_a;&c_v;&c_y;</trd>,
    <trd>&c_p;&c_a;&c_m;&c_a;&c_r;&c_a;&c_n;&c_ch;&c_a;&c_v;&c_y;</trd>
  </trdgrp>
  <trd lng="en">orange</trd>
  <trd lng="pl">pomara&nacute;czowy</trd>
  <trd lng="ro">oranj</trd>
  <trdgrp lng="uk">
    <trd>&c_p;&c_o;&c_m;&c_a;&c_r;&c_a;&c_n;&c_ch;&c_je;&c_v;&c_i;&c_j;</trd>,
    <trd>&c_a;&c_p;&c_je;&c_l;&c_mol;&c_s;&c_i;&c_n;&c_o;&c_v;&c_i;&c_j;</trd>
  </trdgrp>
  <trdgrp lng="zh">
    <trd>&#32249; <pr>t&iacute;</pr></trd>,
    <trd>&#32519; <pr>t&iacute;</pr></trd>,
    <trd>&#27224;&#32005; <pr>j&uacute;h&oacute;ng</pr></trd>,
    <trd>&#27224;&#32418; <pr>j&uacute;h&oacute;ng</pr></trd>
  </trdgrp>
</drv>

<drv mrk="orangx.0arbo">
  <kap><tld/>arbo, <var><kap><tld/>ujo</kap></var></kap>
  <snc mrk="orangx.0arbo.BOT">
    <uzo tip="fak">BOT</uzo>
    <dif>
      Specio de <ref tip="super" cel="citrus.0o">citruso</ref>
      (<trd lng="la">Citrus aurantium</trd>).
    </dif>
  </snc>
  <trd lng="be">&c_a;&c_p;&c_e;&c_l;&c_mol;&c_s;&c_ib;&c_n;&c_a;&c_v;&c_a;&c_je;
  &c_d;&c_r;&c_e;&c_v;&c_a;</trd>
  <trdgrp lng="br">
    <trd>gwezenn-ora&ntilde;jez</trd>,
    <trd>ora&ntilde;jezenn<klr tip="ind"> (gwezenn)</klr></trd>
  </trdgrp>
  <trd lng="ca">taronger</trd>
  <trdgrp lng="de">
    <trd>Apfelsinenbaum</trd>,
    <trd>Orangenbaum</trd>
  </trdgrp>
  <trd lng="el">&pi;&omikron;&rho;&tau;&omikron;&kappa;&alfa;&lambda;&jota;&alfa_ton;</trd>
  <trd lng="en">orange tree</trd>
  <trd lng="fr">oranger</trd>
  <trdgrp lng="fy">
    <trd>sinesappelbeam</trd>,
    <trd>oranjebeam</trd>
  </trdgrp>
  <trd lng="hu">narancsfa</trd>
  <trd lng="id">pohon jeruk</trd>
  <trd lng="ja">&#12458;&#12524;&#12531;&#12472;&#12398;&#26408;
  <pr>&#12362;&#12428;&#12435;&#12376;&#12398;&#12365;</pr></trd>
  <trdgrp lng="nl">
    <trd>sinaasappelboom</trd>,
    <trd>appelsienboom</trd>,
    <trd>oranjeboom</trd>
  </trdgrp>
  <trd lng="pl">pomara&nacute;cza  <klr>(krzew)</klr></trd>
  <trd lng="pt">laranjeira</trd>
  <trd lng="ro">portocala  <klr>(tufa)</klr></trd>
  <trd lng="ru">&c_a;&c_p;&c_je;&c_l;&c_mol;&c_s;&c_i;&c_n;&c_n;&c_o;&c_je;
  &c_d;&c_je;&c_r;&c_je;&c_v;&c_o;</trd>
  <trd lng="sv">apelsintr&auml;d</trd>
  <trdgrp lng="uk">
    <trd>&c_p;&c_o;&c_m;&c_a;&c_r;&c_a;&c_n;&c_ch;&c_a;</trd>,
    <trd>&c_a;&c_p;&c_je;&c_l;&c_mol;&c_s;&c_i;&c_n;(&c_o;&c_v;&c_je; &c_d;&c_je;&c_r;&c_je;&c_v;&c_o;)</trd>
  </trdgrp>
  <trdgrp lng="zh">
    <trd>&#27224;&#26641; <pr>j&uacute;sh&ugrave;</pr></trd>,
    <trd>&#27224;&#27193; <pr>j&uacute;sh&ugrave;</pr></trd>
  </trdgrp>
</drv>

<drv mrk="orangx.0kolora">
  <kap><tld/>kolora</kap>
  <snc>
    <dif>
      Havanta koloron mezan inter ru&gcirc;o kaj flavo; <ref tip="sin" cel="orangx.0a"><tld/>a</ref>.
    </dif>
  </snc>
  <trdgrp lng="be">
    <trd>&c_a;&c_r;&c_a;&c_n;&c_zh;&c_a;&c_v;&c_y;</trd>,
    <trd>&c_p;&c_a;&c_m;&c_a;&c_r;&c_a;&c_n;&c_ch;&c_a;&c_v;&c_y;</trd>
  </trdgrp>
  <trd lng="bo">&#3939;&#3954;&#3851;&#3933;&#3908;&#3851;</trd>
  <trdgrp lng="ca">
    <trd>(de color) <ind>taronja</ind></trd>,
    <trd>carabassa</trd>,
    <trd>carbassa</trd>
  </trdgrp>
  <trd lng="en">orange</trd>
  <trd lng="fy">oranje</trd>
  <trdgrp lng="id">
    <trd>jingga</trd>,
    <trd>oranye</trd>
  </trdgrp>
  <trd lng="io">oranjea</trd>
  <trd lng="ja">&#12458;&#12524;&#12531;&#12472;&#33394;&#12398;
  <pr>&#12362;&#12428;&#12435;&#12376;&#12356;&#12429;&#12398;</pr></trd>
  <trd lng="nl">oranje<klr tip="ind"> (bn.)</klr></trd>
  <trd lng="pl">pomara&nacute;czowy</trd>
  <trdgrp lng="ro">
    <trd>portocal</trd>,
    <trd>portocal&abreve;</trd>
  </trdgrp>
  <trdgrp lng="uk">
    <trd>&c_p;&c_o;&c_m;&c_a;&c_r;&c_a;&c_n;&c_ch;&c_je;&c_v;&c_i;&c_j;</trd>,
    <trd>&c_zh;&c_o;&c_v;&c_t;&c_o;&c_g;&c_a;&c_r;&c_ja;&c_ch;&c_i;&c_j;</trd>
  </trdgrp>
  <trdgrp lng="zh">
    <trd>&#32249; <pr>t&iacute;</pr></trd>,
    <trd>&#32519; <pr>t&iacute;</pr></trd>,
    <trd>&#27224;&#32005; <pr>j&uacute;h&oacute;ng</pr></trd>,
    <trd>&#27224;&#32418; <pr>j&uacute;h&oacute;ng</pr></trd>
  </trdgrp>
</drv>

<drv mrk="orangx.0koloro">
  <kap><tld/>koloro</kap>
  <snc>
    <dif>
      <ref tip="lst" cel="kolor.0o.propre" lst="voko:koloroj">Koloro</ref> de <tld/>o, meza inter
      ru&gcirc;o kaj
      flavo.
    </dif>
  </snc>
  <trdgrp lng="be">
    <trd>&c_a;&c_r;&c_a;&c_n;&c_zh;&c_a;&c_v;&c_y; &c_k;&c_o;&c_l;&c_je;&c_r;</trd>,
    <trd>&c_p;&c_a;&c_m;&c_a;&c_r;&c_a;&c_n;&c_ch;&c_a;&c_v;&c_y; &c_k;&c_o;&c_l;&c_je;&c_r;</trd>
  </trdgrp>
  <trdgrp lng="ca">
    <trd>taronja<klr tip="amb"> (color)</klr></trd>,
    <trd>carabassa<klr tip="amb"> (color)</klr></trd>,
    <trd>carbassa<klr tip="amb"> (color)</klr></trd>
  </trdgrp>
  <trd lng="en">orange</trd>
  <trd lng="fy">oranje</trd>
  <trdgrp lng="id">
    <trd>jingga</trd>,
    <trd>oranye</trd>
  </trdgrp>
  <trd lng="ja">&#12458;&#12524;&#12531;&#12472;&#33394; <pr>&#12362;&#12428;&#12435;&#12376;&#12356;&#12429;</pr></trd>
  <trd lng="nl">oranje<klr tip="ind"> (zn.)</klr></trd>
  <trdgrp lng="pl">
    <trd>pomara&nacute;czowy</trd>,
    <trd>oran&zdot;</trd>
  </trdgrp>
  <trd lng="ro">portocaliu</trd>
  <trdgrp lng="zh">
    <trd>&#27225; <pr>ch&eacute;ng</pr></trd>,
    <trd>&#27224;&#32005; <pr>j&uacute;h&oacute;ng</pr></trd>,
    <trd>&#27224;&#32418; <pr>j&uacute;h&oacute;ng</pr></trd>
  </trdgrp>
</drv>
</art>
