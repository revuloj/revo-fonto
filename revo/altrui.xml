<?xml version="1.0"?>
<!DOCTYPE vortaro SYSTEM "../dtd/vokoxml.dtd">
<vortaro>
<art mrk="$Id: altrui.xml,v 1.33 2026/05/14 20:01:28 revo Exp $">
<kap>
  <rad>altruism</rad>/o <fnt><bib>PVEF</bib></fnt>
</kap>
<drv mrk="altrui.0o">
  <kap><tld/>o<fnt><bib>PV</bib></fnt></kap>
  <snc mrk="altrui.0o.FIL">
    <uzo tip="fak">FIL</uzo>
    <dif>
      <ref tip="dif" cel="ego.mal0ismo.PSI">Malegoismo</ref>:
      <ekz>
        estas homoj, kiuj bonfaras pro egoismo <klr>[&#x2026;]</klr> kaj estas personoj, kiuj
        bonfaras pro nura <tld/>o
        <fnt>
          <bib>IdO</bib>
          <lok>Unua Parto</lok>
        </fnt>;
      </ekz>
      <ekz>
        traduki majstroverkon el la kulturo de alia lando, kiel faris ekzemple <nom>Kalocsay</nom>,
        estas anka&ubreve; nobla supernacieca <tld/>o
        <fnt>
          <bib>Plumamikoj</bib>
          <lok>Tradukoj</lok>
        </fnt>;
      </ekz>
      <ekz>
        la projekto estas ruza merkatika instrumento, per kiu okcidentaj industri-landoj
        volas akapari la merkaton de la tria mondo sub mantelo de <tld/>o
        <fnt>
          <bib>Monato</bib>
          <aut>Stefan Maul</aut>
          <vrk><url ref="&Monato;/2006/008867.php"
              >Primitive</url></vrk>
          <lok>2006</lok>
        </fnt>.
      </ekz>
    </dif>
  </snc>
  <rim>
    La&ubreve; <fnt><bib>BL</bib></fnt>: Prefere diru <ke>bonfarado</ke>.
  </rim>

  <ref tip="vid" cel="altruist.0o">altruisto</ref>
  <trd lng="be">&c_a;&c_l;&c_mol;&c_t;&c_r;&c_u;&c_ib;&c_z;&c_m;</trd>
  <trd lng="bg">&c_a;&c_l;&c_t;&c_r;&c_u;&c_i;&c_z;&c_malmol;&c_m;</trd>
  <trdgrp lng="de">
    <trd>Altruismus</trd>,
    <trd>Selbstlosigkeit</trd>,
    <trd>Uneigenn&uuml;tzigkeit</trd>
  </trdgrp>
  <trd lng="en">altruism</trd>
  <trd lng="es">altruismo</trd>
  <trdgrp lng="fa">
    <trd>&a_n;&a_w;&a_ayn;&zwnj;&a_d;&a_w;&a_s;&a_t;&f_y;</trd>,
    <trd>&a_A;&a_z;&a_kh;&a_w;&a_d;&f_g;&a_dh;&a_sh;&a_t;&f_g;&f_y;</trd>
  </trdgrp>
  <trd lng="fr">altruisme</trd>
  <trd lng="he">&alef;&lamed;&tet;&resh;&vav;&alef;&yod;&zayin;&fmem;</trd>
  <trdgrp lng="hu">
    <trd>&ouml;nzetlens&eacute;g</trd>,
    <trd>altruizmus</trd>
  </trdgrp>
  <trd lng="it">altruismo</trd>
  <trd lng="ja">&#x5229;&#x4ED6;&#x4E3B;&#x7FA9;  <pr>&#x308A;&#x305F;&#x3057;&#x3085;&#x304E;</pr></trd>
  <trd lng="nl">altru&iuml;sme</trd>
  <trd lng="pl">altruizm</trd>
  <trd lng="ru">&c_a;&c_l;&c_mol;&c_t;&c_r;&c_u;&c_i;&c_z;&c_m;</trd>
  <trd lng="sk">altruizmus</trd>
  <trd lng="uk">&c_a;&c_l;&c_mol;&c_t;&c_r;&c_u;&c_ji;&c_z;&c_m; (&c_b;&c_je;&c_z;&c_k;&c_o;&c_r;&c_i;&c_s;&c_l;&c_i;&c_v;&c_je; &c_p;&c_ib;&c_k;&c_l;&c_u;&c_v;&c_a;&c_n;&c_n;&c_ja; &c_p;&c_r;&c_o; &c_b;&c_l;&c_a;&c_g;&c_o; &c_ib;&c_n;&c_sh;&c_i;&c_h;)</trd>
</drv>

<drv mrk="altrui.0a">
  <kap><tld/>a</kap>
  <snc mrk="altrui.0a.FIL">
    <dif>
      Mal<ref tip="ant" cel="ego.0isma">egoisma</ref>:
      <ekz>
        <tld/>a etiko kaj agado senprofitemo
        <fnt>
          <bib>Kon11</bib>
          <lok>&Ccirc;efartikolo</lok>
        </fnt>;
      </ekz>
      <ekz>
        <klr>[la letero al Borovko]</klr> prezentis la a&ubreve;toron de
        Esperanto kiel <tld/>an batalanton por interkompreni&gcirc;o
        trans &ccirc;iujn naciajn antagonismojn
        <fnt><bib>Dan&gcirc;Lng</bib>, <lok>1.1</lok></fnt>.
      </ekz>
    </dif>
    <refgrp tip="vid">
      <ref cel="modest.0a.konduto">modesta<sncref/></ref>,
      <ref cel="profit.ne0ema">neprofitema</ref>,
      <ref cel="don.sin0a">sindona</ref>
    </refgrp>
    <trdgrp lng="zh">
      <trd>&#x4E0D;&#x9867;&#x81EA;&#x5DF1; <pr>b&ugrave;g&ugrave;z&igrave;j&#x1D0;</pr></trd>,
      <trd>&#x4E0D;&#x987E;&#x81EA;&#x5DF1; <pr>b&ugrave;g&ugrave;z&igrave;j&#x1D0;</pr></trd>,
      <trd>&#x4E0D;&#x8B00;&#x53D6;&#x79C1;&#x5229; <pr>b&ugrave;m&oacute;uq&#x1D4;s&imacron;l&igrave;</pr></trd>,
      <trd>&#x4E0D;&#x8C0B;&#x53D6;&#x79C1;&#x5229; <pr>b&ugrave;m&oacute;uq&#x1D4;s&imacron;l&igrave;</pr></trd>,
      <trd>&#x5229;&#x4ED6; <pr>l&igrave;t&amacron;</pr></trd>
    </trdgrp>
  </snc>
  <trd lng="be">&c_a;&c_l;&c_mol;&c_t;&c_r;&c_u;&c_ib;&c_s;&c_t;&c_y;&c_ch;&c_n;&c_y;</trd>
  <trdgrp lng="cs">
    <trd>altruistick&yacute;</trd>,
    <trd>altruistn&iacute;</trd>,
    <trd>nesobeck&yacute;</trd>,
    <trd>nezi&scaron;tn&yacute;</trd>
  </trdgrp>
  <trdgrp lng="de">
    <trd>altruistisch</trd>,
    <trd>selbstlos</trd>,
    <trd>uneigenn&uuml;tzig</trd>
  </trdgrp>
  <trd lng="en">altruistic</trd>
  <trdgrp lng="fa">
    <trd>&a_n;&a_w;&a_ayn;&zwnj;&a_d;&a_w;&a_s;&a_t;</trd>,
    <trd>&a_A;&a_z;&a_kh;&a_w;&a_d;&f_g;&a_dh;&a_sh;&a_t;&a_h;</trd>,
    <trd>&a_A;&f_y;&a_th;&a_A;&a_r;&f_g;&a_r;</trd>,
    <trd>&a_f;&a_d;&a_A;&f_k;&a_A;&a_r;</trd>
  </trdgrp>
  <trd lng="fr">altruiste<klr tip="ind"> (adj.)</klr></trd>
  <trd lng="he">&alef;&lamed;&tet;&resh;&vav;&alef;&yod;&tet;&yod;</trd>
  <trd lng="it">altruistico</trd>
  <trd lng="ja">&#x5229;&#x4ED6;&#x7684;&#x306A;  <pr>&#x308A;&#x305F;&#x3066;&#x304D;&#x306A;</pr></trd>
  <trd lng="pl">altruistyczny</trd>
  <trd lng="ru">&c_a;&c_l;&c_mol;&c_t;&c_r;&c_u;&c_i;&c_s;&c_t;&c_i;&c_ch;&c_je;&c_s;&c_k;&c_i;&c_j;</trd>
  <trdgrp lng="sk">
    <trd>altruistick&yacute;</trd>,
    <trd>nesebeck&yacute;</trd>,
    <trd>nezi&scaron;tn&yacute;</trd>
  </trdgrp>
  <trd lng="uk">&c_a;&c_l;&c_mol;&c_t;&c_r;&c_u;&c_ji;&c_s;&c_t;&c_i;&c_ch;&c_n;&c_i;&c_j;</trd>
</drv>
</art>
