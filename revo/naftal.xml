<?xml version="1.0"?>
<!DOCTYPE vortaro SYSTEM "../dtd/vokoxml.dtd">
<vortaro>
<art mrk="$Id: naftal.xml,v 1.24 2026/05/15 09:26:37 revo Exp $">
<kap>
  <ofc>2</ofc>
  <rad>naftalin</rad>/o <fnt><bib>JED</bib></fnt>,
  <var><kap><rad var="en">naftalen</rad>/o <fnt><bib>PIV1</bib></fnt></kap></var>
</kap>
<drv mrk="naftal.0o">
  <kap><tld/>o</kap>
  <snc mrk="naftal.0o.KEM">
    <uzo tip="fak">KEM</uzo>
    <dif>
      Solida, blanka, forte odoranta karbonida substanco, elprenata el
      terkarba gudro, uzata kiel insekticido, en fabrikado de plastoj ktp.:
      <ekz>
        regis en tiu pendejo malagrabla odoro de <tld/>o
        <fnt><bib>KielAkvo</bib> <lok>1:3</lok></fnt>;
      </ekz>
      <ekz>
        la lo&gcirc;ejo plenas de la odoro de <tld var="en"/>o
        <fnt>
          <aut>F. Moln&aacute;r, trad. J. Horvath</aut>
          <vrk><url ref="https://verkoj.com/tradukistoj/jozefo-horvath/jocxjo_kpl.pdf">
          Jo&ccirc;jo kaj aliaj komedietoj</url></vrk>
          <lok>2025</lok>
        </fnt>.
      </ekz>
    </dif>
  </snc>
  <trd lng="be">&c_n;&c_a;&c_f;&c_t;&c_a;&c_l;&c_ib;&c_n;</trd>
  <trd lng="br">naftalin</trd>
  <trd lng="ca">naftalina</trd>
  <trdgrp lng="cs">
    <trd>naftalin</trd>,
    <trd>naftal&#xED;n</trd>
  </trdgrp>
  <trd lng="de">Naphthalin</trd>
  <trd lng="el">&ny;&alfa;&phi;&theta;&alfa;&lambda;&jota_ton;&ny;&eta;</trd>
  <trd lng="en">naphthalene</trd>
  <trd lng="es">naftalina</trd>
  <trd lng="fa">&a_n;&a_f;&a_t;&a_A;&a_l;&f_y;&a_n;</trd>
  <trd lng="fr">naphtaline</trd>
  <trd lng="hu">naftalin</trd>
  <trd lng="ja">&#x30CA;&#x30D5;&#x30BF;&#x30EA;&#x30F3;</trd>
  <trd lng="nl">naftaleen</trd>
  <trd lng="pl">naftalina</trd>
  <trd lng="pt">naftalina</trd>
  <trd lng="ru">&c_n;&c_a;&c_f;&c_t;&c_a;&c_l;&c_i;&c_n;</trd>
  <trd lng="sk">naftal&#xED;n</trd>
  <trd lng="tr">naftalin</trd>
  <trd lng="uk">&#x43D;&c_r;&#x43A;. &#x43D;&c_a;&c_f;&c_t;&c_a;&#x43B;&c_ib;&#x43D;</trd>
  <trd lng="zh">&#33816; <pr>n&#xE0;i</pr></trd>
</drv>
</art>
