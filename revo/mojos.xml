<kap>
    <rad>mojos</rad>/a
    <fnt><bib>Viki</bib></fnt>
</kap>
<drv mrk="mojos.0a">
  <kap><tld/>a</kap>
  <snc mrk="mojos.0a.junstila">
    <dif>
      Akronimo de
      <em>modernjunstila</em>, t.e. <ctl>mjs-a</ctl>; impresanta a&ubreve;
      pla&ccirc;anta al junuloj:
      <ekz>
        en <tld/>a etoso pasis Aktivula Renkonti&gcirc;o
        <fnt>
          <bib>Kon11</bib>
          <lok>Kvardek aktivuloj renkonti&gcirc;is en Dresdeno</lok>
        </fnt>;
      </ekz>
      <ekz>
        la nuna hiphopo estas ege elektronika kaj nun oni tre zorgeme klopodas fari
        <tld/>ajn sonbatojn
        <fnt>
          <bib>Kon11</bib>
          <lok>Intervjuo</lok>
        </fnt>;
      </ekz>
      <ekz>
        menciinda estas la <tld/>a &jcirc;urnalo La NASKa Fasko
        <fnt>
          <bib>LOdE</bib>, <lok>2013 N&deg;8-9 (226-227)</lok>
        </fnt>.
      </ekz>
    </dif>
    <refgrp tip="vid">
      <ref cel="legxer.0a.stilo">le&gcirc;era<sncref/></ref>,
      <ref cel="preten.sen0a">senpretenda</ref>,
      <ref cel="sxik.0a">&scirc;ika</ref>
    </refgrp>
    <trdgrp lng="en">
      <trd>trendy</trd>,
      <trd>hip</trd>
    </trdgrp>
    <trdgrp lng="ja">
      <trd>&#12514;&#12486;&#12427;</trd>,
      <trd>&#12452;&#12465;&#12390;&#12427;</trd>
    </trdgrp>
    <trdgrp lng="nl">
      <trd>hip</trd>,
      <trd>trendy</trd>,
      <trd>blits</trd>
    </trdgrp>
  </snc>
  <snc mrk="mojos.0a.pla&ccirc;a">
    <dif>
      Tre pla&ccirc;a kaj entuziasmiga:
      <ekz>
        profesiaj ludistoj kapablas flugi kaj poenti en nekredeble <tld/>aj manovroj
        <fnt>
          <aut>Jonas Marx</aut>
          <vrk>Kio estas Rocket League?</vrk>
          <bib>Kon11</bib>
        </fnt>;
      </ekz>
      <ekz>
        do kial lerni Esperanton? Mi ne scias. <ctl>Esperanto <tld/>as</ctl> ne estas argumento
        <fnt>
          <aut>Kl&aacute;ra Ertl</aut>
          <vrk>Kiel la koloro de miaj okuloj</vrk>
          <bib>Esperanto</bib>
          <lok>2014:2</lok>
        </fnt>;
      </ekz>
      <ekz>
        stranga tamen belsona lingvo, kiu havas <tld/>an nomon en la &ccirc;ina &mdash; la mondlingvo
        <fnt>
          <aut>Long Zhang</aut>
          <vrk>Robotiko en Esperanto</vrk>
          <bib>Esperanto</bib>
          <lok>2014:12</lok>
        </fnt>.
      </ekz>
    </dif>
    <refgrp tip="vid">
      <ref cel="bon.0a">bonega</ref>,
      <ref cel="acx.mal0a">mala&ccirc;a</ref>
    </refgrp>
    <trdgrp lng="ja">
      <trd>&#26684;&#22909;&#12356;&#12356; <pr>&#12363;&#12387;&#12371;&#12356;&#12356;</pr></trd>,
      <trd>&#12377;&#12372;&#12356;</trd>
    </trdgrp>
    <trdgrp lng="nl">
      <trd>gaaf</trd>,
      <trd>tof</trd>,
      <trd>te gek</trd>,
      <trd>kicken</trd>
    </trdgrp>
  </snc>
  <rim>
    La&ubreve; <fnt><bib>BL</bib></fnt>: Anka&ubreve; eblas diri <ke>modernjunstila</ke>, <ke>la&ubreve;moda</ke>,
    <ke>bonega</ke>, <ke>mala&ccirc;a</ke>, <ke>&scirc;atindega</ke>, <ke>bonuma</ke>.
  </rim>
  <trdgrp lng="be">
    <trd>&c_f;&c_a;&c_j;&c_n;&c_y;</trd>,
    <trd>&c_k;&c_r;&c_u;&c_t;&c_y;</trd>,
    <trd>&c_s;&c_u;&c_p;&c_e;&c_r;</trd>
  </trdgrp>
  <trdgrp lng="ca">
    <trd>s&uacute;per</trd>,
    <trd>genial</trd>,
    <trd>fant&agrave;stic</trd>,
    <trd>guai</trd>,
    <trd>xulo</trd>
  </trdgrp>
  <trdgrp lng="de">
    <trd>toll</trd>,
    <trd>genial</trd>,
    <trd>geil <klr tip="ind">(cool)</klr></trd>,
    <trd>abgefahren <klr tip="ind">(cool)</klr></trd>,
    <trd>angesagt <klr tip="ind">(cool)</klr></trd>,
    <trd><klr>(voll)</klr> krass <klr tip="ind">(cool)</klr></trd>,
    <trd><klr>(voll)</klr> schick <klr tip="ind">(cool)</klr></trd>,
    <trd>total in <klr tip="ind">(cool)</klr></trd>,
  </trdgrp>
  <trdgrp lng="en">
    <trd>cool</trd>,
    <trd>dope</trd>,
    <trd>based</trd>,
    <trd>rad</trd>,
    <trd>lit</trd>
  </trdgrp>
  <trdgrp lng="es">
    <trd>chulo</trd>,
    <trd>majo</trd>,
    <trd>genial</trd>
  </trdgrp>
  <trdgrp lng="fr">
    <trd>relax</trd>,
    <trd>sympa</trd>
  </trdgrp>
  <trd lng="nl">cool</trd>
  <trdgrp lng="pl">
    <trd>fajny</trd>,
    <trd>wspania&lstroke;y</trd>,
    <trd>&sacute;wietny</trd>,
    <trd>super</trd>,
    <trd>cool</trd>
  </trdgrp>
  <trdgrp lng="zh">
    <trd>&#20426; <pr>z&ugrave;n</pr></trd>,
    <trd>&#20248;&#31168;&#30340;&#19996;&#35199; <pr>y&omacron;uxi&ugrave;ded&omacron;ngxi</pr></trd>,
    <trd>&#20778;&#31168;&#30340;&#26481;&#35199; <pr>y&omacron;uxi&ugrave;ded&omacron;ngxi</pr></trd>,
    <trd>&#24102;&#24863; <pr>d&agrave;ig&#462;n</pr></trd>,
    <trd>&#24118;&#24863; <pr>d&agrave;ig&#462;n</pr></trd>,
    <trd>&#32102;&#21147; <pr>g&ecaron;il&igrave;</pr></trd>,
    <trd>&#32473;&#21147; <pr>g&ecaron;il&igrave;</pr></trd>,
    <trd>&#37239;&#25987; <pr>k&ugrave;b&igrave;</pr></trd>,
    <trd>&#37239;&#27609; <pr>k&ugrave;b&igrave;</pr></trd>
  </trdgrp>
</drv>

<drv mrk="mojos.0e">
  <kap><tld/>e</kap>
  <snc>
    <dif>
      En <tld/>a maniero:
      <ekz>
        tio sonas <tld/>e
        <fnt>
          <bib>Kon11</bib>
          <lok>La unua kaj mojosa. &Ccirc;eSKEJ!</lok>
        </fnt>!
      </ekz>
      <ekz>
        vetkura ludo en <tld/>e brila grafiko
        <fnt>
          <bib>Kon11</bib>
          <lok>Videoludoj</lok>
        </fnt>;
      </ekz>
      <ekz>
        en la Morta Maro <klr>[&#8230;]</klr> se oni provas subakvi&gcirc;i, la akvo tiras onin
        supren, <tld/>e &ccirc;u ne
        <fnt>
          <bib>Kon11</bib>
          <lok>Voja&gcirc;o</lok>
        </fnt>?
      </ekz>
      <ekz>
        &ccirc;u ne estus <tld/>e se ni havus nian propran monon
        <fnt>
          <bib>Kon11</bib>
          <lok>Cifereca mono:</lok>
        </fnt>?
      </ekz>
    </dif>
  </snc>
  <trdgrp lng="be">
    <trd>&c_f;&c_a;&c_j;&c_n;&c_a;</trd>,
    <trd>&c_k;&c_r;&c_u;&c_t;&c_a;</trd>,
    <trd>&c_s;&c_u;&c_p;&c_e;&c_r;</trd>
  </trdgrp>
  <trdgrp lng="de">
    <trd>cool</trd>,
    <trd>krass</trd>
  </trdgrp>
  <trdgrp lng="pl">
    <trd>wspaniale</trd>,
    <trd>&sacute;wietnie</trd>,
    <trd>super</trd>,
    <trd>cool</trd>
  </trdgrp>
</drv>

<drv mrk="mojos.0i">
  <kap><tld/>i</kap>
  <snc>
    <dif>
      Esti <tld/>a:
      <ekz>
        la kuireja koncerto simple <tld/>is
        <fnt>
          <bib>Kon11</bib>
          <lok>&Ccirc;u en kuirejo a&ubreve; sur podio? Kim mojosas &ccirc;ie!</lok>
        </fnt>;
      </ekz>
      <ekz>
        Esperanto lernindas, &ccirc;ar &gcirc;i <tld/>as
        <fnt>
          <bib>Kon11</bib>
          <lok>Sekvinda agado: la levi&gcirc;anta &leftquot;A&ubreve;roro&rightquot;</lok>
        </fnt>.
      </ekz>
    </dif>
  </snc>
  <trd lng="be">&c_b;&c_y;&c_c;&c_mol; <ind>&c_f;&c_a;&c_j;&c_n;&c_y;&c_m;</ind></trd>
  <trdgrp lng="de">
    <trd><ind>cool</ind> sein</trd>,
    <trd>abgehen <klr>(cool sein)</klr></trd>
  </trdgrp>
  <trd lng="en">be cool</trd>
  <trdgrp lng="pl">
    <trd>by&cacute; <ind>fajnym  <klr>(m&lstroke;odzie&zdot;owe)</klr></ind></trd>,
    <trd>by&cacute;  <ind>super</ind></trd>
  </trdgrp>
</drv>

<drv mrk="mojos.0eco">
  <kap><tld/>eco</kap>
  <snc>
    <dif>
      Stato de tio, kio estas <tld/>a:
      <ekz>
        <tld lit="M"/>eco kaj Muziko: Muzaiko!
      </ekz>
      <ekz>
        <nom>Juli&aacute;n Hern&aacute;ndez</nom> <klr>[&#8230;]</klr> per siaj profesieco <klr>[&#8230;]</klr> kaj samtempe
        vigleco, <tld/>eco, <klr>[&#8230;]</klr> &ccirc;iam tenis alte la lernemon
        <fnt>
          <bib>Kon11</bib>
          <lok>Nikaragvo: bona semo estis plantita (Po&oacute;r Veronika)</lok>
        </fnt>.
      </ekz>
    </dif>
  </snc>
  <trd lng="be">&c_c;&c_u;&c_d;&c_o;&c_w;&c_n;&c_a;&c_s;&c_mol;&c_c;&c_mol;</trd>
  <trd lng="de">Coolness</trd>
  <trd lng="en">coolness</trd>
  <trd lng="es">algo fant&aacute;stico</trd>
  <trd lng="nl">coolheid</trd>
  <trdgrp lng="pl">
    <trd>opanowanie</trd>,
    <trd>fantastyczno&sacute;&cacute;</trd>
  </trdgrp>
</drv>

<drv mrk="mojos.0ega">
  <kap><tld/>ega</kap>
  <snc>
    <dif>
      Tre <tld/>a:
    </dif>
    <ekz>
      en Montfort-sur-Meu mi spektis <tld/>egan teatra&jcirc;on en Esperanto verkitan kaj prezentitan de
      &ccirc;efe TEJO-a&gcirc;uloj
      <fnt>
        <aut>PO&Oacute;R Veronika</aut>
        <vrk>Pli-ol-unu-monata intensa esperantumado en Francio</vrk>
        <bib>Kon11</bib>
      </fnt>;
    </ekz>
    <ekz>
      kiam iu diras al mi nur ke mi estas <tld/>ega, mi ne scias kion konkretan mi faris por okazigi
      tiun kontenton
      <fnt>
        <aut>Guillaume Armide</aut>
        <vrk>Trans la ideoj de bono kaj malbono</vrk>
        <bib>Kon11</bib>
      </fnt>.
    </ekz>
    <ref tip="sin" cel="mojos.fek0a">fekmojosa</ref>
  </snc>
  <trdgrp lng="en">
    <trd>supercool</trd>,
    <trd>very cool</trd>,
    <trd>way cool</trd>
  </trdgrp>
  <trd lng="fr">super cool</trd>
  <trd lng="ja">&#36229;&#26684;&#22909;&#12356;&#12356; <pr>&#12385;&#12423;&#12358;&#12363;&#12387;&#12371;&#12356;&#12356;</pr></trd>
  <trd lng="nl">supercool</trd>
</drv>

<drv mrk="mojos.0ulo">
  <kap><tld/>ulo</kap>
  <snc>
    <dif>
      <tld lit="M"/>a homo.
    </dif>
  </snc>
  <trd lng="be">&c_k;&c_r;&c_u;&c_t;&c_y; &c_h;&c_l;&c_o;&c_p;&c_je;&c_c;</trd>
  <trd lng="de">cooler <ind>Typ</ind></trd>
  <trd lng="pl">spoko go&sacute;&cacute;</trd>
</drv>

<drv mrk="mojos.0ejo">
  <kap><tld/>ejo</kap>
  <snc>
    <dif>
      <tld lit="M"/>a renkontejo, renkonto, retpa&gcirc;o; junulejo:
      <ekz>
         MOJOsejo, alternativa semajno por gejunuloj
         <klr>(gejunula renkonto en kastelo Gresiljono)</klr>.
      </ekz>
    </dif>
  </snc>
  <trd lng="be">&c_k;&c_r;&c_u;&c_t;&c_o;&c_je; &c_m;&c_je;&c_s;&c_c;&c_a;</trd>
  <trd lng="de">coole <ind>Location</ind></trd>
  <trd lng="en">cool place</trd>
  <trd lng="es">sitio de reuni&oacute;n de moda</trd>
  <trdgrp lng="pl">
    <trd> modne miejsce  <ind>spotka&nacute;</ind></trd>,
    <trd>fajna miejsc&oacute;wka</trd>
  </trdgrp>
</drv>

<drv mrk="mojos.mal0a">
  <kap>mal<tld/>a</kap>
  <snc mrk="mojos.mal0a.maljunstila">
    <dif>
      Malpla&ccirc;anta a&ubreve; ne impresanta al junuloj:
      <ekz>
        la aran&gcirc;oj estas popularaj kaj tradiciaj, en perfekta <ctl>mal<tld/>a</ctl> stilo, sed bone
        plenumitaj kaj registritaj
        <fnt>
          <aut>Rogener Pavinski</aut>
          <vrk>Recenzoj: ko-diskoj</vrk>
          <bib>Kon11</bib>
        </fnt>.
      </ekz>
    </dif>
  </snc>
  <snc mrk="mojos.mal0a.malplacxa">
    <dif>
      Malpla&ccirc;a kaj ne entuziasmiga:
      <ekz>
        mi finis studi en Kopenhago en 2013, kaj post tio mi ne volis tuj komenci mal<tld/>an
        laboron, do mi kandidati&gcirc;is por esti TEJO-volontulo
        <fnt>
          <aut>Rogier Huurman</aut>
          <vrk>Intervjuo kun la nuna volontulo de TEJO</vrk>
          <bib>Kon11</bib>
        </fnt>.
      </ekz>
    </dif>
  </snc>
  <trdgrp lng="en">
    <trd>uncool</trd>,
    <trd>lame</trd>
  </trdgrp>
  <trdgrp lng="ja">
    <trd>&#12384;&#12373;&#12356;</trd>
    <trd>&#26684;&#22909;&#24746;&#12356; <pr>&#12363;&#12387;&#12371;&#12431;&#12427;&#12356;</pr></trd>
  </trdgrp>
</drv>

<drv mrk="mojos.fek0a">
  <kap>fek<tld/>a</kap>
  <uzo tip="stl">VULG</uzo>
  <snc>
    <dif>
      <ref tip="dif" cel="mojos.0ega"><tld lit="M"/>ega</ref>:
      <ekz>
         ne dubu ke en la malanta&ubreve;o pluraj ideoj-versioj aperas, pridiskutatas kaj konsideratas por
         kiel eble plej malaltigi la perdon kaj alporti al la mondo eventuale fek<tld/>an IJKon,
         kiun ni &ccirc;iuj deziras kaj sopiras
        <fnt>
          <aut>Stela Besenyei-Merge</aut>
          <vrk>Vi mankas al mi</vrk>
          <lok><url
          ref="https://esperanto-nederland.nl/wp-content/uploads/2023/09/Fenikso-de-2020-02-kunpremita.pdf">Fenikso,
          25-a jarkolekto numero 2</url>, pa&gcirc;o 26</lok>
        </fnt>;
      </ekz>
      <ekz>
        mi volas danci kaj iri nun al fek<tld/>a dancfesten'
        <fnt>
          <aut>Joop Kiefte</aut>
          <vrk><url ref="https://kantaro.ikso.net/la_polko_de_eva">La Polko de Eva</url></vrk>
        </fnt>.
      </ekz>
    </dif>
  </snc>
  <trdgrp lng="en">
    <trd>damn cool</trd>,
    <trd>freaking awesome</trd>
  </trdgrp>
  <trd lng="ja">&#12463;&#12477;&#12363;&#12387;&#12371;&#12356;&#12356;</trd>
</drv>

