  <trd lng="pl">ko&lstroke;o z&eogonek;bate</trd>
  <trdgrp lng="ru">
    <trd>&c_z;&c_u;&c_b;&c_ch;&c_a;&c_t;&c_o;&c_je; &c_k;&c_o;&c_l;&c_je;&c_s;&c_o;</trd>,
