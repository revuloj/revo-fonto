<drv mrk="rad.dent0o">
  <kap>dent<tld/>o</kap>
  <snc mrk="rad.dent0o.TEK">
    <uzo tip="fak">TEK</uzo>
    <dif>
      <ref tip="super" cel="rad.0o.TEK"><tld lit="R"/>o</ref>, kies
      rondo estas provizita per dentoj:
      <ekz>
        al iu krutega pinto de la Alpoj <klr>[&#8230;]</klr> oni konstruis dent<tld/>an
        fervojon
        <fnt>
          <bib>VaK</bib>
        </fnt>;
      </ekz>
      <ekz>
        la &scirc;ipo sube movi&gcirc;as sur dent<tld/>aj reloj
        <fnt>
          <bib>Mortul&Scirc;ip</bib>
        </fnt>;
      </ekz>
      <ekz>
        por la supreni&gcirc;o oni uzas nek dent<tld/>ojn, nek dentrelojn, sed zigzagojn kaj
        rondojn
        <fnt>
          <aut>Marta Sol&iacute;s</aut>
          <vrk><url ref="&Monato;/2005/008399.php">Unika fervojo en Andoj</url></vrk>
          <bib>Monato</bib>
          <lok>2005/04, p. 20</lok>
        </fnt>;
      </ekz>
      <ekz>
        <uzo tip="stl">FIG</uzo>
        &ccirc;iu homo havas potencialon esti valora ano de la socio, tamen dume oni estas
        dent<tld/>oj en sistemo
        <fnt>
          <aut>Evgeni Georgiev</aut>
          <vrk><url ref="&Monato;/2012/010826.php">Piratoj hoj!</url></vrk>
          <bib>Monato</bib>
          <lok>2012/10, p. 10</lok>
        </fnt>.
      </ekz>
    </dif>
  </snc>
  <trd lng="be">&c_z;&c_u;&c_b;&c_ch;&c_a;&c_s;&c_t;&c_a;&c_je; &c_k;&c_o;&c_l;&c_a;</trd>
