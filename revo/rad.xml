<drv mrk="rad.spekto0ego">
  <kap>spekto<tld/>ego</kap>
  <snc mrk="rad.spekto0ego.SPO">
    <uzo tip="fak">SPO</uzo>
    <dif>
      granda staranta <ref tip="super" cel="rad.0o.TEK"><tld/>o</ref> en
      amuzparko, kiu turnas se&gcirc;ojn a&ubreve; vagonetojn, vidigante al la
      sursidantoj la &ccirc;irka&ubreve;a&jcirc;on:
      <ekz>
        tie trovi&gcirc;is ru&gcirc;a malgranda spekto-<tld/>ego el a&ccirc;aj lignoj,
        bambuoj kaj &scirc;nuroj
        <fnt><bib>HomojMan&gcirc;antaj</bib>, <lok>&leftquot;man&gcirc;i rubman&gcirc;a&jcirc;on&rightquot;, p.
        16a</lok></fnt>;
      </ekz>
      <ekz>
        alloga&jcirc;oj estas krom spekto<tld/>ego kaj onda fervojo ofte teatroprezentoj
        <fnt>
          <vrk><url ref="&Viki;/Amuzparko">Amuzparko - Vikipedio</url></vrk>
        </fnt>.
      </ekz>
    </dif>
  </snc>
  <trd lng="be">&c_k;&c_o;&c_l;&c_a; &c_a;&c_g;&c_l;&c_ja;&c_d;&c_u;</trd>
