  <trd lng="ja">&#12399;&#12378;&#12415;&#36554;  <pr>&#12399;&#12378;&#12415;&#12375;&#12419;</pr></trd>
  <trd lng="pl">ko&lstroke;o zamachowe</trd>
  <trd lng="ru">&c_m;&c_a;&c_h;&c_o;&c_v;&c_i;&c_k;</trd>
