<drv mrk="rad.sxpin0o">
  <kap>
    &scirc;pin<tld/>o
  </kap>
  <snc mrk="rad.sxpin0o.TEKS">
    <uzo tip="fak">TEKS</uzo>
    <dif>
      La <tld/>o de <ref tip="malprt" cel="sxpin.rad0ilo"><tld/>&scirc;pinilo</ref>,
      metonimie anka&ubreve; la tuta aparato:
      <ekz>
        la maljunulino sidis en sia domo kaj turnis &scirc;pin<tld/>on
        <fnt>
          <bib>ElektFab</bib>
          <lok>Pa&scirc;tistino de anseroj apud puto</lok>
        </fnt>;
      </ekz>
      <ekz>
        festofajroj en la formo de &scirc;pin<tld/>o
        <fnt>
          <aut>Raita Pyh&auml;l&auml;</aut>
          <vrk><url ref="&Monato;/2017/011877.php">Finnlando &#8208;
          Somermeza festo en Seurasaari</url></vrk>
          <bib>Monato</bib>
          <lok>2017/06, p. 24</lok>
        </fnt>;
      </ekz>
      <ekz>
        kaverna fajrejo kaj &scirc;pin<tld/>o, &ccirc;e kiu klinita oldulino <klr>[&#8230;]</klr> sidis
        dorse al mi, silente &scirc;pinante
        <fnt>
          <aut>Sonja Lang</aut>
          <vrk>La Soleno</vrk>
        </fnt>.
      </ekz>
    </dif>
  </snc>
    <trd lng="be">&c_k;&c_o;&c_l;&c_a; &c_k;&c_a;&c_l;&c_a;&c_w;&c_r;&c_o;&c_t;&c_a;</trd>
