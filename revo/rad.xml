<drv mrk="rad.0aro">
  <kap><tld/>aro</kap>
  <snc mrk="rad.0aro.TEK">
    <uzo tip="fak">TEK</uzo>
    <dif>
      Tuto de la <ref tip="prt" cel="rad.0o.TEK"><tld/>oj</ref>
      funkciigantaj aparaton:
    </dif>
    <subsnc mrk="rad.0aro.veturilaj">
      <uzo tip="fak">FER</uzo><uzo tip="fak">AUT</uzo>
      <dif>
        &Ccirc;iuj <tld/>oj kune, sur kiuj movi&gcirc;as veturilo.
      </dif>
      <trdgrp lng="de">
        <trd>Radsatz</trd>,
        <trd>Fahrwerk</trd>
      </trdgrp>
    <trdgrp lng="id">
      <trd>set roda</trd>,
      <trd>sasis</trd>
    </trdgrp>
    </subsnc>
    <subsnc mrk="rad.0aro.transmisia">
      <dif>
        &Ccirc;iuj <tld/>oj de <ref tip="malprt" cel="transmisi.0ilo">transmisiilo</ref>,
        horlo&gcirc;o ktp:
        <ekz>
          &ccirc;u vi devas movi viajn krurojn per <tld/>aroj
          <fnt>
            <aut>Michael Ende, trad. Wolfram Diestel</aut>
            <vrk>La Sen&ccirc;esa Rakonto</vrk>
            <lok>La Urbo de Imperiestroj</lok>
          </fnt>?
        </ekz>
        <ekz>
          <uzo tip="stl">FIG</uzo>
          &jcirc;eti nur sableron en la <tld/>aron de la financa spekulado
          <fnt>
            <bib>MD11</bib>
            <vrk>Tri jarojn post la financa kra&scirc;o</vrk>
          </fnt>;
        </ekz>
        <ekz>
          <uzo tip="stl">FIG</uzo>
          la sekreta <tld/>aro de la vivo
          <fnt>
            <bib>MD05</bib>
            <vrk>Henry Ford, inspirinto de Adolf Hitler</vrk>
          </fnt>.
        </ekz>
      </dif>
      <trdgrp lng="de">
        <trd>Getriebe</trd>,
        <trd>R&auml;derwerk</trd>
      </trdgrp>
    <trd lng="id">roda gigi</trd>
    </subsnc>
  </snc>
  <ref tip="hom" cel="radar.0o">radaro</ref>
  <trdgrp lng="be">
    <trd>&c_k;&c_o;&c_l;&c_a;&c_v;&c_y; &c_m;&c_e;&c_h;&c_a;&c_n;&c_ib;&c_z;&c_m;</trd>,
    <trd>&c_k;&c_o;&c_l;&c_y; <klr>(&c_u;&c_s;&c_je; &c_w;
    &c_t;&c_r;&c_a;&c_n;&c_s;&c_p;&c_a;&c_r;&c_t;&c_n;&c_y;&c_m;
    &c_s;&c_r;&c_o;&c_d;&c_k;&c_u;)</klr></trd>
  </trdgrp>
  <trdgrp lng="ca">
    <trd>conjunt de rodes<baz>roda</baz></trd>,
    <trd>engranatge</trd>
  </trdgrp>
  <trdgrp lng="cs">
    <trd>radar</trd>,
    <trd>radiolok&aacute;tor</trd>
  </trdgrp>
  <trd lng="fr">rouage</trd>
  <trdgrp lng="hu">
    <trd>hajt&oacute;m&udblac;</trd>,
    <trd>ker&eacute;khajt&aacute;s</trd>
  </trdgrp>
  <trd lng="nl">raderwerk</trd>
  <trd lng="pl">mechanizm z<ind> k&oacute;&lstroke;</ind> z&eogonek;batych</trd>
  <trdgrp lng="ru">
    <trd>&c_s;&c_i;&c_s;&c_t;&c_je;&c_m;&c_a; <ind>&c_k;&c_o;&c_l;&c_jo;&c_s;</ind></trd>,
    <trd>&c_k;&c_o;&c_l;&c_jo;&c_s;&c_n;&c_y;&c_j; &c_m;&c_je;&c_h;&c_a;&c_n;&c_i;&c_z;&c_m;</trd>
  </trdgrp>
  <trdgrp lng="sk">
    <trd>radar</trd>,
    <trd>r&aacute;diolok&aacute;tor</trd>
  </trdgrp>
  <trdgrp lng="uk">
    <trd>&c_r;&c_a;&c_d;&c_ib;&c_o;&c_l;&c_o;&c_k;&c_a;&c_t;&c_o;&c_r;</trd>,
    <trd>&c_r;&c_a;&c_d;&c_a;&c_r;</trd>
  </trdgrp>
</drv>

<drv mrk="rad.0umi">
  <kap><tld/>umi</kap>
  <gra><vspec>tr</vspec></gra>
  <snc mrk="rad.0umi.KOMUNE">
    <dif>
      Torture <ref tip="super" cel="mort.0igi.malvivigi">mortigi</ref>
      iun, rompante al li membrojn kaj lasante lin ku&scirc;i sur <tld/>o:
      <ekz>
        li estis <tld/>umita sur la &ccirc;efa placo en septembro 1602
        <fnt>
          <vrk><url ref="&Viki;/Douarnenez">Douarnenez -
          Vikipedio</url></vrk>
        </fnt>;
      </ekz>
      <ekz>
        la reprezentantoj de rezistmovado estis ekzekutitaj (unu senkapigita per
        lignotabulo kaj la alia <tld/>umita)
        <fnt>
          <bib>Viki</bib>
          <lok><url ref="https://eo.wikipedia.org/?curid=37537">Venceslao la 1-a
          (Bohemio)</url></lok>
        </fnt>.
      </ekz>
    </dif>
  </snc>
  <trd lng="be">&c_k;&c_a;&c_l;&c_je;&c_s;&c_a;&c_v;&c_a;&c_c;&c_mol;</trd>
  <trd lng="ca">enrodar</trd>
  <trdgrp lng="cs">
    <trd>l&aacute;mat kolem</trd>,
    <trd>mu&ccaron;it vpl&eacute;t&aacute;n&iacute;m do kola</trd>,
    <trd>umu&ccaron;it vpleten&iacute;m do kola</trd>
  </trdgrp>
  <trd lng="de">r&auml;dern</trd>
  <trdgrp lng="fr">
    <trd>rouer<klr tip="ind"> (supplicier)</klr></trd>,
    <trd>faire subir le supplice de la <ind>roue</ind></trd>
  </trdgrp>
  <trd lng="hu">ker&eacute;kbe t&ouml;r</trd>
  <trd lng="id"><baz>hukum</baz>menghukum dgn roda</trd>
  <trd lng="ja">&#36554;&#35010;&#12365;&#12398;&#21009;&#12395;&#20966;&#12377;&#12427;
  <pr>&#12375;&#12419;&#12373;&#12365;&#12398;&#12369;&#12356;&#12395;&#12375;&#12423;&#12377;&#12427;</pr></trd>
  <trd lng="nl">radbraken</trd>
  <trd lng="pl">ko&lstroke;em &lstroke;ama&cacute; </trd>
  <trd lng="ru">&c_k;&c_o;&c_l;&c_je;&c_s;&c_o;&c_v;&c_a;&c_t;&c_mol;
  <klr>(&c_k;&c_a;&c_z;&c_n;&c_i;&c_t;&c_mol;)</klr></trd>
  <trd lng="sk">l&aacute;ma&tcaron; v kolese</trd>
  <trd lng="uk">&c_k;&c_o;&c_l;&c_je;&c_s;&c_u;&c_v;&c_a;&c_t;&c_i;</trd>
</drv>

<drv mrk="rad.0radio">
  <kap><tld/>radio</kap>
  <snc mrk="rad.0radio.TEK">
    <uzo tip="fak">TEK</uzo>
    <dif>
      <ref tip="super" cel="radi.0o.discelanta">Radio</ref> de <tld/>o;
      <ref tip="sin" cel="spok.0o">spoko</ref>:
      <ekz>
        kiel la aran&gcirc;o de <tld/>oj de veturilo: iliaj aksoj kaj
        <ref tip="prt" cel="aks.0ingo">aksingo</ref>j kaj
        <tld/>radioj kaj <tld/>rondoj, &ccirc;io estis fandita
        <fnt>
          <bib>MT</bib>
          <lok>I. Re&gcirc;oj 7:33</lok>
        </fnt>;
      </ekz>
      <ekz>
        kial la diaro de vi <klr>[&#8230;]</klr> ne
        rompas en pecetojn la radiojn de via <tld/>o
        <fnt>
          <bib>Hamlet</bib>
        </fnt>!
      </ekz>
    </dif>
  </snc>
  <trd lng="be">&c_s;&c_mol;&c_p;&c_ib;&c_c;&c_a;</trd>
  <trdgrp lng="ca">
    <trd>raig</trd>,
    <trd>radi</trd>
  </trdgrp>
  <trdgrp lng="cs">
    <trd>louko&tcaron;</trd>,
    <trd>paprsek kola</trd>
  </trdgrp>
  <trd lng="de">Speiche</trd>
  <trd lng="fr">rayon<klr tip="ind"> (de roue)</klr></trd>
  <trd lng="hu">k&uuml;ll&odblac;</trd>
  <trdgrp lng="id">
    <trd>jari-jari</trd>,
    <trd>ruji-ruji</trd>,
    <trd>radius</trd>
  </trdgrp>
  <trdgrp lng="ja">
    <trd>&#12473;&#12509;&#12540;&#12463;</trd>,
    <trd>&#12420;</trd>
  </trdgrp>
  <trd lng="nl">spaak</trd>
  <trd lng="pl">szprycha</trd>
  <trd lng="ru">&c_s;&c_p;&c_i;&c_c;&c_a;</trd>
  <trd lng="sk">spica</trd>
  <trdgrp lng="zh">
    <trd>&#36667; <pr>f&uacute;</pr></trd>,
    <trd>&#36752; <pr>f&uacute;</pr></trd>,
    <trd>&#25376;&#39592; <pr>n&aacute;og&#468;</pr></trd>,
    <trd>&#25747;&#39592; <pr>n&aacute;og&#468;</pr></trd>,
    <trd>&#36554;&#26781; <pr>ch&emacron;ti&aacute;o</pr></trd>,
    <trd>&#36710;&#26465; <pr>ch&emacron;ti&aacute;o</pr></trd>
  </trdgrp>
</drv>

<drv mrk="rad.0rondo">
  <kap><tld/>rondo</kap>
  <snc mrk="rad.0rondo.TEK">
    <uzo tip="fak">TEK</uzo>
    <dif>
      Cirkla ekstera parto de <ref tip="super" cel="rad.0o.TEK"><tld/>o</ref>:
      <ekz>
        iliaj <tld/>rondoj estis altaj
        <fnt>
          <bib>MT</bib>
          <lok>Je&hcirc;ezkel 1:18</lok>
        </fnt>;
      </ekz>
      <ekz>
        cikloido estas la kurbo difinita per <klr>[&#8230;]</klr> punktoj sur la <tld/>rondo
        de cirklo ruli&gcirc;anta la&ubreve; rekto
        <fnt>
          <bib>Viki</bib>
          <lok><url ref="https://eo.wikipedia.org/?curid=105750">Cikloido</url></lok>
        </fnt>.
      </ekz>
    </dif>
    <refgrp tip="vid">
      <ref cel="nab.0o.TEK">nabo</ref>,
      <ref cel="ring.rad0o"><tld/>ringo</ref>
    </refgrp>
  </snc>
