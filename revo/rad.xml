<drv mrk="rad.0o">
  <kap><ofc>*</ofc><tld/>o</kap>
  <snc mrk="rad.0o.TEK">
    <uzo tip="fak">TEK</uzo>
    <dif>
      Ronda <ref tip="super" cel="disk.0o">disko</ref> turni&gcirc;anta &ccirc;irka&ubreve; centra <ref tip="prt"
      cel="aks.0o.TEK">akso</ref>:
      <ekz>
        li falis sub la <tld/>ojn de veturanta vagonaro
        <fnt>
          <bib>F</bib>
          <lok>&FE; 39</lok>
        </fnt>;
      </ekz>
      <ekz>
        la sonado de bruantaj <tld/>oj
        <fnt>
          <bib>MT</bib>
          <lok>Na&hcirc;um 3:2</lok>
        </fnt>;
      </ekz>
      <ekz>
        la veturilo preska&ubreve; sensone rulas, &ccirc;ar la <tld/>oj estas <klr>[&#8230;]</klr> vestitaj
        per ka&ubreve;&ccirc;ukaj ringoj
        <fnt>
          <bib>Voja&gcirc;Imp</bib>
        </fnt>;
      </ekz>
      <ekz>
        la <tld/>oj turni&gcirc;as la &scirc;oveliloj venkas la kontra&ubreve;staron de la akvo, la &scirc;ipo
        veturas
        <fnt>
          <bib>Fab3</bib>
          <lok>Dorna vojo de la honoro</lok>
        </fnt>;
      </ekz>
      <ekz>
        <klr>[tie]</klr> trovi&gcirc;is granda <tld/>o, metita sur horizontala akso, kun multo da
        malgrandaj siteloj sur la &ccirc;irka&ubreve;o
        <fnt>
          <bib>Far3</bib>
          <lok>&Ccirc;apitro XI</lok>
        </fnt>;
      </ekz>
      <ekz>
        inter la bruantaj <tld/>oj de fabriko
        <fnt>
          <bib>Fab3</bib>
          <lok>&Scirc;tono de la sa&gcirc;uloj</lok>
        </fnt>;
      </ekz>
      <ekz>
        rompi&gcirc;os la kru&ccirc;o &ccirc;e la fonto, kaj falos la <tld/>o en la puton
        <klr>(kp <ref cel="argan.0o.TEK">argano</ref>)</klr>)
        <fnt>
          <bib>MT</bib>
          <lok>Predikanto 12:6</lok>
        </fnt>;
      </ekz>
      <ekz>
        belegaj floroj tiel grandaj kiel <ind>muel<tld/>o</ind>j
        <fnt>
          <bib>Fab1</bib>
          <lok>Sova&gcirc;aj cignoj</lok>
        </fnt>;
        <trd lng="da">m&oslash;llehjul</trd>
        <trd lng="de">M&uuml;hlrad</trd>
        <trd lng="id">roda penggilingan</trd>
        <trd lng="pl">ko&lstroke;o m&lstroke;y&nacute;skie</trd>
      </ekz>
      <ekz>
        grandaj, kiel <tld/>oj de <ref tip="malprt" cel="muel.0ilo">muelilo</ref>
        <fnt>
          <bib>Fab1</bib>
          <lok>Fajrilo</lok>
        </fnt>;
      </ekz>
      <ekz>
        la justeco <klr>[&#8230;]</klr> kondamnos vin nur al morto per la <tld/>o
        <fnt>
          <bib>Rabistoj</bib>
          <lok>Akto Dua</lok>
        </fnt>;
      </ekz>
      <ekz>
        <tld/>o malbona knaras plej multe
        <klr>(kp <ref tip="vid" cel="barel.0o">barelo</ref> malplena)</klr>
        <fnt><bib>PrV</bib></fnt>;
      </ekz>
      <ekz>
        &jcirc;eti bastonon en la <tld/>on <klr>(malhelpi)</klr>
        <fnt><bib>PrV</bib></fnt>;
      </ekz>
      <ekz>
        <uzo tip="stl">FIG</uzo>
        <klr>[esti]</klr> la kvina <tld/>o &ccirc;e veturado
        <fnt>
          <bib>PrV</bib>
        </fnt>
        <klr>(tute seninflua, senutila)</klr>;
      </ekz>
      <ekz>
        <uzo tip="stl">FIG</uzo>
        la <tld/>o <klr>(&scirc;an&gcirc;i&gcirc;oj)</klr> de la sorto;
      </ekz>
      <ekz>
        <uzo tip="stl">FIG</uzo>
        <tld/>o de doloro kaj de &gcirc;ojo en mia kor&#8217; ruli&gcirc;as
        <fnt>
          <bib>Ifigenio</bib>
        </fnt>.
      </ekz>
    </dif>
  </snc>
