<drv mrk="rad.inerto0o">
  <kap>inerto<tld/>o,
  <var><kap>inerci<tld/>o<fnt><bib>PIV1</bib></fnt></kap></var></kap>
  <snc mrk="rad.inerto0o.TEK">
    <uzo tip="fak">TEK</uzo>
    <dif>
      Peza <tld/>o, kies <ref cel="inert.0eco.FIZ">inerteco</ref>
      ebligas kontra&ubreve;stari momentajn rezistojn, reguligi
      rapidon kaj povas e&ccirc; servi kiel &ccirc;efa energifonto:
      <ekz>
        la <klr>[kur]</klr>tapi&scirc;on movas elektra motoro a&ubreve; &gcirc;i estas provizita per
        inerci<tld/>o
        <fnt>
          <bib>Viki</bib>
          <lok><url ref="https://eo.wikipedia.org/?curid=356378">Kurtapi&scirc;o</url></lok>
        </fnt>;
      </ekz>
      <ekz>
        la akompanado imitas la rad&scirc;pinilon per da&ubreve;re turni&gcirc;aj sesdekononotaj figuroj de
        la dekstra mano, en la maldekstra mano oni a&ubreve;das kvaza&ubreve;e la piedon, tretantan
        la pedalon por la inerci<tld/>o
        <fnt>
          <bib>Viki</bib>
          <lok><url ref="https://eo.wikipedia.org/?curid=410850">Gretchen am Spinnrade</url></lok>
        </fnt>.
      </ekz>
    </dif>
  </snc>
  <trd lng="be">&c_m;&c_a;&c_h;&c_a;&c_v;&c_ib;&c_k;</trd>
