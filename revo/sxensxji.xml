<?xml version="1.0"?>
<!DOCTYPE vortaro SYSTEM "../dtd/vokoxml.dtd">
<vortaro>
<art mrk="$Id: sxensxji.xml,v 1.2 2026/07/15 14:06:21 afido Exp $">
<kap>
    <rad>&Scirc;en&scirc;ji</rad>/o <fnt><bib>PIV2</bib></fnt>,
    <var><kap><rad var="aa">&Scirc;aan&scirc;i</rad>/o <fnt><bib>LanLin</bib></fnt></kap></var>
</kap>
<drv mrk="sxensxji.0o">
  <kap><tld/>o,
  <var><kap><tld var="aa"/>o</kap></var></kap>
  <snc mrk="sxensxji.0o.GEOG">
    <uzo tip="fak">GEOG</uzo>
    <uzo tip="fak">POL</uzo>
    <dif>
      Provinco en centra parto de <ref tip="malprt" cel="cxin.CX0ujo">&Ccirc;inujo</ref> kun la &ccirc;efurbo
      <ref tip="prt" cel="sxjian.0o">&Scirc;jiano</ref>:
      <ekz>
        la &ccirc;efa motivo de la dua po&scirc;tmarko estas ar&gcirc;enta kaj orumita incensujo de la 9a jarcento,
        el la trezoro de la &ccirc;ina budhisma templo <nom>Famen</nom> en provinco <tld/>o
        <fnt>
          <aut>J. Hauser</aut>
          <vrk><url ref="https://www.monato.be/2020/012665.php">
          Slovak-&ccirc;inaj po&scirc;tmarkoj</url></vrk>
          <lok>Monato, 2020/06, p. 13a</lok>
        </fnt>;
      </ekz>
      <ekz>
        situo de <tld var="aa"/>o en &Ccirc;inujo
        <fnt>
          <aut>-</aut>
          <vrk><url ref="https://eo.wikinews.org/wiki/Kategorio:%C5%9Caan%C5%9Dio">
          Kategorio: &Scirc;aan&scirc;io</url></vrk>
          <lok>Vikinova&jcirc;oj, 2015-01-04</lok>
        </fnt>.
      </ekz>
    </dif>
  </snc>
  <trd lng="de">Shaanxi</trd>
  <trd lng="fr">Shaanxi</trd>
  <trdgrp lng="zh">
    <trd>&#x965D;&#x897F; <pr>Sh&#x1CE;nx&imacron;</pr></trd>,
    <trd>&#x9655;&#x897F; <pr>Sh&#x1CE;nx&imacron;</pr></trd>
  </trdgrp>
</drv>
</art>

