<kap>
    <rad>mikrobicid</rad>/o <fnt><bib>PIV1</bib></fnt>
</kap>
<drv mrk="mikrobicid.0o">
  <kap><tld/>o</kap>
  <snc mrk="mikrobicid.0o.BIO">
    <uzo tip="fak">BIO</uzo>
    <uzo tip="fak">MED</uzo>
    <dif>
      Substanco per kiu oni mortigas mikroviva&jcirc;ojn (<ref tip="vid" cel="mikrob.0o">mikrobojn</ref>):
      <ekz>
        propamidino estas grava <tld/>o kaj posedas 17 karbonatomojn,
        20 hidrogenatomojn, 4 nitrogenatomojn kaj 2 oksigenatomojn
        <fnt>
          <aut>-</aut>
          <vrk><url ref="https://eo.wikipedia.org/wiki/Propamidino">Propamidino</url></vrk>
          <lok>Vikipedio, 2024-08-13</lok>
        </fnt>.
      </ekz>
    </dif>
  </snc>
  <trd lng="fr">microbicide</trd>
</drv>
</art>

