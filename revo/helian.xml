<?xml version="1.0"?>
<!DOCTYPE vortaro SYSTEM "../dtd/vokoxml.dtd">
<vortaro>
<art mrk="$Id: helian.xml,v 1.31 2026/05/17 06:00:20 revo Exp $">
<kap>
  <rad>heliant</rad>/o <fnt><bib>PVEF</bib></fnt>
</kap>
<drv mrk="helian.0o">
  <kap><tld/>o</kap>
  <snc mrk="helian.0o.BOT">
    <uzo tip="fak">BOT</uzo>
    <dif>
      <ref tip="dif" cel="flor.sun0o.BOT">Sunfloro</ref>:
      <ekz>
        <tld lit="H"/>o estas genro de 67 specioj en la familio de la asteracoj
        <fnt>
          <bib>Viki</bib>
          <lok><url ref="https://eo.wikipedia.org/?curid=212951">Helianto</url></lok>
        </fnt>.
      </ekz>
    </dif>
  </snc>
  <trd lng="be">&c_s;&c_l;&c_a;&c_n;&c_je;&c_ch;&c_n;&c_ib;&c_k;</trd>
  <trd lng="bg">&c_s;&c_l;&c_malmol;&c_n;&c_ch;&c_o;&c_g;&c_l;&c_je;&c_d;</trd>
  <trdgrp lng="ca">
    <trd>heliant</trd>,
    <trd>gira-sol</trd>,
    <trd>mira-sol</trd>,
    <trd>sol coronat</trd>
  </trdgrp>
  <trdgrp lng="cs">
    <trd>heliant</trd>,
    <trd>slune&ccaron;nice</trd>
  </trdgrp>
  <trd lng="de">Sonnenblume</trd>
  <trd lng="el">&eta;&lambda;&jota;&omikron;&tau;&rho;&omikron_ton;&pi;&jota;&omikron;</trd>
  <trd lng="en">sunflower</trd>
  <trd lng="es">girasol</trd>
  <trdgrp lng="fr">
    <trd>h&eacute;lianthe</trd>,
    <trd>tournesol</trd>
  </trdgrp>
  <trd lng="hu">napraforg&oacute;</trd>
  <trd lng="it">girasole<klr> (gen. helianthus)</klr></trd>
  <trd lng="ja">&#12498;&#12510;&#12527;&#12522;</trd>
  <trd lng="nl">zonnebloem</trd>
  <trd lng="pl">s&lstroke;onecznik</trd>
  <trd lng="pt">girassol</trd>
  <trdgrp lng="ru">
    <trd>&c_p;&c_o;&c_d;&c_s;&c_o;&c_l;&c_n;&c_u;&c_h;</trd>,
    <trd>&c_p;&c_o;&c_d;&c_s;&c_o;&c_l;&c_n;&c_je;&c_ch;&c_n;&c_i;&c_k;</trd>
  </trdgrp>
  <trd lng="sk">slne&ccaron;nica</trd>
  <trd lng="tr">ay&ccedil;i&ccedil;e&gbreve;i</trd>
  <trd lng="uk">&c_s;&c_o;&c_n;&c_ja;&c_sh;&c_n;&c_i;&c_k;</trd>
  <trdgrp lng="zh">
    <trd>&#33909; <pr>ku&iacute;</pr></trd>,
    <trd>&#33909;&#33457; <pr>ku&iacute;hu&amacron;</pr></trd>,
    <trd>&#21521;&#26085;&#33909; <pr>xi&agrave;ngr&igrave;ku&iacute;</pr></trd>,
    <trd>&#21521;&#38451;&#33457; <pr>xi&agrave;ngy&aacute;nghu&amacron;</pr></trd>,
    <trd>&#26397;&#38451;&#33457; <pr>ch&aacute;oy&aacute;nghu&amacron;</pr></trd>,
    <trd>&#36681;&#26085;&#34030; <pr>zhu&#462;nr&igrave;li&aacute;n</pr></trd>
  </trdgrp>
</drv>

<drv mrk="helian.tubera0o">
  <kap>tubera <tld/>o</kap>
  <snc mrk="helian.tubera0o.BOT">
    <uzo tip="fak">BOT</uzo>
    <dif>
      <ref tip="dif" cel="pir.ter0o.BOT">Terpiro</ref>:
      <ekz>
        topinamburo (anka&ubreve; terpiro, tubera <tld/>o) estas plurjara, moltiga planto,
        havanta tigotuberojn utiligeblajn kiel legomo, precipe por diabetuloj
        <klr>[&#8230;]</klr> simile al <tld/>o &gcirc;i havas grandajn foliojn kaj hele flavajn
        florojn
        <fnt>
          <bib>Monato</bib>
          <aut>Julius Hauser</aut>
          <vrk><url ref="&Monato;/2012/010553.php">Topinamburo &ccirc;u herba&ccirc;o?</url></vrk>
        </fnt>.
      </ekz>
    </dif>
  </snc>
  <bld lok="../bld/tuberaheliant.jpg">
    la man&gcirc;ebla radiko de tubera <tld/>o
  </bld>
  <trd lng="be">&c_t;&c_a;&c_p;&c_ib;&c_n;&c_a;&c_m;&c_b;&c_u;&c_r;</trd>
  <trd lng="bg">&c_Je;&c_r;&c_u;&c_s;&c_a;&c_l;&c_i;&c_m; &c_a;&c_r;&c_t;&c_i;&c_sh;&c_o;&c_k;</trd>
  <trd lng="ca">ny&agrave;mera</trd>
  <trdgrp lng="de">
    <trd>Topinambur</trd>,
    <trd>Erdbirne</trd>
  </trdgrp>
  <trd lng="be">&c_t;&c_a;&c_p;&c_ib;&c_n;&c_a;&c_m;&c_b;&c_u;&c_r;</trd>
  <trd lng="br">perenn-douar</trd>
  <trdgrp lng="de">
    <trd>Topinambur</trd>,
    <trd>Erdbirne</trd>
  </trdgrp>
  <trd lng="en">Jerusalem artichoke</trd>
  <trd lng="fr">topinambour</trd>
  <trd lng="hu">csics&oacute;ka</trd>
  <trd lng="it">topinambur</trd>
  <trd lng="ja">&#12461;&#12463;&#12452;&#12514;</trd>
  <trd lng="nl">aardpeer</trd>
  <trdgrp lng="pl">
    <trd>s&lstroke;onecznik bulwiasty</trd>,
    <trd>topinambur</trd>
  </trdgrp>
  <trd lng="ru">&c_t;&c_o;&c_p;&c_i;&c_n;&c_a;&c_m;&c_b;&c_u;&c_r;</trd>
  <trd lng="sk">topinambura</trd>
  <trd lng="cs">topinambur</trd>
  <trdgrp lng="zh">
    <trd>&#27915;&#23004; <pr>y&aacute;ngji&amacron;ng</pr></trd>,
    <trd>&#33738;&#33419; <pr>j&uacute;y&ugrave;</pr></trd>
  </trdgrp>
</drv>
</art>
