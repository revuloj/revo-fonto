<drv mrk="trajn.pasagxer0o">
  <kap>pasa&gcirc;er<tld/>o</kap>
  <snc mrk="trajn.pasagxer0o.FER">
    <uzo tip="fak">FER</uzo>
    <dif>
      <ref tip="super" cel="trajn.0o.FER"><tld lit="T"/>o</ref>
      portanta homojn, voja&gcirc;antojn:
      <ekz>
        neniu pasa&gcirc;er<tld/>o haltus, kie ne estas kajo nek signaloj
        <fnt>
          <bib>Monato</bib>
          <aut>Albisturo Kvinke</aut>
          <vrk><url ref="&Monato;/2006/008788.php">Tenebro</url></vrk>
          <lok>2006</lok>
        </fnt>;
      </ekz>
      <ekz>
        Kenja prezidento <nom>Uhuru Kenyatta</nom> merkrede
        lan&ccirc;is la servon de pasa&gcirc;er<tld/>o de la 480-kilometra
        normal&scirc;pura fervojo inter Mombaso kaj Najrobio
        <fnt>
          <aut>Yu</aut>
          <vrk><url ref="&CRI;2521/2017/06/01/179s193447.htm">
          Kenjo oficiale malfermis normal&scirc;puran fervojon</url></vrk>
          <lok>&Ccirc;ina Radio Internacia, 2017-06-01</lok>
        </fnt>.
      </ekz>
    </dif>
  </snc>
