<drv mrk="trajn.0i">
  <kap>
    <tld/>i
  </kap>
  <snc>
    <dif>
      <ref cel="vetur.0i.TRA">Veturi</ref>
      per <tld/>o:
      <ekz>
        sabate, li ien <tld/>os kaj revenos nur malfrue
        <fnt>
          <bib>ChB</bib>
          <lok>30</lok>
        </fnt>;
      </ekz>
      <ekz>
        la nunaj planoj enhavas truon: ne eblos <tld/>i ekzemple el norda Anglio rekte
        al Bruselo a&ubreve; Parizo
        <fnt>
          <bib>Monato</bib>
          <aut>Paul Gubbins</aut>
          <vrk><url ref="&Monato;/2014/011303.php"
              >&Ccirc;iam eblas revi ...</url></vrk>
          <lok>2014</lok>
        </fnt>.
      </ekz>
    </dif>
  </snc>
  <trd lng="de"><klr>(mit dem)</klr> Zug <ind>fahren</ind></trd>
  <trd lng="en">go by train</trd>
</drv>

<drv mrk="trajn.el0igxi">
  <kap>
    el<tld/>i&gcirc;i
  </kap>
  <snc>
    <dif>
      Eliri el <tld/>on:
      <ekz>
        pasa&gcirc;ero el<tld/>i&gcirc;is kaj lasis sian gazeton
        <fnt>
          <bib>VRA</bib>
          <lok>Harald Beijer</lok>
        </fnt>;
      </ekz>
      <ekz>
        mi sukcese el<tld/>i&gcirc;is en la &gcirc;usta stacio, de kie mi devis preni buson
        <fnt>
          <bib>Kon11</bib>
          <lok>Voja&gcirc;o</lok>
        </fnt>.
      </ekz>
    </dif>
  </snc>
  <trdgrp lng="de">
    <trd>aussteigen <klr>(Zug)</klr></trd>,
    <trd>aus dem Zug <ind>steigen</ind></trd>
  </trdgrp>
  <trd lng="en">leave the train</trd>
</drv>

<drv mrk="trajn.en0igxi">
  <kap>
    en<tld/>i&gcirc;i
  </kap>
  <snc>
    <dif>
      Eniri en <tld/>on:
      <ekz>
        &ccirc;ar mi staras &ccirc;e oportuna loko, mi rapide povas en<tld/>i&gcirc;i
        <fnt>
          <bib>FSI</bib>
          <lok>IV</lok>
        </fnt>;
      </ekz>
      <ekz>
        ni en<tld/>i&gcirc;is en Moskvo kun mia patrino
        <fnt>
          <bib>Kon11</bib>
          <lok>La novaj redaktoroj de la revuo Esperanto</lok>
        </fnt>.
      </ekz>
    </dif>
  </snc>
  <trdgrp lng="de">
    <trd>in den Zug <ind>steigen</ind></trd>,
    <trd>einsteigen <klr>(Zug)</klr></trd>
  </trdgrp>
  <trd lng="en">enter the train</trd>
</drv>

<drv mrk="trajn.kargo0o">
  <kap>kargo<tld/>o,
  <var><kap>&scirc;ar&gcirc;<tld/>o</kap></var>,
  <var><kap>var<tld/>o</kap></var>
  </kap>
  <snc mrk="trajn.kargo0o.FER">
    <uzo tip="fak">FER</uzo>
    <dif>
      <ref tip="super" cel="trajn.0o.FER"><tld lit="T"/>o</ref>
      portanta kargon de objektoj:
      <ekz>
        longa kargo<tld/>o el bluaj kaj oran&gcirc;koloraj cisternaj
        vagonoj staras kaj atendas pluan transporton
        <fnt>
          <aut>K. Kniivil&auml;</aut>
          <vrk>Homoj de Putin</vrk>
          <lok>2016</lok>
        </fnt>;
      </ekz>
      <ekz>
        longa &scirc;ar&gcirc;<tld/>o forlasis la urbon kun valoraj provizvaroj, kiujn la milito
        su&ccirc;is al si
        <fnt>
          <bib>KKr</bib>
          <lok>I</lok>
        </fnt>;
      </ekz>
    </dif>
  </snc>
  <trd lng="be">&c_t;&c_a;&c_v;&c_a;&c_r;&c_n;&c_y; <ind>&c_c;&c_ja;&c_g;&c_n;&c_ib;&c_k;</ind></trd>
  <trd lng="de">G&uuml;terzug</trd>
  <trd lng="en">freight <ind>train</ind></trd>
  <trd lng="fr">train de marchandises</trd>
  <trd lng="ja">&#x8CA8;&#x7269;&#x5217;&#x8ECA;  <pr>&#x304B;&#x3082;&#x3064;&#x308C;&#x3063;&#x3057;&#x3083;</pr></trd>
  <trd lng="pl">poci&aogonek;g towarowy</trd>
  <trd lng="uk">&c_t;&c_o;&c_v;&c_a;&c_r;&c_n;&c_i;&c_j;/&c_v;&c_a;&c_n;&c_t;&c_a;&c_zh;&c_n;&c_i;&c_j; &c_p;&c_o;&c_ji;&c_z;&c_d;</trd>
  <trdgrp lng="zh">
    <trd>&#x8CA8;&#x904B; <pr>hu&ograve;y&ugrave;n</pr></trd>,
    <trd>&#x8D27;&#x8FD0; <pr>hu&ograve;y&ugrave;n</pr></trd>
  </trdgrp>
</drv>

