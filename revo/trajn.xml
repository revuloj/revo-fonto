<drv mrk="trajn.0o">
  <kap><tld/>o</kap>
  <snc mrk="trajn.0o.FER">
    <tezrad fak="FER"/>
    <uzo tip="fak">FER</uzo>
    <uzo tip="fak">TEK</uzo>
    <dif>
      <ref tip="sin" cel="vagon.0aro">Vagonaro</ref> kun lokomotivo a&ubreve; motorvagono
      por transporto de personoj a&ubreve; materialo:
      <ekz>
        trivagona <tld/>o
        <fnt>
          <bib>VaK</bib>
          <lok>Dua &Ccirc;apitro</lok>
        </fnt>;
      </ekz>
      <ekz>
        iri hejmen per la malfruvespera <tld/>o
        <fnt>
          <bib>HsT</bib>
          <lok>Disaj vojoj</lok>
        </fnt>;
      </ekz>
      <ekz>
        la <tld/>o trapasas grandajn vila&gcirc;ojn kaj grandajn urbojn
        <fnt>
          <bib>Tor</bib>
          <lok>V.</lok>
        </fnt>;
      </ekz>
      <ekz>
        sur la fervojo inter la stacio kaj la uzino venis <tld/>oj kun brikoj kaj ligno
        <fnt>
          <bib>InfanTorent2</bib>
          <lok>Dua Parto</lok>
        </fnt>;
      </ekz>
      <ekz>
        <klr>[li]</klr> ekskuzis sin, ke la tempo ne permesas tian tralegon, ke li devas
        kapti <klr>(atingi)</klr> <tld/>on
        <fnt>
          <bib>Voja&gcirc;Imp</bib>
          <lok>&Ccirc;e Lev Tolstoj en Jasnaja Poljana</lok>
        </fnt>;
      </ekz>
      <ekz>
        por tiu <tld/>o ne necesas rezervi sidlokon
        <fnt>
          <bib>FSI</bib>
          <lok>IV</lok>
        </fnt>;
      </ekz>
      <ekz>
        mi vendrede matene alvenas en la stacidomo &leftquot;<nom>Berlin Zoo</nom>&rightquot;, kie mi devas &scirc;an&gcirc;i en
        <tld/>on al Pollando
        <fnt>
          <bib>FSI</bib>
          <lok>IV</lok>
        </fnt>.
      </ekz>
    </dif>
    <refgrp tip="vid">
      <ref cel="metro.0o">metroo</ref>,
      <ref cel="tram.0o">tramo</ref>
    </refgrp>
    <trd lng="be">&c_c;&c_ja;&c_g;&c_n;&c_ib;&c_k;</trd>
    <trd lng="bg">&c_v;&c_l;&c_a;&c_k;</trd>
    <trd lng="ca">tren</trd>
    <trd lng="de">Zug</trd>
    <trd lng="en">train</trd>
    <trd lng="es">tren</trd>
    <trdgrp lng="fr">
      <trd>train</trd>
    </trdgrp>
    <trd lng="he">&resh;&kaf;&bet;&tav;</trd>
    <trd lng="hu">vonat</trd>
    <trdgrp lng="it">
      <trd>treno</trd>,
      <trd>convoglio<klr> ferroviario</klr></trd>
    </trdgrp>
    <trd lng="nl">trein</trd>
    <trd lng="pl">poci&aogonek;g</trd>
    <trdgrp lng="pt">
      <trd>trem</trd>,
      <trd>comboio</trd>
    </trdgrp>
    <trd lng="ro">tren</trd>
    <trd lng="ru">&c_p;&c_o;&c_je;&c_z;&c_d;</trd>
    <trd lng="sv">t&aring;g</trd>
    <trdgrp lng="zh">
    <trd>&#x706B;&#x8ECA; <pr>hu&#x1D2;ch&emacron;</pr></trd>,
    <trd>&#x706B;&#x8F66; <pr>hu&#x1D2;ch&emacron;</pr></trd>,
    <trd>&#x5217;&#x8ECA; <pr>li&egrave;ch&emacron;</pr></trd>,
    <trd>&#x5217;&#x8F66; <pr>li&egrave;ch&emacron;</pr></trd>
  </trdgrp>
</snc>
  <rim>
    La&ubreve; <fnt><bib>BL</bib></fnt>: Anka&ubreve; eblas diri <ke>vagonaro</ke>.
  </rim>

