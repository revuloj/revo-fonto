<drv mrk="trajn.rapid0o">
  <kap>
    rapid<tld/>o, <var><kap>ekspresa <tld/>o</kap></var>
  </kap>
  <snc>
    <dif>
      Trajno iranta pli rapida ol ordinara kaj haltanta nur en gravaj stacioj:
      <ekz>
        la ekspresa trajno Parizo-Limo&gcirc;o
        <fnt>
          <bib>Mortul&Scirc;ip</bib>
          <lok>&Ccirc;apitro 12</lok>
        </fnt>;
      </ekz>
      <ekz>
        elreligo de rapid<tld/>o
        <fnt>
          <bib>Monato</bib>
          <aut>Paul GUBBINS</aut>
          <vrk>Politiko elreligita</vrk>
        </fnt>;
      </ekz>
      <ekz>
        cent homoj mortis en germana ekspres<tld/>o <klr>[&#x2026;]</klr> pro unu rompi&gcirc;inta
        rado
        <fnt>
          <bib>Monato</bib>
        </fnt>;
      </ekz>
      <ekz>
        post eniro en la ekspresan <tld/>on &leftquot;Oriento-Okcidento&rightquot; mi denove devas stari en
        la koridoro
        <fnt>
          <bib>FSI</bib>
          <lok>IV</lok>
        </fnt>;
      </ekz>
      <ekz>
        en novaj rapid<tld/>oj oni provizu spacon por bicikloj
        <fnt>
          <bib>Monato</bib>
          <vrk><url ref="&Monato;/2004/008262.html">Kiel solvi trafikproblemojn</url></vrk>
          <lok>2004</lok>
