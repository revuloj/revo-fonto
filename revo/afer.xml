         </trdgrp>
         <trd lng="pl">nie oceniaj rzeczy po wygl&aogonek;dzie</trd>
         <trd lng="tr">g&ouml;r&uuml;n&uuml;&scedil;e
         aldanmamal&inodot;</trd>
       </ekz>
       <ekz>
