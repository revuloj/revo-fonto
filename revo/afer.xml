<drv mrk="afer.cxef0o">
  <kap>
    &ccirc;ef<tld/>o
  </kap>
  <snc>
    <dif>
      La plej grava <tld/>o en iu tasko, entrepreno, celado:
      <ekz>
        en &ccirc;i tiu festo la sanktigado efektive estas nur la flanka <tld/>o, la
        &ccirc;ef<tld/>o estas man&gcirc;i kaj trinki, muziko kaj danco
        <fnt>
          <aut>Ignac Hock</aut>
          <vrk><url ref="https://eo.wikisource.org/wiki/Mia_forpermesa_voja%C4%9Do_1913"
              >Mia forpermesa voja&gcirc;o 1913</url></vrk>
          <lok>Fervoja Esperantisto, 1914 (p. 3-7)</lok>
        </fnt>;
      </ekz>
      <ekz>
        ne sufi&ccirc;as la pin&ccirc;ilo, medikamento kaj banda&gcirc;o, la &ccirc;ef<tld/>o estas la animo de
        la helpo, kiu estas <klr>[&#8230;]</klr> pli saniga ol la sanigiloj
        <fnt>
          <bib>VaK</bib>
          <lok>Kvina &Ccirc;apitro</lok>
        </fnt>.
      </ekz>
    </dif>
    <refgrp tip="vid">
      <ref cel="cxef.0ajxo">&ccirc;efa&jcirc;o</ref>,
      <ref cel="grav.plej0ajxo">plejgrava&jcirc;o</ref>,
      <ref cel="precip.0ajxo">precipa&jcirc;o</ref>,
    </refgrp>
    <refgrp>
      <ref cel="kvinte.0o.KOMUNE">kvintesenco<sncref/></ref>,
      <ref cel="prioritat.0o.KOMUNE">prioritato<sncref/></ref>
    </refgrp>
  </snc>
  <trd lng="de">Hauptsache</trd>
  <trdgrp lng="en">
    <trd>main thing</trd>,
    <trd>main issue</trd>
  </trdgrp>
  <trd lng="fr">principal</trd>
</drv>

<drv mrk="afer.fi0o">
  <kap>
    fi<tld/>o
  </kap>
  <snc>
    <dif>
      Malmorala okupo, plano, interago:
      <ekz>
        li sisteme planadis la fi<tld/>on dum na&ubreve; jaroj
        <fnt>
          <bib>Monato</bib>
          <aut>Douglas Draper</aut>
          <vrk><url ref="&Monato;/2011/010493.php"
              >Floroj, ne armiloj</url></vrk>
          <lok>2011</lok>
        </fnt>;
      </ekz>
      <ekz>
        ven&gcirc;oj kaj forigo de tiuj, kiuj tro scias pri diversaj fi<tld/>oj, kialas por
        dungi murdiston
        <fnt>
          <bib>Monato</bib>
          <aut>Bardhyl Selimi</aut>
          <vrk><url ref="&Monato;/2009/009704.php"
              >Murdo la&ubreve; mendo</url></vrk>
          <lok>2009</lok>
        </fnt>;
      </ekz>
      <ekz>
        oni ironias pri afabla konduto de la ekstremistoj, kiuj tute malaktivis dum la
        novjaraj festoj, kaj revenis al siaj fi<tld/>oj tuj post la dusemajna feriado
        <fnt>
          <bib>LOdE</bib>
          <lok>2003, &#8470; 3 (101)</lok>
        </fnt>.
      </ekz>
    </dif>
    <refgrp tip="vid">
      <ref cel="far.fi0o">fifaro</ref>,
      <ref cel="ag.mis0o">malbonago</ref>,
      <ref cel="ag.mis0o">misago</ref>
    </refgrp>
  </snc>
  <trdgrp lng="de">
    <trd>Untat</trd>,
    <trd>Vergehen</trd>
  </trdgrp>
  <trd lng="en">misdoing</trd>
</drv>

    <drv mrk="afer.jugx0o">
