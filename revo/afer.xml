  <snc mrk="afer.0o.tasko">
    <dif>
       <ref cel="okup.0o">Okupo</ref>, <ref cel="labor.0o.KOMUNE">laboro</ref>
       a&ubreve; <ref cel="task.0o.entrepreno">tasko</ref> kiun oni faras a&ubreve; intencas fari:
       <ekz>
         en tiu &ccirc;i lernejo la infanoj estas edukataj tre bone,
         &ccirc;ar la lernejestro sin okupas je sia <tld/>o kun amo
         <fnt>
           <aut>&Z;</aut>:
           <vrk>Aldono al la Dua Libro de l' Lingvo Internacia</vrk>.
         </fnt>;
       </ekz>
       <ekz>
         li forveturis por unu tago pro tre
         <ind>grava <tld/>o</ind>
	    <fnt>
	      <aut>N.V. Gogol, tr. &Z;</aut>: <vrk>La revizoro</vrk>.
           <lok>5:7</lok>.
	    </fnt>;
         <trd lng="pl">wa&zdot;na sprawa</trd>
         <trd lng="ru">&c_v;&c_a;&c_zh;&c_n;&c_o;&c_je;
         <ind>&c_d;&c_je;&c_l;&c_o;</ind></trd>
       </ekz>
       <ekz>
         la obeado al la personaj gustoj en tiel komuna <tld/>o, kiel
         la nia, estas tre malutila<fnt><bib>LR</bib>, <lok>La
         Esperantisto, 1891, p.49</lok></fnt>;
       </ekz>
       <ekz>
         <nom>Olga</nom> preparas teon, rapidante &gcirc;is lia alveno fini siajn mastrum<tld/>ojn
         <fnt>
           <bib>Metrop</bib>
         </fnt>;
       </ekz>
       <ekz>
         <klr>[li]</klr> tute ne atendis subite fari&gcirc;i posedanto de tiaj ri&ccirc;a&jcirc;oj, neniam
         anta&ubreve;e pripensinte la <ind>mon<tld/>o</ind>jn de sia mortinta patro
         <fnt>
           <bib>MrA</bib>
           <lok>&Ccirc;apitro VI</lok>
         </fnt>;
         <trd lng="de">Geldangelegenheit</trd>
       </ekz>
       <ekz>
         <ind>la <tld/>o ne ur&gcirc;as</ind>
         <fnt><bib>PrV</bib></fnt>;
         <trd lng="es">la cosa no urge</trd>
         <trd lng="fr">il n'y a pas le <ind>feu</ind></trd>
       </ekz>
       <ekz>
         faru vian <tld/>on, Dio zorgos ceteron
	 <fnt><bib>PrV</bib></fnt>;
       </ekz>
       <ekz>
         aran&gcirc;i la <tld/>on
         <fnt><bib>MT</bib>, <lok>&Dan; 11:6</lok></fnt>;
       </ekz>
       <ekz>
         <ind>nun transiru ni al la <tld/>o</ind>
         <klr>(al la diskutata temo)</klr>
         <fnt>
           <bib>Hamlet</bib>
           <lok>Hamleto</lok>
         </fnt>;
         <trd lng="de">kommen wir zur <ind>Sache</ind></trd>
         <trd lng="es">vayamo al asunto en cuesti&oacute;n</trd>
         <trd lng="fr">venons-en &agrave; notre <ind>affaire</ind>
         </trd>
         <trd lng="pl">przejd&zacute;my do rzeczy</trd>
       </ekz>
       <ekz>
         <ind>al la afero!</ind>
         <fnt><bib>PrV</bib></fnt>
         <trd lng="de">zur <ind>Sache</ind>!</trd>
         <trd lng="es">&#xA1;al grano!</trd>
         <trd lng="fi">asiaan!</trd>
         <trd lng="fr"><klr tip="ind">(venez-en) </klr>au <ind>fait
           </ind>!</trd>
         <trd lng="pl">do rzeczy!</trd>
       </ekz>
       <ekz>
         <ind>pri kio estas la <tld/>o</ind>
         <fnt><bib>PrV</bib></fnt>?
         <trd lng="de">worum <ind>geht</ind> es</trd>
         <trd lng="es">&#xBF;de qu&eacute; se trata?</trd>
         <trd lng="fr">de quoi s'<ind>agit</ind>-il?</trd>
         <trd lng="pl">o co chodzi?</trd>
       </ekz>
       <ekz>
         <ind>okupu vin pri viaj <tld/>oj</ind>, sed ne pri la miaj
         <klr>(ne <ref cel="miks.en0igxi">enmiksi&gcirc;u</ref>)</klr>
         <fnt>
           <bib>KPr</bib>
           <lok>&Ccirc;apitro Dekkvina</lok>
         </fnt>;
         <trdgrp lng="de">
           <trd>k&uuml;mmere dich um deine <ind>Angelegenheit</ind>en</trd>
           <trd>was <ind>geht</ind> dich das an?</trd>
         </trdgrp>
         <trd lng="es">&#xA1;m&eacute;tete en tus asuntos!</trd>
         <trdgrp lng="fr">
           <trd>occupez-vous de vos <ind>affaire</ind>s!</trd>,
           <trd>occupez-vous de vos <ind>pied</ind>s!</trd>
         </trdgrp>
         <trd lng="pl">zajmij si&eogonek; swoimi sprawami</trd>
         <trd lng="tr">kendi i&scedil;inizle
         u&gbreve;ra&scedil;&inodot;n</trd>
       </ekz>
       <ekz>
         <ind>estas lia <tld/>o</ind> <klr>(tio koncernas lin)</klr>
         skribi al lia patro;
         <trdgrp lng="de">
           <trd>das ist seine <ind>Angelegenheit</ind></trd>,
           <trd>das ist seine <ind>Sache</ind></trd>
         </trdgrp>
         <trdgrp lng="es">
           <trd>es asunto suyo</trd>,
           <trd>es cosa suya</trd>
         </trdgrp>
         <trdgrp lng="fr">
           <trd>c'est son <ind>affaire</ind></trd>,
           <trd>c'est son <ind>probl&egrave;me</ind></trd>,
           <trd>c'est lui que &ccedil;a <ind>regarde</ind></trd>
         </trdgrp>
         <trd lng="pl">to jest jego sprawa</trd>
         <trdgrp lng="tr">
           <trd>o kendisini ilgilendirir</trd>,
           <trd>o onun problemi</trd>
         </trdgrp>
       </ekz>
       <ekz>
         <ind>min ne tu&scirc;as la afero</ind>, mi staras ekstere
         <fnt><bib>PrV</bib></fnt>;
         <trdgrp lng="de">
           <trd>das ist nicht meine <ind>Sache</ind></trd>,
           <trd>das ist nicht meine <ind>Problem</ind></trd>,
           <trd>lass mich aus dem <ind>Spiel</ind></trd>,
           <trd>da bin ich <ind>au&szlig;en</ind> vor</trd>
         </trdgrp>
         <trd lng="es">no es asunto m&iacute;o</trd>
         <trdgrp lng="fr">
           <trd>ce n'est pas mon <ind>affaire</ind></trd>,
           <trd>ce n'est pas mon <ind>probl&egrave;me</ind></trd>,
           <trd>ce ne sont pas mes <ind>oignon</ind>s</trd>,
           <trd>cette affaire ne me <ind>regarde</ind> pas</trd>
         </trdgrp>
         <trd lng="pl">mnie ta sprawa nie dotyczy</trd>
         <trdgrp lng="tr">
           <trd>beni ilgilendirmez</trd>,
           <trd>o benim problemim de&gbreve;il</trd>
         </trdgrp>
       </ekz>
       <ekz>
         sa&gcirc;a tenas <tld/>on, malsa&gcirc;a esperon
         <fnt><bib>PrV</bib></fnt>.
       </ekz>
     </dif>
     <trd lng="br">afer</trd>
     <trdgrp lng="en">
       <trd>object</trd>,
       <trd>thing</trd>
     </trdgrp>
     <trdgrp lng="fi">
       <trd>asia</trd>,
       <trd>kysymys</trd>
     </trdgrp>
     <trdgrp lng="fr">
       <trd>affaire<klr tip="ind"> (qui occupe)</klr></trd>,
