<drv mrk="afer.am0o">
  <kap>am<tld/>o, <var><kap>amor<tld/>o</kap></var>, <var><kap>seks<tld/>o</kap></var></kap>
  <snc mrk="afer.am0o.KOMUNE">
    <dif>
      Ama kaj seksa interrilato:
      <ekz>
        kiam iu mortis en suspektaj cirkonstancoj, ni sisteme informi&gcirc;as pri la
        am<tld/>oj
        <fnt>
          <bib>ChV</bib>
          <lok>14</lok>
        </fnt>;
      </ekz>
      <ekz>
        viaj amor<tld/>oj tute ne interesas min
        <fnt>
          <bib>KrB</bib>
          <lok>Ia stranga atako al mi ligas subite la manon</lok>
        </fnt>;
      </ekz>
      <ekz>
        rokmuzikisto enplektita en seks<tld/>o
        <fnt>
          <bib>Monato</bib>
          <aut>Paul Gubbins</aut>
          <vrk><url ref="&Monato;/2015/011465.php"
              >Ridante survoje al la banko</url></vrk>
          <lok>2015</lok>
        </fnt>;
      </ekz>
      <ekz>
        mia am<tld/>o intertempe perdis multe el sia ekzalta etoso
        <fnt>
          <bib>CKv</bib>
          <lok>15</lok>
        </fnt>;
      </ekz>
      <ekz>
        <klr>[ili]</klr> moraladmone pritraktas junajn virojn indiferentajn al
        am<tld/>oj kaj edzi&gcirc;o
        <fnt>
          <bib>Kon11</bib>
          <lok>&Ccirc;efartikolo</lok>
        </fnt>.
      </ekz>
    </dif>
    <trd
    lng="th">&#xE40;&#xE23;&#xE37;&#xE48;&#xE2D;&#xE07;&#xE04;&#xE27;&#xE32;&#xE21;&#xE23;&#xE31;&#xE01;</trd>
