<drv mrk="afer.0a">
  <kap><tld/>a</kap>
  <snc>
    <dif>
      Rilata al <tld/>o:
    </dif>
    <subsnc ref="afer.0o.objekto">
      <ekz>
        bestaj radikoj kaj multaj <tld/>aj radikoj signifas
        en verba formo <ctl>agi kiel tia besto a&ubreve;
        <tld/>o</ctl>
        <fnt>
          <aut>B. Wennergren</aut>
          <vrk>Verboj el ne-agaj radikoj</vrk>
          <lok><url ref="&PMEG;vortfarado/principoj/finajhoj/verbaj.html">PMEG</url></lok>
        </fnt>.
      </ekz>
      <trd lng="de">Sach-</trd>
      <trd lng="en">object</trd>
      <trd lng="fr">de <ind>chose</ind></trd>
    </subsnc>
    <subsnc ref="afer.0o.komerco">
      <ekz>
        &ccirc;e sociaj kaj <tld/>aj kunvenoj kutime kaj
        la&ubreve;more estas saluti kaj adia&ubreve;i &ccirc;iun
        personon individue, per manpremo
        <fnt>
          <bib>Voja&gcirc;o</bib>
          <aut>A. Tilmont</aut>
          <vrk>Praktikaj informoj pri Antverpeno</vrk><lok>leciono
            11a
          </lok>
        </fnt>;
      </ekz>
      <ekz>
        retpo&scirc;to estas tre efika en persona kaj <tld/>a
        korespondado
        <fnt>
          <bib>Voja&gcirc;o</bib>
          <aut>B. Kolker</aut>
          <vrk>Pri Interreto per simplaj vortoj</vrk><lok>leciono
            26a
          </lok>
        </fnt>.
      </ekz>
      <trd lng="de">gesch&auml;ftlich</trd>
      <trd lng="en">business</trd>
      <trd lng="fr">d'<ind>affaire</ind>(s)</trd>
    </subsnc>
    <trd lng="fi">asia-</trd>
  </snc>
  <trd lng="be">&c_d;&c_z;&c_je;&c_l;&c_a;&c_v;&c_y;</trd>
