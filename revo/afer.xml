       <trd>question<klr tip="ind"> (qui occupe)</klr></trd>,
     </trdgrp>
     <trd lng="hu">&uuml;gy</trd>
     <trdgrp lng="ja">
       <trd>&#29992;&#x4EF6; <pr>&#12424;&#12358;&#12369;&#12435;</pr></trd>
       <trd>&#29992;&#x4E8B; <pr>&#12424;&#12358;&#12376;</pr></trd>
     </trdgrp>
     <trdgrp lng="pl">
       <trd>sprawa</trd>,
       <trd>rzecz</trd>
     </trdgrp>
     <trdgrp lng="pt">
       <trd>quest&atilde;o</trd>,
       <trd>assunto</trd>,
       <trd>neg&oacute;cio</trd>
     </trdgrp>
     <trd lng="ru">&c_d;&c_je;&c_l;&c_o;</trd>
     <trd lng="sk">z&aacute;le&zcaron;itos&tcaron;</trd>
     <trdgrp lng="th">
       <trd>&#xE40;&#xE23;&#xE37;&#xE48;&#xE2D;&#xE07;&#xE23;&#xE32;&#xE27;</trd>,
       <trd>&#xE01;&#xE32;&#xE23;&#xE07;&#xE32;&#xE19;</trd>
     </trdgrp>
     <trdgrp lng="tr">
       <trd>problem</trd>,
       <trd>sorun</trd>,
       <trd>i&scedil;</trd>,
       <trd>dert</trd>
     </trdgrp>
   </snc>
  <snc mrk="afer.0o.SOC">
    <dif>
      Socia <ref cel="ag.inter0o.reciproka">interago</ref>:
    </dif>
    <subsnc mrk="afer.0o.publika">
      <dif>
        Io koncernanta publikajn interesojn:
        <ekz>
          la sorto de la slovena minoritato en la suda provinco de A&ubreve;strio, Karintio <klr>[&#8230;]</klr>
          tio estas ekskluzive &scirc;tata afero
           <fnt>
             <bib>Monato</bib>
             <aut>Vinko O&scaron;lak</aut>
             <vrk><url ref="&Monato;/2011/010406.php"
                 >Martela jeso, ambosa neo</url></vrk>
             <lok>2011</lok>
           </fnt>;
         </ekz>
         <ekz>
           <ind>ministro pri internaj <tld/>oj</ind>
           <fnt>
             <bib>Monato</bib>
             <aut>Hektor Alos i Font</aut>
             <vrk><url ref="&Monato;/2010/010065.php"
                 >Maljusta justico</url></vrk>
             <lok>2010</lok>
           </fnt>;
           <trd lng="de">Innenminister</trd>
         </ekz>
         <ekz>
           la sveda <ind>ministro pri eksterlandaj <tld/>oj</ind>
           <fnt>
             <bib>Monato</bib>
             <aut>Stefan MAUL</aut>
             <vrk><url ref="&Monato;/2003/008000.html"
                 >Jur-renverso</url></vrk>
             <lok>2003</lok>
           </fnt>;
           <trd lng="de">Au&szlig;enminister</trd>
         </ekz>
         <ekz>
           mi formetas de mi &ccirc;ian oficialan rolon en nia
           <tld/>o
           <fnt>
             <aut>&Z;</aut>:
             <vrk>La parolado anta&ubreve; la Oka Kongreso
             Esperantista</vrk>
             <lok>Krakovo, 1912-08-11</lok>
           </fnt>;
         </ekz>
         <ekz>
           oni &jcirc;us strangolis en Konstantinopolo du vezirojn de la benko <klr>[&#8230;]</klr>,
           kies ofico estis ju&gcirc;i pri diversaj <ind>&scirc;tat<tld/>o</ind>j
           <fnt>
             <bib>Kandid</bib>
             <lok>&Ccirc;apitro XXX</lok>
           </fnt>;
           <trd lng="de">Staatsangelegeheit</trd>
         </ekz>
       </dif>
       <trd lng="id"><ind>urus</ind>an</trd>
     </subsnc>
     <subsnc mrk="afer.0o.JUR">
       <uzo tip="fak">JUR</uzo>
       <dif>
         Io koncernanta privatulojn a&ubreve; publikajn personojn,
         aparte traktata de oficialaj instancoj a&ubreve; gazetaro; precipe
         <ref tip="sub" cel="afer.jugx0o.JUR">ju&gcirc;<tld/>o</ref>:
         <ekz>
           defendu <tld/>on de vidvino
           <fnt><bib>MT</bib>, <lok>&Jes; 1:17</lok></fnt>;
         </ekz>
         <ekz>
           se sa&gcirc;a homo havas ju&gcirc;an <tld/>on kun homo
           malsa&gcirc;a, tiam, &ccirc;u li koleras, &ccirc;u li ridas, li ne havas
           trankvilon.
           <fnt><bib>MT</bib>, <lok>&Sen; &ccirc;ap.
           29:9</lok></fnt>;
         </ekz>
         <ekz>
           <nom>David</nom> <klr>[&#8230;]</klr> ne forklini&gcirc;is de &ccirc;io,
           kion la Eternulo ordonis al li, krom la <tld/>o kun <nom>Urija</nom>, la
           &Hcirc;etido
           <fnt><bib>MT</bib>, <lok>&Re1; 15:5</lok></fnt>;
         </ekz>
         <ekz>
           <klr>[se]</klr> metiistoj havas plend<tld/>on kontra&ubreve; iu, la ju&gcirc;ejoj estas je
           ilia dispono
           <fnt>
             <bib>NT</bib>
             <lok>La agoj 19:38</lok>
           </fnt>;
         </ekz>
         <ekz>
           mia &ccirc;efo, foje faris konsiderindan eraron, sufi&ccirc;e seriozkonsekvencan por ke la
           <tld/>o venu anta&ubreve; tribunalon
           <fnt>
             <bib>CKv</bib>
             <lok>15</lok>
           </fnt>;
         </ekz>
         <ekz>
           mi legas &jcirc;urnalojn <klr>[&ccirc;ar]</klr> mi trovas en ili ekscitajn <tld/>ojn
           <fnt>
             <bib>LOdE</bib>
             <lok>2000, No 6 (68)</lok>
           </fnt>;
         </ekz>
         <ekz>
           la ideo esti implikita en murdo<tld/>o &scirc;in ektimigis
           <fnt>
             <bib>ChV</bib>
             <lok>23</lok>
           </fnt>;
         </ekz>
         <ekz>
           sesono de la historio pritraktas la
           <ctl><tld/>on <nom>Lapenna</nom></ctl>
           <fnt>
             <aut>Petro DESMET'</aut>:
             <vrk>Politika historio de la ne&ubreve;trala UEA</vrk>.
             <bib>Monato</bib>. <lok>2007</lok>
           </fnt>;
         </ekz>
         <ekz>
           formeti la <tld/>on en la keston de forgeso
           <fnt><bib>PrV</bib></fnt>.
           <trd lng="de">Gras &uuml;ber eine <ind>Sache</ind> wachsen lassen</trd>
         </ekz>
       </dif>
       <trd lng="br">afer</trd>
       <trdgrp lng="en">
         <trd>case</trd>
       </trdgrp>
       <trdgrp lng="es">
         <trd>caso</trd>,
         <trd>asunto</trd>
       </trdgrp>
       <trdgrp lng="fi">
         <trd>(oikeus)asia</trd>,
         <trd>tapaus</trd>,
         <trd>juttu</trd>
       </trdgrp>
       <trdgrp lng="fr">
         <trd>affaire<klr tip="ind"> (en justice)</klr></trd>,
         <trd>cas<klr tip="ind"> (en justice)</klr></trd>
         <trd>cause<klr tip="ind"> (en justice)</klr></trd>
         <trd>dossier<klr tip="ind"> (en justice)</klr></trd>
         <trd>proc&egrave;s</trd>
       </trdgrp>
       <trd lng="hu">&uuml;gy</trd>
       <trd lng="id">kasus</trd>
       <trdgrp lng="pl">
         <trd>sprawa</trd>
       </trdgrp>
       <trdgrp lng="pt">
         <trd>caso</trd>,
         <trd>quest&atilde;o</trd>,
         <trd>causa</trd>
       </trdgrp>
       <trd lng="ru">&c_d;&c_je;&c_l;&c_o;</trd>
       <trd lng="sk">pr&iacute;pad</trd>
       <trdgrp lng="tr">
         <trd>dosya<klr>(hukuk)</klr></trd>,
         <trd>dava</trd>
       </trdgrp>
     </subsnc>
     <subsnc mrk="afer.0o.komerco">
       <uzo tip="fak">EKON</uzo>
       <dif>
         <ref cel="komerc.0o">Komerco</ref>, <ref cel="negoc.0o">negoco</ref> a&ubreve; rilata interago:
         <ekz>
           kelkajn vortojn pri aferoj negocaj, dum ni estas ankora&ubreve; &ccirc;e la matenman&gcirc;o
           <fnt>
             <bib>BdV</bib>
             <lok>La Batalo de l' Vivo</lok>
           </fnt>;
         </ekz>
         <ekz>
           dank&#8217; al potencaj mondumrilatoj, kiujn liaj bank<tld/>oj al li altiris
           <klr>[&#8230;]</klr>
           <fnt>
             <bib>ChL</bib>
             <lok>&Ccirc;apitro Kvina</lok>
           </fnt>;
         </ekz>
         <ekz>
           kio nepras por da&ubreve;rigi sportajn negoc<tld/>ojn
           <fnt>
             <bib>Kon11</bib>
             <lok>&Ccirc;efartikolo</lok>
           </fnt>?
         </ekz>
         <ekz>
           lingvoj uzeblaj en dogan<tld/>oj
           <fnt>
             <bib>LOdE</bib>
             <lok>2004, &#8470; 4 (114)</lok>
           </fnt>;
         </ekz>
         <ekz>
           negocaj <tld/>oj estas severaj
           <fnt><bib>PrV</bib></fnt>;
         </ekz>
         <ekz>
           <ind>amikeco aparte, <tld/>o aparte</ind>
           <fnt><bib>PrV</bib></fnt>;
           <trd lng="de">beim Geld h&ouml;rt die Freundschaft auf</trd>
           <trdgrp lng="fr">
             <trd>en affaires, on ne fait pas de <ind>sentiment</ind>
             </trd>,
             <trd>les <ind>affaire</ind>s sont les affaires</trd>
           </trdgrp>
         </ekz>
         <ekz>
           tago festa, for <tld/>oj
           <fnt><bib>PrV</bib></fnt>.
         </ekz>
       </dif>
