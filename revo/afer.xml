  <snc mrk="afer.0o.cxio">
    <uzo tip="stl">FIG</uzo>
    <dif>
      <ref tip="sin" cel="io.0.nepreciza">Io</ref> estanta en la
      mondo, konkreta a&ubreve; abstrakta <ref tip="sub" cel="objekt.0o">objekto</ref>,
      <ref tip="sub" cel="cirkon1.0o">cirkonstanco</ref>,
      <ref tip="sub" cel="fenome.0o">fenomeno</ref>:
      <ekz>
        e&ccirc; la plej nekredeblajn <tld/>ojn <klr>[&#8230;]</klr> li tuj kredas
        <fnt><bib>F</bib>, <lok>&FE;41.</lok></fnt>.
      </ekz>
      <ekz>
        lerni kaj fari diversajn <tld/>ojn
        <fnt>
          <bib>InfanTorent2</bib>
          <lok>Unua Parto</lok>
        </fnt>;
      </ekz>
      <ekz>
        la tiel nomata civilizo estas malbenita fu&scirc;<tld/>o
        <fnt>
          <bib>InfanTorent2</bib>
          <lok>Unua Parto</lok>
        </fnt>;
      </ekz>
      <ekz>
        li bone konas tion, pri kio li parolas, ke la <tld/>o estas al li plene klara
        <fnt>
          <bib>Ret</bib>
          <lok>Dua Parto</lok>
        </fnt>;
      </ekz>
      <ekz>
        vi rakontas interesajn <tld/>ojn
        <fnt>
          <bib>Far2</bib>
          <lok>&Ccirc;apitro XXII</lok>
        </fnt>;
      </ekz>
      <ekz>
        mi povas montri al vi kelkajn geografiajn kartojn kaj aliajn interesajn <tld/>ojn
        <fnt>
          <bib>MrA</bib>
          <lok>&Ccirc;apitro VIII</lok>
        </fnt>;
      </ekz>
      <ekz>
        li volos scii, <klr>[&#8230;]</klr> pri kiaj <tld/>oj ni parolas
        <fnt>
          <bib>MJA</bib>
          <lok>Parto Unua</lok>
        </fnt>;
        <trd lng="pl">o czym mowa?</trd>
      </ekz>
      <ekz>
        oni parolas pri pse&ubreve;dosciencaj <tld/>oj
        <fnt>
          <bib>Kon11</bib>
          <lok>&Ccirc;efartikolo</lok>
        </fnt>;
      </ekz>
      <ekz>
        de la teoria vidpunkto la duelo estas sensenca&jcirc;o, sed de la praktika vidpunkto &ndash;
        <ind>tio estas alia <tld/>o</ind>
        <fnt>
          <bib>PatrojFiloj</bib>
          <lok>XXIV</lok>
        </fnt>;
        <trd lng="de">das ist <ind>etwas</ind> anderes</trd>
        <trdgrp lng="fr">
         <trd>c'est une autre <ind>affaire</ind></trd>,
         <trd>c'est autre <ind>chose</ind></trd>
         <trd>c'est une autre paire de <ind>manche</ind>s</trd>
        </trdgrp>
        <trd lng="pl">to jest inna sprawa</trd>
        <trd lng="ru">&c_e;&c_t;&c_o;
         &c_d;&c_r;&c_u;&c_g;&c_o;&c_je; <ind>&c_d;&c_je;&c_l;&c_o;</ind></trd>
      </ekz>
      <ekz>
         <ind>paroloj kaj faroj estas malsamaj <tld/>oj</ind>
         <fnt><bib>PrV</bib></fnt>;
         <trd lng="de">Sagen und Tun ist zweierlei</trd>
         <trd lng="es">del dicho al hecho hay un trecho</trd>
         <trd lng="fr">entre dire et faire, il y a un
           <ind>monde</ind>
         </trd>
         <trd lng="pl">
           co innego m&oacute;wi&cacute;, a co innego robi&cacute;
         </trd>
         <trd lng="tr">lafla pilav pi&scedil;mez</trd>
       </ekz>
       <ekz>
         <ind>ne ju&gcirc;u pri <tld/>o la&ubreve; &gcirc;ia ekstero</ind>
         <fnt><bib>PrV</bib></fnt>;
         <trd lng="fi">ulkon&auml;k&ouml; pett&auml;&auml;</trd>
         <trdgrp lng="fr">
           <trd>il ne faut pas juger de l'arbre par
             l'<ind>&eacute;corce</ind></trd>,
