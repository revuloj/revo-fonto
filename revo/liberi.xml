<?xml version="1.0"?>
<!DOCTYPE vortaro SYSTEM "../dtd/vokoxml.dtd">
<vortaro>
<art mrk="$Id: liberi.xml,v 1.19 2026/07/03 06:00:24 revo Exp $">
<kap>
  <ofc>8</ofc><rad>Liberi</rad>/o <fnt><bib>PV</bib></fnt>
</kap>

<drv mrk="liberi.L0o">
  <kap>
    <ofc>8</ofc>
    <tld/>o
    <fnt><aut>Akademio de Esperanto</aut>,
<vrk><url ref="&AdE;/aktoj/aktoj2/8oa.html"> 8a
Oficiala Aldono</url></vrk>, <lok>II.C.1</lok></fnt>
    <fnt><aut>Akademio de Esperanto</aut>,
<vrk><url ref="&AdE;/decidoj/landnomoj/listo_de_rekomendataj_landnomoj/index.html">Oficiala
Informo 12</url>, Listo de Rekomendataj Landnomoj</vrk></fnt>
    <fnt><bib>Viki</bib>, <lok><url ref="&Viki;/Liberio">Liberio</url></lok></fnt>
  </kap>
  <snc mrk="liberi.L0o.GEOG">
    <uzo tip="fak">GEOG</uzo>
    <uzo tip="fak">POL</uzo>
    <mlg kod="ISO-3166">LR</mlg>
    <dif>
      Lando en la okcidenta <ref tip="malprt" cel="afrik.A0o">Afriko</ref> kun
      <ref tip="lst" lst="voko:&ccirc;efurboj" cel="urb.cxef0o.POL">&ccirc;efurbo</ref>
      <ref tip="prt" cel="monrovi.0o">Monrovio</ref>; teritorio de Respubliko <tld/>o;
      limas kun
      <ref tip="vid" cel="ebur.E0Bordo.GEOG">Ebur-Bordo</ref>,
      <ref tip="vid" cel="gvine.G0o.GEOG">Gvineo</ref>,
      <ref tip="vid" cel="sieraleo.S0o.GEOG">Sieraleono</ref>
      kaj <ref tip="vid" cel="atlant.A0o.GEOG">Atlantiko</ref>:
      <ekz>
        permesu prezenti al vi mian karan gaston,
        s-ro Hju-&aacute;m-&aacute;m, samideano el <tld/>o
        <fnt>
         <aut>N. Hohlov</aut>,
         <vrk><url ref="http://esperanto.net/literaturo/dram/libr/mortdelegit.pdf">
         La Morto de la Delegito de U.E.A.</url></vrk>,
         <lok>1924</lok>
        </fnt>.
      </ekz>
    </dif>
    </snc>
    <trd lng="be">&c_L;&c_ib;&c_b;&c_e;&c_r;&c_y;&c_ja;</trd>
    <trd lng="bg">&c_L;&c_i;&c_b;&c_je;&c_r;&c_i;&c_ja;</trd>
    <trd lng="ca">Lib&egrave;ria</trd>
  <trd lng="de">Liberia</trd>
    <trd lng="en">Liberia</trd>
    <trd lng="es">Liberia</trd>
  <trdgrp lng="fr">
      <trd>Lib&eacute;ria</trd>,
      <trd>R&eacute;publique du Lib&eacute;ria</trd>
    </trdgrp>
    <trd lng="fy">Liberia</trd>
    <trd lng="hu">Lib&eacute;ria</trd>
    <trd lng="id">Liberia</trd>
    <trd lng="io">Liberia</trd>
    <trd lng="ja">&#12522;&#12505;&#12522;&#12450;</trd>
    <trd lng="nl">Liberia</trd>
    <trdgrp lng="pl">
      <trd>Liberia</trd>,
      <trd>Republika <ind>Liberii</ind></trd>
    </trdgrp>
    <trd lng="pt">Lib&eacute;ria</trd>
    <trd lng="uk">&c_L;&c_ib;&c_b;&c_je;&c_r;&c_ib;&c_ja;</trd>
    <trd lng="vo">Liber&auml;n</trd>
    <trdgrp lng="zh">
      <trd>&#36084;&#27604;&#29790;&#20126; <pr>L&agrave;ib&#464;ru&igrave;y&agrave;</pr></trd>,
      <trd>&#36182;&#27604;&#29790;&#20122; <pr>L&agrave;ib&#464;ru&igrave;y&agrave;</pr></trd>,
      <trd>&#21033;&#27604;&#37324;&#20122; <pr>L&igrave;b&#464;l&#464;y&agrave;</pr></trd>,
      <trd>&#21033;&#27604;&#37324;&#20126; <pr>L&igrave;b&#464;l&#464;y&agrave;</pr></trd>,
      <trd>&#21033;&#27604;&#35041;&#20126; <pr>l&igrave;b&#464;l&#464;y&agrave;</pr></trd>,
      <trd>&#21033;&#27604;&#37324;&#20122; <pr>l&igrave;b&#464;l&#464;y&agrave;</pr></trd>
    </trdgrp>
</drv>

<drv mrk="liberi.0ano">
  <kap><tld lit="l"/>ano</kap>
  <snc>
    <dif>
      Civitano de <tld/>o:
      <ekz>
        anka&ubreve; Jamusukro mobilizis <tld lit="l"/>anojn kaj armis
        civilulojn, &ccirc;efe indi&gcirc;enajn
        <fnt>
          <aut>F. Pigeaud, trad. J.-M. Cash</aut>,
          <vrk><url ref="&Mondediplo;article1873.html">
          Milito por kakao en okcidento de Eburbordo</url></vrk>,
          <lok>le Monde diplomatique, 2012-09</lok>
        </fnt>.
      </ekz>
    </dif>
  </snc>
  <trd lng="be">&c_l;&c_ib;&c_b;&c_e;&c_r;&c_y;&c_je;&c_c;</trd>
  <trd lng="ca">liberi&agrave;</trd>
  <trd lng="en">Liberian</trd>
  <trdgrp lng="fr">
    <trd>Lib&eacute;rien</trd>
    <trd>Lib&eacute;rienne<klr> (subst.)</klr></trd>
  </trdgrp>
  <trd lng="fy">Liberiaan</trd>
  <trd lng="io">Liberiano</trd>
  <trd lng="nl">Liberiaan</trd>
  <trdgrp lng="pl">
    <trd>Liberyjczyk</trd>,
    <trd>Liberyjka</trd>
  </trdgrp>
  <trd lng="vo">Liber&auml;nan</trd>
</drv>

<drv mrk="liberi.0a">
  <kap><tld lit="l"/>a</kap>
  <snc>
    <dif>
      Rilata al <tld/>o:
      <ekz>
        li ver&scirc;ajne helpis tiel s-ron <nom>Charles Taylor</nom>,
        ekzilita en Burkina Faso, prepari la sangan sturmon kontra&ubreve; la
        <tld lit="l"/>a re&gcirc;imo fine de 1989
        <fnt>
          <aut>A. Frintz, trad. J.-M. Cash</aut>,
          <vrk><url ref="&Mondediplo;article2163.html">
          La burkina junularo &scirc;ancelas la &#171; Francafrikon &#187;</url></vrk>,
          <lok>le Monde diplomatique, 2014-12</lok>
        </fnt>.
      </ekz>
    </dif>
  </snc>
  <trd lng="be">&c_l;&c_ib;&c_b;&c_e;&c_r;&c_y;&c_j;&c_s;&c_k;&c_ib;</trd>
  <trd lng="ca">liberi&agrave;</trd>
  <trd lng="en">Liberian</trd>
  <trdgrp lng="fr">
    <trd>lib&eacute;rien</trd>
    <trd>lib&eacute;rienne<klr> (adj.)</klr></trd>
  </trdgrp>
  <trd lng="fy">Liberiaansk</trd>
  <trd lng="io">Liberiana</trd>
  <trd lng="nl">Liberiaans</trd>
  <trdgrp lng="pl">
    <trd>liberyjski</trd>,
    <trd>liberyjska</trd>
  </trdgrp>
  <trd lng="vo">Liber&auml;nik</trd>
</drv>
</art>

