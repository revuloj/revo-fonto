<?xml version="1.0"?>
<!DOCTYPE vortaro SYSTEM "../dtd/vokoxml.dtd">
<vortaro>
<art mrk="$Id: karate.xml,v 1.24 2026/06/22 18:19:49 revo Exp $">
<kap>
  <rad>karate</rad>/o <fnt><bib>EncJap</bib></fnt>
</kap>

<drv mrk="karate.0o">
  <kap><tld/>o</kap>
  <uzo tip="fak">SPO</uzo>
  <snc>
    <dif>
      Japandevena lukto<ref tip="super" cel="sport.0o">sporto</ref>
      ataka kaj defenda, en kiu oni uzas subitajn pu&scirc;atakojn kaj
batojn
      per mano, pugno, kubuto, genuo, piedo...:
      <ekz>
        &ccirc;ar mi ne iris al la trinkejo, mi havis tempon por <tld/>o kaj
        kurado, kiuj helpos mian sanon
        <fnt>
          <aut>kir&ccirc;o</aut>,
          <vrk><url ref="http://kircxo.livejournal.com/">livejournal</url></vrk>,
          <lok><url ref="http://kircxo.livejournal.com/6008.html">sena&ubreve;te</url>,
          2004-11-16</lok>
        </fnt>;
      </ekz>
      <ekz>
        lia talento kiel regiona &ccirc;ampiono de <tld/>o gajnis al li admiron ekde la unua tago
        <fnt>
          <aut>Pierre Souchon, trad. Mike Leon</aut>
          <vrk><url ref="https://eo.mondediplo.com/2015/02/article2204">
            "Ni kredas je nenio krom la Profeto"</url></vrk>
          <bib>MD14</bib>
        </fnt>.
      </ekz>
    </dif>
  </snc>
  <trd lng="be">&c_k;&c_a;&c_r;&c_a;&c_t;&c_e;</trd>
  <trd lng="bg">&c_k;&c_a;&c_r;&c_a;&c_t;&c_je;</trd>
  <trd lng="ca">karate</trd>
  <trd lng="cs">karate</trd>
  <trd lng="de">Karate</trd>
  <trd lng="en">karate</trd>
  <trd lng="es">k&aacute;rate</trd>
  <trd lng="fr">karat&eacute;</trd>
  <trd lng="hr">karate</trd>
  <trd lng="hu">karate</trd>
  <trdgrp lng="ja">
    <trd>&#31354;&#25163; <pr>&#12363;&#12425;&#12390;</pr></trd>,
    <trd>&#31354;&#25163;&#36947; <pr>&#12363;&#12425;&#12390;&#12393;&#12358;</pr></trd>
  </trdgrp>
  <trdgrp lng="ko">
    <trd>&#44277;&#49688;&#46020;<klr> (&#31354;&#25163;&#36947;)</klr></trd>,
    <trd>&#44032;&#46972;&#53580;</trd>,
    <trd>&#44032;&#46972;&#45936;</trd>
  </trdgrp>
  <trd lng="nl">karate</trd>
  <trd lng="pl">karate</trd>
  <trd lng="ru">&c_k;&c_a;&c_r;&c_a;&c_t;&c_je;</trd>
  <trd lng="sk">karate</trd>
  <trd lng="uk">&c_k;&c_a;&c_r;&c_a;&c_t;&c_je;</trd>
  <trd lng="zh">&#31354;&#25163;&#36947; <pr>k&omacron;ngsh&#466;ud&agrave;o</pr></trd>
</drv>

<drv mrk="karate.0isto">
  <kap><tld/>isto</kap>
  <snc mrk="karate.0isto.SPO">
    <dif>
      Sportisto, kiu praktikas <tld/>on:
      <ekz>
        kvieta kaj respektinda ulo kun okulvitroj subite
transformi&gcirc;as al
        <tld/>isto kun nigra zono
        <fnt>
          <vrk>Kiu na&ubreve;zas sur viajn &scirc;uojn?</vrk>
          <lok><url
          ref="https://web.archive.org/web/20080511192838/http://abonu.com/archive/kulturo.mozaiko/200210/28202845.html">Art-mozaiko,
          2002-10-28, numero 6a</url></lok>
        </fnt>;
      </ekz>
      <ekz>
        se interbati&gcirc;as du ebriuloj a&ubreve; se batalas du sportistoj, &jcirc;udistoj, <tld/>istoj a&ubreve; boksistoj,
        ili ankau defendas sin kaj frontas kontra&ubreve; la perforton
        <fnt>
          <aut>J. Nok&aacute;k kaj I. &Scaron;pi&ccaron;ka</aut>
          <vrk><url ref="https://scienca-revuo.info/article/126">Scienco pri la
          sindefendo</url></vrk>
          <lok>Scienca Revuo de Internacia Scienca Asocio Esperanta, vol. 28, n-ro 3 (125),
          1977-05-30</lok>
        </fnt>.
      </ekz>
    </dif>
  </snc>
  <trd lng="be">&c_k;&c_a;&c_r;&c_a;&c_t;&c_y;&c_s;&c_t;</trd>
  <trd lng="ca">karateka</trd>
  <trd lng="cs">karatista</trd>
  <trd lng="de">Karateka</trd>
  <trdgrp lng="en">
    <trd>karateka</trd>,
    <trd>karate practitioner</trd>,
    <trd>karate athlete</trd>
  </trdgrp>
  <trd lng="es">karateca</trd>
  <trd lng="fr">karat&eacute;ka</trd>
  <trd lng="hr">karatist</trd>
  <trd lng="ja">&#31354;&#25163;&#23478; <pr>&#12363;&#12425;&#12390;&#12363;</pr></trd>
  <trdgrp lng="nl">
    <trd>karateka</trd>,
    <trd>karate-beoefenaar</trd>
  </trdgrp>
  <trd lng="pl">karateka</trd>
  <trd lng="sk">karatista</trd>
  <trd lng="uk">&c_k;&c_a;&c_r;&c_a;&c_t;&c_je;&c_ji;&c_s;&c_t;</trd>
</drv>
</art>
