<!DOCTYPE vortaro SYSTEM "../dtd/vokoxml.dtd">
<vortaro>
<art mrk="$Id: dram.xml,v 1.37 2026/06/11 23:54:08 revo Exp $">
<kap>
  <ofc>1</ofc><rad>dram</rad>/o
  <fnt><bib>JED</bib></fnt>
</kap>

<drv mrk="dram.0o">
  <kap><tld/>o</kap>
  <snc mrk="dram.0o.TEA">
    <uzo tip="fak">TEA</uzo>
    <dif>
      <ref tip="super" cel="teatr.0ajxo">Teatra&jcirc;o</ref>, precipe
      tia, en kia alternas sentoj, ne nur amuza (komedia) a&ubreve; serioza
      (tragedia):
      <ekz>
        la <tld/>oj de &Scirc;ekspiro;
      </ekz>
      <ekz>
        <nom>Calderon</nom> kantis siajn <tld/>ojn en belritmaj versoj
        <fnt><bib>Fab3</bib> <lok>Post jarmiloj</lok></fnt>;
      </ekz>
      <ekz>
        jen komenci&gcirc;is la prezentado, kaj tio estis tre bela <tld/>o kun re&gcirc;o kaj re&gcirc;ino
        <fnt><bib>Fab1</bib> <lok>Vojkamarado</lok></fnt>;
      </ekz>
      <ekz>
        nenia <tld/>o donis e&ccirc; iajn enspezojn, se la a&ubreve;toro kaj aktoroj ne atakadis en
        &gcirc;i siajn kontra&ubreve;ulojn
        <fnt><bib>Hamlet</bib></fnt>;
      </ekz>
      <ekz>
        kiam estis ludata ekzemple la <tld/>o de Vilhelmo <nom>Tell</nom>, mi estis en la unua akto
        la soldato, kiu arestis Vilhelmon
        <fnt><bib>IdO</bib> <lok>Unua Parto</lok></fnt>.
      </ekz>
    </dif>
    <refgrp tip="prt">
      <ref cel="klimaks.0o.BELE">klimakso<sncref/></ref>,
      <ref cel="peripeti.0o">peripetio</ref>,
      <ref cel="nod.el0igxo.BELE">elnodi&gcirc;o<sncref/></ref>
    </refgrp>
    <trd lng="ca">drama</trd>
    <trd lng="pl">dramat</trd>
  </snc>
  <snc mrk="dram.0o.FIG">
    <uzo tip="stl">FIG</uzo>
    <dif>
      Terura okazo:
      <ekz>
        pri kio &scirc;i pensas? <tld/>o el la vivo preterporti&gcirc;as anta&ubreve; &scirc;ia spirito
        <fnt>
          <bib>Fab2</bib>
          <lok>El fenestro en Vartou</lok>
        </fnt>;
      </ekz>
      <ekz>
        a&ubreve;skultu la da&ubreve;rigon de la <tld/>o de mia vivo
        <fnt><bib>Marta</bib></fnt>;
      </ekz>
      <ekz>
        se vi rakontus, la&ubreve; &ccirc;iuj &gcirc;iaj detaloj, la <tld/>on tiel, kiel &gcirc;i okazis inter
        vi, eble la ju&gcirc;antaro vidos en tio nur akcidenton
        <fnt>
          <bib>ChL</bib>
          <lok>&Ccirc;apitro Kvara</lok>
        </fnt>.
      </ekz>
    </dif>
    <refgrp tip="vid">
      <ref cel="fatal.0o">fatalo</ref>,
      <ref cel="katast.0o">katastrofo</ref>,
      <ref cel="traged.0o.FIG">tragedio<sncref/></ref>
    </refgrp>
    <trdgrp lng="ca">
      <trd>drama</trd>,
      <trd>desastre</trd>
    </trdgrp>
    <trd lng="pl">dramat</trd>
  </snc>
  <trd lng="be">&c_d;&c_r;&c_a;&c_m;&c_a;</trd>
  <trd lng="bg">&c_d;&c_r;&c_a;&c_m;&c_a;</trd>
  <trdgrp lng="cs">
    <trd>drama</trd>,
    <trd>nap&iacute;nav&aacute; situace</trd>,
    <trd>trag&eacute;die</trd>
  </trdgrp>
  <trd lng="de">Drama</trd>
  <trd lng="en">drama</trd>
  <trd lng="es">drama</trd>
  <trd lng="fr">drame</trd>
  <trd lng="id">drama</trd>
  <trdgrp lng="ja">
    <trd>&#27491;&#21127;  <pr>&#12379;&#12356;&#12370;&#12365;</pr></trd>,
    <trd/>,
    <trd>&#28436;&#21127;  <pr>&#12360;&#12435;&#12370;&#12365;</pr></trd>,
    <trd>&#25135;&#26354;  <pr>&#12366;&#12365;&#12423;&#12367;</pr></trd>,
    <trd>&#21127;&#30340;&#20107;&#20214;  <pr>&#12370;&#12365;&#12390;&#12365;&#12376;&#12369;&#12435;</pr></trd>,
    <trd>&#12489;&#12521;&#12510;  <pr>&#12393;&#12425;&#12414;</pr></trd>
  </trdgrp>
  <trd lng="pt">drama</trd>
  <trd lng="ru">&c_d;&c_r;&c_a;&c_m;&c_a;</trd>
  <trdgrp lng="sk">
    <trd>dr&aacute;ma</trd>,
    <trd>trag&eacute;dia</trd>
  </trdgrp>
  <trd lng="sv">drama</trd>
  <trd lng="uk">&c_d;&c_r;&c_a;&c_m;&c_a;</trd>
  <trdgrp lng="zh">
    <trd>&#25103;&#21095; <pr>x&igrave;j&ugrave;</pr></trd>,
    <trd>&#25137; <pr>x&igrave;</pr></trd>,
    <trd>&#25103; <pr>x&igrave;</pr></trd>,
    <trd>&#21095; <pr>j&ugrave;</pr></trd>
  </trdgrp>
</drv>

<drv mrk="dram.0a">
  <kap><tld/>a</kap>
  <snc mrk="dram.0a.teatra">
    <uzo tip="fak">TEA</uzo>
    <dif>
      Teatra, rilata al <tld/>o:
      <ekz>
        la <tld/>a verkisto <klr>[&#8230;]</klr> pere de la aktoro prezenti&gcirc;as al la publiko
        <fnt><bib>Ret</bib> <lok>Dua Parto</lok></fnt>;
      </ekz>
      <ekz>
        <nom>Shakespeare</nom> uzis en &ccirc;iuj siaj <tld/>aj verkoj &ccirc;. 15&#8239;000 vortojn
        <fnt><bib>Ret</bib> <lok>Unua Parto</lok></fnt>;
      </ekz>
      <ekz>
        el tiu historio ne nur mankis la restarigo de la <tld/>a ekvilibro, sed anka&ubreve; &gcirc;i
        renversis mian &gcirc;eneralan moralsenton
        <fnt><bib>VaK</bib> <lok>Tria &Ccirc;apitro</lok></fnt>.
      </ekz>
    </dif>
    <trd lng="de">Theater-</trd>
    <trdgrp lng="id">
      <trd>teatrikal</trd>,
      <trd>teatris</trd>
    </trdgrp>
    <trd lng="pl">dramatyczny</trd>
    <trd lng="ro">dramatic</trd>
    <trd lng="sv">teatrisk</trd>
  </snc>
  <snc mrk="dram.0a.FIG">
    <uzo tip="stl">FIG</uzo>
    <dif>
      Tre emociiga:
      <ekz>
        li rakontis sian <tld/>an voja&gcirc;on
        <fnt><bib>KPr</bib> <lok>&Ccirc;apitro Dua</lok></fnt>;
      </ekz>
      <ekz>
        li parolis per tono tiel <tld/>a, ke Matildo kaj &scirc;ia patrino estis konvinkitaj
        <fnt><bib>KPr</bib> <lok>&Ccirc;apitro Sesa</lok></fnt>;
      </ekz>
      <ekz>
        mi jam priskribis pri lia <tld/>a eniro en la oficejon
        <fnt><bib>KKl</bib> <lok>&Ccirc;apitro 10</lok></fnt>;
      </ekz>
      <ekz>
        vi imagis ion <tld/>an, dum temas pri <klr>[&#8230;]</klr> tute natura
        okaza&jcirc;o
        <fnt><bib>Gerda</bib>, <lok>&ccirc;apitro 5a</lok></fnt>.
      </ekz>
    </dif>
    <trd lng="de">dramatisch</trd>
    <trdgrp lng="id">
      <trd>dramatik</trd>,
      <trd>dramatis</trd>
    </trdgrp>
    <trd lng="pl">dramatyczny</trd>
    <trd lng="ro">dramatic</trd>
    <trd lng="ru">&c_d;&c_r;&c_a;&c_m;&c_a;&c_t;&c_i;&c_ch;&c_je;&c_s;&c_k;&c_i;&c_j;</trd>
    <trd lng="sv">dramatisk</trd>
    <trdgrp lng="zh">
    <trd>&#25103;&#21095;&#24615; <pr>x&igrave;j&ugrave;x&igrave;ng</pr></trd>,
    <trd>&#25187;&#20154;&#24515;&#24358; <pr>k&ograve;ur&eacute;nx&imacron;nxi&aacute;n</pr></trd>
  </trdgrp>
</snc>
  <trd lng="be">&c_d;&c_r;&c_a;&c_m;&c_a;&c_t;&c_y;&c_ch;&c_n;&c_y;</trd>
  <trd lng="ca">dram&agrave;tic</trd>
  <trdgrp lng="cs">
    <trd>dramatick&yacute;</trd>,
    <trd>tragick&yacute;</trd>
  </trdgrp>
  <trd lng="en">dramatic</trd>
  <trd lng="es">dram&aacute;tico</trd>
  <trd lng="fr">dramatique</trd>
  <trd lng="he">&dalet;&resh;&mem;&tet;&yod;</trd>
  <trdgrp lng="ja">
    <trd>&#28436;&#21127;&#12398;  <pr>&#12360;&#12435;&#12370;&#12365;&#12398;</pr></trd>,
    <trd>&#21127;&#30340;&#12394;  <pr>&#12370;&#12365;&#12390;&#12365;&#12394;</pr></trd>
  </trdgrp>
  <trd lng="sk">dramatick&yacute;</trd>
  <trd lng="uk">&c_d;&c_r;&c_a;&c_m;&c_a;&c_t;&c_i;&c_ch;&c_n;&c_i;&c_j;</trd>
</drv>

<drv mrk="dram.0igi">
  <kap><tld/>igi</kap>
  <snc>
    <dif>
      Igi <tld/>a:
      <ekz>
        &ccirc;i tiu verko <tld/>igas tiun historian murdon
        <fnt>
          <bib>Monato</bib>
          <aut>Donald Broadribb</aut>
          <vrk><url ref="&Monato;/2004/008131.html">Bone prezentita dramo malkvietiga</url></vrk>
          <lok>2004</lok>
        </fnt>;
      </ekz><ekz>
        li e&ccirc; ne troe <tld/>igus, se la registaro postulus malkonstrui la kontra&ubreve;le&gcirc;an
        krea&jcirc;on
        <fnt>
          <bib>Monato</bib>
          <aut>Laimius Stra&zcaron;nickas</aut>
          <vrk><url ref="&Monato;/2003/007949.html">Sur propra tereno propra pre&gcirc;ejo</url></vrk>
          <lok>2003</lok>
        </fnt>;
      </ekz><ekz>
        oni nenion <tld/>igu, sed trankvile alfrontu la dan&gcirc;eron
        <fnt>
          <bib>Monato</bib>
          <aut>Marko Naoki Lins</aut>
          <vrk><url ref="&Monato;/2004/008331.html">Judaj premgrupoj en Bruselo</url></vrk>
          <lok>2004</lok>
        </fnt>.
      </ekz>
    </dif>
    <refgrp tip="vid">
      <ref cel="panik.0igi">panikigi</ref>,
      <ref cel="tro.0igi">troigi</ref>
    </refgrp>
  </snc>
  <trd lng="be">&c_d;&c_r;&c_a;&c_m;&c_a;&c_t;&c_y;&c_z;&c_a;&c_v;&c_a;&c_c;&c_mol;</trd>
  <trd lng="ca">dramatitzar</trd>
  <trd lng="cs">zdramatizovat</trd>
  <trd lng="de">dramatisieren</trd>
  <trd lng="en">dramatize</trd>
  <trd lng="fr">dramatiser</trd>
  <trd lng="he">&lamed;&#1456;&he;&#1463;&mem;&het;&#1460;&yod;&zayin;</trd>
  <trd lng="id"><baz>dramatisasi</baz>mendramatisasi</trd>
  <trdgrp lng="ja">
    <trd>&#21127;&#21270;&#12377;&#12427;  <pr>&#12370;&#12365;&#12363;&#12377;&#12427;</pr></trd>,
    <trd>&#33050;&#33394;&#12377;&#12427;  <pr>&#12365;&#12419;&#12367;&#12375;&#12423;&#12367;&#12377;&#12427;</pr></trd>
  </trdgrp>
  <trd lng="pl">dramatyzowa&cacute;</trd>
  <trd lng="ru">&c_i;&c_n;&c_s;&c_c;&c_je;&c_n;&c_i;&c_r;&c_o;&c_v;&c_a;&c_t;&c_mol;</trd>
  <trd lng="sk">zdramatizova&tcaron;</trd>
  <trd lng="sv">dramatisera</trd>
  <trd lng="uk">&c_d;&c_r;&c_a;&c_m;&c_a;&c_t;&c_i;&c_z;&c_u;&c_v;&c_a;&c_t;&c_i;</trd>
  <trd lng="zh">&#25913;&#32232;&#28858;&#21127;&#26412; <pr>g&#462;ibi&amacron;nw&eacute;ij&ugrave;b&ecaron;n</pr></trd>
</drv>

<drv mrk="dram.0isto">
  <kap><tld/>isto</kap>
  <snc mrk="dram.0isto.TEA">
    <dif>
      <ref tip="dif" cel="verk.dram0isto.TEA"><tld lit="D"/>verkisto</ref>:
      <ekz>
        Sokrato trovis malmulton bonan por diri pri la <tld/>istoj de tiu epoko
        <fnt>
          <aut>D. Broadribb</aut>
          <vrk>Anta&ubreve;parolo de la Tradukinto</vrk>
          <lok>en: La Respubliko, 1993</lok>
        </fnt>.
      </ekz>
    </dif>
    <trd lng="de">Dramaturg</trd>
    <trdgrp lng="en">
      <trd>playwright</trd>,
      <trd>dramatist</trd>
    </trdgrp>
    <trd lng="fr">dramaturge</trd>
  </snc>
<trd lng="be">&c_d;&c_r;&c_a;&c_m;&c_a;&c_t;&c_u;&c_r;&c_g;</trd>
<trdgrp lng="ca">
    <trd>dramaturg</trd>,
    <trd>autor dram&agrave;tic</trd>
  </trdgrp>
  <trd lng="es">dramaturgo</trd>
  <trdgrp lng="id">
  <trd>dramaturg</trd>,
  <trd><baz>tulis</baz>penulis drama</trd>
</trdgrp>
</drv>

<drv mrk="dram.lego0o">
  <kap>lego<tld/>o <fnt><bib>Viki</bib></fnt></kap>
  <snc mrk="dram.lego0o.BELE">
    <uzo tip="fak">BELE</uzo>
    <uzo tip="fak">TEA</uzo>
    <dif>
      Beletra verko en formo de <ref tip="super" cel="teatr.0ajxo">teatra&jcirc;o</ref>,
      destinita ne tiom por surscenigo, kiom por legado fare de unuopaj
      legantoj a&ubreve; eventuale por <ref cel="recital.0o">recitalo</ref>:
      <ekz>
        &leftquot;Fa&ubreve;sto&rightquot; de Goeto, &leftquot;Rabistoj&rightquot; de &Scirc;ilero, &leftquot;La
        tragedietoj&rightquot; de Pu&scirc;kino
        estis verkitaj kiel lego<tld/>oj.
      </ekz>
    </dif>
  </snc>
  <trd lng="be">&c_p;&#8217;&c_je;&c_s;&c_a; &c_d;&c_l;&c_ja;
  &c_ch;&c_y;&c_t;&c_a;&c_n;&c_mol;&c_n;&c_ja;</trd>
  <trd lng="ca">obra dram&agrave;tica per ser llegida</trd>
  <trd lng="de">Lesedrama</trd>
  <trd lng="en">closet drama</trd>
  <trd lng="id">drama baca</trd>
  <trd lng="pl">dramat niesceniczny</trd>
  <trd lng="ru">&c_p;&c_mol;&c_je;&c_s;&c_a; &c_d;&c_l;&c_ja;
  &c_ch;&c_t;&c_je;&c_n;&c_i;&c_ja;</trd>
</drv>
