<?xml version="1.0"?>
<!DOCTYPE vortaro SYSTEM "../dtd/vokoxml.dtd">
<vortaro>
<art mrk="$Id: belot.xml,v 1.2 2026/05/06 06:45:26 afido Exp $">
<kap>
    <rad>belot</rad>/o <fnt><aut>R. Eichholtz k. a.</aut> <vrk>Pekoteko</vrk> <lok>1994</lok></fnt>
</kap>
<drv mrk="belot.0o">
  <kap><tld/>o</kap>
  <snc mrk="belot.0o.SPO">
    <uzo tip="fak">SPO</uzo>
    <dif>
      <ref tip="super" cel="kart.0ludo.SPO">Kartludo </ref>por tri a&ubreve; kvar ludantoj, ludata per 32
      kartoj, kun atuto:
      <ekz>
        frondo estas jam io: sub &gcirc;i oni almena&ubreve; povas ludi <tld/>on
        <fnt>
          <aut>F. Moln&aacute;r, trad. J. Horvath</aut>
          <vrk><url ref="https://verkoj.com/tradukistoj/jozefo-horvath/jocxjo_kpl.pdf">
          Jo&ccirc;jo kaj aliaj komedietoj</url></vrk>
          <lok>2025</lok>
        </fnt>.
      </ekz>
    </dif>
  </snc>
  <trdgrp lng="de">
    <trd>Belote</trd>,
    <trd>Bela</trd>
  </trdgrp>
  <trd lng="fr">belote</trd>
</drv>
</art>

