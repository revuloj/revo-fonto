<?xml version="1.0"?>
<!DOCTYPE vortaro SYSTEM "../dtd/vokoxml.dtd">
<vortaro>
<art mrk="$Id: centri.xml,v 1.37 2026/03/07 20:06:12 revo Exp $">
<kap>
  <rad>centrifug</rad>/a  <fnt><bib>PVEF</bib></fnt>
</kap>
<drv mrk="centri.0a">
  <kap><tld/>a</kap>
  <snc mrk="centri.0a.FIZ">
    <uzo tip="fak">FIZ</uzo>
    <dif>
      Movanta, aganta el la centro, decentrokura:
      <ekz>
        la reloj klini&gcirc;is flanken tridek gradojn tiel, <klr>[&#8230;]</klr> kaj ni preska&ubreve;
        glui&gcirc;is al la sidlokoj pro la <ind><tld/>a forto</ind>
        <fnt>
          <bib>VaK</bib>
          <lok>Dua &Ccirc;apitro</lok>
        </fnt>;
        <trd lng="de">Zentrifugalkraft</trd>
      </ekz>
      <ekz>
        la vivo, &ccirc;i giganta, enigma karusel', &#11005; Sencelan bardon portis la&ubreve; <tld/>a rondo
        <fnt>
          <bib>LSB</bib>
          <lok>Al Paul Verlaine</lok>
        </fnt>;
      </ekz>
      <ekz>
        <uzo tip="stl">FIG</uzo>
        ekstremismaj starpunktoj kun fortaj <tld/>aj tendencoj
        <fnt>
          <bib>EeP</bib>
          <lok>Kvara Parto</lok>
        </fnt>.
      </ekz>
    </dif>
    <ref tip="vid" cel="inert.0eca">inerteca</ref>
    <trd lng="be">&c_c;&c_e;&c_n;&c_t;&c_r;&c_a;&c_b;&c_je;&c_zh;&c_n;&c_y;</trd>
    <trd lng="ca">centr&iacute;fug</trd>
    <trd lng="de">zentrifugal</trd>
    <trd lng="el">&sigma;&ypsilon;&gamma;&omikron_ton;&kappa;&epsilon;&ny;&tau;&rho;&omikron;&sigma_fina;</trd>
    <trd lng="es">centr&iacute;fuga</trd>
    <trd lng="fr">centrifuge</trd>
    <trd lng="hu">centrifug&aacute;lis</trd>
    <trd lng="it">cent&iacute;fugo</trd>
    <trdgrp lng="nl">
      <trd>centrifugaal</trd>,
      <trd>middelpuntvliedend</trd>
    </trdgrp>
    <trd lng="pl">od&sacute;rodkowy</trd>
    <trd lng="pt">centr&iacute;fuga</trd>
    <trd lng="ru">&c_c;&c_je;&c_n;&c_t;&c_r;&c_o;&c_b;&c_je;&c_zh;&c_n;&c_y;&c_j;</trd>
    <trd lng="sk">odstrediv&yacute;</trd>
    <trdgrp lng="zh">
      <trd>&#x79BB;&#x5FC3; <pr>l&iacute;x&imacron;n</pr></trd>,
      <trd>&#x79BB;&#x5FC3;&#x5F0F; <pr>l&iacute;x&imacron;nsh&igrave;</pr></trd>
    </trdgrp>
  </snc>
  <snc mrk="centri.0a.BOT">
    <uzo tip="fak">BOT</uzo>
    <dif>
      <klr>(pri <ref cel="inflor.0o">infloresko</ref>)</klr>
      &Ccirc;e kiu la centra floro elvolvi&gcirc;as unue.
    </dif>
    <trd lng="be">&c_c;&c_e;&c_n;&c_t;&c_r;&c_a;&c_b;&c_je;&c_zh;&c_n;&c_y;</trd>
    <trdgrp lng="ca">
      <trd>centr&iacute;fug</trd>,
      <trd>cim&oacute;s</trd>
    </trdgrp>
    <trd lng="hu">f&uuml;rt&ouml;s</trd>
    <trd lng="nl">centrifugaal</trd>
  </snc>
  <rim>
    La&ubreve; <fnt><bib>BL</bib></fnt>: Prefere diru <ke>decentra</ke>.
  </rim>
  <ref tip="ant" cel="centri1.0a">centripeta</ref>
  <trd lng="he">&samekh;&#x5B7;&resh;&kaf;&#x5BC;&#x5B6;&zayin;&#x5B6;&tav;</trd>
  <trd lng="ja">&#36960;&#x5FC3;&#x306E;  <pr>&#12360;&#12435;&#12375;&#12435;&#x306E;</pr></trd>
  <trd lng="sk">centrifug&aacute;lny, odstrediv&yacute;</trd>
  <trd lng="sk">centrifug&aacute;lny, odstrediv&yacute;</trd>
  <trdgrp lng="cs">
    <trd>odst&rcaron;ediv&yacute;</trd>,
    <trd>odvodn&yacute;</trd>
  </trdgrp>
  <trd lng="uk">&c_v;&c_ib;&c_d;&c_c;&c_je;&c_n;&c_t;&c_r;&c_o;&c_v;&c_i;&c_j;</trd>
</drv>

<drv mrk="centri.0ilo">
  <kap><tld/>ilo</kap>
  <snc mrk="centri.0ilo.MAS">
    <uzo tip="fak">MAS</uzo>
    <dif>
      <tld lit="C"/>a ma&scirc;ino, precipe uzata por
      disigi malsame densajn flua&jcirc;ojn, elpeli
      flua&jcirc;on de solida&jcirc;o...:
      <ekz>
        sur la laborebeno de la kuirejo mi malkovris
        monstran <tld/>ilon kaj dispecigitajn resta&jcirc;ojn
        de verdaj folioj kaj &scirc;osoj
        <fnt>
          <aut>G. P. Savio</aut>,
          <vrk><url
          ref="http://esperantaretradio.blogspot.com/2013/11/nur-legomsukoj-kaj-fruktosukoj.html">
          Nur legomsukoj kaj fruktosukoj</url></vrk>,
          <lok>Esperanta Retradio, 2014-11-06</lok>
        </fnt>;
      </ekz>
      <ekz>
        trog&ccirc;enoj elmarigis la nafton, tamen eblus aliaj metodoj: pumpiloj, rulbendoj,
        padelradoj, <tld/>iloj
        <fnt>
          <bib>Monato</bib>
          <aut>Christian Bertin</aut>
          <vrk><url ref="&Monato;/2003/008085.html"
              >&Ccirc;u revo iam fari&gcirc;os realo?</url></vrk>
          <lok>2003</lok>
        </fnt>;
      </ekz>
      <ekz>
        unu el la gravaj punktoj estas la nombro da <tld/>iloj, kiujn Irano estonte
        rajtos uzi <klr>[por ri&ccirc;igi uranon]</klr>
        <fnt>
          <bib>Monato</bib>
          <aut>Evgeni Georgiev</aut>
          <vrk><url ref="&Monato;/2015/011421.php"
              >Intertraktoj interrompitaj</url></vrk>
          <lok>2015</lok>
        </fnt>.
      </ekz>
    </dif>
  </snc>
  <trd lng="be">&c_c;&c_e;&c_n;&c_t;&c_r;&c_y;&c_f;&c_u;&c_g;&c_a;</trd>
  <trdgrp lng="cs">
    <trd>centrifuga</trd>,
    <trd>centrovka</trd>,
    <trd>odst&rcaron;edivka</trd>
  </trdgrp>
  <trd lng="de">Zentrifuge</trd>
  <trd lng="en">centrifuge</trd>
  <trd lng="fr">centrifugeuse</trd>
  <trd lng="he">&samekh;&#x5B7;&resh;&kaf;&#x5BC;&#x5B6;&zayin;&#x5B6;&tav;</trd>
  <trd lng="it">centrifuga</trd>
  <trdgrp lng="ja">
    <trd>&#33073;&#x6C34;&#x6A5F;  <pr>&#12384;&#12387;&#12377;&#12356;&#x304D;</pr></trd>,
    <trd>&#36960;&#x5FC3;&#20998;&#x96E2;&#x6A5F;  <pr>&#12360;&#12435;&#12375;&#12435;&#12406;&#12435;&#x308A;&#x304D;</pr></trd>
  </trdgrp>
  <trd lng="sk">odstredivka</trd>
  <trd lng="uk">&c_c;&c_je;&c_n;&c_t;&c_r;&c_i;&c_f;&c_u;&c_gu;&c_a;</trd>
  <trd lng="zh">&#x79BB;&#x5FC3;&#20998;&#x79BB;&#x673A; <pr>l&iacute;x&imacron;nf&emacron;nl&iacute;j&imacron;</pr></trd>
</drv>
</art>
