    <trd>extempore</trd>,
    <trd>improviz&aacute;cia</trd>
  </trdgrp>
  <trdgrp lng="uk">
    <trd>&c_je;&#x43A;&c_s;&c_t;&c_je;&#x43C;&#x43F;&#x43E;&c_r;&c_a;&#x43B;&c_ib;&#x44F;</trd>,
    <trd>&c_je;&#x43A;&c_s;&c_t;&c_je;&#x43C;&#x43F;&#x43E;&c_r;&c_a;&#x43B;&c_je; (&c_v;&c_i;&c_d; &#x43A;&#x43B;&c_a;&c_s;&#x43D;&#x43E;&c_g;&#x43E;
