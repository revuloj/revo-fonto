      Lerneja <ref tip="super" cel="ekzerc.0o">ekzerco</ref>, farata improvize, senprepare:
      <ekz>
        li ricevis nesufi&ccirc;an poenton por <tld/>o
        <fnt>
          <aut>Valentina &Jcirc;uravlova</aut>
          <vrk><url ref="http://www.esperanto.mv.ru/TRIZ/aventuro.html">Aventuro</url></vrk>
          <lok>&ccirc;ap. 2</lok>
        </fnt>.
      </ekz>
    </dif>
  </snc>
  <rim>
    La&ubreve; <fnt><bib>BL</bib></fnt>: Prefere diru <ke>improviza&jcirc;o</ke>, <ke>improvizita ekzerco</ke>,
    <ke>senprepara ekzerco</ke>.
  </rim>
  <trdgrp lng="be">
    <trd>&c_t;&c_v;&c_o;&c_r;&c_a;&c_p;&c_ib;&c_s;</trd>,
    <trd>&c_s;&c_a;&c_ch;&c_y;&c_n;&c_je;&c_n;&c_mol;&c_n;&c_je;</trd>
  </trdgrp>
  <trdgrp lng="cs">
    <trd>extempore</trd>,
    <trd>improvizace</trd>
  </trdgrp>
  <trdgrp lng="de">
     <trd>Extemporale</trd>,
     <trd>unangek&uuml;ndigte Arbeit</trd>,
     <trd>Probearbeit</trd>
  </trdgrp>
  <trd lng="es">extemporaneo</trd>
  <trd lng="hu">r&ouml;pdolgozat</trd>
  <trd lng="ja">&#x6F14;&#x7FD2;&#x554F;&#x984C;  <pr>&#12360;&#12435;&#12375;&#12421;&#12358;&#12418;&#12435;&#12384;&#12356;</pr></trd>
  <trdgrp lng="pl">
    <trd>kartk&oacute;wka</trd>,
    <trd>klas&oacute;wka<klr> (k. s&aogonek; zazwyczaj
    zapowiadane)</klr></trd>
