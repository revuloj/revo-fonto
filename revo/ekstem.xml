  <trd lng="pt">improvisa&ccedil;&atilde;o</trd>
  <trd lng="ru">&c_s;&c_o;&c_ch;&c_i;&c_n;&c_je;&c_n;&c_i;&c_je;
  <klr>(&c_sh;&c_k;&c_o;&c_l;&c_mol;&c_n;&c_o;&c_je;)</klr></trd>
