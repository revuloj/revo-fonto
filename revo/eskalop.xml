<?xml version="1.0"?>
<!DOCTYPE vortaro SYSTEM "../dtd/vokoxml.dtd">
<vortaro>
<art mrk="$Id: eskalop.xml,v 1.13 2026/03/06 08:00:21 revo Exp $">
<kap>
  <rad>eskalop</rad>/o <fnt><bib>PIV1</bib></fnt>
</kap>
<drv mrk="eskalop.0o">
  <kap><tld/>o</kap>
  <snc mrk="eskalop.0o.KUI">
    <dif>
      Maldika fi&scirc;- a&ubreve; viandotran&ccirc;a&jcirc;o sen ostoj:
      <ekz>
        unu el la rabistoj <klr>...</klr> regalis sin per <tld/>oj
        <fnt><bib>RabistFab</bib></fnt>;
      </ekz>
      <ekz>
        <ind>Viena <tld/>o</ind> kun terpomsalato kaj legomsalato
        <fnt>
          <aut>Bavara Esperanto-Ligo</aut>,
          <vrk><url ref="">Invito al la bavara
          Zamenhoffesto...</url></vrk>,
          <lok>2006</lok>
        </fnt>.
        <trd lng="ca">escalopa vienesa</trd>
        <trd lng="de">Wiener Schnitzel</trd>
        <trd lng="en">Wiener schnitzel</trd>
        <trdgrp lng="fr">
          <trd>escalope &agrave; la viennoise</trd>,
          <trd>escalope viennoise</trd>
        </trdgrp>
        <trd lng="hu">b&eacute;csi szelet</trd>
        <trd lng="ja">&#12532;&#12451;&#12540;&#12490;&#12540;&#12539;&#12471;&#12517;&#12491;&#12483;&#12484;&#12455;&#12523;</trd>
        <trdgrp lng="nl">
          <trd>Wienerschnitzel</trd>,
          <trd>schnitzel</trd>
        </trdgrp>
        <trd lng="pl">sznycel wiede&nacute;ski</trd>
        <trd lng="zh">&#32173;&#20063;&#32013;&#28856;&#32905;&#25490; <pr>W&eacute;iy&ecaron;n&agrave; zh&aacute; r&ograve;up&aacute;i</pr></trd>
      </ekz>
    </dif>
    <ref tip="vid" cel="kotlet.0o">kotleto</ref>
  </snc>
  <trd lng="be">&c_e;&c_s;&c_k;&c_a;&c_l;&c_o;&c_p;</trd>
  <trd lng="ca">escalopa</trd>
  <trd lng="cs">&rcaron;&iacute;zek</trd>
  <trdgrp lng="de">
    <trd>Schnitzel</trd>
  </trdgrp>
  <trdgrp lng="en">
    <trd>escalope</trd>,
    <trd>scallop</trd>,
    <trd>schnitzel</trd>,
    <trd>cutlet</trd>,
    <trd>thin slice of meat</trd>
  </trdgrp>
  <trd lng="es">escalope</trd>
  <trd lng="fr">escalope</trd>
  <trdgrp lng="hu">
    <trd>h&uacute;sszelet</trd>,
    <trd>halszelet</trd>
  </trdgrp>
  <trd lng="it">scaloppina</trd>
  <trdgrp lng="nl">
    <trd>vleeslapje</trd>,
    <trd>filetlapje</trd>,
    <trd>escalope</trd>,
    <trd>schnitzel</trd>
  </trdgrp>
  <trdgrp lng="pl">
    <trd>eskalopka</trd>,
    <trd>eskalop</trd>,
    <trd>eskalopek</trd>
  </trdgrp>
  <trd lng="pt">escalope</trd>
  <trd lng="sk">reze&ncaron;</trd>
  <trd lng="uk">&c_je;&c_s;&c_k;&c_a;&c_l;&c_o;&c_p;</trd>
  <trdgrp lng="zh">
    <trd>&#32048;&#29255; <pr>x&igrave;pi&agrave;n</pr></trd>,
    <trd>&#30862;&#24067;&#26465; <pr>su&igrave;b&ugrave;ti&aacute;o</pr></trd>
  </trdgrp>
</drv>
</art>

