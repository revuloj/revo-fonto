<?xml version="1.0"?>
<!DOCTYPE vortaro SYSTEM "../dtd/vokoxml.dtd">
<vortaro>
<art mrk="$Id: sxtrum.xml,v 1.38 2026/04/29 12:00:22 revo Exp $">
<kap>
  <ofc>*</ofc>
  <rad>&scirc;trump</rad>/o
<fnt><bib>UV</bib></fnt></kap>
<drv mrk="sxtrum.0o">
  <kap><ofc>*</ofc><tld/>o</kap>
  <uzo tip="fak">TEKS</uzo>
  <snc>
    <dif>
      Sakforma al&gcirc;ustigita pli malpli &gcirc;isgenua
      <ref tip="lst" lst="voko:vesta&jcirc;oj" cel="vest.pied0o">piedvesto</ref> trikita:
      <ekz>
        altkvalita servistaro, kiu paradis en silkaj <tld/>oj
        <fnt>
          <bib>Fab3</bib>
        </fnt>;
      </ekz>
      <ekz>
        li venas la&ubreve; la &scirc;tuparo malla&ubreve;te, &ccirc;ar li havas sur la piedoj nur <tld/>ojn
        <fnt>
          <bib>Fab2</bib>
          <lok>Dio de dormo</lok>
        </fnt>;
      </ekz>
      <ekz>
        &scirc;i trikis <tld/>on, kaj la &scirc;talaj trikiloj brilis en la radioj de la suno,
        kvaza&ubreve; fajreroj
        <fnt>
          <bib>IK</bib>
          <lok>&Ccirc;aptiro V</lok>
        </fnt>;
      </ekz>
      <ekz>
        per rapida movo &scirc;i formetis siajn <tld/>ojn, kaj ilin &jcirc;etis malproksimen, en
        angulon de la &ccirc;ambro
        <fnt>
          <bib>ChL</bib>
          <lok>&Ccirc;apitro Deka</lok>
        </fnt>;
      </ekz>
      <ekz>
        mi vestis la nigrajn <tld/>ojn kaj nigran
        kostumon<fnt><aut>Spomenka &Scirc;timec</aut>: <vrk>Hejmo en
        Meze&ubreve;ropo</vrk>, <bib>Monato</bib><lok>jaro 1996a, numero
        1a, p. 20a</lok></fnt>.
      </ekz>
    </dif>
    <refgrp tip="vid">
      <ref cel="gamasx.0o">gama&scirc;o</ref>
    </refgrp>
  </snc>
  <trd lng="be">&c_p;&c_a;&c_n;&c_ch;&c_o;&c_h;&c_a;</trd>
  <trd lng="bg">&c_ch;&c_o;&c_r;&c_a;&c_p;</trd>
  <trdgrp lng="ca">
    <trd>mitja</trd>,
    <trd>cal&ccedil;a</trd>
  </trdgrp>
  <trd lng="cs">pun&ccaron;ocha</trd>
  <trd lng="de">Strumpf</trd>
  <trd lng="el">&kappa;&alfa_ton;&lambda;&tau;&sigma;&alfa;</trd>
  <trd lng="en">stocking</trd>
  <trdgrp lng="es">
    <trd>media</trd>,
    <trd>calceta</trd>
  </trdgrp>
  <trd lng="fr">bas</trd>
  <trd lng="hu">harisnya</trd>
  <trd lng="id">stoking</trd>
  <trd lng="it">calza</trd>
  <trdgrp lng="ja">
    <trd>&#38263;&#38772;&#19979;  <pr>&#12394;&#12364;&#12367;&#12388;&#12375;&#12383;</pr></trd>,
    <trd>&#12473;&#12488;&#12483;&#12461;&#12531;&#12464;</trd>
  </trdgrp>
  <trd lng="nl">kous</trd>
  <trdgrp lng="pl">
    <trd>po&nacute;czocha</trd>,
    <trd>skarpeta</trd>
  </trdgrp>
  <trd lng="pt">meia</trd>
  <trd lng="ru">&c_ch;&c_u;&c_l;&c_o;&c_k;</trd>
  <trd lng="sk">pan&ccaron;ucha</trd>
  <trd lng="sv">strumpa</trd>
  <trd lng="uk">&c_p;&c_a;&c_n;&c_ch;&c_o;&c_h;&c_a;</trd>
  <trdgrp lng="zh">
    <trd>&#38263;&#35178; <pr>ch&aacute;ngw&agrave;</pr></trd>,
    <trd>&#38271;&#34972; <pr>ch&aacute;ngw&agrave;</pr></trd>,
    <trd>&#34972; <pr>w&agrave;</pr></trd>,
    <trd>&#35178; <pr>w&agrave;</pr></trd>
  </trdgrp>
</drv>

<drv mrk="sxtrum.0eto">
  <kap><tld/>eto</kap>
  <uzo tip="fak">TEKS</uzo>
  <snc>
    <dif>
      Mallonga saka <ref tip="super" cel="vest.pied0o">piedvesto</ref>
      kovranta nur la piedon kaj la malsupron de la kruro:
      <ekz>
        &scirc;i flikis al mi la <tld/>etojn
        <fnt>
          <bib>IKr</bib>
          <lok>Bol&ccirc;jo</lok>
        </fnt>;
      </ekz>
      <ekz>
        hezitante inter diverskoloraj <tld/>etoj
        <fnt>
          <bib>ChV</bib>
          <lok>2</lok>
        </fnt>;
      </ekz>
      <ekz>
        lia kvadratita pantalono estas tirita tiom alte ke videblas la malpuraj blankaj
        <tld/>etoj
        <fnt>
          <bib>MkM</bib>
          <lok>3</lok>
        </fnt>.
      </ekz>
    </dif>
    <refgrp tip="sin">
      <ref cel="sxtrum.duon0o">duon<tld/>o</ref>
    </refgrp>
  </snc>
  <trd lng="be">&c_sh;&c_k;&c_a;&c_r;&c_p;&c_e;&c_t;&c_k;&c_a;</trd>
  <trd lng="bg">&c_k;&c_malmol;&c_s;
  <ind>&c_ch;&c_o;&c_r;&c_a;&c_p;</ind></trd>
  <trdgrp lng="ca">
    <trd>mitj&oacute;</trd>,
    <trd>calcet&iacute;</trd>
  </trdgrp>
  <trd lng="cs">pono&zcaron;ka</trd>
  <trd lng="de">Socke</trd>
  <trd lng="en">sock</trd>
  <trd lng="es">calcet&iacute;n</trd>
  <trd lng="fr">chaussette</trd>
  <trdgrp lng="hu">
    <trd>r&ouml;vid <ind>harisnya</ind></trd>,
    <trd>zokni</trd>
  </trdgrp>
  <trdgrp lng="id">
    <trd><baz>kaus</baz>kaus kaki</trd>,
    <trd>mojah</trd>
  </trdgrp>
  <trd lng="it">calzino</trd>
  <trdgrp lng="ja">
    <trd>&#38772;&#19979;  <pr>&#12367;&#12388;&#12375;&#12383;</pr></trd>,
    <trd>&#12477;&#12483;&#12463;&#12473;</trd>
  </trdgrp>
  <trd lng="nl">sok</trd>
  <trd lng="pl">skarpetka</trd>
  <trd lng="pt">pe&uacute;ga</trd>
  <trdgrp lng="ru">
    <trd>&c_n;&c_o;&c_s;&c_o;&c_k;</trd>,
    <trd>&c_g;&c_o;&c_l;&c_mol;&c_f;</trd>
  </trdgrp>
  <trd lng="sk">pono&zcaron;ka</trd>
  <trdgrp lng="sv">
    <trd>socka</trd>,
    <trd>strumpa</trd>
  </trdgrp>
  <trd lng="uk">&c_sh;&c_k;&c_a;&c_r;&c_p;&c_je;&c_t;&c_k;&c_a;</trd>
  <trdgrp lng="zh">
    <trd>&#34972;&#23376; <pr>w&agrave;zi</pr></trd>,
    <trd>&#35178;&#23376; <pr>w&agrave;zi</pr></trd>,
    <trd>&#30701;&#34972; <pr>du&#462;nw&agrave;</pr></trd>,
    <trd>&#30701;&#35178; <pr>du&#462;nw&agrave;</pr></trd>
  </trdgrp>
</drv>

<drv mrk="sxtrum.duon0o">
  <kap>duon<tld/>o</kap>
  <uzo tip="fak">TEKS</uzo>
  <snc>
    <dif>
      <ref tip="dif" cel="sxtrum.0eto"><tld lit="&Scirc;"/>eto</ref>:
      <ekz>
        li &jcirc;etis la pantalonon &scirc;ultren kaj en duon<tld/>oj iris en la kuirejon
        <fnt>
          <bib>VRA</bib>
          <lok>Lars Ahlin</lok>
        </fnt>.
      </ekz>
    </dif>
  </snc>
  <trd lng="be">&c_sh;&c_k;&c_a;&c_r;&c_p;&c_e;&c_t;&c_k;&c_a;</trd>
  <trdgrp lng="ca">
    <trd>mitj&oacute;</trd>,
    <trd>calcet&iacute;</trd>
  </trdgrp>
  <trd lng="de">Socke</trd>
  <trd lng="en">sock</trd>
  <trdgrp lng="es">
    <trd>calcet&iacute;n</trd>,
    <trd>media <klr>(en Am&eacute;rica Latina)</klr></trd>
  </trdgrp>
  <trd lng="fr">chaussette</trd>
  <trd lng="hu">f&eacute;lharisnya</trd>
  <trdgrp lng="id">
    <trd><baz>kaus</baz>kaus kaki</trd>,
    <trd>mojah</trd>
  </trdgrp>
  <trd lng="it">calzino</trd>
  <trdgrp lng="ja">
    <trd>&#21322;&#38772;&#19979;  <pr>&#12399;&#12435;&#12367;&#12388;&#12375;&#12383;</pr></trd>,
    <trd>&#12495;&#12452;&#12477;&#12483;&#12463;&#12473;</trd>
  </trdgrp>
  <trd lng="nl">sok</trd>
  <trd lng="pl">kr&oacute;tka  <ind>skarpetka</ind></trd>
  <trd lng="pt">pe&uacute;ga</trd>
  <trdgrp lng="ru">
    <trd>&c_n;&c_o;&c_s;&c_o;&c_k;</trd>,
    <trd>&c_g;&c_o;&c_l;&c_mol;&c_f;</trd>
  </trdgrp>
  <trdgrp lng="sv">
    <trd>socka</trd>,
    <trd>strumpa</trd>
  </trdgrp>
  <trdgrp lng="zh">
    <trd>&#33337;&#34972; <pr>chu&aacute;nw&agrave;</pr></trd>,
    <trd>&#33337;&#35178; <pr>chu&aacute;nw&agrave;</pr></trd>,
    <trd>&#30701;&#34972; <pr>du&#462;nw&agrave;</pr></trd>,
    <trd>&#30701;&#35178; <pr>du&#462;nw&agrave;</pr></trd>
  </trdgrp>
</drv>

<drv mrk="sxtrum.0oligilo0osxelko">
  <kap><tld/>oligilo, <var><kap><tld/>o&scirc;elko</kap></var></kap>
  <uzo tip="fak">TEKS</uzo>
  <snc>
    <dif>
      Elasta <ref tip="super" cel="ruband.0o.ornamo">rubando</ref>
      servanta por stre&ccirc;e teni la <tld/>ojn:
      <ekz>
        levu mian <tld/>ligilon
        <fnt>
          <bib>Kandid</bib>
          <lok>&Ccirc;apitro XXII</lok>
        </fnt>;
      </ekz>
      <ekz>
        sinjorino Herbeno malagrafumis sian korseton, kaj, sin malforte flankenklininte,
        malalligis siajn <tld/>o&scirc;elkojn
        <fnt>
          <bib>ChL</bib>
          <lok>&Ccirc;apitro Deka</lok>
        </fnt>.
      </ekz>
    </dif>
    <refgrp tip="vid">
    <ref cel="ruband.sxtrumpa_0o">&scirc;trumpa rubando</ref>,
    <ref cel="gxarter.0o">&gcirc;artero</ref>,
    <ref cel="jxartel.0o">&jcirc;artelo</ref>
    </refgrp>
  </snc>
  <trd lng="be">&c_p;&c_a;&c_d;&c_v;&c_ja;&c_z;&c_k;&c_a;</trd>
  <trdgrp lng="ca">
    <trd>lligacama</trd>,
    <trd>camalliga</trd>,
    <trd>lliga</trd>,
    <trd>garrotera</trd>
  </trdgrp>
  <trdgrp lng="cs">
    <trd>podvazek</trd>,
    <trd>podvazkov&yacute; p&aacute;s</trd>
  </trdgrp>
  <trd lng="de">Strumpfband</trd>
  <trd lng="en">garter</trd>
  <trd lng="es">liga <klr>(sujeta calcetines)</klr></trd>
  <trd lng="fr">jarretelle</trd>
  <trd lng="hu">harisnyak&ouml;t&odblac;</trd>
  <trdgrp lng="id">
    <trd><baz>ikat</baz>ikat kaus kaki</trd>,
    <trd><baz>ikat</baz>pengikat kaus kaki</trd>
  </trdgrp>
  <trd lng="it">reggicalze</trd>
  <trdgrp lng="ja">
    <trd>&#38772;&#19979;&#30041;&#12417;  <pr>&#12367;&#12388;&#12375;&#12383;&#12393;&#12417;</pr></trd>,
    <trd>&#12460;&#12540;&#12479;&#12540;</trd>
  </trdgrp>
  <trd lng="nl">jarretel</trd>
  <trd lng="pl">podwi&aogonek;zka</trd>
  <trd lng="ru">&c_ch;&c_u;&c_l;&c_o;&c_ch;&c_n;&c_a;&c_ja;
  &c_p;&c_o;&c_d;&c_v;&c_ja;&c_z;&c_k;&c_a;</trd>
  <trdgrp lng="sk">
    <trd>podv&auml;zok</trd>,
    <trd>podv&auml;zkov&yacute; p&aacute;s</trd>
  </trdgrp>
  <trd lng="sv">strumpeband</trd>
  <trdgrp lng="zh">
    <trd>&#21514;&#24102; <pr>di&agrave;od&agrave;i</pr></trd>,
    <trd>&#21514;&#24118; <pr>di&agrave;od&agrave;i</pr></trd>,
    <trd>&#34972;&#24102; <pr>w&agrave;d&agrave;i</pr></trd>,
    <trd>&#35178;&#24118; <pr>w&agrave;d&agrave;i</pr></trd>
  </trdgrp>
</drv>
</art>
