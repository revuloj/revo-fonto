<?xml version="1.0"?>
<!DOCTYPE vortaro SYSTEM "../dtd/vokoxml.dtd">
<vortaro>
<art mrk="$Id: gxilin.xml,v 1.2 2026/07/15 14:06:14 afido Exp $">
<kap>
    <rad>&Gcirc;ilin</rad>/o <fnt><bib>LanLin</bib></fnt>,
    <var><kap><rad var="&gcirc;j">&Gcirc;jilin</rad>/o <fnt><bib>PIV2</bib></fnt></kap></var>
</kap>
<drv mrk="gxilin.0o">
  <kap><tld/>o,
  <var><kap><tld var="&gcirc;j"/>o</kap></var></kap>
  <snc mrk="gxilin.0o.GEOG">
    <uzo tip="fak">GEOG</uzo>
    <uzo tip="fak">POL</uzo>
    <dif>
      Provinco en la nord-orienta parto de <ref tip="malprt" cel="cxin.CX0ujo">&Ccirc;inujo</ref> kun la
      &ccirc;efurbo <ref tip="prt" cel="cxangcxun.0o">&Ccirc;ang&ccirc;uno</ref>:
      <ekz>
        nova&jcirc;oj pri la &ccirc;ina <klr>[&#x2026;]</klr> provinco <tld/>o
        <fnt>
          <aut>-</aut>
          <vrk><url ref="https://eo.wikinews.org/wiki/Kategorio:%C4%9Cilino">
          Kategorio: &Gcirc;ilino</url></vrk>
          <lok>Vikinova&jcirc;oj, 2015-01-04</lok>
        </fnt>;
      </ekz>
      <ekz>
        &Ccirc;inio celos <klr>[&#x2026;]</klr> poste plivastigi la zonon por ampleksi urbon &Ccirc;ang&ccirc;uno kaj
        provincon <tld var="&gcirc;j"/>o &gcirc;is la rivero <nom>Tumen</nom>
        <fnt>
          <aut>P. Pons, trad. M. Leon</aut>
          <vrk><url ref="https://eo.mondediplo.com/2011/01/article1705">
          En Nord-Koreio, la socio veki&gcirc;as</url></vrk>
          <lok>Le Monde diplomatique, 2011-01</lok>
        </fnt>.
      </ekz>
    </dif>
  </snc>
  <trd lng="de">Jilin</trd>
  <trd lng="fr">Jilin</trd>
  <trd lng="zh">&#x5409;&#x6797;&#x7701; <pr>J&iacute;l&iacute;n Sh&ecaron;ng</pr></trd>
</drv>
</art>

