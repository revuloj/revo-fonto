<kap>
  <ofc>3</ofc> <rad>korupt</rad>/i <fnt><bib>PVEF</bib></fnt>
</kap>
<drv mrk="korupt.0i">
  <kap><tld/>i</kap>
  <gra><vspec>tr</vspec></gra>
  <snc mrk="korupt.0i.EKON">
    <uzo tip="fak">EKON</uzo>
    <dif>
      <ref tip="dif" cel="acxet.sub0i">Suba&ccirc;eti</ref>:
      <ekz>
        <tld/>i ju&gcirc;iston;
      </ekz>
      <ekz>
        <tld/>ado okazas anka&ubreve; en demokratio, sed &gcirc;i ne restas por&ccirc;iame
        ka&scirc;ita, kiel
        montras la kazo
        <fnt>
          <bib>Monato</bib>
          <aut>Stefan Maul</aut>
          <vrk><url ref="&Monato;/2000/006835.php">Germanio: Pekoj de patriarko</url></vrk>
        </fnt>;
      </ekz>
      <ekz>
        en minimume unu lando vivas nek <tld/>antoj nek <tld/>atoj: Antarkto
        <fnt>
          <aut>Stefan Maul</aut>
          <vrk><url ref="&Monato;/2000/007252.php">Du mil</url></vrk>
          <bib>Monato</bib>
          <lok>2000/12, p. 5</lok>
        </fnt>;
      </ekz>
      <ekz>
        unu el la gangrenoj estas la mal&scirc;paremo kaj <tld/>ado, kiuj karakterizas
        preska&ubreve;
        &ccirc;iujn instancojn en la lando
        <fnt>
          <bib>Monato</bib>
          <aut>Bardhyl Selimi</aut>
          <vrk><url ref="&Monato;/2005/008378.php">Venkis mal&scirc;paremo kaj koruptado</url></vrk>
        </fnt>.
      </ekz>
    </dif>
    <refgrp tip="vid">
      <ref cel="cxanta.0i">&ccirc;anta&gcirc;i</ref>,
      <ref cel="kompro1.0i">kompromiti</ref>
    </refgrp>
    <trdgrp lng="be">
      <trd>&c_p;&c_a;&c_d;&c_k;&c_u;&c_p;&c_a;&c_c;&c_mol;</trd>,
      <trd>&c_d;&c_a;&c_v;&c_a;&c_c;&c_mol; <ind>&c_h;&c_a;&c_b;&c_a;&c_r;</ind></trd>
    </trdgrp>
    <trd lng="de">bestechen</trd>
    <trd lng="en">corrupt</trd>
    <trd lng="es">sobornar</trd>
    <trdgrp lng="fr">
      <trd>corrompre<klr tip="ind"> (par de l'argent)</klr></trd>,
      <trd>acheter<klr tip="ind"> (soudoyer)</klr></trd>,
      <trd>graisser la patte (&agrave;)</trd>,
      <trd>payer<klr tip="ind"> (soudoyer)</klr></trd>,
      <trd>soudoyer</trd>,
      <trd>suborner<klr tip="ind"> (par de l'argent)</klr></trd>
    </trdgrp>
    <trdgrp lng="hu">
      <trd>megv&aacute;s&aacute;rol <klr tip="ind">(megveszteget)</klr></trd>,
      <trd>megveszteget</trd>
    </trdgrp>
    <trdgrp lng="nl">
      <trd>omkopen</trd>
      <trd>corrumperen</trd>,
      <trd><ind>corrupt</ind> maken</trd>
    </trdgrp>
    <trdgrp lng="pt">
      <trd>corromper</trd>,
      <trd>fazer <ind>corrup&ccedil;&atilde;o</ind></trd>
    </trdgrp>
    <trdgrp lng="ru">
      <trd>&c_p;&c_o;&c_d;&c_k;&c_u;&c_p;&c_a;&c_t;&c_mol;</trd>,
      <trd>&c_d;&c_a;&c_v;&c_a;&c_t;&c_mol; &c_v;&c_z;&c_ja;&c_t;&c_k;&c_u;</trd>
    </trdgrp>
  </snc>
  <snc mrk="korupt.0i.morale">
    <dif>
      Morale putrigi, morale difekti, malvirtigi, defaligi, malbonigi,
      a&ccirc;igi:
      <ekz>
        &ccirc;i tiujn homojn oni povas nek timigi, nek <tld/>i
        <fnt>
          <bib>Far3</bib>
          <lok>&Ccirc;apitro VII</lok>
        </fnt>;
      </ekz>
      <ekz>
        potenco <tld/>as
        <fnt>
          <aut>Stefan Maul</aut>

          <vrk><url ref="&Monato;/1993/A930802.php">Alarmsignalo el Italio</url></vrk>
          <bib>Monato</bib>
          <lok>1993/08, p. 5</lok>
        </fnt>;
      </ekz>
      <ekz>
        simpluloj ne <tld/>itaj de la civilizo;
      </ekz>
      <ekz>
        <tld/>i la stilon;
      </ekz>
      <ekz>
        la spiritaj kaj korpaj <tld/>itoj de nia epoko.
      </ekz>
    </dif>
    <trd lng="be">&c_k;&c_a;&c_r;&c_u;&c_m;&c_p;&c_a;&c_v;&c_a;&c_c;&c_mol;</trd>
    <trdgrp lng="de">
        <trd>verderben</trd>,
        <trd>korrumpieren</trd>
     </trdgrp>
    <trdgrp lng="en">
      <trd>corrupt</trd>,
      <trd>taint</trd>
    </trdgrp>
    <trdgrp lng="hu">
      <trd>megront <klr tip="ind">(erk&ouml;lcsileg)</klr></trd>,
      <trd>korrump&aacute;l</trd>
    </trdgrp>
    <trd lng="nl">bederven</trd>
    <trd lng="es">corromper</trd>
    <trd lng="ru">&c_k;&c_o;&c_r;&c_r;&c_u;&c_m;&c_p;&c_i;&c_r;&c_o;&c_v;&c_a;&c_t;&c_mol;</trd>
  </snc>
  <rim>
    La&ubreve; <fnt><bib>BL</bib></fnt>: Anka&ubreve; eblas diri <ke>suba&ccirc;eti</ke>.
  </rim>

  <trdgrp lng="cs">
    <trd>po&scaron;kozovat</trd>,
    <trd>zra&ncaron;ovat</trd>
  </trdgrp>
  <trdgrp lng="fr">
    <trd>corrompre</trd>
  </trdgrp>
  <trdgrp lng="ja">
    <trd>&#x8CB7;&#x53CE;&#x3059;&#x308B;  <pr>&#x3070;&#x3044;&#x3057;&#x3085;&#x3046;&#x3059;&#x308B;</pr></trd>,
    <trd>&#x5815;&#x843D;&#x3055;&#x305B;&#x308B;  <pr>&#x3060;&#x3089;&#x304F;&#x3055;&#x305B;&#x308B;</pr></trd>,
    <trd>&#x8150;&#x6557;&#x3055;&#x305B;&#x308B;  <pr>&#x3075;&#x306F;&#x3044;&#x3055;&#x305B;&#x308B;</pr></trd>
  </trdgrp>
  <trdgrp lng="pl">
    <trd>przekupi&cacute;</trd>,
    <trd>korumpowa&cacute;</trd>
  </trdgrp>
  <trd lng="ro">corupe</trd>
  <trdgrp lng="sk">
    <trd>demoralizova&tcaron;</trd>,
    <trd>korumpova&tcaron;</trd>,
    <trd>podpl&aacute;ca&tcaron;</trd>
  </trdgrp>
  <trdgrp lng="zh">
    <trd>&#x8CD5; <pr>qi&uacute;</pr></trd>,
    <trd>&#x6557;&#x58DE; <pr>b&agrave;ihu&agrave;i</pr></trd>,
    <trd>&#x7AB3;&#x6557; <pr>y&#x1D4;b&agrave;i</pr></trd>,
    <trd>&#x884C;&#x8CC4; <pr>x&iacute;nghu&igrave;</pr></trd>,
    <trd>&#x8CC4;&#x8CB7; <pr>hu&igrave;m&#x1CE;i</pr></trd>,
    <trd>&#x8CC4;&#x8CC2; <pr>hu&igrave;l&ugrave;</pr></trd>
  </trdgrp>
</drv>

<drv mrk="korupt.0a">
  <kap>
    <tld/>a
  </kap>
  <snc mrk="korupt.0a.koruptanta">
    <dif>
      <tld lit="K"/>anta:
      <ekz>
        neniam li akceptis <tld/>an monon a&ubreve; donacon de suba&ccirc;etantoj
        <fnt>
          <bib>CKv</bib>
          <lok>7</lok>
        </fnt>;
      </ekz>
      <ekz>
        tiuj grandegaj spektaklegoj aktuale enfluigas multege da mona&ccirc;o en malklaran
        buljonon, kie miksi&gcirc;as investa&jcirc;oj sponsoraj, publikaj, politikaj kaj fine
        neeviteble <tld/>aj
        <fnt>
          <bib>Kon11</bib>
          <lok>&Ccirc;efartikolo</lok>
        </fnt>.
      </ekz>
    </dif>
    <trd lng="de">Bestechungs-</trd>
  </snc>
  <snc mrk="korupt.0a.envolvita">
    <dif>
      Envolvita en, difektita de <tld/>ado:
      <ekz>
        <tld/>a re&gcirc;imo
        <fnt>
          <bib>Kon11</bib>
          <lok>&Ccirc;efartikolo</lok>
        </fnt>;
      </ekz>
      <ekz>
        burokratoj <klr>[&#x2026;]</klr> &gcirc;is sangover&scirc;o defendos sian <tld/>an postenon
        <fnt>
          <bib>Kon11</bib>
          <lok>&Ccirc;efartikolo</lok>
        </fnt>;
      </ekz>
      <ekz>
        <tld/>aj parlamentanoj vo&ccirc;donas kontra&ubreve; siaj propraj interesoj
        <fnt>
          <bib>Monato</bib>
          <aut>Werner Schad</aut>
          <vrk>Putrantaj demokratioj</vrk>
        </fnt>;
      </ekz>
      <ekz>
        ri&ccirc;a&jcirc;oj eniras la po&scirc;ojn de <tld/>aj politikistoj
        <fnt>
          <bib>Monato</bib>
          <aut>Princo Henriko Oguinye/pg</aut>
          <vrk><url ref="&Monato;/2006/008821.php"
              >Forpasi, elspezi</url></vrk>
          <lok>2006</lok>
        </fnt>.
      </ekz>
    </dif>
    <trdgrp lng="de">
      <trd>korrupt</trd>,
      <trd>bestechlich</trd>,
      <trd>korrumpiert</trd>,
      <trd>verdorben</trd>
    </trdgrp>
    <trd lng="en">corrupt</trd>
  </snc>
</drv>

<drv mrk="korupt.0o">
  <kap><tld/>o, <var><kap><tld/>ado</kap></var></kap>
  <snc mrk="korupt.0o.KOMUNE">
    <dif>
      Ago <tld/>i; rezulto de tiu ago, <tld/>eco:
      <ekz>
        degenero de tradiciaj partioj, akompanata de <tld/>o
        <fnt>
          <aut>Stefan Maul</aut>
          <vrk><url ref="&Monato;/1993/A930802.php">Alarmsignalo el Italio</url></vrk>
          <bib>Monato</bib>
          <lok>1993/08, p. 5</lok>
        </fnt>;
      </ekz>
      <ekz>
        <tld/>o vidi&gcirc;as en preska&ubreve; &ccirc;iuj landoj
        <fnt>
          <aut>Stefan Maul</aut>
          <vrk><url ref="&Monato;/1993/A930802.php">Alarmsignalo el Italio</url></vrk>
          <bib>Monato</bib>
          <lok>1993/08, p. 5</lok>
        </fnt>;
      </ekz>
      <ekz>
        ne &ccirc;io glatas en la lando &ndash; polico kruelas, <tld/>ado grandas, &ccirc;efaj
        televidkanaloj plenas je &scirc;tata propagando
        <fnt>
          <bib>Monato</bib>
          <aut>Nikolao Gudskov </aut>
          <vrk><url ref="&Monato;/2015/011365.php"
              >Rigardo al la interna Rusio deekstere</url></vrk>
          <lok>2015</lok>
        </fnt>;
      </ekz>
      <ekz>
        se iu ajn estus tiel malsa&gcirc;a, ke li ekstarus en la senato kaj proponus tion, li
        estus akuzita pri <tld/>o a&ubreve; adulto a&ubreve; iu simila krimo
        <fnt>
          <bib>MJA</bib>
          <lok>Parto Tria</lok>
        </fnt>;
      </ekz>
      <ekz>
        parolante, ekzemple, pri <tld/>o, oni bone povas uzi la antikvan aludon: Azeno
        &scirc;argita per oro transsaltas e&ccirc; la plej altajn murojn
        <fnt>
          <bib>Ret</bib>
          <lok>Dua Parto</lok>
        </fnt>!
      </ekz>
    </dif>
  </snc>
  <trdgrp lng="be">
    <trd>&c_k;&c_a;&c_r;&c_u;&c_p;&c_c;&c_y;&c_ja;</trd>,
    <trd>&c_k;&c_a;&c_r;&c_u;&c_m;&c_p;&c_a;&c_v;&c_a;&c_n;&c_a;&c_s;&c_mol;&c_c;&c_mol;</trd>
  </trdgrp>
  <trdgrp lng="de">
    <trd>Bestechung</trd>
    <trd>Korruption</trd>
  </trdgrp>
  <trd lng="fr">corruption</trd>
  <trd lng="ja">&#x6C5A;&#x8077;&#x4F53;&#x8CEA;  <pr>&#x304A;&#x3057;&#x3087;&#x304F;&#x305F;&#x3044;&#x3057;&#x3064;</pr></trd>
  <trd lng="nl">corruptie</trd>
  <trd lng="pl">korupcja</trd>
  <trd lng="ro">corup&tcomma;ie</trd>
  <trdgrp lng="zh">
    <trd>&#x8CAA;&#x6C61; <pr>t&amacron;nw&umacron;</pr></trd>,
    <trd>&#x8CC4;&#x8CC2; <pr>hu&igrave;l&ugrave;</pr></trd>,
    <trd>&#x8CAA;&#x6C59;&#x8150;&#x5316; <pr>t&amacron;nw&umacron;f&#x1D4;hu&agrave;</pr></trd>,
    <trd>&#x8CAA;&#x6C61;&#x8150;&#x6557; <pr>t&amacron;nw&umacron;f&#x1D4;b&agrave;i</pr></trd>,
    <trd>&#x8CC4;&#x8CB7; <pr>hu&igrave;m&#x1CE;i</pr></trd>,
    <trd>&#x4E0D;&#x8AA0;&#x4FE1; <pr>b&ugrave;ch&eacute;ngx&igrave;n</pr></trd>,
    <trd>&#x71DF;&#x79C1;&#x821E;&#x5F0A; <pr>y&iacute;ngs&imacron;w&#x1D4;b&igrave;</pr></trd>,
    <trd>&#x8CAA;&#x6C61;&#x7F6A; <pr>t&amacron;nw&umacron;zu&igrave;</pr></trd>,
    <trd>&#x8150;&#x8CC2; <pr>f&#x1D4;l&ugrave;</pr></trd>
  </trdgrp>
</drv>

<drv mrk="korupt.0eco">
  <kap><var><kap><tld/>eco</kap></var></kap>
  <snc mrk="korupt.0eco.KOMUNE">
    <dif>
      Stato de tio, kio <tld/>i&gcirc;is:
      <ekz>
        pro <tld/>eco jam centoj da &scirc;ajne bonfamaj politikistoj de l' grandaj partioj
        perdis postenon kaj reputacion
        <fnt>
          <aut>Stefan Maul</aut>

          <vrk><url ref="&Monato;/1993/A930802.php">Alarmsignalo el Italio</url></vrk>
          <bib>Monato</bib>
          <lok>1993/08, p. 5</lok>
        </fnt>;
      </ekz>
      <ekz>
        Albanio ne &scirc;an&gcirc;i&gcirc;is: regas sama <tld/>eco kiel en la pasinteco
        <fnt>
          <aut>Bardhyl Selimi</aut>
            <vrk><url ref="&Monato;/2001/007284.html">Listo de ruzo kaj manipulado</url></vrk>
            <bib>Monato</bib>
            <lok>2001/01, p. 7</lok>
          </fnt>.
