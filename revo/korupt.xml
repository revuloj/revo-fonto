  </snc>
  <trdgrp lng="be">
    <trd>&c_k;&c_a;&c_r;&c_u;&c_p;&c_c;&c_y;&c_ja;</trd>,
    <trd>&c_k;&c_a;&c_r;&c_u;&c_m;&c_p;&c_a;&c_v;&c_a;&c_n;&c_a;&c_s;&c_mol;&c_c;&c_mol;</trd>
