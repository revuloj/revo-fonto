    <trd>&#x8CC4;&#x8CC2; <pr>hu&igrave;l&ugrave;</pr></trd>,
    <trd>&#x8CAA;&#x6C59;&#x8150;&#x5316; <pr>t&amacron;nw&umacron;f&#x1D4;hu&agrave;</pr></trd>,
    <trd>&#x8CAA;&#x6C61;&#x8150;&#x6557; <pr>t&amacron;nw&umacron;f&#x1D4;b&agrave;i</pr></trd>,
    <trd>&#x8CC4;&#x8CB7; <pr>hu&igrave;m&#x1CE;i</pr></trd>,
    <trd>&#x4E0D;&#x8AA0;&#x4FE1; <pr>b&ugrave;ch&eacute;ngx&igrave;n</pr></trd>,
    <trd>&#x71DF;&#x79C1;&#x821E;&#x5F0A; <pr>y&iacute;ngs&imacron;w&#x1D4;b&igrave;</pr></trd>,
    <trd>&#x8CAA;&#x6C61;&#x7F6A; <pr>t&amacron;nw&umacron;zu&igrave;</pr></trd>,
    <trd>&#x8150;&#x8CC2; <pr>f&#x1D4;l&ugrave;</pr></trd>
  </trdgrp>
</drv>

<drv mrk="korupt.ne0ebla">
  <kap>ne<tld/>ebla</kap>
  <snc mrk="korupt.ne0ebla.KOMUNE">
    <dif>
      Kiun oni ne povas <tld/>i, kiu kontra&ubreve; <tld/>o rezistas:
      <ekz>
        ne<tld/>ebla oficisto;
      </ekz>
      <ekz>
        la ekzamenoj estis severaj kaj la tri Meditantoj estis ne<tld/>eblaj
        <fnt>
          <aut>Michael Ende, trad. Wolfram Diestel</aut>
          <vrk>La Sen&ccirc;esa Rakonto</vrk>
          <lok>La Stelmona&hcirc;ejo</lok>
        </fnt>.
