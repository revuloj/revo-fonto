<art mrk="$Id: icid.xml,v 1.1 2026/05/28 23:43:20 afido Exp $">
<kap>
    -<rad>icid</rad>/ <fnt><bib>PIV1</bib></fnt>
</kap>
<drv mrk="icid.0">
  <kap><tld/></kap>
  <gra><vspec>sufikso</vspec></gra>
  <snc mrk="icid.0o.KOMUNE">
    <uzo tip="fak">AGR</uzo>
    <uzo tip="fak">MED</uzo>
    <dif>
      Substanco venena por iu kategorio de viva&jcirc;oj, kaj uzata
      en agrikulturo (<ref tip="vid" cel="pesticid.0o">pesticido</ref>),
      en medicino (mikrobicido kaj aliaj)...:
      <ekz>
        <ref tip="vid" cel="fungicid.0o">fung<tld/>o</ref>;
      </ekz>
      <ekz>
        teni<tld/>o
        <fnt><bib>PIV2</bib></fnt>.
      </ekz>
    </dif>
  </snc>
  <trd lng="fr">-icide</trd>
</drv>
</art>

