<?xml version="1.0"?>
<!DOCTYPE vortaro SYSTEM "../dtd/vokoxml.dtd">

<vortaro>
  <art mrk="$Id: perversi.xml,v 1.1 2026/06/26 09:50:23 afido Exp $">
    <kap>
      <rad>perversi</rad>/o
      <fnt><bib>PIV1</bib></fnt>
    </kap>

<drv mrk="perversi.0o">
  <kap><tld/>o</kap>
  <snc mrk="perversi.0o.MED">
    <uzo tip="fak">MED</uzo>
    <dif>
      Devio de normala funkcio, komunlingve
      ofte rilate al volupto kaj seksumado.
    </dif>
    <ref tip="vid" cel="patolo.0o.procezo">patologio<sncref/></ref>
    <trdgrp lng="de">
      <trd>Devianz</trd>,
      <trd>Paraphilie</trd>,
      <trd>Perversion</trd>
    </trdgrp>
  </snc>
  <snc mrk="perversi.0o.perverseco">
    <uzo tip="stl">KOMUNE</uzo>
    <dif>
      Perversa&jcirc;o:
      <ekz>
        &ccirc;ar la sistemoj kreitaj ne sukcesas funkcii, ree aperas malordo, <tld/>oj, do
        ree la abomeninda vorto &leftquot;anarkio&rightquot;, sed en la mala signifo rilate al demokratio
        <fnt>
          <bib>Monato</bib>
          <aut>Gilbert Ledon</aut>
          <vrk><url ref="https://www.monato.be/2001/007283.php"
              >Putraj demokratioj</url></vrk>
        </fnt>.
      </ekz>
    </dif>
    <trdgrp lng="de">
      <trd>Sittenlosigkeit</trd>,
      <trd>Unmoral</trd>,
      <trd>Abartigkeit</trd>
    </trdgrp>
  </snc>
  <trd lng="en">perversion</trd>
  <trd lng="fr">perversion</trd>
</drv>

<drv mrk="perversi.0a">
  <kap>
    <tld/>a
  </kap>
  <snc mrk="perversi.0a.MED">
    <uzo tip="fak">MED</uzo>
    <dif>
      Rilata al <tld/>o.
    </dif>
    <trdgrp lng="de">
      <trd>deviant</trd>,
      <trd>paraphil</trd>,
      <trd>pathologisch <klr>(krankhaft)</klr></trd>
    </trdgrp>
  </snc>
  <snc mrk="perversi.0a.KOMUNE">
    <uzo tip="stl">KOMUNE</uzo>
    <dif>
      <ref tip="dif" cel="perver.0a">Perversa</ref>:
      <ekz>
        oni nomas maljusta &ccirc;iun agon kiu detruas <klr>[&#x2026;]</klr> tian regantan principon
        de agado oni nomas <tld/>a
        <fnt>
          <bib>Rsp</bib>
          <lok>Parto Kvar</lok>
        </fnt>;
      </ekz>
      <ekz>
        la dosieroj plenas je malmoralaj kaj <tld/>aj porno-skriptoj
        <fnt>
          <bib>MMa</bib>
          <lok>&Ccirc;apitro 9</lok>
        </fnt>.
      </ekz>
    </dif>
    <trdgrp lng="de">
      <trd>unmoralisch</trd>,
      <trd>sittenlos</trd>,
      <trd>abartig</trd>,
      <trd>pervers</trd>
    </trdgrp>
  </snc>
  <trd lng="en">perverted</trd>
</drv>

  </art>


