<?xml version="1.0"?>
<!DOCTYPE vortaro SYSTEM "../dtd/vokoxml.dtd">
<vortaro>
<art mrk="$Id: sagac.xml,v 1.29 2026/05/21 20:10:44 revo Exp $">
<kap>
  <ofc>*</ofc>
  <rad>sagac</rad>/a <fnt><bib>UV</bib></fnt>
</kap>
<drv mrk="sagac.0a">
  <kap><ofc>*</ofc><tld/>a</kap>
  <snc mrk="sagac.0a.iu">
    <uzo tip="klr">(iu)</uzo>
    <dif>
      Spirite akrevida kaj klarju&gcirc;a, singarde elturni&gcirc;ema, subtile
      <ref cel="trov.el0ema">eltrovema</ref>:
      <ekz>
        vi perdis la <tld/>econ, kiun mi admiris en vi
        <fnt>
          <bib>Far3</bib>
          <lok>&Ccirc;apitro XI</lok>
        </fnt>;
      </ekz>
      <ekz>
        oni ne bezonis esti tre <tld/>a observanto, por penetri &gcirc;is fundo la dol&ccirc;an
        sekreton
        <fnt>
          <bib>ChL</bib>
          <lok>&Ccirc;apitro Dekunua</lok>
        </fnt>;
      </ekz>
      <ekz>
        la pika, morda, <tld/>a ironio de <nom>Volter</nom>
        <fnt>
          <bib>Kandid</bib>
          <lok>Anta&ubreve;parolo</lok>
        </fnt>;
      </ekz>
      <ekz>
        ver&scirc;ajne, diros <tld/>a kritikisto post du mil jaroj, la a&ubreve;toro estis nur
        dudek-kvinjara, kiam li verkis <nom>Kandid</nom>
        <fnt>
          <bib>Kandid</bib>
          <lok>Anta&ubreve;parolo</lok>
        </fnt>.
      </ekz>
    </dif>
    <refgrp tip="vid">
      <ref cel="inteli.0a">inteligenta</ref>,
      <ref cel="penetr.0ema">penetrema</ref>,
      <ref cel="sagx.0a">sa&gcirc;a</ref>,
      <ref cel="sprit.0a">sprita</ref>,
      <ref cel="subtil.0a">subtila</ref>
    </refgrp>
  </snc>
  <snc mrk="sagac.0a.io">
    <uzo tip="klr">(io)</uzo>
    <dif>
      Subtile, lerte eltrovita:
      <ekz>
        neniaj <tld/>aj politikaj kontraktoj donos pacon al la homaro
        <fnt>
          <aut>L.L. Zamenhof</aut>
          <vrk>Gentoj kaj Lingvo Internacia</vrk>
          <lok>1911</lok>
        </fnt>;
      </ekz>
      <ekz>
        birdoj fajfis <tld/>ajn trilojn
        <fnt>
          <bib>Metrop</bib>
        </fnt>;
      </ekz>
      <ekz>
        &ccirc;io en la &gcirc;ardeno de la imperiestro estis aran&gcirc;ita plej <tld/>e
        <fnt>
          <bib>Fab2</bib>
          <lok>La najtingalo</lok>
        </fnt>.
      </ekz>
    </dif>
  <trd lng="de">ausgekl&uuml;gelt</trd>
  <trd lng="en">sophisticated</trd>
  </snc>
  <trdgrp lng="be">
    <trd>&c_p;&c_r;&c_a;&c_n;&c_ib;&c_k;&c_l;&c_ib;&c_v;&c_y;</trd>,
    <trd>&c_p;&c_r;&c_a;&c_z;&c_o;&c_r;&c_l;&c_ib;&c_v;&c_y;</trd>
  </trdgrp>
  <trd lng="ca">saga&ccedil;</trd>
  <trdgrp lng="cs">
    <trd>chytr&yacute;</trd>,
    <trd>vychytral&yacute;</trd>
  </trdgrp>
  <trdgrp lng="de">
    <trd>scharfsinnig</trd>,
    <trd><ofc>*</ofc>spitzfindig</trd>
  </trdgrp>
  <trdgrp lng="en">
    <trd>sagacious</trd>,
    <trd>astute</trd>,
    <trd>shrewd</trd>,
    <trd>sharp</trd>
  </trdgrp>
  <trdgrp lng="fr">
    <trd>sagace</trd>,
    <trd>perspicace</trd>
  </trdgrp>
  <trdgrp lng="hu">
    <trd>&eacute;les esz&udblac;</trd>,
    <trd>lelem&eacute;nyes</trd>,
    <trd>tal&aacute;l&eacute;kony</trd>
  </trdgrp>
  <trd lng="it">sagace</trd>
  <trdgrp lng="ja">
    <trd>&#x660E;&#x654F;&#x306A;  <pr>&#12417;&#12356;&#12403;&#12435;&#x306A;</pr></trd>,
    <trd>&#x8CE2;&#x660E;&#x306A;  <pr>&#12369;&#12435;&#12417;&#12356;&#x306A;</pr></trd>,
    <trd>&#x5DE7;&#22937;&#x306A;  <pr>&#12371;&#12358;&#x307F;&#12423;&#12358;&#x306A;</pr></trd>,
    <trd>&#x629C;&#12369;&#x76EE;&#x306E;&#x306A;&#12356;  <pr>&#x306C;&#12369;&#12417;&#x306E;&#x306A;&#12356;</pr></trd>
  </trdgrp>
  <trdgrp lng="nl">
    <trd>schrander</trd>,
    <trd>scherpzinnig</trd>,
    <trd>vernuftig</trd>
  </trdgrp>
  <trdgrp lng="pl">
    <trd>bystry</trd>,
    <trd>przebieg&lstroke;y</trd>,
    <trd>przenikliwy</trd>,
    <trd>sprytny</trd>
  </trdgrp>
  <trdgrp lng="pt">
   <trd>sagaz</trd>
  </trdgrp>
  <trdgrp lng="ru">
    <trd>&c_p;&c_r;&c_o;&c_n;&c_i;&c_c;&c_a;&c_t;&c_je;&c_l;&c_mol;&c_n;&c_y;&c_j;</trd>,
    <trd>&c_p;&c_r;&c_o;&c_z;&c_o;&c_r;&c_l;&c_i;&c_v;&c_y;&c_j;</trd>
  </trdgrp>
  <trdgrp lng="sk">
    <trd>bystrohlav&yacute;</trd>,
    <trd>bystr&yacute;</trd>,
    <trd>d&ocirc;vtipn&yacute;</trd>,
    <trd>pref&iacute;kan&yacute;</trd>,
    <trd>umn&yacute;</trd>,
    <trd>vynaliezav&yacute;</trd>
  </trdgrp>
  <trdgrp lng="uk">
    <trd>&c_p;&c_r;&c_o;&c_n;&c_i;&c_k;&c_l;&c_i;&c_v;&c_i;&c_j;</trd>,
    <trd>&c_p;&c_r;&c_o;&c_z;&c_ib;&c_r;&c_l;&c_i;&c_v;&c_i;&c_j;</trd>,
    <trd>&c_p;&c_r;&c_o;&c_z;&c_o;&c_r;&c_l;&c_i;&c_v;&c_i;&c_j;</trd>
  </trdgrp>
  <trdgrp lng="zh">
    <trd>&#24935; <pr>hu&igrave;</pr></trd>,
    <trd>&#x660E;&#x667A; <pr>m&iacute;ngzh&igrave;</pr></trd>
  </trdgrp>
</drv>

<drv mrk="sagac.0o">
  <kap>
    <tld/>o
  </kap>
  <snc>
    <dif>
      Kapablo klare ju&gcirc;i, akre vidi, singarde elturni&gcirc;i ktp:
      <ekz>
        virino kun mirindaj <tld/>o kaj kono de la homa koro
        <fnt>
          <bib>I&scirc;tar</bib>
          <lok>&Ccirc;apitro III</lok>
        </fnt>;
      </ekz>
      <ekz>
        penu per via <tld/>o helpi al mi eviti &ccirc;i tiun malfeli&ccirc;on
        <fnt>
          <bib>I&scirc;tar</bib>
          <lok>&Ccirc;apitro XVIII</lok>
        </fnt>;
      </ekz>
      <ekz>
        li alte estimis la sa&gcirc;on kaj la <tld/>on de la amiko
        <fnt>
          <bib>I&scirc;tar</bib>
          <lok>&Ccirc;apitro III</lok>
        </fnt>;
      </ekz>
      <ekz>
        iliaj metodoj estas preska&ubreve; mirindaj pro sia <tld/>o
        <fnt>
          <bib>VaK</bib>
          <lok>Dekunua &Ccirc;apitro</lok>
        </fnt>.
      </ekz>
    </dif>
  </snc>
  <trdgrp lng="de">
    <trd>Scharfsinn</trd>,
    <trd>Klugheit</trd>,
    <trd>Spitzfindigkeit</trd>
  </trdgrp>
  <trdgrp lng="fr">
    <trd>sagacit&eacute;</trd>
  </trdgrp>
</drv>

<drv mrk="sagac.0ulo">
  <kap><tld/>ulo</kap>
  <snc mrk="sagac.0ulo.KOMUNE">
    <dif>
      Homo <tld/>a, bone ju&gcirc;anta, lerte aganta:
      <ekz>
        &leftquot;Korvino estas <tld/>ulino, mi &scirc;in admiras pro &scirc;ia
        klara ju&gcirc;kapablo&rightquot;
        <fnt>
          <aut>Chun-Chan Yeh, trad. W. Auld</aut>,
          <vrk>Montara Vila&gcirc;o</vrk>,
          <lok>1984</lok>
        </fnt>;
      </ekz>
      <ekz>
        <tld/>uloj atentigas, ke multe pli da homoj &ccirc;iutage mortas sur niaj stratoj
        <klr>[&#8230;]</klr>, sed &ccirc;u oni rajtas argumenti per unu malbono por pravigi alian
        fatala&jcirc;on
        <fnt>
          <bib>Monato</bib>
        </fnt>?
      </ekz>
    </dif>
  </snc>
  <trdgrp lng="be">
    <trd>&c_p;&c_r;&c_a;&c_n;&c_ib;&c_k;&c_l;&c_ib;&c_v;&c_y; &c_ch;&c_a;&c_l;&c_a;&c_v;&c_je;&c_k;</trd>,
    <trd>&c_s;&c_p;&c_r;&c_y;&c_t;&c_n;&c_ju;&c_g;&c_a;</trd>
  </trdgrp>
  <trdgrp lng="de">
    <trd>Scharfsinniger</trd>,
    <trd>Schlaumeier</trd>,
    <trd>kluger <ind>Kopf</ind></trd>,
    <trd>Fuchs <klr>(Schlaukopf)</klr></trd>
  </trdgrp>
  <trdgrp lng="fr">
    <trd>malin<klr> (subst.)</klr></trd>,
    <trd>perspicace<klr> (subst.)</klr></trd>
  </trdgrp>
  <trdgrp lng="pl">
    <trd>cwaniak</trd>,
    <trd>chytrus</trd>
  </trdgrp>
</drv>
</art>
