<?xml version="1.0"?>
<!DOCTYPE vortaro SYSTEM "../dtd/vokoxml.dtd">
<vortaro>
<art mrk="$Id: padel.xml,v 1.35 2026/07/11 06:00:21 revo Exp $">
<kap><rad>padel</rad>/o<fnt><bib>JED</bib></fnt></kap>
<drv mrk="padel.0o">
  <kap><tld/>o</kap>
    <snc mrk="padel.0o.TEK">
    <uzo tip="fak">TEK</uzo>
    <dif>
      <ref tip="super" cel="plat.0o">Plata</ref> parto de aparato 
      interaganta kun <ref tip="vid" cel="fluid.0ajxo">fluida&jcirc;o</ref> 
      por transformi me&hcirc;anikan <ref tip="vid" cel="mov.0o">movon</ref> 
      al <ref tip="vid" cel="flu.0o">fluo</ref> a&ubreve; fluon al 
      me&hcirc;anika movo:
      <ekz>
        <tld/>o de <ref tip="malprt" cel="rem.0ilo">remilo</ref>,
        <ref tip="malprt" cel="pagaj.0o">pagajo</ref>,
        <ref tip="malprt" cel="rad.padel0o"><tld/>rado</ref>;
      </ekz>
      <ekz>
        stir<tld/>o de raketo;
      </ekz>
      <ekz>
        tra vitromuro mi vidis, ke <tld/>oj de kelkaj vento-energiaj 
        radoj turni&gcirc;as malrapide
        <fnt>
          <aut>Sun Aijun</aut>:
          <vrk><url ref="http://www.china.org.cn/world/shi-sichou/sichou21.htm">en
          Dabancheng</url></vrk>
        </fnt>;
      </ekz>
      <ekz>
        la naboj trovi&gcirc;as en alteco de 135 metroj, la nacelo &ndash; kiu portas la
        rotor-<tld/>ojn &ndash; estas 14&#8239;m alta, <klr>[&#8230;]</klr> la diametro de la
        rotor-<tld/>oj estas 126&#8239;m
        <fnt>
          <aut>Evgeni Georgiev</aut>
          <vrk><url ref="&Monato;/2012/010765.php">A&ubreve;strio &#8208;
          Gigantaj ventoturbinoj</url></vrk>
          <bib>Monato</bib>
          <lok>2012/10, p. 27</lok>
        </fnt>.
      </ekz>
    </dif>
    <refgrp tip="sin">
    <ref cel="al1.0o">alo</ref>,
    <ref cel="flug.0ilo">flugilo</ref>.
  </refgrp>
  </snc>
  <trd lng="be">&c_l;&c_o;&c_p;&c_a;&c_s;&c_mol;&c_c;&c_mol;</trd>
  <trdgrp lng="ca">
    <trd>paleta<klr tip="amb"> (de roda hidr&agrave;ulica, de turbina)</klr></trd>,
    <trd>pala<klr tip="amb"> (d&#8217;h&egrave;lix, d&#8217;un rem)</klr></trd>
  </trdgrp>
  <trdgrp lng="cs">
    <trd>list</trd>,
    <trd>lopatka <klr>(turbiny, p&aacute;dla, vesla)</klr></trd>
  </trdgrp>
  <trdgrp lng="de">
    <trd>Fl&uuml;gel <klr tip="ind">(Windm&uuml;hle)</klr></trd>,
    <trd>Blatt <klr tip="ind">(Turbine, M&uuml;hlrad, Ruder)</klr></trd>.
  </trdgrp>
  <trdgrp lng="es">
     <trd>pala</trd>,
     <trd>aleta<klr tip="amb"> (de una h&eacute;lice)</klr></trd>
  </trdgrp>
  <trd lng="fr">pale</trd>
  <trdgrp lng="hu">
    <trd>lap&aacute;t <klr tip="ind">(ker&eacute;k&eacute;)</klr></trd>,
    <trd>toll <klr tip="ind">(evez&odblac;&eacute;)</klr></trd>.
  </trdgrp>
  <trd lng="it">pala<klr> (di remo, di elica, di turbina)</klr>
</trd>
  <trdgrp lng="ja">
    <trd>&#32701;&#26681;&#26495;  <pr>&#12399;&#12397;&#12356;&#12383;</pr></trd>,
    <trd>&#27700;&#12363;&#12365;  <pr>&#12415;&#12378;&#12363;&#12365;</pr></trd>,
    <trd>&#27330;  <pr>&#12363;&#12356;</pr></trd>,
    <trd>&#27700;&#12363;&#12365;&#26495;  <pr>&#12415;&#12378;&#12363;&#12365;&#12356;&#12383;</pr></trd>
  </trdgrp>
  <trd lng="nl">paddel</trd>
  <trd lng="pl">&lstroke;opata &sacute;mig&lstroke;a lub wirnika</trd>
  <trd lng="pt">p&aacute; <klr>(de roda, h&eacute;lice, turbina, remo)</klr></trd>
  <trd lng="ro">palet&abreve; de direc&#539;ie</trd>
  <trd lng="ru">&c_l;&c_o;&c_p;&c_a;&c_s;&c_t;&c_mol;</trd>
  <trd lng="sk">lopatka vesla</trd>
  <trdgrp lng="sv">
    <trd>paddel</trd>,
    <trd>skovel</trd>
  </trdgrp>
  <trdgrp lng="uk">
    <trd>&c_l;&c_o;&c_p;&c_a;&c_t;&c_mol; (&c_v;&c_je;&c_s;&c_l;&c_a;</trd>,
    <trd>&c_g;&c_r;&c_je;&c_b;&c_n;&c_o;&c_g;&c_o; &c_k;&c_o;&c_l;&c_je;&c_s;&c_a;</trd>,
    <trd>&c_t;&c_u;&c_r;&c_b;&c_ib;&c_n;&c_i;)</trd>
  </trdgrp>
  <trdgrp lng="zh">
    <trd>&#39080;&#24070; <pr>f&#275;ngf&#257;n</pr></trd>,
    <trd>&#39118;&#24070; <pr>f&#275;ngf&#257;n</pr></trd>,
    <trd>&#21494;&#29255; <pr>y&egrave;pi&agrave;n</pr></trd>,
    <trd>&#33865;&#29255; <pr>y&egrave;pi&agrave;n</pr></trd>
  </trdgrp>
</drv>

<drv mrk="padel.0i">
  <kap><tld/>i</kap>
  <gra><vspec>ntr</vspec></gra>
   <fnt><bib>ZR</bib></fnt>
  <snc mrk="padel.0i.SPO">
  <uzo tip="fak">SPO</uzo>
    <dif>
      Pu&scirc;i sin tra akvo per <tld/>batoj:
      <ekz>
        ili <tld/>is en miloj da kanuoj sur la riveroj kaj rikoltis maizon el siaj kampoj
        <fnt>
          <bib>Viki</bib>
          <vrk><url ref="&Viki;/Indianoj">Indianoj</url></vrk>
        </fnt>;
      </ekz>
      <ekz>
        li prenis malgrandan kanoton, en kiu <tld/>ante li kontra&ubreve;fluenveturis la
        rivereton
        <fnt>
          <aut>A. Strindberg</aut>
          <vrk><url
          ref="https://web.archive.org/web/20190206134748/http://miresperanto.com/biblioteko/insulo/04.htm">Insulo
          de feli&ccirc;uloj</url></vrk>
          <lok>&ccirc;ap. 4</lok>
        </fnt>;
      </ekz>
      <ekz>
        <uzo tip="stl">FIG</uzo>
        li <tld/>is per siaj grandaj piedoj pendantaj de la boataj flankoj
        <fnt>
          <bib>LOdE</bib>
          <vrk><url ref="&Tekstaro;?nomo=ondo-de-esperanto">La hobito, a&ubreve; tien kaj
          reen</url></vrk>
          <lok>Fragmento el la 5a &ccirc;apitro</lok>
        </fnt>.
      </ekz>
    </dif>
    <refgrp tip="vid">
      <ref cel="nagx.0i">na&gcirc;i</ref>,
      <ref cel="rem.0i">remi</ref>,
      <ref cel="vad.0i">vadi</ref>
    </refgrp>
    <trd lng="de">paddeln</trd>
    <trd lng="en">paddle</trd>
    <trd lng="fr">pagayer</trd>
    <trd lng="hu">lap&aacute;tol <klr tip="ind">(evez)</klr></trd>
    <trd lng="nl">paddelen</trd>
    <trd lng="ru">&c_g;&c_r;&c_je;&c_s;&c_t;&c_i;</trd>
    <trd lng="sv">paddla</trd>
    <trd lng="it">pagaiare</trd>
    <adm>
      PIV markas tiun sencon evitinda kaj preferas pagaji. <aut>wd</aut>
    </adm>
  </snc>
<!-- dubinda senco, kaj ne trovi&gcirc;is fonto!
  <snc mrk="padel.0i.VAD">
    <fnt>Z</fnt>
    <dif>
      Pene vadi en &scirc;limo; pla&ubreve;di 2.
    </dif>
    <trd lng="hu">tocsog</trd>
    <trd lng="nl">ploeteren</trd>
    <trd lng="ru">&c_sh;&c_l;&c_jo;&c_p;&c_a;&c_t;&c_mol; 
<klr tip="amb">(&c_b;&c_r;&c_je;&c_s;&c_t;&c_i; &c_p;&c_o;
    &c_v;&c_o;&c_d;&c_je;)</klr></trd>
    <trdgrp lng="it">
    <trd>guazzare</trd>,
    <trd>sguazzare</trd>
    </trdgrp>
    <adm>
    Kie Z uzis tiun vorton? <aut>wd</aut>
    </adm>
  </snc>
-->
<trd lng="be">&c_v;&c_je;&c_s;&c_l;&c_a;&c_v;&c_a;&c_c;&c_mol;</trd>
  <trdgrp lng="cs">
    <trd>p&aacute;dlovat</trd>,
    <trd>&scaron;plouchat</trd>
  </trdgrp>
  <trd lng="de">paddeln</trd>
  <trdgrp lng="ja">
    <trd>&#27497;&#12367;  <pr>&#12354;&#12427;&#12367;</pr></trd>,
    <trd>&#21205;&#12365;&#22238;&#12427;  <pr>&#12358;&#12372;&#12365;&#12414;&#12431;&#12427;</pr></trd>,
    <trd>&#26292;&#12428;&#12427;  <pr>&#12354;&#12400;&#12428;&#12427;</pr></trd>,
    <trd>&#12497;&#12481;&#12515;&#12497;&#12481;&#12515;&#12377;&#12427;</trd>
  </trdgrp>
  <trdgrp lng="pl">
    <trd>wios&lstroke;owa&cacute; pagajem</trd>,
    <trd>pluska&cacute; si&eogonek;</trd>
  </trdgrp>
  <trdgrp lng="ro">
    <trd>c&abreve;l&abreve;torie cu pagai</trd>,
    <trd>se ocupa</trd>
  </trdgrp>  
  <trdgrp lng="sk">
    <trd>p&aacute;dlova&tcaron;</trd>,
    <trd>&ccaron;&lcaron;apota&tcaron;</trd>
  </trdgrp>
  <trdgrp lng="uk">
    <trd>&c_v;&c_je;&c_s;&c_l;&c_u;&c_v;&c_a;&c_t;&c_i;</trd>,
    <trd>&c_g;&c_r;&c_je;&c_b;&c_t;&c_i;</trd>,
    <trd>&c_p;&c_l;&c_je;&c_s;&c_k;&c_a;&c_t;&c_i; (&c_v;&c_je;&c_s;&c_l;&c_o;&c_m; &c_ib; &c_t;.&c_p;.) &c_p;&c_o;
    &c_v;&c_o;&c_d;&c_ib;</trd>
  </trdgrp>
  <trdgrp lng="zh">
    <trd>&#21010;&#26728; <pr>hu&aacute;ji&#462;ng</pr></trd>,
    <trd>&#21010;&#27123; <pr>hu&aacute;ji&#462;ng</pr></trd>,
    <trd>&#21010; <pr>hu&aacute;</pr></trd>
  </trdgrp>
</drv>
</art>
