<?xml version="1.0"?>
<!DOCTYPE vortaro SYSTEM "../dtd/vokoxml.dtd">
<vortaro>
<art mrk="$Id: karmin.xml,v 1.26 2026/03/16 07:46:48 revo Exp $">
<kap>
  <ofc>*</ofc>
  <rad>karmin</rad>/o
<fnt><bib>UV</bib></fnt></kap>
<drv mrk="karmin.0o">
  <kap><ofc>*</ofc><tld/>o</kap>
  <snc mrk="karmin.0o.kolorilo">
    <dif>
      Iom viole ru&gcirc;a <ref tip="super" cel="kolor.0ilo">kolorilo</ref>, ekstraktata el
      <ref cel="kocxen.0o.ZOO">ko&ccirc;enilo<sncref/></ref>, ekzemple per
      precipitado de flua&jcirc;a prepara&jcirc;o el ili.
    </dif>
    <bld
      lok="&WCU;/thumb/8/85/Carmine.JPG/250px-Carmine.JPG"
      prm="CC BY-SA 3.0"
      >pigmento de <tld/>o
        <fnt>
          <aut>Stephhzz, propra verko</aut>
          <lok><url ref="&WCW;/File:Carmine.JPG"
              >https://commons.wikimedia.org/wiki/File:Carmine.JPG</url></lok>
        </fnt>
    </bld>
  </snc>
  <snc mrk="karmin.0o.koloro">
    <dif>
      Samaspekta <ref tip="super" cel="kolor.0o.propre">koloro</ref>:
      <ekz>
        en la grundo aperas senfina gamo de kolornuancoj: de helega flavsafrano &gcirc;is
        vinfe&ccirc;kolora purpurviolo, kaj de <tld/>o &gcirc;is vermiljono
        <fnt>
          <bib>Monato</bib>
          <aut>Robert Roze</aut>
          <vrk>Francio: Flagrantaj koloroj</vrk>
        </fnt>.
      </ekz>
    </dif>
  </snc>
  <trd lng="be">&c_k;&c_a;&c_r;&c_m;&c_ib;&c_n;</trd>
  <trd lng="bg">&c_k;&c_a;&c_r;&c_m;&c_i;&c_n;</trd>
  <trd lng="br">ruz-tane</trd>
  <trd lng="ca">carm&iacute;</trd>
  <trd lng="cs">karm&iacute;n</trd>
  <trd lng="de">Karminrot</trd>
  <trd lng="en">carmine</trd>
  <trd lng="es">carm&iacute;n</trd>
  <trd lng="fr">carmin<klr tip="ind"> (subst., colorant)</klr></trd>
  <trdgrp lng="hu">
    <trd>k&aacute;rmin</trd>,
    <trd>b&iacute;borv&ouml;r&ouml;s fest&eacute;k</trd>
  </trdgrp>
  <trdgrp lng="ja">
    <trd>&#x30AB;&#x30EB;&#x30DF;&#x30F3;</trd>,
    <trd>&#x6D0B;&#x7D05;  <pr>&#x3088;&#x3046;&#x3053;&#x3046;</pr></trd>
  </trdgrp>
  <trd lng="nl">karmijn</trd>
  <trd lng="pl">karmin</trd>
  <trd lng="ro">carmin</trd>
  <trd lng="ru">&c_k;&c_a;&c_r;&c_m;&c_i;&c_n;</trd>
  <trd lng="sk">karm&iacute;n</trd>
  <trd lng="uk">&c_k;&c_a;&c_r;&c_m;&c_ib;&c_n; (&c_f;&c_a;&c_r;&c_b;&c_a;)</trd>
</drv>

<drv mrk="karmin.0a">
  <kap>
    <tld/>a
  </kap>
  <snc>
    <dif>
      <tld lit="K"/>kolora:
      <ekz>
        <tld/>a ru&gcirc;o kovris la viza&gcirc;on de Klaro
        <fnt>
          <bib>IK</bib>
          <lok>&Ccirc;apitro I</lok>
        </fnt>;
      </ekz>
      <ekz>
        <tld/>a koloro de la lipoj
        <fnt>
          <bib>Marta</bib>
        </fnt>;
      </ekz>
      <ekz>
        ru&gcirc;a <klr>[&#x2026;]</klr> karmezina, skarlata, punca, <tld/>a, vermiljona, eble anka&ubreve;
        al fuksina, rufa, kaj e&ccirc; al oran&gcirc;a
        <fnt>
          <bib>LAE</bib>
          <lok>5. Leksiko Kaj Semantiko</lok>
        </fnt>;
      </ekz>
      <ekz>
        ili sidis en <tld/>velura kupeo
        <fnt>
          <bib>MMa</bib>
          <lok>&Ccirc;apitro 8</lok>
        </fnt>.
      </ekz>
    </dif>
  </snc>
  <trd lng="de">karminrot</trd>
  <trd lng="fr">carmin<klr tip="ind"> (adj.)</klr></trd>
</drv>

</art>
