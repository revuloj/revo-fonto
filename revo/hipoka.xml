<?xml version="1.0"?>
<!DOCTYPE vortaro SYSTEM "../dtd/vokoxml.dtd">
<vortaro>
<art mrk="$Id: hipoka.xml,v 1.37 2026/04/20 15:43:48 revo Exp $">
<kap>
  <rad>hipoka&scirc;tan</rad>/o <fnt><bib>PVEF</bib></fnt>
</kap>
<drv mrk="hipoka.0o">
  <kap><tld/>o</kap>
  <snc mrk="hipoka.0o.KUI">
    <uzo tip="fak">KUI</uzo>
    <dif>
      Neman&gcirc;ebla frukto de <tld/>arbo, simila al ka&scirc;tano:
      <ekz>
        ili vizitis la <tld/>ajn arbojn kaj enpo&scirc;igis &ccirc;iujn <tld/>ojn surtere videblajn
        <fnt>
          <aut>D. W. Munns</aut>
          <vrk><url ref="https://mondmilito.hypotheses.org/files/2019/12/londonadinoj2.pdf">
          Londonanidoj</url></vrk>
          <lok>1946</lok>
        </fnt>.
      </ekz>
    </dif>
    <trd lng="fr">marron d'inde</trd>
  <bld
  lok="&WCU;/thumb/0/06/Aesculus_hippocastanum_fruit_J3.jpg/330px-Aesculus_hippocastanum_fruit_J3.jpg"
  prm="CC BY-SA 3.0"><tld/>a frukto, fotita en Belgujo
       <fnt>
         <aut>Jamain, propra verko</aut>
         <lok><url
         ref="&WCW;/File:Aesculus_hippocastanum_fruit_J3.jpg">&WCW;/File:Aesculus_hippocastanum_fruit_J3.jpg</url></lok>
       </fnt>
  </bld>
  </snc>
  <snc mrk="hipoka.0o.BOT">
    <uzo tip="fak">BOT</uzo>
    <dif>
      <ref tip="dif" cel="hipoka.0ujo.BOT"><tld lit="H"/>arbo</ref>:
      <ekz>
        ekde 1991 en A&ubreve;strio kaj &ccirc;irka&ubreve;aj landoj la minista tineo &ccirc;iun someron brunigas la foliojn
        de <tld/>oj
        <fnt>
          <bib>Monato</bib>
          <aut>Walter Klag/pg</aut>
          <vrk><url ref="&Monato;/2006/008925.php">Kribrilo mortiga</url></vrk>
        </fnt>;
      </ekz>
      <ekz>
        la interkolegiaj sportaj ludantoj kaj teamoj de Ohia &Scirc;tata Universitato
        (O&Scirc;U) estas nomataj <nom>Buckeye</nom>, la&ubreve; la &scirc;tata arbo, la amerika <tld/>o
        <fnt>
          <bib>Monato</bib>
          <aut>Barry Friedman</aut>
          <vrk><url ref="&Monato;/2008/009591.php">Ohiaj &scirc;tataj Hipoka&scirc;tanoj</url></vrk>
        </fnt>.
      </ekz>
    </dif>
  <trd lng="be">&c_k;&c_o;&c_n;&c_s;&c_k;&c_ib; &c_k;&c_a;&c_sh;&c_t;&c_a;&c_n;</trd>
  <trdgrp lng="bg">
    <trd>&c_k;&c_o;&c_n;&c_s;&c_k;&c_i; &c_k;&c_je;&c_s;&c_t;&c_je;&c_n;</trd>,
    <trd>&c_d;&c_i;&c_v; &c_k;&c_je;&c_s;&c_t;&c_je;&c_n;</trd>
  </trdgrp>
  <trdgrp lng="de">
    <trd>Rosskastanie</trd>, <trd>Kastanie</trd>
  </trdgrp>
  <trd lng="en">horse chestnut</trd>
  <trdgrp lng="es">
    <trd>falso casta&ntilde;o<klr tip="ind"> (&aacute;rbol)</klr></trd>,
    <trd><ind>casta&ntilde;o</ind> de Indias</trd>
  </trdgrp>
  <trd lng="fa">&a_sh;&a_A;&a_h;&#8204;&a_b;&a_l;&a_w;&a_T; &a_h;&a_n;&a_d;&f_y;</trd>
  <trd lng="fr">marronnier d'inde</trd>
  <trdgrp lng="hu">
    <trd>vadgesztenye<klr tip="ind"> (fa)</klr></trd>,
    <trd>bokr&eacute;tafa</trd>,
    <trd>l&oacute;gesztenye<klr tip="ind"> (fa)</klr></trd>
  </trdgrp>
  <trdgrp lng="it">
    <trd>ippocastano</trd>,
    <trd><ind>castagno</ind> d'India</trd>
  </trdgrp>
  <trdgrp lng="ja">
    <trd>&#x30DE;&#x30ED;&#x30CB;&#x30A8;</trd>,
    <trd>&#x30BB;&#x30A4;&#x30E8;&#x30A6;&#x30C8;&#x30C1;&#x30CE;&#x30AD;</trd>
  </trdgrp>
  <trdgrp lng="nl">
    <trd>paardekastanje</trd>,
    <trd>wilde <ind>kastanje</ind></trd>
  </trdgrp>
  <trd lng="pl">kasztanowiec</trd>
  <trd lng="pt">hipocastan&aacute;cea</trd>
  <trd lng="ru">&c_k;&c_o;&c_n;&c_s;&c_k;&c_i;&c_j; &c_k;&c_a;&c_sh;&c_t;&c_a;&c_n;</trd>
  <trd lng="uk">&c_g;&c_ib;&c_r;&#x43A;&#x43E;&#x43A;&c_a;&c_sh;&c_t;&c_a;&#x43D;</trd>
  <trd lng="zh">&#x686B; <pr>su&#x14D;</pr></trd>
  </snc>
</drv>

<drv mrk="hipoka.0ujo">
  <kap><tld/>ujo <fnt><aut> W. F. Pilger</aut> <vrk><url
  ref="https://www.eventoj.hu/steb/vortaroj/pplp-u8.htm">Provizora Privata Listo de Komunlingvaj
  Nomoj de Plantoj de Nord-Okcidenta E&ubreve;ropo</url></vrk> <lok>1982</lok></fnt>,
  <var><kap><tld/>arbo</kap></var></kap>
  <snc mrk="hipoka.0ujo.BOT">
    <uzo tip="fak">BOT</uzo>
    <dif>
      <ref tip="lst" cel="genr.0o.BIO" lst="voko:botanikaj_genroj">Genro</ref> el familio <ref
      tip="malprt" cel="hipoka1.0oj"><tld/>acoj</ref>
      (<trd lng="la">Aesculus</trd>):
      <ekz>
        la suno mallevi&gcirc;is <klr>[&#8230;]</klr> malanta&ubreve; la pintoj de aro da grandaj <tld/>arboj
        <fnt>
          <aut>H. A. Luyken</aut>
          <vrk><url ref="https://www.gutenberg.org/files/55954/55954-h/55954-h.htm">
          Stranga Hereda&jcirc;o</url></vrk>
          <lok>1922</lok>
        </fnt>.
      </ekz>
    </dif>
  </snc>
  <ref tip="vid" cel="kasxta.0arbo.BOT">ka&scirc;tanarbo</ref>
  <trd lng="be">&c_k;&c_o;&c_n;&c_s;&c_k;&c_ib; &c_k;&c_a;&c_sh;&c_t;&c_a;&c_n;</trd>
  <trdgrp lng="bg">
    <trd>&c_k;&c_o;&c_n;&c_s;&c_k;&c_i; &c_k;&c_je;&c_s;&c_t;&c_je;&c_n;</trd>,
    <trd>&c_d;&c_i;&c_v; &c_k;&c_je;&c_s;&c_t;&c_je;&c_n;</trd>
  </trdgrp>
  <trdgrp lng="de">
    <trd>Rosskastanie</trd>, <trd>Kastanie</trd>
  </trdgrp>
  <trd lng="en">horse chestnut</trd>
  <trdgrp lng="es">
    <trd>falso casta&ntilde;o<klr tip="ind"> (&aacute;rbol)</klr></trd>,
    <trd><ind>casta&ntilde;o</ind> de Indias</trd>
  </trdgrp>
  <trd lng="fa">&a_sh;&a_A;&a_h;&#8204;&a_b;&a_l;&a_w;&a_T; &a_h;&a_n;&a_d;&f_y;</trd>
  <trd lng="fr">marronnier d'inde</trd>
  <trdgrp lng="hu">
    <trd>vadgesztenye<klr tip="ind"> (fa)</klr></trd>,
    <trd>bokr&eacute;tafa</trd>,
    <trd>l&oacute;gesztenye<klr tip="ind"> (fa)</klr></trd>
  </trdgrp>
  <trdgrp lng="it">
    <trd>ippocastano</trd>,
    <trd><ind>castagno</ind> d'India</trd>
  </trdgrp>
  <trdgrp lng="ja">
    <trd>&#x30DE;&#x30ED;&#x30CB;&#x30A8;</trd>,
    <trd>&#x30BB;&#x30A4;&#x30E8;&#x30A6;&#x30C8;&#x30C1;&#x30CE;&#x30AD;</trd>
  </trdgrp>
  <trdgrp lng="nl">
    <trd>paardekastanje</trd>,
    <trd>wilde <ind>kastanje</ind></trd>
  </trdgrp>
  <trd lng="pl">kasztanowiec</trd>
  <trd lng="pt">hipocastan&aacute;cea</trd>
  <trd lng="ru">&c_k;&c_o;&c_n;&c_s;&c_k;&c_i;&c_j; &c_k;&c_a;&c_sh;&c_t;&c_a;&c_n;</trd>
  <trd lng="uk">&c_g;&c_ib;&c_r;&#x43A;&#x43E;&#x43A;&c_a;&c_sh;&c_t;&c_a;&#x43D;</trd>
  <trd lng="zh">&#x686B; <pr>su&#x14D;</pr></trd>
  <bld lok="&WCU;/thumb/d/de/Aesculus_hippocastanum_002.JPG/500px-Aesculus_hippocastanum_002.JPG"
  prm="CC BY-SA 3.0">folioj kaj floraro de <tld/>arbo (Aesculus hippocastanum), Karlsruhe, Germanujo
       <fnt>
         <aut>H. Zell, propra verko</aut>
         <lok><url
         ref="&WCW;/File:Aesculus_hippocastanum_002.JPG">&WCW;/File:Aesculus_hippocastanum_002.JPG</url></lok>
       </fnt>
  </bld>
</drv>
</art>
