<!DOCTYPE vortaro SYSTEM "../dtd/vokoxml.dtd">
<vortaro>
<art mrk="$Id: gvejgxo.xml,v 1.1 2026/07/14 17:34:57 afido Exp $">
<kap>
    <rad>Gvej&gcirc;o</rad>/o <fnt><bib>LanLin</bib></fnt>,
    <var><kap><rad var="vi">Gvi&gcirc;o&ubreve;</rad>/o </kap></var>,
    <var><kap><rad var="uj">Guj&gcirc;o&ubreve;</rad>/o  <fnt><bib>Po&scirc;Atlas</bib></fnt>
    <fnt><bib>PIV2</bib></fnt></kap></var>,
    <var><kap><rad var="&ubreve;i">G&ubreve;i&gcirc;o&ubreve;</rad>/o <fnt><bib>Viki</bib></fnt></kap></var>
</kap>
<drv mrk="gvejgxo.0o">
  <kap><tld/>o,
  <var><kap><tld var="vi"/>o</kap></var>,
  <var><kap><tld var="uj"/>o</kap></var>,
  <var><kap><tld var="&ubreve;i"/>o</kap></var>
  </kap>
  <snc mrk="gvejgxo.0o.GEOG">
    <uzo tip="fak">GEOG</uzo>
    <uzo tip="fak">POL</uzo>
    <dif>
      Provinco en la suda parto de <ref tip="malprt" cel="cxin.CX0ujo">&Ccirc;inujo</ref>:
      <ekz>
        nova&jcirc;oj pri la &ccirc;ina <klr>[&#8230;]</klr> provinco <tld/>o
        <fnt>
          <aut></aut>
          <vrk><url ref="https://eo.wikinews.org/wiki/Kategorio:Gvej%C4%9Doo">
          Kategorio: Gvej&gcirc;oo</url></vrk>
          <lok>Vikinova&jcirc;oj, 2015-01-04</lok>
        </fnt>;
      </ekz>
      <ekz>
        listo de la unuanivelaj dividoj de &Ccirc;inio: ... <tld var="vi"/>o
        <fnt>
          <aut>-</aut>
          <vrk><url ref="https://eo.wikipedia.org/wiki/Administra_divido_de_%C4%88inio">
          Administra divido de &Ccirc;inio</url></vrk>
          <lok>Vikipedio, 2026-07-01</lok>
        </fnt>;
      </ekz>
      <ekz>
        <tld var="uj"/>o nun estas centro por renovigebla energio, precipe venta energio
        <fnt>
          <aut>Y. Kurniawan</aut>
          <vrk><url
          ref="https://www.pressbridge.net/eo/2024/10/14/china-the-tech-powerhouse-and-cultural-preserver/">
          &Ccirc;inio: la Teknologia Potenco kaj Kultura Konservanto</url></vrk>
          <lok>2024-10-14</lok>
        </fnt>;
      </ekz>
      <ekz>
        <tld var="&ubreve;i"/>o <klr>[&#8230;]</klr> estas nomata &#8218;provinco de karbo&#8216;
        <fnt>
          <aut>-</aut>
          <vrk><url ref="https://eo.wikipedia.org/wiki/G%C5%ADi%C4%9Do%C5%ADo">
          G&ubreve;i&gcirc;o&ubreve;o</url></vrk>
          <lok>Vikipedio, 2026-02-05</lok>
        </fnt>.
      </ekz>
    </dif>
  </snc>
  <trd lng="fr">Guizhou</trd>
</drv>
</art>


