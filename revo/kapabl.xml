        kaj plue forigas la instruadon de geografio, art-historio kaj filozofio
        <fnt>
          <bib>Monato</bib>
          <aut>Roberto Pigro</aut>
          <vrk><url ref="&Monato;/2014/011257.php"
              >En rubujon, kulturo kaj lingvo de Italio</url></vrk>
          <lok>2014</lok>
        </fnt>.
      </ekz>
    </dif>
    <refgrp tip="vid">
