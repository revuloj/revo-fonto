<?xml version="1.0"?>
<!DOCTYPE vortaro SYSTEM "../dtd/vokoxml.dtd">

<vortaro>
  <art mrk="$Id: fotodiod.xml,v 1.1 2026/06/07 14:18:27 afido Exp $">
    <kap>
      <rad>fotodiod</rad>/o
    </kap>

<drv mrk="fotodiod.0o">
  <kap><tld/>o</kap>
  <snc mrk="fotodiod.0o.ELET">
    <uzo tip="fak">ELET</uzo>
    <dif>
      <ref tip="super" cel="diod.0o">Diodo</ref> transformanta lumon en elektron:
      <ekz>
        sun&ccirc;elo <klr>[&#x2026;]</klr> funkcias principe kiel <tld/>o
        <fnt>
          <bib>Viki</bib>
          <lok><url ref="https://eo.wikipedia.org/?curid=40324"
              >Sun&ccirc;elo</url></lok>
        </fnt>;
      </ekz>
      <ekz>
        kadmia telurido <klr>[&#x2026;]</klr> estas uzata <klr>[&#x2026;]</klr> kun kadmia sulfido,
        por formi p-n-transiron, <klr>[en]</klr> <tld/>o
        <fnt>
          <bib>Viki</bib>
          <lok><url ref="https://eo.wikipedia.org/?curid=338722"
              >Kadmia telurido</url></lok>
        </fnt>.
      </ekz>
    </dif>
    <trd lng="de">Photodiode</trd>
    <trd lng="en">photodiode</trd>
    <trd lng="fr">photodiode</trd>
    <trd lng="ru">&c_f;&c_o;&c_t;&c_o;&c_d;&c_i;&c_o;&c_d;</trd>
  </snc>
</drv>

  </art>

