<?xml version="1.0"?>
<!DOCTYPE vortaro SYSTEM "../dtd/vokoxml.dtd">
<vortaro>
<art mrk="$Id: harem.xml,v 1.27 2026/06/15 05:25:00 revo Exp $">
<kap>
  <ofc>2</ofc>
  <rad>harem</rad>/o <fnt><bib>JED</bib></fnt>
</kap>
<drv mrk="harem.0o">
  <kap><tld/>o</kap>
  <snc mrk="harem.0o.ejo">
    <dif>
      En <ref cel="poliga.0o.GEN">poligamia</ref> familio,
      apartamento rezervita al la edzinoj kaj kromvirinoj;
      virinejo:
      <ekz>
        legendo rakontas pri la &gcirc;ardeno de la <tld/>o en la
        tempo de la turkoj
        <fnt><bib>Fab3</bib>, <lok>Post jarmiloj</lok></fnt>;
      </ekz>
      <ekz>
        pro la scenoj en la <tld/>o kun duonnudaj dancistinoj en iuj bikino-similaj
        vesta&jcirc;oj la e&ubreve;ropaj kopioj plej ofte estis cenzuritaj, la dancoj fortran&ccirc;itaj
        <fnt>
          <bib>Monato</bib>
          <aut>Bernhard Pabst</aut>
          <vrk><url ref="&Monato;/2005/008759.php"
              >Internacia festivalo de la muta filmo</url></vrk>
          <lok>2005</lok>
        </fnt>.
      </ekz>
    </dif>
    <refgrp tip="vid">
      <ref cel="ginece.0o">gineceo</ref>,
      <ref cel="serajl.0o">serajlo</ref>.
    </refgrp>
    <rim>
      La&ubreve; <fnt><bib>BL</bib></fnt>: Anka&ubreve; eblas diri <ke>(vir)inejo</ke>.
    </rim>
  </snc>
  <snc mrk="harem.0o.inaro">
    <dif>
      La aro de tiuj inoj:
      <ekz>
        Salomono havis <tld/>on el sepcent &ccirc;efedzinoj kaj
        tricent kromvirinoj
        <fnt><bib>PIV1</bib></fnt>;
      </ekz>
      <ekz>
        forlasu la templon kaj ali&gcirc;u al mia <tld/>o
        <fnt>
          <bib>Far2</bib>
          <lok>&Ccirc;apitro X</lok>
        </fnt>;
      </ekz>
      <ekz>
        tiu pesto ne mortigis min, sed mian e&ubreve;nukon, la guberniestron kaj preska&ubreve; la
        tutan <tld/>an virinaron
        <fnt>
          <bib>Kandid</bib>
          <lok>&Ccirc;apitro XII</lok>
        </fnt>.
      </ekz>
    </dif>
  </snc>
  <trd lng="be">&c_g;&c_a;&c_r;&c_e;&c_m;</trd>
  <trd lng="br">harem</trd>
  <trd lng="cs">har&eacute;m</trd>
  <trd lng="de">Harem</trd>
  <trd lng="el">&chi;&alfa;&rho;&epsilon_ton;&my;&jota;</trd>
  <trd lng="en">harem</trd>
  <trd lng="es">harem</trd>
  <trd lng="fr">harem</trd>
  <trd lng="hu">h&aacute;rem</trd>
  <trd lng="it">harem</trd>
  <trdgrp lng="ja">
    <trd>&#x30CF;&#x30EC;&#x30E0;</trd>,
    <trd>&#x30CF;&#x30FC;&#x30EC;&#x30E0;</trd>,
    <trd>&#x5F8C;&#x5BAE;  <pr>&#x3053;&#x3046;&#x304D;&#x3085;&#x3046;</pr></trd>
  </trdgrp>
  <trd lng="nl">harem</trd>
  <trd lng="pl">harem</trd>
  <trd lng="pt">har&eacute;m</trd>
  <trd lng="ru">&c_g;&c_a;&c_r;&c_je;&c_m;</trd>
  <trd lng="sk">h&aacute;rem</trd>
  <trd lng="uk">&c_g;&c_a;&c_r;&c_je;&c_m;</trd>
  <trdgrp lng="zh">
    <trd>&#x95A8;&#x623F;&#x91CC;&#x7684;&#x59BB;&#x59BE;&#x7FA4;
    <pr>gu&imacron;f&aacute;ngl&#x1D0;deq&imacron;qi&egrave;q&uacute;n</pr></trd>,
    <trd>&#x95A8;&#x623F; <pr>gu&imacron;f&aacute;ng</pr></trd>
  </trdgrp>
</drv>
</art>
