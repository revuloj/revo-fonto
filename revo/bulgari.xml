<kap>
  <rad>Bulgari</rad>/o
</kap>

<drv mrk="bulgari.B0o">
  <kap><tld/>o</kap>
  <snc mrk="bulgari.B0o.GEOG">
    <uzo tip="fak">GEOG</uzo>
    <uzo tip="fak">POL</uzo>
    <dif>
      <ref tip="dif" cel="bulgar.B0ujo">Bulgarujo</ref>:
      <ekz>
        <tld lit="B"/>o estas lando en la balkana duoninsulo;
        <fnt><bib>Viki</bib>, <lok><url ref="&Viki;/Bulgario">Bulgario</url></lok></fnt>.
      </ekz>
      <ekz>
        <tld/>o efektivigis 65&#8239;% de sia eksporto la&ubreve; la rivero Danubo
        <fnt>
       <aut>Evgeni Georgiev</aut>
          <vrk><url ref="&Monato;/2000/006857.php">Danuba &scirc;iptrafiko paralizita</url></vrk>
          <bib>Monato</bib>
          <lok>2000/03, p. 16</lok>
        </fnt>;
      </ekz>
      <ekz>
        mi lo&gcirc;is en malgranda urbo en la norda <tld/>o, kie multaj lo&gcirc;antoj estis turkoj
        <fnt>
          <aut>Julian Modest</aut>
            <vrk><url ref="&Monato;/2001/007140.html">Vetiha</url></vrk>
            <bib>Monato</bib>
            <lok>2001/02, p. 26</lok>
          </fnt>;
      </ekz>
      <ekz>
        mi eklernis kiel 14-jara knabo en mia naski&gcirc;urbo Sofio, <tld/>o
        <fnt>
          <bib>Monato</bib>
          <vrk><url ref="&Monato;/2003/008035.html">Evgeni Georgiev</url></vrk>
          <lok>2003</lok>
        </fnt>.
      </ekz>
    </dif>
    <trd lng="zh">&#20445;&#21152;&#21033;&#20122; <pr>b&#462;oji&amacron;l&igrave;y&agrave;</pr></trd>
</snc>
  <trd lng="be">&c_B;&c_a;&c_w;&c_g;&c_a;&c_r;&c_y;&c_ja;</trd>
  <trd lng="bg">&c_B;&c_malmol;&c_l;&c_g;&c_a;&c_r;&c_i;&c_ja;</trd>
  <trd lng="ca">Bulg&agrave;ria</trd>
  <trd lng="cs">Bulharsko</trd>
  <trd lng="de">Bulgarien</trd>
  <trd lng="en">Bulgaria</trd>
  <trd lng="es">Bulgaria</trd>
  <trdgrp lng="fr">
    <trd>Bulgarie</trd>,
    <trd>R&eacute;publique de Bulgarie</trd>
  </trdgrp>
  <trd lng="he">&bet;&vav;&lamed;&gimel;&resh;&yod;&he;</trd>
  <trd lng="id">Bulgaria</trd>
  <trd lng="ja">&#12502;&#12523;&#12460;&#12522;&#12450;</trd>
  <trd lng="nl">Bulgarije</trd>
  <trd lng="pl">Bu&lstroke;garia</trd>
  <trd lng="ro">Bulgaria</trd>
  <trd lng="sk">Bulharsko</trd>
  <trd lng="uk">&c_B;&c_o;&c_l;&c_g;&c_a;&c_r;&c_ib;&c_ja;</trd>
</drv>
</art>

