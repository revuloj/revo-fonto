<?xml version="1.0"?>
<!DOCTYPE vortaro SYSTEM "../dtd/vokoxml.dtd">
<vortaro>
<art mrk="$Id: eklipt.xml,v 1.17 2026/06/14 05:06:36 revo Exp $">
<kap>
  <rad>ekliptik</rad>/o
  <fnt><bib>JED</bib></fnt>
</kap>
<drv mrk="eklipt.0o">
  <kap><tld/>o</kap>
  <uzo tip="fak">AST</uzo>
  <snc>
    <dif>
      Sur&ccirc;iela <ref cel="projek.0o">projekcio</ref>
      de la &scirc;ajna orbito, kiun faras la <ref cel="sun.0o.nia">suno</ref>
      &ccirc;irka&ubreve; la tero dum unu jaro:
      <ekz>
        solstico <klr>[okazas en]</klr> unu el la du punktoj de la <tld/>o mezaj inter
        la ekvinoksoj (t.e. apartigitaj de ili 90 gradojn), &ccirc;e la solsticoj, la suno
        atingas sian plej grandan altecon super a&ubreve; sub la &ccirc;iela ekvatoro
        <fnt>
          <bib>Viki</bib>
          <lok><url ref="https://eo.wikipedia.org/?curid=3982">Solstico</url></lok>
        </fnt>;
      </ekz>
      <ekz>
        la signoj de la zodiako kontra&ubreve;e estas nuraj partoj de la <tld/>o: oni dividas
        la vojon de la Suno (vidata el la Tero) en 12 partojn po 30 gradoj, ili
        ricevis la nomojn de la konstelacioj, en kiuj ili pli-malpli situis anta&ubreve;
        2000 jaroj
        <fnt>
          <bib>Viki</bib>
          <lok><url ref="https://eo.wikipedia.org/?curid=6721">Zodiako</url></lok>
        </fnt>;
      </ekz>
      <ekz>
        la orbito de Plutono estas tre nekutima por planedoj: &gcirc;i vagas ekster la
        <tld/>o, for de la zodiako, kaj e&ccirc; transiras la orbiton de Neptuno
        <fnt>
          <bib>Viki</bib>
          <lok><url ref="https://eo.wikipedia.org/?curid=3319">Plutono</url></lok>
        </fnt>.
      </ekz>
    </dif>
    <rim>
      La&ubreve; <fnt><bib>BL</bib></fnt>: Prefere diru <ke>suntera orbitebeno</ke>, <ke>tersuna
      orbitebeno</ke>.
    </rim>
  </snc>
  <trd lng="be">&c_e;&c_k;&c_l;&c_ib;&c_p;&c_t;&c_y;&c_k;&c_a;</trd>
  <trd lng="ca">ecl&iacute;ptica</trd>
  <trd lng="cs">ekliptika</trd>
  <trd lng="da">ekliptika</trd>
  <trd lng="de">Ekliptik</trd>
  <trd lng="en">ecliptic</trd>
  <trd lng="es">ecl&iacute;ptica</trd>
  <trd lng="fi">ekliptika</trd>
  <trd lng="fr">&eacute;cliptique</trd>
  <trdgrp lng="hu">
  <trd>ekliptika</trd>,
  <trd>napp&aacute;lya</trd></trdgrp>
  <trd lng="it">eclittica</trd>
  <trd lng="ja">&#x9EC4;&#36947; <pr>&#12371;&#12358;&#12393;&#12358;</pr></trd>
  <trd lng="nl">ecliptica</trd>
  <trd lng="pl">ekliptyka</trd>
  <trd lng="pt">ecl&iacute;ptica</trd>
  <trd lng="ru">&c_e;&c_k;&c_l;&c_i;&c_p;&c_t;&c_i;&c_k;&c_a;</trd>
  <trd lng="sk">ekliptika</trd>
  <trd lng="sv">ekliptikan</trd>
  <trdgrp lng="tr">
    <trd>ekliptik</trd>,
    <trd>tutulum</trd>
  </trdgrp>
  <trd lng="uk">&c_je;&#x43A;&#x43B;&c_ib;&#x43F;&c_t;&c_i;&#x43A;&c_a;</trd>
  <trd lng="zh">&#x9EC3;&#36947; <pr>hu&#xE1;ngd&#xE0;o</pr></trd>
</drv>
</art>
