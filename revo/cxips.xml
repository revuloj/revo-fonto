<?xml version="1.0"?>
<!DOCTYPE vortaro SYSTEM "../dtd/vokoxml.dtd">
<vortaro>
<art mrk="$Id: cxips.xml,v 1.16 2026/06/22 18:19:37 revo Exp $">
<kap>
  <rad>&ccirc;ips</rad>/o
</kap>
<drv mrk="cxips.0o">
  <kap><tld/>o</kap>
  <uzo tip="fak">KUI</uzo>
  <fnt><bib>HejmVort</bib></fnt>
  <snc>
    <dif>
      Tre maldika fritita tran&ccirc;a&jcirc;o de legomo a&ubreve; pasto, ofte el terpomo kaj salita a&ubreve; spicita:
      <ekz>
        malvaste konata in&gcirc;eniera atingo de <nom>Wolfe</nom> estas ke li
        estas kuninventinto de ma&scirc;ino uzata por fari la terpomajn <tld/>ojn
        <fnt>
          <bib>Viki</bib>
          <lok><url ref="https://eo.wikipedia.org/?curid=7356">Gene Wolfe</url></lok>
        </fnt>.
      </ekz>
    </dif>
    <ref tip="sub" cel="ter.0pomfloko">terpomfloko</ref>
  </snc>
  <rim>
    Kvankam oni ofte subkomprenas la plej kutiman terpoman <tld/>on, oni faras ilin ekz. anka&ubreve; el
    karotoj, pastinakoj, betoj, rizopasto, salikok-tapioka&jcirc;o ktp.
  </rim>
  <rim>
    La&ubreve; <fnt><bib>BL</bib></fnt>: (pri man&gcirc;a&jcirc;etoj) prefere diru <ke>floko</ke>; (se temas pri
    terpomoj) prefere diru <ke>terpomfloko</ke>; (se temas pri maizo) prefere diru (sala)
    <ke>maizfloko</ke> ; (se temas pri tiuj <nac>chips</nac>, kiuj angle nomi&gcirc;as <nac>tortilla
    chips</nac>) prefere diru <ke>maizpana floko</ke>; (la&ubreve; la signifo, kiun <nac>chips</nac> havas
    en kelkaj landoj) prefere diru <ke>terpomfingro</ke>.
  </rim>
  <trd lng="be">&c_ch;&c_y;&c_p;&c_s;&c_y;</trd>
  <trdgrp lng="en">
    <trd>potato chip <klr>(usone)</klr></trd>,
    <trd>crisp <klr>(brite)</klr></trd>
  </trdgrp>
  <trd lng="de">Chip</trd>
  <trd lng="es"><ind>papas</ind> fritas</trd>
  <trd lng="fr">chips</trd>
  <trd lng="he">&tsadi;'&yod;&pe;&samekh;</trd>
  <trdgrp lng="hu">
    <trd>burgonyaszirom</trd>,
    <trd>chips</trd>
  </trdgrp>
  <trdgrp lng="it">
   <trd><ind>patatina</ind> fritta <klr> (tipo tondo o
   croccante)</klr></trd>,
   <trd><ind>patata</ind> fritta <klr> (tipo tondo o
   croccante)</klr></trd>
  </trdgrp>
  <trdgrp lng="ja">
    <trd>&#12509;&#12486;&#12488;&#12481;&#12483;&#12503;</trd>,
    <trd>&#12509;&#12486;&#12481;</trd>
  </trdgrp>
  <trd lng="nl">chip<klr tip="ind"> (aardappelchip)</klr></trd>
  <trdgrp lng="pl">
    <trd>chips</trd>,
    <trd>chrupka <ind>ziemniaczana</ind></trd>,
    <trd>chrupka <ind>kartoflana</ind></trd>
  </trdgrp>
  <trd lng="ro">cipsuri</trd>
  <trd lng="ru">&c_ch;&c_i;&c_p;&c_s;&c_y; <klr>(plurale)</klr></trd>
</drv>
</art>

