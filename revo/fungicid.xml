<?xml version="1.0"?>
<!DOCTYPE vortaro SYSTEM "../dtd/vokoxml.dtd">
<vortaro>
<art mrk="$Id: fungicid.xml,v 1.1 2026/05/24 17:17:13 afido Exp $">
<kap>
    <rad>fungicid</rad>/o <fnt><bib>PIV1</bib></fnt>
</kap>
<drv mrk="fungicid.0o">
  <kap><tld/>o</kap>
  <snc mrk="fungicid.0o.AGR">
    <uzo tip="fak">AGR</uzo>
    <dif>
      <ref tip="super" cel="pesticid.0o.AGR">Pesticido</ref> per kiu oni mortigas fungojn a&ubreve; iliajn
      sporojn:
      <ekz>
        kemia&jcirc;oj <klr>[&#8230;]</klr> igas tiujn tomatojn dan&gcirc;eraj por la konsumantoj:
        akaricidoj, <tld/>oj, herbicidoj <klr>[&#8230;]</klr>
        <fnt>
          <aut>P. Daum, trad. T. Tailhades</aut>
          <vrk><url ref="https://eo.mondediplo.com/2016/05/article2357">
          Al&gcirc;eria Saharo : Eldorado de tomatoj</url></vrk>
          <lok>Le Monde diplomatique, 2016-06</lok>
        </fnt>.
      </ekz>
    </dif>
  </snc>
  <trd lng="de">Fungizid</trd>
  <trd lng="en">fungicide</trd>
  <trd lng="fr">fongicide</trd>
  <trd lng="it">fungicida</trd>
</drv>
</art>

