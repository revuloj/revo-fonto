<?xml version="1.0"?>
<!DOCTYPE vortaro SYSTEM "../dtd/vokoxml.dtd">
<vortaro>
<art mrk="$Id: friz.xml,v 1.34 2026/06/08 16:00:21 revo Exp $">
<kap>
  <ofc>*</ofc>
  <rad>friz</rad>/i <fnt><bib>UV</bib></fnt>
</kap>
<drv mrk="friz.0i">
  <kap><ofc>*</ofc><tld/>i</kap>
  <gra><vspec>tr</vspec></gra>
  <snc mrk="friz.0i.KOMUNE">
    <dif>
      Arte aran&gcirc;i harojn per kombado, tondado kaj similaj:
      <ekz>
        la sinjorinoj estis interrompitaj de <tld/>ita kelnero, kiu
        eniris dancante sur la pintoj de la piedoj
        <fnt><bib>FK</bib>, <lok>4, la porcio da glacia&jcirc;o</lok></fnt>;
      </ekz>
      <ekz>
        malnova portreto <klr>[&#8230;]</klr> prezentis <klr>[&#8230;]</klr> sinjorinon kun pudritaj
        alte <tld/>itaj haroj
        <fnt>
          <bib>Fab3</bib>
        </fnt>;
      </ekz>
      <ekz>
        virino de meza a&gcirc;o, kun haroj <klr>[&#8230;]</klr> glate <tld/>itaj sub eleganta
        blanka kufo
        <fnt>
          <bib>Marta</bib>
        </fnt>;
      </ekz>
      <ekz>
        delikata, preska&ubreve; diafana mano tu&scirc;etis la <tld/>itan kapon de la brava knabo
        <fnt>
          <bib>Far2</bib>
          <lok>&Ccirc;apitro XXIII</lok>
        </fnt>;
      </ekz>
      <ekz>
        ili prezentis majstra&jcirc;on de la <tld/>a arto
        <fnt>
          <bib>Marta</bib>
        </fnt>;
      </ekz>
      <ekz>
        junulo kun ne grandaj lipharoj kaj glate <tld/>itaj haroj
        <fnt><aut>Ivan G. &Scirc;irjaev</aut>, <vrk>Sen titolo</vrk>,
        <lok>&ccirc;apitro 37a</lok></fnt>.
      </ekz>
    </dif>
    <trdgrp lng="ca">
      <trd>arranjar<klr tip="ind"> (els cabells)</klr></trd>,
      <trd>arreglar<klr tip="amb"> (els cabells)</klr></trd>
    </trdgrp>
  </snc>
  <snc mrk="friz.0i.bukligi">
    <dif>
      Krispe, bukle kombi harojn:
      <ekz>
        <tld/>i harojn, barbon, plumojn;
      </ekz>
      <ekz>
        tiel ili paroladus, <tld/>ante la lipharojn
        <fnt>
          <bib>VivZam</bib>
        </fnt>.
      </ekz>
    </dif>
    <refgrp tip="sin">
       <ref cel="bukl.0i">bukli</ref>,
       <ref cel="krisp.0igi">krispigi</ref>,
       <ref cel="ond.0umi">ondumi</ref>
    </refgrp>
    <trdgrp lng="ca">
      <trd>arrissar</trd>,
      <trd>rullar</trd>
    </trdgrp>
    <trdgrp lng="de">
      <trd>zwirnen <klr>(Bart)</klr></trd>,
      <trd>zwirbeln</trd>,
    </trdgrp>
  </snc>
  <trd lng="be">&c_z;&c_a;&c_v;&c_ib;&c_v;&c_a;&c_c;&c_mol;
  <klr>(&c_v;&c_a;&c_l;&c_a;&c_s;&c_y;)</klr></trd>
  <trdgrp lng="cs">
    <trd>friz&iacute;rovat</trd>,
    <trd>kade&rcaron;it</trd>,
    <trd>nakade&rcaron;it</trd>,
    <trd>ondulovat</trd>,
    <trd>u&ccaron;esat</trd>,
    <trd>&ccaron;esat</trd>
  </trdgrp>
  <trd lng="de">frisieren</trd>
  <trdgrp lng="en">
    <trd>curl</trd>,
    <trd>friz</trd>,
    <trd>frizz</trd>,
    <trd>dress <klr tip="amb">(hair)</klr></trd>
  </trdgrp>
  <trdgrp lng="es">
    <trd>frisar <klr tip="amb">(cabello)</klr></trd>,
    <trd>rizar <klr tip="amb">(cabello)</klr></trd>,
    <trd>encrespar <klr tip="amb">(cabello)</klr></trd>
  </trdgrp>
  <trdgrp lng="fr">
    <trd>coiffer</trd>,
    <trd>friser<klr tip="ind"> (les cheveux)</klr></trd>
  </trdgrp>
  <trdgrp lng="hu">
    <trd>g&ouml;nd&ouml;r&iacute;t</trd>,
    <trd>bodor&iacute;t</trd>,
    <trd>frizur&aacute;t k&eacute;sz&iacute;t</trd>
  </trdgrp>
  <trdgrp lng="ja">
    <trd>&#12459;&#12540;&#12523;&#12377;&#12427;</trd>,
    <trd>&#12497;&#12540;&#12510;&#12434;&#12363;&#12369;&#12427; 
    <pr>&#12401;&#12540;&#12414;&#12434;&#12363;&#12369;&#12427;</pr></trd>
  </trdgrp>
  <trd lng="nl">kappen<klr tip="ind"> (haar)</klr></trd>
  <trdgrp lng="pl">
    <trd>fryzowa&cacute;</trd>,
    <trd>uk&lstroke;ada&cacute; w&lstroke;osy</trd>
  </trdgrp>
  <trdgrp lng="pt">
    <trd>frisar <klr tip="amb">(cabelo)</klr></trd>,
    <trd>encrespar <klr tip="amb">(cabelo)</klr></trd>,
    <trd>anelar <klr tip="amb">(cabelo)</klr></trd>
  </trdgrp>
  <trd lng="ru">&c_z;&c_a;&c_v;&c_i;&c_v;&c_a;&c_t;&c_mol;<klr tip="amb">
  (&c_v;&c_o;&c_l;&c_o;&c_s;&c_y;)</klr></trd>
  <trdgrp lng="sk">
    <trd>nakaderi&tcaron;</trd>,
    <trd>ondulova&tcaron;</trd>,
    <trd>&ccaron;esa&tcaron;</trd>
  </trdgrp>
  <trdgrp lng="uk">
    <trd>&c_z;&c_a;&c_v;&c_i;&c_v;&c_a;&c_t;&c_i;/&c_u;&c_k;&c_l;&c_a;&c_d;&c_a;&c_t;&c_i;
    &c_v;&c_o;&c_l;&c_o;&c_s;&c_s;&c_ja;</trd>,
    <trd>&c_r;&c_o;&c_b;&c_i;&c_t;&c_i; &c_z;&c_a;&c_ch;&c_ib;&c_s;&c_k;&c_u;</trd>
  </trdgrp>
  <trd lng="zh">&#39677; <pr>zhu&amacron;</pr></trd>
</drv>

<drv mrk="friz.0ajxo">
  <kap><tld/>a&jcirc;o</kap>
  <snc mrk="friz.0ajxo.KOMUNE">
    <dif>
      Arta <ref tip="super" cel="arangx.har0o">hararan&gcirc;o</ref>:
      <ekz>
        bruna frunto kun densa, nigra, malalte tondita <tld/>a&jcirc;o
        <fnt><bib>Marta</bib></fnt>;
      </ekz>
      <ekz>
        sur &scirc;ia pala bu&scirc;o aperadis de tempo al tempo rideto <klr>[&#8230;]</klr> kiam la
        eksaltoj de la magazenaj sinjoroj fari&gcirc;adis plej risortosimilaj, la
        <tld/>a&jcirc;oj plej movi&gcirc;emaj
        <fnt>
          <bib>Marta</bib>
        </fnt>;
      </ekz>
      <ekz>
        &scirc;iaj haroj estis ru&gcirc;aj kiel fajro kaj turigitaj je plej mirinda <tld/>a&jcirc;o el
        plekta&jcirc;oj kaj faskoj
        <fnt>
          <aut>Michael Ende, trad. Wolfram Diestel</aut>
          <vrk>La Sen&ccirc;esa Rakonto</vrk>
          <lok>La Vidanta Mano</lok>
        </fnt>.
      </ekz>
    </dif>
  </snc>
  <trd lng="be">&c_z;&c_a;&c_v;&c_ib;&c_w;&c_k;&c_a;</trd>
  <trd lng="ca">pentinat</trd>
  <trd lng="de">Frisur</trd>
  <trdgrp lng="en">
    <trd>friz</trd>,
    <trd>frizz</trd>,
    <trd>hairdo</trd>
  </trdgrp>
  <trdgrp lng="es">
    <trd>rizo</trd>,
    <trd>crespo</trd>,
    <trd>peinado</trd>
  </trdgrp>
  <trd lng="fr">coiffure<klr> (de cheveux)</klr></trd>
  <trd lng="hu">frizura</trd>
  <trdgrp lng="ja">
    <trd>&#12459;&#12540;&#12523;</trd>,
    <trd>&#24059;&#12365;&#27611;  <pr>&#12414;&#12365;&#12370;</pr></trd>
  </trdgrp>
  <trd lng="nl">kapsel</trd>
  <trd lng="pl">fryzura</trd>
  <trd lng="ro">coafur&abreve;</trd>
  <trd lng="ru">&c_z;&c_a;&c_v;&c_i;&c_v;&c_k;&c_a;</trd>
  <trdgrp lng="zh">
    <trd>&#21457;&#22411; <pr>f&#462;x&iacute;ng</pr></trd>,
    <trd>&#21457;&#24335; <pr>f&agrave;sh&igrave;</pr></trd>
  </trdgrp>
</drv>

<drv mrk="friz.0ejo">
  <kap><tld/>ejo</kap>
  <snc mrk="friz.0ejo.KOMUNE">
    <dif>
      Loko, kie oni <tld/>as, tondas, kombas, aran&gcirc;as la hararojn de
      klientoj:
      <ekz>
        mastrino de <tld/>ejo <klr>[&#8230;]</klr> tondis harojn de klientoj kaj eminentuloj
        <fnt>
          <bib>Monato</bib>
          <aut>Jomo Ipfelkofer</aut>
          <vrk><url ref="&Monato;/2009/009801.php">La blua miraklo</url></vrk>
          <lok>2009</lok>
        </fnt>.
      </ekz>
    </dif>
  </snc>
  <trd lng="be">&c_c;&c_y;&c_r;&c_u;&c_l;&c_mol;&c_n;&c_ja;</trd>
  <trd lng="bo">&t_sa;&t_kata;&t_rata;&t_tsheg;&t_kha;&t_nga;&t_tsheg;</trd>
  <trd lng="ca">perruqueria</trd>
  <trd lng="cs">kade&rcaron;nictv&iacute;</trd>
  <trd lng="de">Friseursalon</trd>
  <trd lng="en">hairdressing salon</trd>
  <trd lng="es">peluquer&iacute;a</trd>
  <trd lng="fr">salon de coiffure</trd>
  <trdgrp lng="ja">
    <trd>&#32654;&#23481;&#38498;  <pr>&#12403;&#12424;&#12358;&#12356;&#12435;</pr></trd>,
    <trd>&#12497;&#12540;&#12510;&#23627;  <pr>&#12497;&#12540;&#12510;&#12420;</pr></trd>
  </trdgrp>
  <trdgrp lng="pl">
    <trd>zak&lstroke;ad <ind>fryzjerski</ind></trd>,
    <trd>salon pi&eogonek;kno&sacute;ci</trd>
  </trdgrp>
  <trd lng="sk">kadern&iacute;ctvo</trd>
  <trd lng="uk">&c_p;&c_je;&c_r;&c_u;&c_k;&c_a;&c_r;&c_n;&c_ja;</trd>
  <trdgrp lng="zh">
    <trd>&#29702;&#21457;&#39302; <pr>l&#464;f&agrave;gu&#462;n</pr></trd>,
    <trd>&#21457;&#23627; <pr>f&amacron;w&#363;</pr></trd>,
    <trd>&#29702;&#21457;&#28857; <pr>l&#464;f&#462;di&agrave;n</pr></trd>,
    <trd>&#32654;&#21457;&#21381; <pr>m&ecaron;if&#462;t&#299;ng</pr></trd>
  </trdgrp>
</drv>

<drv mrk="friz.0ilo">
  <kap><tld/>ilo</kap>
  <snc mrk="friz.0ilo.KOMUNE">
    <dif>
      Ilo por <tld/>i, precipe por bukligi harojn:
      <ekz>
        neniu bonorda kavaliro povas nun dece aperi en societo, se mi lin ne havis sub
        mia tondilo a&ubreve; mia varma <tld/>ilo
        <fnt>
          <aut>Zden&ecaron;k Hr&scaron;el</aut>
          <vrk><url ref="http://www.literatura.bucek.name/brno/vivoantau150jaroj.html">Vivo anta&ubreve;
          150 jaroj: Inter sinjoro kaj frizisto</url></vrk>
        </fnt>.
      </ekz>
    </dif>
  </snc>
  <trd lng="be">&c_sh;&c_ch;&c_y;&c_p;&c_c;&c_y; &c_d;&c_l;&c_ja;
  &c_z;&c_a;&c_v;&c_ib;&c_w;&c_k;&c_ib;</trd>
  <trdgrp lng="ca">
    <trd>bigud&iacute;</trd>,
    <trd>rul&oacute;</trd>,
    <trd>rul&middot;lo</trd>
  </trdgrp>
  <trd lng="cs">kulma</trd>
  <trd lng="de">Frisierstab</trd>
  <trd lng="en">curler <klr tip="amb">(hair)</klr></trd>
  <trd lng="es">rizador <klr tip="amb">de pelo</klr></trd>
  <trd lng="fr">fer &agrave; friser</trd>
  <trd lng="hu">s&uuml;t&odblac;vas</trd>
  <trd lng="ja">&#12504;&#12450;&#12450;&#12452;&#12525;&#12531;</trd>
  <trdgrp lng="nl">
    <trd>krulijzer</trd>,
    <trd>krultang</trd>
  </trdgrp>
  <trdgrp lng="pl">
    <trd>karb&oacute;wka</trd>,
    <trd>&zdot;elazko fryzjerskie</trd>
  </trdgrp>
  <trd lng="ru">&c_shch;&c_i;&c_p;&c_c;&c_y; &c_d;&c_l;&c_ja;
  &c_z;&c_a;&c_v;&c_i;&c_v;&c_k;&c_i;</trd>
  <trd lng="sk">kulma</trd>
  <trdgrp lng="uk">
    <trd>&c_shch;&c_i;&c_p;&c_c;&c_ib;</trd>,
    <trd>&c_p;&c_r;&c_i;&c_s;&c_t;&c_o;&c_s;&c_u;&c_v;&c_a;&c_n;&c_n;&c_ja; &c_d;&c_l;&c_ja; &c_z;&c_a;&c_v;&c_i;&c_v;&c_k;&c_i;
    &c_v;&c_o;&c_l;&c_o;&c_s;&c_s;&c_ja;</trd>
  </trdgrp>
</drv>

<drv mrk="friz.0isto">
  <kap><tld/>isto</kap>
  <snc mrk="friz.0isto.KOMUNE">
    <dif>
      <ref tip="dif" cel="barbir.0o">Barbiro</ref>:
      <ekz>
        kiam la <tld/>isto demandis lin plej humile, &ccirc;u li ordonas razi
        la kapon kaj barbon, la estro respondis: &ndash; &leftquot;superflue&rightquot;
        <fnt><bib>Far3</bib>, <lok>&ccirc;apitro 1a</lok></fnt>;
      </ekz>
      <ekz>
        kio &ccirc;agrenas vin, maljuna barbo<tld/>isto
        <fnt>
          <bib>ElektFab</bib>
          <lok>La bremenaj muzikistoj</lok>
        </fnt>?
      </ekz>
      <ekz>
        li mem lavas sin, mem sin vestas, kaj lia <tld/>isto tutajn tagojn kaptas per
        la&ccirc;oj birdojn kaj ne aplikas sian talenton
        <fnt>
          <bib>Far1</bib>
          <lok>&Ccirc;apitro XIV</lok>
        </fnt>;
      </ekz>
      <ekz>
        &ccirc;iu volas posedi kiel eble plej multe da &ccirc;ambristinoj, modistinoj, <tld/>istoj
        <fnt>
          <bib>Far1</bib>
          <lok>&Ccirc;apitro XVIII</lok>
        </fnt>;
      </ekz>
      <ekz>
        <tld/>istoj estas fifamaj pro sia babilemo
        <fnt>
          <aut>A. Tsirimokos</aut>,
          <vrk>Re: matematikaj enigmetoj</vrk>,
          <lok><url ref="&SCE;">soc.culture.esperanto</url>,
          2003-11-19</lok>
        </fnt>.
      </ekz>
    </dif>
  </snc>
  <trd lng="be">&c_c;&c_y;&c_r;&c_u;&c_l;&c_mol;&c_n;&c_ib;&c_k;</trd>
  <trd lng="bo">&t_sa;&t_kata;&t_rata;&t_tsheg;&t_kha;&t_nga;&t_tsheg;</trd>
  <trd lng="ca">perruquer</trd>
  <trdgrp lng="cs">
    <trd>friz&eacute;r</trd>,
    <trd>kade&rcaron;n&iacute;k</trd>
  </trdgrp>
  <trd lng="de">Fris&ouml;r</trd>
  <trdgrp lng="en">
    <trd>hairdresser</trd>,
    <trd>hair stylist</trd>
  </trdgrp>
  <trd lng="es">peluquero</trd>
  <trd lng="fr">coiffeur</trd>
  <trd lng="hu">fodr&aacute;sz</trd>
  <trd lng="ja">&#32654;&#23481;&#24107;  <pr>&#12403;&#12424;&#12358;&#12375;</pr></trd>
  <trd lng="nl">kapper</trd>
  <trdgrp lng="pl">
    <trd>fryzjer</trd>,
    <trd>balwierz</trd>
  </trdgrp>
  <trd lng="ru">&c_p;&c_a;&c_r;&c_i;&c_k;&c_m;&c_a;&c_h;&c_je;&c_r;</trd>
  <trd lng="sk">kadern&iacute;k</trd>
  <trd lng="uk">&c_p;&c_je;&c_r;&c_u;&c_k;&c_a;&c_r;</trd>
  <trdgrp lng="zh">
    <trd>&#32654;&#21457;&#24072; <pr>m&ecaron;if&agrave;sh&#299;</pr></trd>,
    <trd>&#29702;&#21457;&#24072; <pr>l&#464;f&agrave;sh&#299;</pr></trd>,
    <trd>&#29702;&#21457;&#21592; <pr>l&#464;f&agrave;yu&aacute;n</pr></trd>,
    <trd>&#29702;&#21457; <pr>l&#464;f&agrave;</pr></trd>
  </trdgrp>
</drv>
</art>
