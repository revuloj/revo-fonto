<?xml version="1.0"?>
<!DOCTYPE vortaro SYSTEM "../dtd/vokoxml.dtd">
<vortaro>
<art mrk="$Id: seraf.xml,v 1.25 2026/05/31 11:51:40 revo Exp $">
<kap>
  <ofc>2</ofc>
  <rad>seraf</rad>/o
  <fnt><bib>JED</bib></fnt>
</kap>
<drv mrk="seraf.0o">
  <kap><tld/>o</kap>
  <snc mrk="seraf.0o.BIB">
    <uzo tip="fak">BIB</uzo>
    <dif>
      Flugilhava fajra esta&jcirc;o, origine serpenta:
      <ekz>
        <tld/>oj staris supre de Li, &ccirc;iu havis po ses flugiloj, per
        du li kovris sian viza&gcirc;on, per du li kovris siajn piedojn, kaj per du li flugis
        <fnt>
          <bib>MT</bib>
          <lok>&Jes; 6:2</lok>
        </fnt>;
      </ekz>
      <ekz>
        la Korano identigas Satanon kiel &Gcirc;inon <klr>[&#8230;]</klr> ideo <klr>[rilata al]</klr>
        la biblia <tld/>o, rango de an&gcirc;eloj aspektantaj kiel brulanta fajro
        <fnt>
          <bib>Viki</bib>
          <lok><url ref="https://eo.wikipedia.org/?curid=4001">Satano</url></lok>
        </fnt>.
      </ekz>
    </dif>
  </snc>
  <snc mrk="seraf.0o.REL">
    <uzo tip="fak">REL</uzo>
    <dif>
      <ref tip="super" cel="angxel.0o.REL">An&gcirc;elo</ref> de plej alta rango:
      <ekz>
        &scirc;ajnis al li, ke li a&ubreve;das <tld/>an &hcirc;oron la&ubreve;di Dion
        kaj prikanti sian propran feli&ccirc;egon pro la &ccirc;eesto de la eterna Spirito
        <fnt>
          <aut>H. A. Luyken</aut>
          <vrk>Mirinda amo</vrk>
          <lok>1913</lok>
        </fnt>.
      </ekz>
    </dif>
    <refgrp tip="vid">
      <ref cel="kerub.0o.angxel">kerubo<sncref/></ref>,
      <ref cel="ureus.0o">ureuso</ref>
    </refgrp>
  </snc>
  <trd lng="be">&c_s;&c_e;&c_r;&c_a;&c_f;&c_ib;&c_m;</trd>
  <trd lng="bg">&c_s;&c_je;&c_r;&c_a;&c_f;&c_i;&c_m;</trd>
  <trdgrp lng="cs">
    <trd>seraf</trd>,
    <trd>seraf&iacute;n</trd>
  </trdgrp>
  <trd lng="de">Seraph</trd>
  <trd lng="en">seraph</trd>
  <trd lng="fa">&a_A;&a_s;&a_r;&a_A;&a_f;&f_y;&a_l;</trd>
  <trd lng="fr">s&eacute;raphin</trd>
  <trd lng="hu">szer&aacute;f</trd>
  <trd lng="it">serafino</trd>
  <trdgrp lng="ja">
    <trd>&#x30BB;&#x30E9;&#x30D4;&#x30E0;</trd>,
    <trd>&#x30BB;&#x30E9;&#x30D5;&#x30A3;&#x30E0;</trd>,
    <trd>&#x71BE;&#22825;&#x4F7F;  <pr>&#12375;&#12390;&#12435;&#12375;</pr></trd>
  </trdgrp>
  <trdgrp lng="nl">
    <trd>seraf</trd>,
    <trd>serafijn</trd>
  </trdgrp>
  <trd lng="pl">serafin</trd>
  <trd lng="ru">&c_s;&c_je;&c_r;&c_a;&c_f;&c_i;&c_m;</trd>
  <trdgrp lng="sk">
    <trd>seraf</trd>,
    <trd>seraf&iacute;n</trd>
  </trdgrp>
  <trd lng="uk">&c_s;&c_je;&c_r;&c_a;&c_f;&c_i;&c_m;</trd>
  <trdgrp lng="zh">
    <trd>&#x70BD;&#22825;&#x4F7F; <pr>ch&#xEC;ti&amacron;nsh&#x1D0;</pr></trd>,
    <trd>&#x71BE;&#22825;&#x4F7F; <pr>ch&#xEC;ti&amacron;nsh&#x1D0;</pr></trd>
  </trdgrp>
</drv>
</art>
