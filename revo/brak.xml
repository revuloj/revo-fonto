<drv mrk="brak.cxirkaux0i">
  <kap>&ccirc;irka&ubreve;<tld/>i</kap>
  <gra><vspec>tr</vspec></gra>
  <snc mrk="brak.cxirkaux0i.brakumi">
    <dif>
      &Ccirc;irka&ubreve;igi per amba&ubreve; <tld/>oj, plejofte kun
      samtempa amema premo al la &ccirc;irka&ubreve;igata objekto
      a&ubreve;
      persono:
      <ekz>
        estas tempo por &ccirc;irka&ubreve;<tld/>i, kaj tempo
        por foriri de &ccirc;irka&ubreve;<tld/>ado
        <fnt><bib>MT</bib><lok>&Pre; 3:5</lok></fnt>;
      </ekz><ekz>
        preninte infanon, li starigis &gcirc;in meze de ili, kaj
        &ccirc;irka&ubreve;<tld/>inte &gcirc;in, li diris
        <klr>[...]</klr>
        <fnt><bib>NT</bib><lok>&Mar; 9:36</lok></fnt>;
      </ekz><ekz>
        mi ricevis sufi&ccirc;egan dankon, dol&ccirc;an kison kaj
        <ind>&ccirc;irka&ubreve;<tld/>o</ind>n
        <fnt><bib>I&scirc;tar</bib><lok>&ccirc;ap. 5</lok></fnt>.
        <trd lng="ca">abra&ccedil;ada</trd>
        <trdgrp lng="fr">
          <trd>accolade</trd>,
          <trd>embrassement</trd>,
          <trd>enlacement</trd>,
          <trd>&eacute;treinte</trd>
        </trdgrp>
        <trd lng="nl">omhelzing</trd>
      </ekz>
    </dif>
    <ref tip="sin" cel="brak.0umi"><tld/>umi</ref>
    <trdgrp lng="zh">
    <trd>&#32039;&#25265; <pr>j&#464;nb&agrave;o</pr></trd>,
    <trd>&#32039;&#32039;&#25317;&#25265; <pr>j&#464;nj&#464;ny&#333;ngb&agrave;o</pr></trd>,
    <trd>&#25602; <pr>l&#466;u</pr></trd>,
    <trd>&#25265; <pr>b&agrave;o</pr></trd>,
    <trd>&#25317;&#25265; <pr>y&#333;ngb&agrave;o</pr></trd>,
    <trd>&#25265;&#25317; <pr>b&agrave;oy&#333;ng</pr></trd>,
    <trd>&#25597;&#20837;&#24576;&#20013; <pr>l&#462;nr&ugrave;hu&aacute;izh&#333;ng</pr></trd>
  </trdgrp>
</snc>
  <trdgrp lng="be">
    <trd>&c_a;&c_b;&c_d;&c_y;&c_m;&c_a;&c_c;&c_mol;</trd>,
    <trd>&c_a;&c_b;&c_n;&c_ja;&c_c;&c_mol;</trd>
  </trdgrp>
  <trd lng="br">briata</trd>
  <trd lng="ca">abra&ccedil;ar</trd>
  <trd lng="de">umarmen</trd>
  <trd lng="en">hug</trd>
  <trd lng="es">abrazar</trd>
  <trdgrp lng="fr">
    <trd>embrasser<klr tip="ind"> (enlacer)</klr></trd>,
    <trd>enlacer</trd>,
    <trd>&eacute;treindre<klr tip="ind"> (avec les bras)</klr></trd>
  </trdgrp>
  <trd lng="he">&lamed;<ind>&het;&bet;&qof;</ind></trd>
  <trdgrp lng="hu">
    <trd>meg&ouml;lel</trd>,
    <trd>&aacute;t&ouml;lel</trd>
  </trdgrp>
  <trdgrp lng="id">
    <trd><baz>peluk</baz>memeluk</trd>,
    <trd><baz>rangkul</baz>merangkul</trd>,
    <trd><baz>dekap</baz>mendekap</trd>
  </trdgrp>
  <trd lng="it">abbracciare</trd>
  <trdgrp lng="nl">
    <trd>omarmen</trd>,
    <trd>omhelzen</trd>
  </trdgrp>
  <trdgrp lng="pl">
    <trd>obejmowa&cacute; <klr>(ramionami)</klr></trd>
    <trd>bra&cacute; w <ind>ramiona</ind></trd>,
    <trd>u&sacute;ciska&cacute;</trd>
  </trdgrp>
  <trdgrp lng="ru">
    <trd>&c_o;&c_b;&c_n;&c_i;&c_m;&c_a;&c_t;&c_mol;</trd>,
    <trd>&c_z;&c_a;&c_k;&c_l;&c_ju;&c_ch;&c_a;&c_t;&c_mol; &c_v;
    &c_o;&c_b;&c_malmol;&c_ja;&c_t;&c_i;&c_ja;</trd>
  </trdgrp>
  <trd lng="sk">obja&tcaron;</trd>
  <trdgrp lng="sv">
    <trd>krama</trd>,
    <trd>omfamna</trd>
  </trdgrp>
  <trdgrp lng="tr">
    <trd>kucaklamak</trd>,
    <trd>sar&inodot;lmak</trd>
  </trdgrp>
</drv>

<drv mrk="brak.duon0umi">
  <kap>duon<tld/>umi</kap>
  <gra><vspec>tr</vspec></gra>
  <snc>
    <dif>
      <tld lit="B"/>umi per unu <tld/>o, meti <tld/>on &ccirc;irka&ubreve; ies
      &scirc;ultroj a&ubreve; talio:
      <ekz>
        Sed mia Princo duon<tld/>umis min: <ctl>Jen nia Marjorie</ctl>
        <fnt>
          <aut>Marjorie Boulton</aut>:
          <vrk>Kiel noktpapilio al lampo</vrk>.
          <bib>Esperanto</bib>
          <lok>&#8470; 644-5 (1959:7&ndash;8), p. 125</lok>
        </fnt>;
      </ekz>
      <ekz>
        <klr>[la kovrilo]</klr> prezentis kirasitan viron, kiu
        duon<tld/>umas knabinon, kiu alrigardas lin&#8230;
        <fnt>
          <aut>VikS</aut>: <vrk>La lasta babilado de VikS</vrk>
          <bib>LOdE</bib> <lok>&#8470;257 (2016:3)</lok>
        </fnt>.
      </ekz>
    </dif>
  </snc>
    <trd lng="be">&c_p;&c_a;&c_w;&c_a;&c_b;&c_d;&c_y;&c_m;&c_a;&c_c;&c_mol;</trd>
    <trdgrp lng="ru">
    <trd>&c_p;&c_o;&c_l;&c_u;&c_o;&c_b;&c_n;&c_ja;&c_t;&c_mol;</trd>,
    <trd>&c_p;&c_r;&c_i;&c_o;&c_b;&c_n;&c_ja;&c_t;&c_mol;</trd>
  </trdgrp>
</drv>

<drv mrk="brak.en0igi">
  <kap>en<tld/>igi</kap>
  <gra><vspec>tr</vspec></gra>
  <snc mrk="brak.en0igi.cxirkauxbraki">
    <dif>
      <ref tip="dif" cel="brak.cxirkaux0i.brakumi">&Ccirc;irka&ubreve;<tld/>i</ref>:
      <ekz>
        post unu jaro en &ccirc;i tiu tempo vi en<tld/>igos filon
        <fnt><bib>MT</bib> <lok>&Re2; 4:16</lok></fnt>;
      </ekz>
      <ekz>
        kial, mia filo, vi volas ser&ccirc;i al vi plezuron &ccirc;e
        fremda virino kaj en<tld/>igi ne apartenantan al vi
        <fnt><bib>MT</bib>, <lok>&Sen; 5:20</lok></fnt>?
      </ekz>
      <ekz>
        la interfrapi&gcirc;o estas senbrida: la unua viro en la vico alfrontanta la ta&ubreve;ron
        en<tld/>igas &gcirc;ian kapon, kaj forte-firme eltenas sin inter ties kornoj
        <fnt>
          <bib>Monato</bib>
          <aut>Eduardo Novembro</aut>
          <vrk><url ref="&Monato;/2014/011318.php">Ta&ubreve;ro??? Festo!!!</url></vrk>
          <lok>2014</lok>
        </fnt>.
      </ekz>
    </dif>
    <trdgrp lng="be">
      <trd>&c_a;&c_b;&c_d;&c_y;&c_m;&c_a;&c_c;&c_mol;</trd>,
      <trd>&c_a;&c_b;&c_n;&c_ja;&c_c;&c_mol;</trd>
    </trdgrp>
    <trd lng="ca">abra&ccedil;ar</trd>
    <trdgrp lng="id">
      <trd><baz>peluk</baz>memeluk</trd>,
      <trd><baz>rangkul</baz>merangkul</trd>,
      <trd><baz>dekap</baz>mendekap</trd>
    </trdgrp>
    <trdgrp lng="pl">
      <trd>obejmowa&cacute; <klr>(ramionami)</klr></trd>
      <trd>bra&cacute; w <ind>ramiona</ind></trd>,
      <trd>u&sacute;ciska&cacute;</trd>
    </trdgrp>
    <trdgrp lng="sv">
      <trd>krama</trd>,
      <trd>omfamna</trd>
    </trdgrp>
    <trdgrp lng="zh">
      <trd>&#25597; <pr>l&#462;n</pr></trd>,
      <trd>&#25265;&#25265; <pr>b&agrave;ob&agrave;o</pr></trd>
    </trdgrp>
  </snc>
  <snc mrk="brak.en0igi.surbrakigi">
    <dif>
      Levi, <ref tip="super" cel="pren.0i.surmeti">surpreni</ref> sur siajn <tld/>ojn:
      <ekz>
        Marta <klr>[...]</klr> genui&gcirc;inte volis en<tld/>igi la
        filineton
        <fnt><bib>Marta</bib></fnt>.
      </ekz>
    </dif>
    <trdgrp lng="be">
      <trd>&c_p;&c_a;&c_d;&c_y;&c_m;&c_a;&c_c;&c_mol; <klr>(&c_n;&c_a;
      &c_r;&c_u;&c_k;&c_a;&c_h;)</klr></trd>,
      <trd>&c_b;&c_r;&c_a;&c_c;&c_mol; &c_n;&c_a; <ind>&c_r;&c_u;&c_k;&c_ib;</ind></trd>
    </trdgrp>
    <trd lng="br">kemer en e zivrec'h</trd>
    <trd lng="ca">agafar en bra&ccedil;os</trd>
    <trd lng="fr">prendre sur ses bras</trd>
    <trdgrp lng="it">
      <trd>inbracciare</trd>,
      <trd>prendere in braccio</trd>
    </trdgrp>
    <trd lng="pl">bra&cacute; na <ind>r&eogonek;ce</ind></trd>
  </snc>
  <trd lng="cs">obejmout</trd>
  <trd lng="de">in die <ind>Arm</ind>e nehmen</trd>
  <trd lng="en">hug</trd>
  <trd lng="ja">&#25265;&#12367;  <pr>&#12358;&#12384;&#12367;</pr></trd>
  <trd lng="nl">omhelzen</trd>
  <trdgrp lng="sk">
    <trd>obja&tcaron;</trd>,
    <trd>zovrie&tcaron; do n&aacute;ru&ccaron;ia</trd>
  </trdgrp>
  <adm>
     Interesa estas anka&ubreve; la ekzemplo el Sentencoj
     "se vi [la sa&gcirc;on] enbrakigos", kun la &scirc;ajna senco
     "alpreni", "akcepti kiel gvidregulon"... (kiel la
     franca "embrasser (une opinion)"), sed eble anka&ubreve;
     "protekti".
     <aut>MB</aut>
  </adm>
</drv>

