    <trd lng="sgn"
    kod="M521x545S14701467x523S2ff00482x476S36d00479x520S3770a467x521S20500456x533S20500456x533">b@11*</trd>
    <trd lng="sk">pa&zcaron;a</trd>
    <trd lng="sv">arm</trd>
  </snc>
  <snc mrk="brak.0o.sxultro_gxis_kubuto">
    <uzo tip="fak">ANA</uzo>
    <dif>
      Parto de tiu membro ekde &scirc;ultro &gcirc;is kubuto.
    </dif>
    <refgrp tip="vid">
      <ref cel="humer.0o">humero</ref>
    </refgrp>
    <trd lng="be">&c_r;&c_u;&c_k;&c_a; <klr>(&c_a;&c_d; &c_p;&c_l;&c_ja;&c_ch;&c_a; &c_d;&c_a;
    &c_k;&c_ib;&c_s;&c_mol;&c_c;&c_ib;)</klr></trd>
    <trd lng="de">Oberarm</trd>
    <trd lng="en">upper arm</trd>
    <trd lng="hu">felkar</trd>
    <trd lng="id"><ind>lengan</ind> atas</trd>
    <trd lng="nl">bovenarm</trd>
    <trd lng="pl">rami&eogonek;</trd>
    <trd lng="ru">&c_r;&c_u;&c_k;&c_a;<klr> (&c_o;&c_t; &c_p;&c_l;&c_je;&c_ch;&c_a; &c_d;&c_o;
    &c_k;&c_i;&c_s;&c_t;&c_i;)</klr></trd>
    <trd lng="sk">rameno</trd>
    <trd lng="sv">&ouml;verarm</trd>
    <trdgrp lng="zh">
      <trd>&#19978;&#33218; <pr>sh&agrave;ngb&igrave;</pr></trd>,
      <trd>&#33233; <pr>n&agrave;o</pr></trd>,
      <trd>&#33218; <pr>b&igrave;</pr></trd>
    </trdgrp>
    <adm>Mankas ekzemploj por pruvi tian uzon <aut>WD</aut></adm>
  </snc>
  <snc mrk="brak.0o.FIG">
    <uzo tip="stl">FIG</uzo>
    <dif>
      Parto de objekto, kiu etendi&gcirc;as, flanke de &gcirc;i kiel
      <tld/>o:
      <ekz>
        <tld/>o de cirkelo, de <ref tip="malprt" cel="gru.0o.TEK">gruo</ref>,
      </ekz><ekz>
        de lustro, de helico, de levilo, de rivero;
      </ekz><ekz>
        orbrilantaj kandelabroj etendis siajn bran&ccirc;formajn <tld/>ojn
        <fnt><bib>Marta</bib></fnt>;
      </ekz><ekz>
        Nilo anstata&ubreve; flui en mallar&gcirc;a koridoro, dividi&gcirc;as en kelke da <tld/>oj sur vasta ebena&jcirc;o
        <klr>(vd <ref tip="vid" cel="delt.0o.GEOG">delto<sncref/></ref>)</klr>
        <fnt>
          <bib>Far1</bib>
          <lok>Anta&ubreve;parolo</lok>
        </fnt>;
      </ekz><ekz>
        la mano, ku&scirc;anta sur <tld/>o de la se&gcirc;o, tremetis
        <fnt><bib>I&scirc;tar</bib> <lok>&ccirc;apitro 19a, la
        krizo</lok></fnt>.
      </ekz>
    </dif>
    <refgrp tip="vid">
      <ref cel="al1.0o">alo</ref>,
      <ref cel="brancx.0o.FIG">bran&ccirc;o</ref>
    </refgrp>
    <trdgrp lng="be">
      <trd>&c_r;&c_u;&c_ch;&c_k;&c_a;</trd>,
      <trd>&c_d;&c_z;&c_ja;&c_r;&c_zh;&c_a;&c_l;&c_mol;&c_n;&c_a;</trd>,
