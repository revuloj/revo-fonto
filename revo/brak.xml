  <trd lng="fr">avant-bras</trd>
  <trd lng="he">&bet;&yod;&tav; &he;&shin;&het;&yod;</trd>
  <trd lng="hu">alkar</trd>
  <trdgrp lng="id">
    <trd>hasta</trd>,
    <trd><ind>lengan</ind> bawah</trd>
  </trdgrp>
  <trd lng="it">avanbraccio</trd>
  <trd lng="nl">onderarm</trd>
