<drv mrk="brak.antaux0o">
  <kap>anta&ubreve;<tld/>o</kap>
  <snc mrk="brak.antaux0o.ANA">
    <uzo tip="fak">ANA</uzo>
    <dif>
      Parto de la supera membro, de kubuto &gcirc;is mano:
      <ekz>
        <klr>[li]</klr> tordis lian anta&ubreve;<tld/>on, kaj
        nesciante direktis la tubon de l&#8217;
        revolvero kontra&ubreve; la bruston de sia malamiko
        <fnt>
          <bib>ChL</bib>
        </fnt>;
      </ekz>
      <ekz>
        la konsulo levis la &scirc;ultrojn &gcirc;is la oreloj, kiam li diris tion, liaj <tld/>oj
        samtempe levi&gcirc;is, kaj la anta&ubreve;<tld/>oj pendis perpendikulare kaj pendolis de
        la kubutoj
        <fnt>
          <bib>Mortul&Scirc;ip</bib>
        </fnt>;
      </ekz>
      <ekz>
        la tria knabino dormas kun kapo apogita
        sur la anta&ubreve;<tld/>oj
        <fnt>
          <aut>S. Rodin</aut>,
          <vrk>Bildoj pri Norda Lando</vrk>,
          <lok>2006</lok>
        </fnt>.
      </ekz>
    </dif>
    <trdgrp lng="zh">
    <trd>&#21069;&#33218; <pr>qi&aacute;nb&igrave;</pr></trd>,
    <trd>&#33099;&#19979; <pr>y&egrave;xi&agrave;</pr></trd>
  </trdgrp>
</snc>
  <trd lng="be">&c_p;&c_je;&c_r;&c_a;&c_d;&c_p;&c_l;&c_je;&c_ch;&c_ch;&c_a;</trd>
  <trd lng="br">arvrec'h</trd>
  <trd lng="ca">avantbra&ccedil;</trd>
  <trd lng="de">Unterarm</trd>
  <trd lng="en">forearm</trd>
