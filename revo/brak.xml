  <snc mrk="brak.0en0e.MIEN">
    <dif>
      <tld lit="B"/>on intermetitan kun <tld/>o de apudulo:
      <ekz>
        <klr>[li]</klr> promenas <tld/>enbrake kun amikino, anta&ubreve; ol reiri al la laboro
        <fnt>
          <bib>LOdE</bib>
          <lok>1999, No 1 (51)</lok>
        </fnt>;
      </ekz>
      <ekz>
        oni ameme gvidas lin, <tld/>en<tld/>e, la&ubreve;
        la stratetoj de la provinca urbo
        <fnt>
          <aut>S. Rodin</aut>,
          <vrk>Bildoj pri Norda Lando</vrk>,
          <lok>2006</lok>
        </fnt>.
      </ekz>
    </dif>
    <trdgrp lng="zh">
    <trd>&#20132;&#33218; <pr>ji&amacron;ob&igrave;</pr></trd>,
    <trd>&#25226;&#33218; <pr>b&#462;b&igrave;</pr></trd>
