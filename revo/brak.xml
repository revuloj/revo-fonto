<drv mrk="brak.0o">
  <kap><ofc>*</ofc><tld/>o</kap>
  <snc mrk="brak.0o.homa_membro">
    <uzo tip="fak">ANA</uzo>
    <dif>
      La supra (resp. anta&ubreve;a) <ref tip="super" cel="membr.0o.ANA">membro</ref>
      &ccirc;e la homo kaj <ref tip="malprt" cel="primat.0o">primato</ref>j:
      <ekz>
        grandan paperujon mi portas sub la <tld/>o
        <fnt><bib>F</bib>, <lok>&FE; 40</lok></fnt>;
      </ekz><ekz>
        <tld/>o en <tld/>o ili iris
        <fnt><bib>Fab1</bib>, <lok>La virineto de maro</lok></fnt>;
      </ekz><ekz>
        <tld/>o sub <tld/>o ili iris sur la alta&jcirc;on
        <fnt>
          <bib>Fab3</bib>
          <lok>Ib kaj malgranda kristino</lok>
        </fnt>;
      </ekz><ekz>
        prenas lin sub la <tld/>o kaj forkondukas flanken
        <fnt>
          <bib>Revizoro</bib>
          <lok>Akto unua</lok>
        </fnt>;
      </ekz><ekz>
        &scirc;i mem senvive falis en la <tld/>ojn de siaj fratoj, tiel efikis sur &scirc;i la stre&ccirc;eco, timo
        kaj doloro
        <fnt><bib>Fab1</bib> <lok>Sova&gcirc;aj cignoj</lok></fnt>;
      </ekz><ekz>
        apogante sin al la <tld/>o de juna kaj klera edzo
        <fnt><bib>Marta</bib></fnt>.
      </ekz>
    </dif>
    <trd lng="be">&c_r;&c_u;&c_k;&c_a;<klr> (&c_c;&c_a;&c_l;&c_k;&c_a;&c_m;)</klr></trd>
    <trd lng="bg">&c_r;&c_malmol;&c_k;&c_a;</trd>
    <trd lng="de">Arm</trd>
    <trd lng="hu">kar</trd>
