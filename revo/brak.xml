      <trd>&c_r;&c_u;&c_k;&c_o;&c_ja;&c_t;&c_k;&c_a;</trd>,
      <trd>&c_p;&c_l;&c_je;&c_ch;&c_o;<klr> (&c_r;&c_y;&c_ch;&c_a;&c_g;&c_a;)</klr></trd>,
      <trd>&c_r;&c_u;&c_k;&c_a;&c_v;<klr> (&c_r;&c_je;&c_k;&c_i;)</klr></trd>
    </trdgrp>
  </snc>
