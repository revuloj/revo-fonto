<drv mrk="brak.0ingo">
  <kap>
    <tld/>ingo
  </kap>
  <snc>
    <uzo tip="fak">TEKS</uzo>
    <dif>
      Parto de vesto, per kiu oni fiksas &gcirc;in &ccirc;e la supra parto de la brako a&ubreve; &scirc;ultro:
      <ekz>
        <klr>[li]</klr> formar&scirc;is en sia longa kaftano kun flirtantaj lar&gcirc;aj
        <tld/>ingoj kaj penda&jcirc;oj
        <fnt><bib>Voja&gcirc;Imp</bib></fnt>;
      </ekz><ekz>
        baleta jupo <klr>[&#8230;]</klr> povas anka&ubreve; ligi&gcirc;i al supraj
        trika&jcirc;oj, kutime kun longaj <tld/>ingoj
        <fnt>
          <bib>Viki</bib>
          <lok><url ref="https://eo.wikipedia.org/?curid=290930">Baleta jupo</url></lok>
        </fnt>.
      </ekz>
    </dif>
    <refgrp tip="vid">
      <ref cel="ring.brak0o">brakringo</ref>,
      <ref cel="manik.0o">maniko</ref>,
      <ref cel="sxelk.0o">&scirc;elko</ref>
    </refgrp>
  </snc>
  <trdgrp lng="be">
    <trd>&c_l;&c_ja;&c_m;&c_k;&c_a;</trd>,
    <trd>&c_sh;&c_l;&c_je;&c_j;&c_k;&c_a;</trd>
  </trdgrp>
  <trd lng="ca">tirant</trd>
  <trd lng="de">Tr&auml;ger <klr>(Kleid)</klr></trd>
  <trd lng="en">shoulder straps</trd>
  <trd lng="fr">bretelle</trd>
  <trdgrp lng="id">
    <trd>bretel</trd>,
    <trd>suspender</trd>,
    <trd><ind>tali</ind> bahu</trd>,
    <trd><ind>tali</ind> sandang</trd>
  </trdgrp>
  <trdgrp lng="pl">
    <trd>pasek</trd>,
    <trd>szelka</trd>
  </trdgrp>
  <adm>
    Dubinda deriva&jcirc;o. &Gcirc;i estas malklara; por la signifo kiun donas la
    tradukoj ni havas la fundamentan &#171;&scirc;elko&#187;n; kaj la ekzemplo pri
    &#171;longa kaftano kun flirtantaj lar&gcirc;aj brakingoj&#187; estas absurda (&ccirc;u
    vere tie temas pri &scirc;elkoj?). Necesas kontroli la sencon, kaj se &gcirc;i
    efektive estas &#171;&scirc;elko&#187;, ni prefere marku tiun deriva&jcirc;on per EVI.
    <aut>Sergio Pokrovskij</aut>
  </adm>
</drv>

<drv mrk="brak.0umi">
  <kap><tld/>umi</kap>
  <gra><vspec>tr</vspec></gra>
  <snc>
    <dif>
      <ref tip="dif" cel="brak.cxirkaux0i">&Ccirc;irka&ubreve;<tld/>i</ref>:
      <ekz>
        &scirc;i tre vigli&gcirc;is <klr>[kaj]</klr> sin premis al mi
        <tld/>umante min je la kolo
        <fnt><bib>MkM</bib><lok>&ccirc;ap. 13</lok></fnt>;
      </ekz><ekz>
        mi vin kisis, kisis sur kanap', mi vin alpremis en
        <ind><tld/>umo</ind> muta
        <fnt>
          <aut>P. Peneter</aut>
          <vrk>Sekretaj Sonetoj</vrk>
          <lok>XLVII</lok>
        </fnt>.
        <trd lng="ca">abra&ccedil;ada</trd>
        <trdgrp lng="fr">
          <trd>accolade</trd>,
          <trd>embrassement</trd>,
          <trd>enlacement</trd>,
          <trd>&eacute;treinte</trd>
        </trdgrp>
        <trdgrp lng="tr">
          <trd>kucakla&scedil;ma</trd>,
          <trd>sar&inodot;lma</trd>
        </trdgrp>
      </ekz>
    </dif>
  </snc>
  <trdgrp lng="be">
    <trd>&c_a;&c_b;&c_d;&c_y;&c_m;&c_a;&c_c;&c_mol;</trd>,
    <trd>&c_a;&c_b;&c_n;&c_ja;&c_c;&c_mol;</trd>
  </trdgrp>
  <trd
  lng="bo">&t_tha;&t_ma;&t_tsheg;&amp;t_-a;&t_kha;&t_yata;&t_shabchu;&t_da;&t_tsheg;&t_ba;&t_yata;&t_drengbu;&t_da;&t_tsheg;</trd>
  <trd lng="br">briata</trd>
  <trd lng="ca">abra&ccedil;ar</trd>
  <trdgrp lng="cs">
    <trd>obejmout</trd>,
    <trd>obj&iacute;mat</trd>
  </trdgrp>
  <trd lng="de">umarmen</trd>
  <trd lng="en">hug</trd>
  <trd lng="es">abrazar</trd>
  <trdgrp lng="fr">
    <trd>embrasser<klr tip="ind"> (enlacer)</klr></trd>,
    <trd>enlacer</trd>,
    <trd>&eacute;treindre<klr tip="ind"> (avec les bras)</klr></trd>
  </trdgrp>
  <trd lng="he">&lamed;<ind>&het;&bet;&qof;</ind></trd>
  <trdgrp lng="hu">
    <trd>meg&ouml;lel</trd>,
    <trd>&aacute;t&ouml;lel</trd>
  </trdgrp>
  <trdgrp lng="id">
    <trd><baz>peluk</baz>memeluk</trd>,
    <trd><baz>rangkul</baz>merangkul</trd>,
    <trd><baz>dekap</baz>mendekap</trd>
  </trdgrp>
  <trd lng="it">abbracciare</trd>
  <trdgrp lng="ja">
    <trd>&#25265;&#25793;&#12377;&#12427;  <pr>&#12411;&#12358;&#12424;&#12358;&#12377;&#12427;</pr></trd>,
    <trd>&#25265;&#12365;&#12375;&#12417;&#12427;  <pr>&#12384;&#12365;&#12375;&#12417;&#12427;</pr></trd>
  </trdgrp>
  <trd lng="nl">omarmen</trd>
  <trdgrp lng="pl">
    <trd>obejmowa&cacute; <klr>(ramionami)</klr></trd>
    <trd>bra&cacute; w <ind>ramiona</ind></trd>,
    <trd>u&sacute;ciska&cacute;</trd>
  </trdgrp>
  <trdgrp lng="ru">
    <trd>&c_o;&c_b;&c_n;&c_i;&c_m;&c_a;&c_t;&c_mol;</trd>,
    <trd>&c_z;&c_a;&c_k;&c_l;&c_ju;&c_ch;&c_a;&c_t;&c_mol; &c_v;
    &c_o;&c_b;&c_malmol;&c_ja;&c_t;&c_i;&c_ja;</trd>
  </trdgrp>
  <trdgrp lng="sk">
    <trd>obja&tcaron;</trd>,
    <trd>zovrie&tcaron; do n&aacute;ru&ccaron;ia</trd>
  </trdgrp>
  <trdgrp lng="sv">
    <trd>krama</trd>,
    <trd>omfamna</trd>
  </trdgrp>
  <trdgrp lng="uk">
    <trd>&c_o;&c_b;&c_ib;&c_j;&c_m;&c_a;&c_t;&c_i;</trd>,
