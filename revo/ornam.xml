    <trd>&#x9970;&#x7269; <pr>sh&igrave;w&ugrave;</pr></trd>,
    <trd>&#x6DFB;&#x98FE; <pr>ti&amacron;nsh&igrave;</pr></trd>,
    <trd>&#x6DFB;&#x9970; <pr>ti&amacron;nsh&igrave;</pr></trd>,
    <trd>&#x88C5;&#x9970;&#x7269; <pr>zhu&amacron;ngsh&igrave;w&ugrave;</pr></trd>,
