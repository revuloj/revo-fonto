<drv mrk="ornam.sen0a">
  <kap>
    sen<tld/>a
  </kap>
  <snc>
    <dif>
      Ne <tld/>ita:
      <ekz>
        sen<tld/>a &ccirc;ambreto
        <fnt>
          <bib>Fab3</bib>
          <lok>Koboldo &ccirc;e la butikisto</lok>
        </fnt>;
      </ekz>
      <ekz>
        malgra&ubreve; sia sen<tld/>a, preska&ubreve; malri&ccirc;ula vesto, <klr>[li]</klr> havis la
        aspekton de nobelo
        <fnt>
          <bib>I&scirc;tar</bib>
          <lok>&Ccirc;apitro XXIII</lok>
        </fnt>;
      </ekz>
      <ekz>
        li verkis siajn mallongajn rakontojn proze, en sen<tld/>a stilo
        <fnt>
          <bib>Monato</bib>
          <aut>Gerrit Berveling</aut>
          <vrk><url ref="&Monato;/2007/008635.php"
              >Ezop(ec)aj fabloj el Japanio</url></vrk>
          <lok>2007</lok>
        </fnt>;
      </ekz>
      <ekz>
        la vortoj kaj la frazoj estis sen<tld/>aj kaj senarte aran&gcirc;itaj, sed ili <klr>[&#x2026;]</klr>
        ili bone esprimis tion, kion li volis komuniki
        <fnt>
          <bib>ViV</bib>
          <lok>I.</lok>
        </fnt>;
      </ekz>
      <ekz>
        min tedis vagadi sur la sen<tld/>aj, dezertaj stratoj, en kiujn ne alportis
        variecon statuo, kolono a&ubreve; almena&ubreve; portalo
        <fnt>
          <bib>VaK</bib>
          <lok>Sesa &Ccirc;apitro</lok>
        </fnt>.
      </ekz>
    </dif>
    <refgrp tip="vid">
      <ref cel="modest.0a">modesta</ref>,
      <ref cel="nud.0a.FIG_senornama">nuda<sncref/></ref>,
      <ref cel="luks.sen0ane0a">senluksa</ref>,
      <ref cel="poezi.sen0a">senpoezia</ref>,
      <ref cel="pomp.sen0a">senpompa</ref>,
      <ref cel="simpl.0a.senornama">simpla<sncref/></ref>
    </refgrp>
  </snc>
  <trdgrp lng="de">
    <trd>schmucklos</trd>,
    <trd>schlicht</trd>
  </trdgrp>
  <trdgrp lng="en">
    <trd>austere</trd>,
    <trd>undecorated</trd>
  </trdgrp>
  <trd lng="fr">sans ornement</trd>
</drv>

