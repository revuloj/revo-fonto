  <trdgrp lng="uk">
    <trd>&c_p;&c_r;&c_i;&c_k;&c_r;&c_a;&c_s;&c_a;</trd>,
    <trd>&c_o;&c_r;&c_n;&c_a;&c_m;&c_je;&c_n;&c_t;</trd>,
