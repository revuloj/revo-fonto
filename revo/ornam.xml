      <ekz>
        longa tuniko kun oraj <tld/>a&jcirc;oj
        <fnt>
          <bib>I&scirc;tar</bib>
          <lok>&Ccirc;apitro XI</lok>
        </fnt>;
      </ekz>
      <ekz>
        ili ekfunebris, kaj neniu metis sur sin siajn <tld/>a&jcirc;ojn
        <fnt>
          <bib>MT</bib>
          <lok>Eliro 33:4</lok>
        </fnt>;
      </ekz>
      <ekz>
        troigo de &ccirc;iaspecaj retorikaj figuroj kaj aliaj <tld/>a&jcirc;oj
        <fnt>
          <bib>Ret</bib>
          <lok>Dua Parto</lok>
        </fnt>.
      </ekz>
    </dif>
    <refgrp tip="sin">
      <ref cel="dekora.0o">dekoracio</ref>
    </refgrp>
