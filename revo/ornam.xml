  <fnt><bib>UV</bib></fnt>
</kap>
<drv mrk="ornam.0i">
  <kap><ofc>*</ofc><tld/>i</kap>
  <gra><vspec>tr</vspec></gra>
  <snc mrk="ornam.0i.iu">
    <uzo tip="klr">(iu)</uzo>
    <dif>
      Aldoni al tuto plibeligajn detalojn:
      <ekz>
        <tld/>i tablon per
        floroj, <tld/>i &ccirc;ambron per pentra&jcirc;oj;
      </ekz>
      <ekz>
        <klr>[la]</klr> tombon <klr>[&#x2026;]</klr> ili <tld/>is per folietoj de tilioj
        <fnt>
          <bib>Fab1</bib>
          <lok>Lekanto</lok>
        </fnt>;
      </ekz>
      <ekz>
        la Eternulo <klr>[&#x2026;]</klr> <tld/>as humilulojn per savo
        <fnt>
          <bib>MT</bib>
          <lok>Psalmaro 149:4</lok>
        </fnt>;
      </ekz>
      <ekz>
        iu el la plej junaj komizoj <tld/>is sian &ccirc;apelon per plumo
        <fnt>
          <bib>Fab3</bib>
          <lok>Nokta &ccirc;apo de fra&ubreve;lo</lok>
        </fnt>;
      </ekz>
      <ekz>
        la ringofingron <klr>[&#x2026;]</klr> <tld/>is sin per ora ringo
        <fnt>
          <bib>Fab2</bib>
          <lok>Monteto de elfoj</lok>
        </fnt>;
      </ekz>
      <ekz>
        e&ccirc; &scirc;tipo estos bela, se vi &gcirc;in <tld/>os
        <fnt><bib>PrV</bib></fnt>;
      </ekz>
      <ekz>
        flag<tld/>i domon, &scirc;ipon.
      </ekz>
    </dif>
    <ref tip="sub" cel="drapir.0i">drapiri</ref>
  </snc>
  <snc mrk="ornam.0i.io">
    <uzo tip="klr">(io)</uzo>
    <dif>
      Servi kiel plibeliga&jcirc;o:
      <ekz>
        cipreso, abio, kaj bukso kuni&gcirc;os, por <tld/>i la lokon
        <fnt>
          <bib>MT</bib>
          <lok>Jesaja 60:13</lok>
        </fnt>;
      </ekz>
      <ekz>
        rozokolora atlaso kaj artefaritaj floroj <tld/>is &ccirc;iujn murojn
        <fnt>
          <bib>Fab2</bib>
          <lok>Ne&gcirc;a re&gcirc;ino</lok>
        </fnt>;
      </ekz>
      <ekz>
        bonkora rideto <tld/>is &scirc;iajn dikajn lipojn
        <fnt>
          <bib>IK</bib>
          <lok>&Ccirc;apitro II</lok>
        </fnt>;
      </ekz>
      <ekz>
        en aprilo tiom da violoj <tld/>as la herbaron, ke la verda&jcirc;o malaperas sub ili
        <fnt>
          <bib>IK</bib>
          <lok>&Ccirc;apitro I</lok>
        </fnt>;
      </ekz>
      <ekz>
        kiun vesto <tld/>as, tiun homoj ekamas
        <fnt><bib>PrV</bib></fnt>;
      </ekz>
      <ekz>
        tablon <tld/>as ne tuko, sed kuko
        <fnt>
          <bib>PrV</bib>
        </fnt>.
      </ekz>
    </dif>
  </snc>
  <refgrp tip="sin">
    <ref cel="dekora.0i">dekoracii</ref>,
    <ref cel="bel.pli0igi">plibeligi</ref>
  </refgrp>
  <trdgrp lng="be">
    <trd>&c_u;&c_p;&c_r;&c_y;&c_g;&c_o;&c_zh;&c_v;&c_a;&c_c;&c_mol;</trd>,
    <trd>&c_a;&c_z;&c_d;&c_a;&c_b;&c_l;&c_ja;&c_c;&c_mol;</trd>
  </trdgrp>
  <trdgrp lng="cs">
    <trd>b&yacute;t zdobn&yacute;</trd>,
    <trd>vyzdobit</trd>,
    <trd>zdobit</trd>
  </trdgrp>
  <trdgrp lng="de">
    <trd>schm&uuml;cken</trd>,
    <trd>verzieren</trd>
  </trdgrp>
  <trd lng="el">&delta;&jota;&alfa;&sigma;&kappa;&omikron;&my;&omega_ton;</trd>
  <trdgrp lng="en">
    <trd>adorn</trd>,
    <trd>decorate</trd>
  </trdgrp>
  <trd lng="es">adornar</trd>
  <trdgrp lng="fr">
    <trd>d&eacute;corer</trd>,
    <trd>enjoliver</trd>,
    <trd>orner</trd>,
    <trd>ornementer</trd>,
    <trd>parer</trd>
  </trdgrp>
  <trd lng="hu">d&iacute;sz&iacute;t</trd>
  <trdgrp lng="id">
    <trd>hias</trd>,
    <trd><baz>hias</baz>menghias</trd>,
    <trd><baz>hias</baz>menghiasi</trd>,
    <trd><baz>ornamen</baz>mengornamenkan</trd>,
    <trd><baz>dekorasi</baz>mendekorasi</trd>
  </trdgrp>
  <trdgrp lng="ja">
    <trd>&#x98FE;&#x308B;  <pr>&#x304B;&#x3056;&#x308B;</pr></trd>,
    <trd>&#x88C5;&#x98FE;&#x3059;&#x308B;  <pr>&#x305D;&#x3046;&#x3057;&#x3087;&#x304F;&#x3059;&#x308B;</pr></trd>
  </trdgrp>
  <trd lng="nl">versieren</trd>
  <trdgrp lng="pl">
    <trd>ozdabia&cacute;</trd>,
    <trd>stroi&cacute;</trd>,
    <trd>udekorowa&cacute;</trd>
  </trdgrp>
  <trdgrp lng="pt">
    <trd>ornamentar</trd>,
    <trd>decorar</trd>
  </trdgrp>
  <trdgrp lng="ro">
    <trd>orna</trd>,
    <trd>&icirc;mpodobi&tcomma;i</trd>,
    <trd>decora&tcomma;i</trd>
  </trdgrp>
  <trd lng="ru">&c_u;&c_k;&c_r;&c_a;&c_sh;&c_a;&c_t;&c_mol;</trd>
  <trd lng="sk">zdobi&tcaron;</trd>
  <trdgrp lng="sv">
    <trd>pryda</trd>,
    <trd>smycka</trd>
  </trdgrp>
  <trdgrp lng="uk">
    <trd>&c_p;&c_r;&c_i;&c_k;&c_r;&c_a;&c_sh;&c_a;&c_t;&c_i;&c_s;&c_ja;</trd>,
    <trd>&c_n;&c_a;&c_d;&c_ja;&c_g;&c_a;&c_t;&c_i; &c_p;&c_r;&c_i;&c_k;&c_r;&c_a;&c_s;&c_i;</trd>
  </trdgrp>
  <trdgrp lng="zh">
    <trd>&#x4FEE;&#x98FE; <pr>xi&umacron;sh&igrave;</pr></trd>,
    <trd>&#x4FEE;&#x9970; <pr>xi&umacron;sh&igrave;</pr></trd>,
    <trd>&#x98FE; <pr>sh&igrave;</pr></trd>,
    <trd>&#x9970; <pr>sh&igrave;</pr></trd>,
    <trd>&#x88C5;&#x9970; <pr>zhu&amacron;ngsh&igrave;</pr></trd>,
    <trd>&#x88DD;&#x98FE; <pr>zhu&amacron;ngsh&igrave;</pr></trd>,
    <trd>&#x70B9;&#x7F00; <pr>di&#x1CE;nzhu&igrave;</pr></trd>,
    <trd>&#x9EDE;&#x7DB4; <pr>di&#x1CE;nzhu&igrave;</pr></trd>,
    <trd>&#x88C5;&#x70B9; <pr>zhu&amacron;ngdi&#x1CE;n</pr></trd>,
    <trd>&#x88DD;&#x9EDE; <pr>zhu&amacron;ngdi&#x1CE;n</pr></trd>
  </trdgrp>
</drv>

<drv mrk="ornam.0o">
  <kap><tld/>o</kap>
  <!-- ne trovi&gcirc;is ekzemplo de tia uzo:
  <snc mrk="ornam.0o.ado">
    <ref tip="dif" cel="ornam.0ado"><tld/>ado</ref>
    <trdgrp lng="be">
      <trd>&c_u;&c_p;&c_r;&c_y;&c_g;&c_o;&c_zh;&c_v;&c_a;&c_n;&c_mol;&c_n;&c_je;</trd>,
      <trd>&c_a;&c_z;&c_d;&c_a;&c_b;&c_l;&c_je;&c_n;&c_mol;&c_n;&c_je;</trd>
    </trdgrp>
    <trdgrp lng="de">
      <trd>Schm&uuml;cken</trd>,
      <trd>Verzieren</trd>
    </trdgrp>
    <trdgrp lng="zh">
      <trd>&#x98FE; <pr>sh&igrave;</pr></trd>,
      <trd>&#x9970; <pr>sh&igrave;</pr></trd>,
      <trd>&#x88C5;&#x9970;&#x7269; <pr>zhu&amacron;ngsh&igrave;w&ugrave;</pr></trd>,
      <trd>&#x88DD;&#x98FE;&#x7269; <pr>zhu&amacron;ngsh&igrave;w&ugrave;</pr></trd>,
      <trd>&#x74D6; <pr>xi&amacron;ng</pr></trd>,
      <trd>&#x85CF;&#x54C1; <pr>c&aacute;ngp&#x1D0;n</pr></trd>
    </trdgrp>
  </snc>
  -->
  <snc mrk="ornam.0o.ajxo">
    <dif>
      Tio, kio <tld/>as; la <ref tip="dif" cel="ornam.0ajxo"><tld/>a&jcirc;o</ref>j de io:
      <ekz>
        jen renkonte al li iras virino en <tld/>o de publikulino
        <fnt>
          <bib>MT</bib>
          <lok>Sentencoj 7:10</lok>
        </fnt>;
      </ekz>
      <ekz>
        malgranda bufedo kun la ordinara <tld/>o de boteloj kaj glasoj kaj kun solida
        horlo&gcirc;o
        <fnt>
          <bib>BdV</bib>
          <lok>La Batalo de l' Vivo</lok>
        </fnt>;
      </ekz>
      <ekz>
        &scirc;ia belega persono estis vera <tld/>o de la festeno
        <fnt>
          <bib>QuV</bib>
          <lok>&Ccirc;apitro VII</lok>
        </fnt>;
      </ekz>
      <ekz>
        kelkfoje la plej bona <tld/>o estas nenia <tld/>o
        <fnt>
          <bib>Ret</bib>
          <lok>Dua Parto</lok>
        </fnt>;
      </ekz>
      <ekz>
        <uzo tip="stl">FIG</uzo>
        <tld/>o por maljunuloj estas grizeco
        <fnt>
          <bib>MT</bib>
          <lok>Sentencoj 20:29</lok>
        </fnt>.
      </ekz>
    </dif>
    <trd lng="be">&c_a;&c_z;&c_d;&c_o;&c_b;&c_a;</trd>
    <trdgrp lng="hu">
      <trd>d&iacute;sz</trd>,
      <trd>d&iacute;sz&iacute;tm&eacute;ny</trd>,
      <trd>ornamentum</trd>
    </trdgrp>
    <trdgrp lng="de">
      <trd>Schmuck</trd>,
      <trd>Verzierung</trd>,
      <trd>Zierrat</trd>,
      <trd>Ornament</trd>
    </trdgrp>
  </snc>
  <trdgrp lng="cs">
    <trd>ornament</trd>,
    <trd>ozdoba</trd>,
    <trd>zdoben&iacute;</trd>
  </trdgrp>
  <trd lng="en">decoration</trd>
  <trdgrp lng="id">
    <trd>hiasan</trd>,
    <trd>ornamen</trd>,
    <trd>dekorasi</trd>
  </trdgrp>
  <trdgrp lng="ja">
    <trd>&#x98FE;&#x308A;&#x3064;&#x3051;  <pr>&#x304B;&#x3056;&#x308A;&#x3064;&#x3051;</pr></trd>,
    <trd>&#x98FE;&#x308A;  <pr>&#x304B;&#x3056;&#x308A;</pr></trd>,
    <trd>&#x88C5;&#x98FE;  <pr>&#x305D;&#x3046;&#x3057;&#x3087;&#x304F;</pr></trd>
  </trdgrp>
  <trdgrp lng="pl">
    <trd>ornament</trd>,
    <trd>ozdoba</trd>
  </trdgrp>
  <trdgrp lng="ro">
    <trd>ornament</trd>,
    <trd>podoab&abreve;</trd>
  </trdgrp>
  <trdgrp lng="sk">
    <trd>ozdoba</trd>,
    <trd>v&yacute;zdoba</trd>
  </trdgrp>
</drv>

<drv mrk="ornam.0ado">
  <kap><tld/>ado</kap>
  <snc>
    <dif>
      Provizado de loko a&ubreve; objekto per <tld/>a&jcirc;oj:
      <ekz>
        &ccirc;iuj konataj fremdlandoj &scirc;ajne kontribuis el siaj plej bonaj trezoroj al la
        konstruado kaj <tld/>ado de lo&gcirc;ejo, inda je potenca reganto
        <fnt>
          <bib>I&scirc;tar</bib>
          <lok>&Ccirc;apitro XI</lok>
        </fnt>;
      </ekz>
      <ekz>
        <klr>[nenio]</klr> montrus &ccirc;e la a&ubreve;toro la intencon de arta <tld/>ado, &gcirc;i estis
        verkita en maniero simpla, sana kaj agrabla, multe pli bela, ol <tld/>ita
        <fnt>
          <bib>Hamlet</bib>
          <lok>Hamleto</lok>
        </fnt>.
      </ekz>
    </dif>
    <trd lng="hu">d&iacute;sz&iacute;tm&eacute;s</trd>
  </snc>
  <trdgrp lng="be">
    <trd>&c_u;&c_p;&c_r;&c_y;&c_g;&c_o;&c_zh;&c_v;&c_a;&c_n;&c_mol;&c_n;&c_je;</trd>,
    <trd>&c_a;&c_z;&c_d;&c_a;&c_b;&c_l;&c_je;&c_n;&c_mol;&c_n;&c_je;</trd>
  </trdgrp>
  <trd lng="cs">zdoben&iacute;</trd>
  <trdgrp lng="de">
    <trd>Schm&uuml;cken</trd>,
    <trd>Verzieren</trd>
  </trdgrp>
  <trd lng="el">&delta;&jota;&alfa;&kappa;&omikron_ton;&sigma;&my;&eta;&sigma;&eta;</trd>
  <trdgrp lng="fr">
    <trd>d&eacute;coration<klr> (action)</klr></trd>
  </trdgrp>
  <trdgrp lng="id">
    <trd><baz>hias</baz>penghiasan</trd>,
    <trd><baz>ornamen</baz>pengornamenan</trd>,
    <trd><baz>dekorasi</baz>pendekorasian</trd>
  </trdgrp>
  <trdgrp lng="ja">
    <trd>&#x98FE;&#x308A;&#x3064;&#x3051;  <pr>&#x304B;&#x3056;&#x308A;&#x3064;&#x3051;</pr></trd>,
    <trd>&#x88C5;&#x98FE;  <pr>&#x305D;&#x3046;&#x3057;&#x3087;&#x304F;</pr></trd>
  </trdgrp>
  <trdgrp lng="pl">
    <trd>ornamentyka</trd>,
    <trd>zdobnictwo</trd>
  </trdgrp>
  <trdgrp lng="pt">
    <trd>ornamenta&ccedil;&atilde;o</trd>,
    <trd>decora&ccedil;&atilde;o</trd>
  </trdgrp>
  <trdgrp lng="ro">
    <trd>ornamentare</trd>,
    <trd>arta decorativ&abreve;</trd>
  </trdgrp>
  <trd lng="ru">&c_u;&c_k;&c_r;&c_a;&c_sh;&c_je;&c_n;&c_i;&c_je;<klr> (&c_d;&c_je;&c_j;&c_s;&c_t;&c_v;&c_i;&c_je;)</klr></trd>
  <trd lng="sk">zdobenie</trd>
  <trdgrp lng="uk">
    <trd>&c_p;&c_r;&c_i;&c_k;&c_r;&c_a;&c_sh;&c_a;&c_n;&c_n;&c_ja;</trd>,
    <trd>&c_p;&c_r;&c_i;&c_k;&c_r;&c_a;&c_sh;&c_u;&c_v;&c_a;&c_n;&c_n;&c_ja;</trd>,
    <trd>&c_p;&c_r;&c_i;&c_k;&c_r;&c_a;&c_sh;&c_je;&c_n;&c_n;&c_ja;</trd>
  </trdgrp>
  <trdgrp lng="zh">
    <trd>&#x98FE; <pr>sh&igrave;</pr></trd>,
    <trd>&#x9970; <pr>sh&igrave;</pr></trd>
  </trdgrp>
</drv>

<drv mrk="ornam.0ajxo">
  <kap><tld/>a&jcirc;o</kap>
  <uzo tip="fak">BELA</uzo>
  <snc>
    <dif>
