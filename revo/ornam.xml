    <trd>&#x7CA7; <pr>zhu&amacron;ng</pr></trd>,
    <trd>&#x74D6; <pr>xi&amacron;ng</pr></trd>,
    <trd>&#x5986; <pr>zhu&amacron;ng</pr></trd>,
    <trd>&#x599D; <pr>zhu&amacron;ng</pr></trd>,
    <trd>&#x4F69;&#x98FE; <pr>p&egrave;ish&igrave;</pr></trd>,
    <trd>&#x4F69;&#x9970; <pr>p&egrave;ish&igrave;</pr></trd>,
    <trd>&#x88C5;&#x6F62; <pr>zhu&amacron;nghu&aacute;ng</pr></trd>,
    <trd>&#x88DD;&#x6F62; <pr>zhu&amacron;nghu&aacute;ng</pr></trd>,
    <trd>&#x88C5;&#x9970;&#x54C1; <pr>zhu&amacron;ngsh&igrave;p&#x1D0;n</pr></trd>,
    <trd>&#x88DD;&#x98FE;&#x54C1; <pr>zhu&amacron;ngsh&igrave;p&#x1D0;n</pr></trd>,
    <trd>&#x914D;&#x98FE; <pr>p&egrave;ish&igrave;</pr></trd>,
    <trd>&#x914D;&#x9970; <pr>p&egrave;ish&igrave;</pr></trd>,
    <trd>&#x98FE;&#x54C1; <pr>sh&igrave;p&#x1D0;n</pr></trd>,
    <trd>&#x9970;&#x54C1; <pr>sh&igrave;p&#x1D0;n</pr></trd>,
