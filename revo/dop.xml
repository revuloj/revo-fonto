<?xml version="1.0"?>
<!DOCTYPE vortaro SYSTEM "../dtd/vokoxml.dtd">

<vortaro>
  <art mrk="$Id: dop.xml,v 1.1 2026/03/05 07:07:56 afido Exp $">
    <kap>
      <rad>dop</rad>/i
      <fnt><bib>PIV2</bib></fnt>
    </kap>

<drv mrk="dop.0i">
  <kap><tld/>i</kap>
  <snc mrk="dop.0i.SPO">
    <uzo tip="fak">SPO</uzo><uzo tip="fak">MED</uzo>
    <dif>
      Medikamente <ref tip="super" cel="stimul.0i">stimuli</ref> ies korpajn a&ubreve; mensajn kapablojn, precipe en sporto:
      <ekz>
        sufi&ccirc;e da skandaloj kredigas je &gcirc;enerala <tld/>ado de la altnivela sportistaro
        <fnt>
          <bib>Kon11</bib>
          <lok>&Ccirc;efartikolo</lok>
        </fnt>;
      </ekz>
      <ekz>
        la homa korpo, kvankam <tld/>ita, post kelkaj jaroj atingos siajn biologiajn
        limojn
        <fnt>
          <bib>Kon11</bib>
          <lok>&Ccirc;efartikolo</lok>
        </fnt>;
      </ekz>
      <ekz>
        la kontra&ubreve;<tld/>a batalo pravi&gcirc;as nur &ccirc;ar oni nepre enmensigu koncepton de
        sporto pura, senmakula
        <fnt>
          <bib>Kon11</bib>
          <lok>&Ccirc;efartikolo</lok>
        </fnt>.
      </ekz>
    </dif>
    <trd lng="de">dopen</trd>
    <trd lng="en">dope</trd>
    <trd lng="fr">doper</trd>
    <trd lng="ru">&c_d;&c_a;&c_v;&c_a;&c_t;&c_mol; <ind>&c_d;&c_o;&c_p;&c_i;&c_n;&c_g;</ind></trd>
  </snc>
  <snc mrk="dop.0i.TEK">
    <uzo tip="fak">TEK</uzo>
    <dif>
      Malpurigi per kvanteto de ia substanco, por atingi celitan kvaliton devian de la
      pura substanco:
      <ekz>
        nanokristaloj el pura zinka oksido kaj el zinka oksido <tld/>ita je <frm>Mn<sup>2+</sup></frm> jonoj
        je du malsimilaj molfrakcioj
        <fnt>
          <aut>Orlando E. Raola</aut>
          <vrk><url ref="https://tekstaro.com/t?nomo=iku&amp;uzistreketojn=0&amp;tipo=&amp;sekcio=dx-artikolo-2010-85"
              >Ne&ubreve;trona difrakto: Aplikoj al esplorado de nanomaterialoj</url></vrk>
          <lok>Internacia Kongresa Universitato 1998-2013</lok>
        </fnt>.
      </ekz>
    </dif>
    <trd lng="de">dotieren</trd>
    <trd lng="en">dope <klr>(chem.)</klr></trd>
    <trd lng="ru">&c_l;&c_je;&c_g;&c_i;&c_r;&c_o;&c_v;&c_a;&c_n;&c_i;&c_je;</trd>
  </snc>
</drv>

  </art>

