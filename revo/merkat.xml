  <trd lng="en">labor market</trd>
  <trd lng="es"><ind>mercado</ind> de trabajo</trd>
  <trdgrp lng="fr">
    <trd>march&eacute; du travail</trd>
  </trdgrp>
  <trd lng="ja">&#21172;&#20685;&#24066;&#22580;  <pr>&#12429;&#12358;&#12393;&#12358;&#12375;&#12376;&#12423;&#12358;</pr></trd>
  <trd lng="nl">arbeidsmarkt</trd>
  <trd lng="pl">rynek pracy</trd>
  <trd lng="ru">&c_r;&c_y;&c_n;&c_o;&c_k;
  &c_t;&c_r;&c_u;&c_d;&c_a;</trd>
  <trd lng="sk">trh pr&aacute;ce</trd>
  <trd lng="uk">&c_r;&c_i;&c_n;&c_o;&c_k; &c_p;&c_r;&c_a;&c_c;&c_ib;</trd>
  <trdgrp lng="zh">
    <trd>&#21171;&#21160;&#21147;&#24066;&#22330; <pr>l&aacute;od&ograve;ngl&igrave;sh&igrave;ch&#462;ng</pr></trd>,
