<drv mrk="merkat.sur0igi">
  <kap>sur<tld/>igi</kap>
  <gra><vspec>tr</vspec></gra>
  <snc mrk="merkat.sur0igi.EKON">
    <uzo tip="fak">EKON</uzo>
    <dif>
      Ekvendi novan produkton, aran&gcirc;ante &gcirc;ian prireklamadon,
      liveradon,
      uzhelpon:
      <ekz>
        eta kompanio, kiu sur<tld/>igis komputilan programon, kiu tuj
        tutmonde furoras, i&gcirc;as ege valora
        <fnt>
        <aut>R. Rotsaert</aut>,
        <vrk>Piramidaj investoj...</vrk>,
        <bib>Monato</bib>,
        <lok>jaro 1997a, numero 7a, p. 24a</lok>
        </fnt>;
      </ekz>
      <ekz>
        komputila tradukprogramo Atlas, sur<tld/>igita en 1984
        <fnt>
       <aut>Roland Rotsaert</aut>
          <vrk><url ref="&Monato;/2000/006881.php">Universala Retlingvo</url></vrk>
          <bib>Monato</bib>
          <lok>2000/04, p. 26</lok>
        </fnt>;
      </ekz>
      <ekz>
        oni senprokraste sendis skipojn da laboristoj por ekspluati la okron, kiu rapide estis
        sur<tld/>igita
        <fnt><aut>Robert Roze</aut>,
        <vrk><url ref="&Monato;/2000/006945.php">Flagrantaj koloroj</url></vrk>,
        <bib>Monato</bib>,
        <lok>2000/06, p. 17</lok>
        </fnt>;
      </ekz>
      <ekz>
        kiam la persona komputilo estis disvolvita kaj sur<tld/>igita en Usono,
        &gcirc;i estis planita kaj programita por anglalingvanoj
        <fnt>
          <bib>Monato</bib>
          <aut>Garbhan MacAoidh</aut>
          <vrk><url ref="&Monato;/2005/008705.php">Plurlingva tekstoprilaborado</url></vrk>
        </fnt>.
      </ekz>
    </dif>
    <refgrp tip="sin">
      <ref cel="merkat.en0igi">en<tld/>igi</ref>
    </refgrp>
    <refgrp tip="vid">
      <ref cel="lancx.0i.sociajxon">lan&ccirc;i</ref>
    </refgrp>
  </snc>
  <trdgrp lng="be">
    <trd>&c_v;&c_y;&c_p;&c_u;&c_s;&c_mol;&c_c;&c_ib;&c_c;&c_mol; &c_n;&c_a;
    <ind>&c_r;&c_y;&c_n;&c_a;&c_k;</ind></trd>,
    <trd>&c_v;&c_y;&c_v;&c_je;&c_s;&c_mol;&c_c;&c_ib; &c_n;&c_a;
    <ind>&c_r;&c_y;&c_n;&c_a;&c_k;</ind></trd>
  </trdgrp>
  <trdgrp lng="ca">
    <trd>comercialitzar</trd>,
    <trd>posar al <ind>mercat</ind></trd>
  </trdgrp>
  <trd lng="cs">uv&eacute;st na trh</trd>
  <trd lng="de">auf den <ind>Markt bringen</ind></trd>
  <trd lng="en">to bring to market</trd>
  <trd lng="es">comercializar</trd>
  <trdgrp lng="fr">
    <trd>commercialiser</trd>,
    <trd>lancer<klr> (un produit)</klr></trd>,
    <trd>mettre sur le <ind>march&eacute;</ind></trd>
  </trdgrp>
  <trdgrp lng="ja">
    <trd>&#24066;&#22580;&#12395;&#20986;&#12377;  <pr>&#12356;&#12385;&#12400;&#12395;&#12384;&#12377;</pr></trd>,
    <trd>&#22770;&#12426;&#20986;&#12377;  <pr>&#12358;&#12426;&#12384;&#12377;</pr></trd>
  </trdgrp>
  <trdgrp lng="nl">
    <trd>commercialiseren</trd>,
    <trd>op de <ind>markt</ind> brengen</trd>
  </trdgrp>
  <trd lng="pl">wprowadza&cacute; na <ind>rynek</ind></trd>
  <trd lng="ru">&c_v;&c_y;&c_p;&c_u;&c_s;&c_t;&c_i;&c_t;&c_mol;
  &c_n;&c_a; &c_r;&c_y;&c_n;&c_o;&c_k;</trd>
  <trd lng="sk">uvies&tcaron; na trh</trd>
  <trd lng="uk">&c_p;&c_o;&c_s;&c_t;&c_a;&c_v;&c_l;&c_ja;&c_t;&c_i; &c_n;&c_a; &c_r;&c_i;&c_n;&c_o;&c_k;</trd>
  <trdgrp lng="zh">
    <trd>&#21830;&#19994;&#21270; <pr>sh&#257;ngy&egrave;hu&agrave;</pr></trd>,
    <trd>&#21830;&#26989;&#21270; <pr>sh&#257;ngy&egrave;hu&agrave;</pr></trd>
  </trdgrp>
</drv>

<drv mrk="merkat.labor0o">
  <kap>labor<tld/>o</kap>
  <snc mrk="merkat.labor0o.EKON">
    <uzo tip="fak">EKON</uzo>
    <dif>
      Momenta kaj loka stato de dungemo, senlaboreco, salajroj:
      <ekz>
        elastaj labortempoj kreis en la lastaj dek jaroj pli flekseblan
        labor<tld/>on
        <fnt>
        <aut>E. Georgiev</aut>,
        <vrk>Pli maljunaj, pli sa&gcirc;aj...</vrk>,
        <bib>Monato</bib>,
        <lok>jaro 1999a, numero 3a, p. 18a</lok>
        </fnt>;
      </ekz>
      <ekz>
        homoj, kiuj apartenas al komunumoj aliaj ol la tradiciaj kristanaj eklezioj,
        ofte spertas ekskludojn kaj rifuzojn en la labor<tld/>o, eduko kaj aliaj vivokampoj
        <fnt>
          <bib>Monato</bib>
          <aut>Istvan Ertl</aut>
          <vrk><url ref="&Monato;/2003/008103.html">Dio en la konstitucio, diablo en la
          detaloj</url></vrk>
        </fnt>;
      </ekz>
      <ekz>
        la ceteraj EU-&scirc;tatoj, &scirc;ajne, intencas plu rifuzi al &leftquot;nov-landaj&#8221; 
        laborprenantoj liberan aliron al ilia labor<tld/>o, kvankam &ccirc;i tiuj homoj devus &gcirc;ui samajn
        rajtojn
        <fnt>
          <bib>Monato</bib>
          <aut>Istv&aacute;n Ertl</aut>
          <vrk><url ref="&Monato;/2003/008140.html">Pri orienti&gcirc;o kaj
          okcidenti&gcirc;o</url></vrk>
        </fnt>.
      </ekz>
    </dif>
  </snc>
  <trd lng="be">&c_r;&c_y;&c_n;&c_a;&c_k; &c_p;&c_r;&c_a;&c_c;&c_y;</trd>
  <trd lng="ca">mercat de treball</trd>
  <trdgrp lng="cs">
    <trd>pracovn&iacute; trh</trd>,
    <trd>trh pr&aacute;ce</trd>
  </trdgrp>
