          <aut>Garbhan MacAoidh</aut>
            <vrk><url ref="&Monato;/2000/007159.php">Flugilhavaj vortoj</url></vrk>
            <bib>Monato</bib>
            <lok>2000/10, p. 22</lok>
          </fnt>;
      </ekz>
      <ekz>
        malperfekta&jcirc;oj ekzistas nur en la en<tld/>igo
        <fnt>
        <aut>Evgeni Georgiev</aut>,
        <vrk>A&ubreve;strio: lando de ekologia kultivado</vrk>,
        <bib>Monato</bib>,
        <lok>1997/09, p. 19</lok>
