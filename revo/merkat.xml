<drv mrk="merkat.0o">
  <kap><tld/>o</kap>
  <snc mrk="merkat.0o.EKON">
    <tezrad fak="EKON"/>
    <uzo tip="fak">EKON</uzo>
    <dif>
      Stato de a&ccirc;etpovo kaj a&ccirc;etemo pri iu komerca&jcirc;o
      a&ubreve; borsa valoro:
      <ekz>
        la koton<tld/>o;
      </ekz>
      <ekz>
        tiu varo havas vastan <tld/>on;
      </ekz>
      <ekz>
        ser&ccirc;i al si novajn <tld/>ojn;
      </ekz>
      <ekz>
        la &ccirc;ina bilo<tld/>o funkcias kiel barometro de la
        ekonomio
        <fnt>
        <aut>Huang Tingsheng</aut>,
        <vrk>La &ccirc;ina bilomerkato</vrk>,
        <bib>Monato</bib>,
        <lok>jaro 2001a, numero 8a, p. 10a</lok>
        </fnt>;
      </ekz>
      <ekz>
        la multeco de varoj en la <tld/>o pu&scirc;as homojn en materialismon
        <fnt>
          <aut>Remigiusz Mielcarek</aut>
          
          <vrk><url ref="&Monato;/1994/A940101.php">Enmigrintoj en ora ka&gcirc;o</url></vrk>
          <bib>Monato</bib>
          <lok>1994/01, p. 15</lok>
        </fnt>;
      </ekz>
      <ekz>
        kafo &leftquot;solidara&rightquot; <klr>[&#8230;]</klr> konsistigas malpli ol 1 % de la tuta
        kafo<tld/>o
        <fnt>
          <aut>Gianfranco Cazzaro</aut>
          <vrk><url ref="&Monato;/1994/A940602.php">Morale a&ccirc;eti, konscie subteni</url></vrk>
          <bib>Monato</bib>
          <lok>1994/06, p. 9</lok>
        </fnt>;
      </ekz>
      <ekz>
        la konkurenca forto de Usono en la monda eksporta <tld/>o estis pli granda ol tiu de E&ubreve;ropo
        <fnt>
	<aut>Marc Vanden Bempt</aut>
	<vrk><url ref="&Monato;/2000/006821.php">E&ubreve;ro unujara</url></vrk>
	<bib>Monato</bib>
	<lok>2000/03, p. 14</lok>
        </fnt>;
      </ekz>
      <ekz>
        cigaredojn, kiuj kontrabande trafis la britan nigran <tld/>on, 
        litovaj krimuloj disvastigas helpe de tie lo&gcirc;antaj samlandanoj
       <fnt>
	<aut>Laimius Stra&zcaron;nickas</aut>
	<vrk><url ref="&Monato;/2000/006830.php">Kontrabanditaj cigaredoj invadas Brition</url></vrk>
	<bib>Monato</bib>
	<lok>2000/04, p. 13</lok>
        </fnt>;
      </ekz>
      <ekz>
        internacia <tld/>sistemo
        <fnt>
          <aut>Gianfranco Cazzaro</aut>
          <vrk><url ref="&Monato;/1994/A940602.php">Morale a&ccirc;eti, konscie subteni</url></vrk>
          <bib>Monato</bib>
          <lok>1994/06, p. 9</lok>
        </fnt>;
      </ekz>
      <ekz>
        financa <tld/>o <klr>(kie oni vendas valutojn)</klr>
        <fnt>
	<aut>Marc Vanden Bempt</aut>
	<vrk><url ref="&Monato;/2000/006821.php">E&ubreve;ro unujara</url></vrk>
	<bib>Monato</bib>
	<lok>2000/03, p. 14</lok>
        </fnt>;
      </ekz>
      <ekz>
        akcia <tld/>o.
      </ekz>
    </dif>
    <ref tip="malprt" cel="ekonom1.0o.situacio">ekonomio</ref>
    <rim mrk="merkat.0o.RIM_EVI">
      <em>Merkato</em> neniam signifas placon a&ubreve; ejon. Kp <ref cel="bazar.0o">bazaro</ref>.
    </rim>
  </snc>
  <trd lng="be">&c_r;&c_y;&c_n;&c_a;&c_k; <klr>(&c_ja;&c_k;
  &c_e;&c_k;&c_a;&c_n;&c_a;&c_m;&c_ib;&c_ch;&c_n;&c_a;&c_ja;
