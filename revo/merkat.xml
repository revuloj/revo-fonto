<drv mrk="merkat.0isto">
  <kap><tld/>isto</kap>
  <snc mrk="merkat.0isto.EKON">
    <uzo tip="fak">EKON</uzo>
    <dif>
      Esploristo de <tld/>oj helpanta difini produktojn ta&ubreve;gajn
      por a&ccirc;etantoj:
      <ekz>
        duono de la laboro estas helpado por reklamistoj kaj <tld/>istoj
        <fnt>
          <aut>Kronostar</aut>,
          <vrk><url ref="http://www.eklaboru.com/posteno_priskribo.php?id=17">
          Asistanto por &gcirc;enerala direktoro</url></vrk>,
          <lok>Eklaboru!, 2006-11-17</lok>
        </fnt>;
      </ekz>
      <ekz>
        gren<tld/>isto lastan jaron asertis ke Francio facile povas 
        produkti grenojn por nutri dekoble sian propran lo&gcirc;antaron
        <fnt>
	<aut>Guido van Damme</aut>
	<vrk><url ref="&Monato;/2001/007272.php">Reen al la edena paradizo</url></vrk>
	<bib>Monato</bib>
	<lok>2001/02, p. 20</lok>
        </fnt>;
      </ekz>
      <ekz>
        liber<tld/>istoj
        <fnt>
	<aut>Donald Rogers</aut>
	<vrk><url ref="&Monato;/2000/006819.php">Laborema koalicio</url></vrk>
	<bib>Monato</bib>
	<lok>2000/03, p. 11</lok>
        </fnt>.
      </ekz>
    </dif>
  </snc>
  <trdgrp lng="be">
    <trd>&c_m;&c_a;&c_r;&c_k;&c_je;&c_t;&c_o;&c_l;&c_ja;&c_g;</trd>,
