<drv mrk="merkat.en0igi">
  <kap>en<tld/>igi</kap>
  <gra><vspec>tr</vspec></gra>
  <snc mrk="merkat.en0igi.EKON">
    <uzo tip="fak">EKON</uzo>
    <dif>
      <ref tip="dif" cel="merkat.sur0igi">Sur<tld/>igi</ref>:
      <ekz>
        malgranda firmao <klr>[&#8230;]</klr> provis en<tld/>igi kurson sur kompakta disko pri aviada
        lingvo
