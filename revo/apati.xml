<?xml version="1.0"?>
<!DOCTYPE vortaro SYSTEM "../dtd/vokoxml.dtd">
<vortaro>
<art mrk="$Id: apati.xml,v 1.25 2026/04/24 04:01:26 revo Exp $">
<kap>
  <ofc>1</ofc>
  <rad>apati</rad>/o
<fnt><bib>JED</bib></fnt></kap>
<drv mrk="apati.0o">
  <kap><tld/>o</kap>
  <snc>
    <dif>
      <ref tip="sin" cel="vigl.mal0o">Malvigleco</ref>,
      <ref tip="sin" cel="indife.0eco">indiferenteco</ref>:
      <ekz>
        li sukcesis tiel rapide forigi de la viza&gcirc;o de la laca maljunulo maldol&ccirc;on kaj
        <tld/>on!
        <fnt>
          <bib>IK</bib>
        </fnt>;
      </ekz>
      <ekz>
        lacaj de la sendanka laborado, ni kun malespero kaj <tld/>o lasus fali la
        manojn, &dash; tute egale
        <fnt>
          <bib>EE</bib>
        </fnt>;
      </ekz>
      <ekz>
        fra&ubreve;lino, nek malbona, nek gaja, &scirc;toni&gcirc;inta en la <tld/>o de sia vivo
        <fnt>
          <bib>IKr</bib>
        </fnt>;
      </ekz>
      <ekz>
        sen pensoj, sen ribelo, en kompleta <tld/>o ili faris tion
        <fnt>
          <bib>LGA</bib>
        </fnt>;
      </ekz>
      <ekz>
        &scirc;i frostis, sed ankora&ubreve; sentis la dol&ccirc;on de la panpeco kaj &scirc;i subite revivi&gcirc;is
        el sia <tld/>o
        <fnt>
          <bib>LGA</bib>
        </fnt>;
      </ekz>
      <ekz>
        sur la viza&gcirc;o de <nom>Omar</nom> sin montris <tld/>o, kiu tamen subite &scirc;an&gcirc;i&gcirc;is en rigardon
        de granda surprizo
        <fnt>
          <bib>I&scirc;tar</bib>
        </fnt>;
      </ekz>
      <ekz>
        post la unua katastrofo de la tago li jam toleris tiun &ccirc;i duan kun la <tld/>o de
        martiroj
        <fnt>
          <bib>KKr</bib>
        </fnt>;
      </ekz>
    </dif>
    <refgrp tip="vid">
      <ref cel="deprim.0o">deprimo</ref>,
      <ref cel="inert.0eco.psika">inerteco<sncref/></ref>,
      <ref cel="flegm.0o">flegmo</ref>,
      <ref cel="marasm.0o">marasmo</ref>
    </refgrp>
  </snc>
  <trdgrp lng="be">
    <trd>&c_a;&c_p;&c_a;&c_t;&c_y;&c_ja;</trd>,
    <trd>&c_a;&c_b;&c_y;&c_ja;&c_k;&c_a;&c_v;&c_a;&c_s;&c_mol;&c_c;&c_mol;</trd>
  </trdgrp>
  <trdgrp lng="cs">
    <trd>apatie</trd>,
    <trd>lhostejnost</trd>
  </trdgrp>
  <trdgrp lng="de">
      <trd>Teilnahmslosigkeit</trd>,
      <trd>Apathie</trd>
  </trdgrp>
  <trd lng="en">apathy</trd>
  <trd lng="es">apat&iacute;a</trd>
  <trd lng="fr">apathie</trd>
  <trd lng="he">&alef;&#x5B2;&dalet;&#x5B4;&yod;&shin;&#x5C1;&vav;&#x5BC;&tav;</trd>
  <trdgrp lng="hu">
    <trd>ap&aacute;tia</trd>,
    <trd>egykedv&udblac;s&eacute;g</trd>
  </trdgrp>
  <trdgrp lng="it">
    <trd>apatia</trd>
  </trdgrp>
  <trdgrp lng="ja">
    <trd>&#x7121;&#x611F;&#x52D5;  <pr>&#x3080;&#x304B;&#x3093;&#x3069;&#x3046;</pr></trd>,
    <trd>&#x7121;&#x95A2;&#x5FC3;  <pr>&#x3080;&#x304B;&#x3093;&#x3057;&#x3093;</pr></trd>,
    <trd>&#x51B7;&#x6DE1;  <pr>&#x308C;&#x3044;&#x305F;&#x3093;</pr></trd>
  </trdgrp>
  <trd lng="nl">apathie</trd>
  <trd lng="pl">apatia</trd>
  <trd lng="ro">apatie</trd>
  <trdgrp lng="ru">
    <trd>&c_a;&c_p;&c_a;&c_t;&c_i;&c_ja;</trd>,
    <trd>&c_b;&c_je;&c_z;&c_r;&c_a;&c_z;&c_l;&c_i;&c_ch;&c_i;&c_je;</trd>,
    <trd>&c_r;&c_a;&c_v;&c_n;&c_o;&c_d;&c_u;&c_sh;&c_i;&c_je;</trd>
  </trdgrp>
  <trdgrp lng="sk">
    <trd>apatia</trd>,
    <trd>nev&scaron;&iacute;mavos&tcaron;</trd>,
    <trd>otupenos&tcaron;</trd>,
    <trd>&lcaron;ahostajnos&tcaron; vo&ccaron;i okoliu</trd>
  </trdgrp>
  <trdgrp lng="uk">
    <trd>&c_a;&c_p;&c_a;&c_t;&c_ib;&c_ja;</trd>,
    <trd>&c_b;&c_a;&c_j;&c_d;&c_u;&c_zh;&c_n;&c_ib;&c_s;&c_t;&c_mol;</trd>,
    <trd>&c_b;&c_a;&c_j;&c_d;&c_u;&c_zh;&c_ib;&c_s;&c_t;&c_mol;</trd>
  </trdgrp>
</drv>

<drv mrk="apati.0a">
  <kap>
    <tld/>a
  </kap>
  <snc>
    <dif>
      <ref tip="dif" cel="vigl.mal0a">Malvigla</ref>,
      <ref tip="dif" cel="indife.0a.iu">indiferenta</ref>:
      <ekz>
        la duone acida, duone <tld/>a mieno montris homon &hcirc;ronike malsanan
        <fnt>
          <bib>IK</bib>
          <lok>&Ccirc;aptiro III</lok>
        </fnt>;
      </ekz>
      <ekz>
        li &scirc;ajnis <tld/>a, sed tiuj briletoj sub la dormemaj palpebroj memorigis pri
        kato, kiu senmove observas sian kapta&jcirc;on
        <fnt>
          <bib>HsT</bib>
          <lok>Heredanto</lok>
        </fnt>;
      </ekz>
      <ekz>
        la infanoj estis lacaj kaj <tld/>aj
        <fnt>
          <bib>Monato</bib>
          <aut>Zofia Banet-Fornalowa</aut>
          <vrk>Li semis bonon kaj belon</vrk>
          <lok>2003</lok>
        </fnt>.
      </ekz>
    </dif>
    <refgrp tip="vid">
      <ref cel="flegm.0a">flegma</ref>,
      <ref cel="inert.0a.FIG">inerta<sncref/></ref>,
      <ref cel="pasiv.0a.malagema">pasiva<sncref/></ref>
    </refgrp>
  </snc>
  <trd lng="de">apathisch</trd>
  <trd lng="en">apathetic</trd>
  <trd lng="fr">apathique</trd>
</drv>

</art>
