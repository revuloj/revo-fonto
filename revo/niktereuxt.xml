<?xml version="1.0"?>
<!DOCTYPE vortaro SYSTEM "../dtd/vokoxml.dtd">
<vortaro>
<art mrk="$Id: niktereuxt.xml,v 1.13 2026/03/08 18:51:49 revo Exp $">
<kap>
  <rad>niktere&ubreve;t</rad>/o <fnt><bib>EncJap</bib></fnt>
</kap>

<drv mrk="niktereuxt.0o">
  <kap><tld/>o</kap>
  <snc mrk="niktereuxt.0o.ZOO">
    <uzo tip="fak">ZOO</uzo>
    <dif>
      <ref tip="lst" lst="voko:zoologiaj_genroj" cel="genr.0o.BIO">Genro</ref>
      el la familio <ref tip="malprt" cel="hunded.0oj">hundedoj</ref>
      (<trd lng="la">Nyctereutes procyonoides</trd>), vulpe granda mamulo
      kun pufa malhelgriza hararo
      kaj pli hela ventro, vivanta en orienta Azio de Siberio &gcirc;is
      Japanujo, enkondukita en Rusujo kaj orienta E&ubreve;ropo
      (iom simila al <ref cel="procion.0o">prociono</ref>):
      <ekz>
        mi <klr>[&#x2026;]</klr> vidis la desegnofilmon &leftquot;Batalo de la
        <tld/>oj&rightquot;
        <fnt>
        <aut>Hirotaka M.</aut>,
        <vrk>Re: vulpoj geedzi&gcirc;as</vrk>,
        <lok>soc.culture.esperanto, 1997-06-03</lok>
        </fnt>;
      </ekz>
      <ekz>
        kvar oraj punktoj subite aperis! vulpo a&ubreve; <tld/>o
        <fnt>
          <aut>Misa&ubreve;a Seii&ccirc;irou</aut>
          <vrk><url ref="https://revuoesperanto.org/nokta_monteto"
              > Nokta Monteto</url></vrk>
          <lok>Revuo Esperanto</lok>
        </fnt>?
      </ekz>
    </dif>
    <bld
      lok="https://upload.wikimedia.org/wikipedia/commons/thumb/3/36/%D0%95%D0%BD%D0%BE%D1%82%D0%BE%D0%B2%D0%B8%D0%B4%D0%BD%D0%B0%D1%8F_%D1%81%D0%BE%D0%B1%D0%B0%D0%BA%D0%B0_%D0%93%D1%80%D0%BE%D0%B4%D0%BD%D0%BE_%28cropped_2%29.jpg/960px-%D0%95%D0%BD%D0%BE%D1%82%D0%BE%D0%B2%D0%B8%D0%B4%D0%BD%D0%B0%D1%8F_%D1%81%D0%BE%D0%B1%D0%B0%D0%BA%D0%B0_%D0%93%D1%80%D0%BE%D0%B4%D0%BD%D0%BE_%28cropped_2%29.jpg"
      prm="CC BY-SA 3.0"
      ><tld/>o, en Grodna Zoo
        <fnt>
          <aut>&c_D;&c_o;&c_k;&c_t;&c_o;&c_r; &c_r;&c_u;&c_k;&c_i;&c_n;&c_o;&c_g;&c_i;, propra verko</aut>
          <lok><url ref="&WCW;/File:%D0%95%D0%BD%D0%BE%D1%82%D0%BE%D0%B2%D0%B8%D0%B4%D0%BD%D0%B0%D1%8F_%D1%81%D0%BE%D0%B1%D0%B0%D0%BA%D0%B0_%D0%93%D1%80%D0%BE%D0%B4%D0%BD%D0%BE_(cropped_2).jpg"
              >https://commons.wikimedia.org/wiki/File:&c_Je;&c_n;&c_o;&c_t;&c_o;&c_v;&c_i;&c_d;&c_n;&c_a;&c_ja;_&c_s;&c_o;&c_b;&c_a;&c_k;&c_a;_&c_G;&c_r;&c_o;&c_d;&c_n;&c_o;_(cropped_2).jpg</url></lok>
        </fnt>
    </bld>
  </snc>
  <trd lng="be">&c_ja;&c_n;&c_o;&c_t;&c_a;&c_p;&c_a;&c_d;&c_o;&c_b;&c_n;&c_y; &c_s;&c_a;&c_b;&c_a;&c_k;&c_a;</trd>
  <trd lng="bg">&c_je;&c_n;&c_o;&c_t;&c_o;&c_v;&c_i;&c_d;&c_n;&c_o; &c_k;&c_u;&c_ch;&c_je;</trd>
  <trdgrp lng="de">
    <trd>Marderhund</trd>,
    <trd>Enok</trd>
  </trdgrp>
  <trd lng="en">raccoon dog</trd>
  <trd lng="fr">chien viverrin</trd>
  <trd lng="hu">nyestkutya</trd>
  <trdgrp lng="nl">
    <trd>wasbeerhond</trd>,
    <trd>marterhond</trd>
  </trdgrp>
  <trd lng="pl">jenot</trd>
  <trdgrp lng="pt">
    <trd>cachorro-racum</trd>,
    <trd>c&atilde;o-racum</trd>
  </trdgrp>
  <trd lng="ro">c&acirc;ine enot</trd>
  <trd lng="ru">&c_je;&c_n;&c_o;&c_t;&c_o;&c_v;&c_i;&c_d;&c_n;&c_a;&c_ja; &c_s;&c_o;&c_b;&c_a;&c_k;&c_a;</trd>
  <trd lng="uk">&c_jeu;&c_n;&c_o;&c_t;&c_o;&c_v;&c_i;&c_d;&c_n;&c_i;&c_j; &c_s;&c_o;&c_b;&c_a;&c_k;&c_a;</trd>
  <trdgrp lng="zh">
    <trd>&#x8C89; <pr>m&ograve;</pr></trd>,
    <trd>&#x8C89; <pr>h&eacute;</pr></trd>
  </trdgrp>
</drv>
</art>

