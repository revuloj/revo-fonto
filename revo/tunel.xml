<?xml version="1.0"?>
<!DOCTYPE vortaro SYSTEM "../dtd/vokoxml.dtd">
<vortaro>
<art mrk="$Id: tunel.xml,v 1.34 2026/06/30 16:59:42 revo Exp $">
<kap>
  <ofc>1</ofc>
  <rad>tunel</rad>/o <fnt><bib>JED</bib></fnt>
</kap>
<drv mrk="tunel.0o">
  <kap><tld/>o</kap>
  <snc mrk="tunel.0o.KON">
    <uzo tip="fak">KON</uzo><uzo tip="fak">TRA</uzo>
    <dif>
      Tubforma subtera <ref tip="super" cel="kav.fos0o">foskavo</ref> ebliganta
      pasi tra monto, sub rivero, trafikvojoj ks:
      <ekz>
        kial Hanibalo iris trans la Alpojn? &mdash; &ccirc;ar tiam la <tld/>o ne estis ankora&ubreve; preta
        <fnt>
          <bib>FK</bib>
        </fnt>;
      </ekz>
      <ekz>
        en la <tld/>o oni a&ubreve;das la bruon de &jcirc;us trapasinta vagonaro
        <fnt>
          <bib>IKr</bib>
        </fnt>;
      </ekz>
      <ekz>
        tra la kanala <tld/>o oni veturas al Francujo
        <fnt>
          <bib>Fab3</bib>
          <lok>Post jarmiloj</lok>
        </fnt>;
      </ekz>
      <ekz>
        ni iras nun malsupre en luma koridoro de la estonta <tld/>o, la&ubreve;longe de nealtaj
        blankaj muretoj staras en senfinaj vicoj lignaj subteniloj
        <fnt>
          <bib>Metrop</bib>
        </fnt>;
      </ekz>
      <ekz>
        tra la fojnamasoj ili faris longajn <tld/>ojn, en kiuj ili ka&scirc;ludis
        <fnt>
          <bib>InfanTorent2</bib>
        </fnt>;
      </ekz>
      <ekz>
        ni trasusuris <tld/>on sub la rivero, poste, aliborde suprenkurante
        <fnt>
          <bib>VaK</bib>
        </fnt>;
      </ekz>
      <ekz>
        la formik<klr>[&#x2026;]</klr>oj kunportadis multe da nutra&jcirc;o kaj &ccirc;ion ordigis en
        profundaj <tld/>oj
        <fnt>
          <bib>LOdE</bib>
          <lok>2003, &#x2116; 1</lok>
        </fnt>;
      </ekz>
      <ekz>
        <uzo tip="stl">FIG</uzo>
        la fino de la ekonomia krizo jam alvenis, <klr>[&#x2026;]</klr> finfine videblas lumo
        fine de la <tld/>o
        <fnt>
          <bib>Monato</bib>
          <aut>Roberto Pigro</aut>
          <vrk><url ref="&Monato;/2014/011257.php"
              >En rubujon, kulturo kaj lingvo de Italio</url></vrk>
          <lok>2014</lok>
        </fnt>;
      </ekz>
      <ekz>
        <uzo tip="stl">FIG</uzo>
        se vi suferas de ajna formo de dormoproblemo, estas bona ideo provi tiun
        substancon, anta&ubreve; ol eniri la tre dan&gcirc;eran <tld/>on de psikomedikamentoj
        <fnt>
          <bib>Monato</bib>
          <aut>Roberto Pigro</aut>
          <vrk><url ref="&Monato;/2012/010764.php"
              >Dormu bone, vivu bone (per melatonino)</url></vrk>
          <lok>2012</lok>
        </fnt>.
      </ekz>
    </dif>
    <refgrp tip="vid">
       <ref cel="galeri.0o.mineja">galerio<sncref/></ref>,
       <ref cel="korido.0o.GEOL">koridoro<sncref/></ref>,
       <ref cel="sxakt.0o.mineja">&scirc;akto<sncref/></ref>
    </refgrp>
  </snc>
  <trd lng="be">&c_t;&c_u;&c_n;&c_e;&c_l;&c_mol;</trd>
  <trd lng="bg">&c_t;&c_u;&c_n;&c_je;&c_l;</trd>
  <trd lng="bo">&t_sa;&t_tsheg;&t_-a;&t_naro;&t_ga;&t_tsheg;&t_ga;&t_rata;&t_naro;&t_tsheg;&t_la;&t_ma;&t_tsheg;</trd>
  <trd lng="ca">t&uacute;nel</trd>
  <trdgrp lng="cs">
    <trd>chodba</trd>,
    <trd>tunel</trd>
  </trdgrp>
  <trd lng="de">Tunnel</trd>
  <trd lng="en">tunnel</trd>
  <trd lng="es">t&uacute;nel</trd>
  <trdgrp lng="fa">
    <trd>&a_t;&a_w;&a_n;&a_l;</trd>,
    <trd>&a_d;&a_A;&a_l;&a_A;&a_n;&a_h;</trd>
  </trdgrp>
  <trd lng="fr">tunnel</trd>
  <trd lng="hu">alag&uacute;t</trd>
  <trdgrp lng="it">
    <trd>tunnel</trd>,
    <trd>galleria</trd>,
    <trd>cunicolo</trd>
  </trdgrp>
  <trdgrp lng="ja">
    <trd>&#x30C8;&#x30F3;&#x30CD;&#x30EB;  <pr>&#x3068;&#x3093;&#x306D;&#x308B;</pr></trd>,
    <trd>&#x96A7;&#x9053;  <pr>&#x3059;&#x3044;&#x3069;&#x3046;</pr></trd>,
    <trd>&#x5730;&#x4E0B;&#x9053;  <pr>&#x3061;&#x304B;&#x3069;&#x3046;</pr></trd>
  </trdgrp>
  <trd lng="nl">tunnel</trd>
  <trd lng="pl">tunel</trd>
  <trd lng="pt">t&uacute;nel</trd>
  <trdgrp lng="ru">
    <trd>&c_t;&c_u;&c_n;&c_n;&c_je;&c_l;&c_mol;</trd>,
    <trd>&c_t;&c_o;&c_n;&c_n;&c_je;&c_l;&c_mol;</trd>
  </trdgrp>
  <trd lng="sk">tunel</trd>
  <trd lng="sv">tunnel</trd>
  <trd lng="uk">&c_t;&c_u;&c_n;&c_je;&c_l;&c_mol;</trd>
  <trdgrp lng="zh">
    <trd>&#x5730;&#x9053; <pr>d&igrave;d&agrave;o</pr></trd>,
    <trd>&#x96A7;&#x9053; <pr>su&igrave;d&agrave;o</pr></trd>,
    <trd>&#x96A7; <pr>su&igrave;</pr></trd>,
    <trd>&#x5730;&#x4E0B;&#x901A;&#x9053; <pr>d&igrave;xi&agrave;t&omacron;ngd&agrave;o</pr></trd>
  </trdgrp>
</drv>

<drv mrk="tunel.0i">
  <kap><tld/>i</kap>
  <gra><vspec>x</vspec></gra>
  <snc mrk="tunel.0i.fosi">
    <dif>
      Per fosado estigi <tld/>on:
      <ekz>
        sufi&ccirc;e grandaj animaloj, kiel kunikloj, talpoj
        kaj musoj <klr>[&#x2026;]</klr> <tld/>as en la grundo
        <fnt>
          <aut>W. F. Rolt</aut>,
          <vrk>El la Polvo de la Tero</vrk>,
          <lok>1967</lok>
        </fnt>;
      </ekz>
      <ekz>
        <uzo tip="stl">FIG</uzo>
        oni &scirc;teladas e&ccirc; pli ofte, pli rafinite, ruze, vidu la t.n. <tld/>adon: la
        malaperigon de publika mono en po&scirc;ojn de financ-ruzuloj
        <fnt>
          <bib>Monato</bib>
          <aut>HRADIL Jozefo</aut>
          <vrk><url ref="&Monato;/2004/007952.html"
              >&Ccirc;u la dekalogo ankora&ubreve; validas?</url></vrk>
          <lok>2004</lok>
        </fnt>.
      </ekz>
    </dif>
    <trd lng="de">durchtunneln</trd>
  </snc>
  <trd lng="be">&c_k;&c_a;&c_p;&c_a;&c_c;&c_mol; <ind>&c_t;&c_u;&c_n;&c_e;&c_l;&c_mol;</ind></trd>
  <trd lng="ca">excavar, contruir un t&uacute;nel</trd>
  <trdgrp lng="cs">
    <trd>razit tunel</trd>,
    <trd>tunelovat</trd>
  </trdgrp>
  <trd lng="en">tunnel</trd>
  <trdgrp lng="es">
     <trd>tunelar</trd>,
     <trd>hacer un t&uacute;nel</trd>
  </trdgrp>
  <trdgrp lng="fa">
    <trd>&a_t;&a_w;&a_n;&a_l; &a_z;&a_d;&a_n;</trd>,
    <trd>&a_t;&a_w;&a_n;&a_l; &f_k;&a_n;&a_d;&a_n;</trd>
  </trdgrp>
  <trd lng="ja">&#x30C8;&#x30F3;&#x30CD;&#x30EB;&#x3092;&#x3064;&#x3051;&#x308B;
  <pr>&#x3068;&#x3093;&#x306D;&#x308B;&#x3092;&#x3064;&#x3051;&#x308B;</pr></trd>
  <trdgrp lng="pl">
    <trd>kopa&cacute; tunel</trd>,
    <trd>dr&aogonek;&zdot;y&cacute; tunel</trd>
  </trdgrp>
  <trd lng="sk">razi&tcaron; tunel</trd>
  <trd lng="uk">&c_p;&c_r;&c_o;&c_k;&c_l;&c_a;&c_d;&c_a;&c_t;&c_i; &c_t;&c_u;&c_n;&c_je;&c_l;&c_mol;</trd>
</drv>

<drv mrk="tunel.vento0o">
  <kap>
    vento<tld/>o, <var><kap>blov<tld/>o</kap></var>
  </kap>
  <snc>
    <uzo tip="fak">TEK</uzo><uzo tip="fak">AVI</uzo>
    <dif>
      Instala&jcirc;o por aerodinamikaj esploroj per forta aerfluo:
      <ekz>
        <nom>Konstantin Ciolkovskij</nom> <klr>[&#x2026;]</klr> konstruis en &ccirc;ambro de sia lo&gcirc;ejo unuan
        ventokanalon de Rusio, kiu ebligis mezuri la aerreziston
        <fnt>
          <bib>Viki</bib>
          <lok><url ref="https://eo.wikipedia.org/?curid=25271"
              >Konstantin Ciolkovskij</url></lok>
        </fnt>;
      </ekz>
      <ekz>
        la formo de karoserio estas optimumigita en blov-<tld/>o
        <fnt>
          <aut>Ren&eacute; Bastong</aut>
          <vrk><url ref="https://scienca-revuo.info/files/1465-1-1603-1-10-20140426.pdf"
              >Per a&ubreve;tomobilo &scirc;pareme kaj sekure</url></vrk>
          <lok>Scienca Revuo, vol. 35 (1948), nr-o 2 (148), p. 51</lok>
        </fnt>;
      </ekz>
      <ekz>
        la skalo de la modelo en vento<tld/>o estas kutime proksimume 1:250, en modelado
        por komputado oni kompreneble ne bezonas skali
        <fnt>
          <aut>Fabien van Mook</aut>
          <vrk><url ref="http://fabien.galerio.org/pp/2006-nen8100/nen8100-jk2006-20090312.pdf"
              >La nova nederlanda normo pri venta &#x2C6;geno kaj venta dan&#x2C6;gero por piedirantoj</url></vrk>
          <lok>Determinaj metodoj, p. 80</lok>
        </fnt>.
      </ekz>
    </dif>
  </snc>
  <trd lng="de">Windkanal</trd>
  <trd lng="en">wind tunnel</trd>
  <trd lng="fr">soufflerie</trd>
  <trd lng="ru">&c_a;&c_e;&c_r;&c_o;&c_d;&c_i;&c_n;&c_a;&c_m;&c_i;&c_ch;&c_je;&c_s;&c_k;&c_a;&c_ja; &c_t;&c_r;&c_u;&c_b;&c_a;</trd>
  <trd lng="uk">&c_a;&c_je;&c_r;&c_o;&c_d;&c_i;&c_n;&c_a;&c_m;&c_ib;&c_ch;&c_n;&c_a; &c_t;&c_r;&c_u;&c_b;&c_a;</trd>
</drv>

</art>
