<drv mrk="provizi.0o">
  <kap><tld/>o</kap>
  <snc mrk="provizi.0o.EKON">
    <uzo tip="fak">EKON</uzo>
    <dif>
      <ref tip="super" cel="gratif.0o.EKON">Gratifiko</ref> interkonsente donota pro sukcesa servo
      a&ubreve; perado;
      <ref tip="vid" cel="makler.0ajxo.pago">maklera&jcirc;o</ref>:
      <ekz>
        mi peris tie vilaon en mil okcent okdek tri, kaj amba&ubreve; partneroj trompis min pri la <tld/>o
        <fnt>
          <aut>F. Moln&aacute;r, trad. J. Horvath</aut>
          <vrk><url ref="https://verkoj.com/tradukistoj/jozefo-horvath/jocxjo_kpl.pdf">
          Jo&ccirc;jo kaj aliaj komedietoj</url></vrk>
          <lok>2025</lok>
        </fnt>.
      </ekz>
    </dif>
  </snc>
  <trd lng="fr">commission<klr> (r&eacute;mun&eacute;ration)</klr></trd>
</drv>
