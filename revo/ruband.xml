<?xml version="1.0"?>
<!DOCTYPE vortaro SYSTEM "../dtd/vokoxml.dtd">
<vortaro>
<art mrk="$Id: ruband.xml,v 1.30 2026/04/29 12:00:22 revo Exp $">
<kap>
  <ofc>*</ofc> <rad>ruband</rad>/o
<fnt><bib>UV</bib></fnt></kap>
<drv mrk="ruband.0o">
  <kap><ofc>*</ofc><tld/>o</kap>
  <snc mrk="ruband.0o.ornamo">
    <uzo tip="fak">TEKS</uzo>
    <dif>
      &Scirc;tofa <ref tip="super" cel="bend.0o">bendo</ref> uzata kiel ornamo:
      <ekz>
        <klr>[la]</klr> malgranda knabino <klr>[&#8230;]</klr> havis sur &gcirc;i silkan veston kaj
        malgrandan, mallar&gcirc;an, bluan rubandon trans la &scirc;ultroj
        <fnt>
          <bib>Fab1</bib>
          <lok>Persista stana soldato</lok>
        </fnt>;
      </ekz>
      <ekz>
        <klr>[la]</klr> sova&gcirc;aj cignoj <klr>[&#8230;]</klr> &scirc;vebis unu post la alia, tio
        aspektis kiel longa blanka <tld/>o
        <fnt>
          <bib>Fab1</bib>
          <lok>Sova&gcirc;aj cignoj</lok>
        </fnt>;
      </ekz>
      <ekz>
        longaj verdaj silkaj <tld/>oj flirtas de la &ccirc;apeloj
        <fnt>
          <bib>Fab2</bib>
          <lok>Ne&gcirc;a re&gcirc;ino</lok>
        </fnt>;
      </ekz>
      <ekz>
        ordena <tld/>o
        <fnt>
          <bib>Fab2</bib>
          <lok>Dano Holger</lok>
        </fnt>;
      </ekz>
      <ekz>
        kolumetoj el plisita <tld/>o
        <fnt>
          <aut>Maxime Lechien</aut>
          <vrk><url ref="&Monato;/2000/006955.php">Fama karnavalo en Binche</url></vrk>
          <bib>Monato</bib>
          <lok>2000/06, p. 16</lok>
        </fnt>.
      </ekz>
    </dif>
    <refgrp tip="vid">
      <ref cel="bander.0o">banderolo</ref>,
      <ref cel="orden.0o">ordeno</ref>,
      <ref cel="stri.0o">strio</ref>,
      <ref cel="zon.0o">zono</ref>.
    </refgrp>
    <trdgrp lng="be">
      <trd>&c_s;&c_t;&c_u;&c_zh;&c_k;&c_a;</trd>,
      <trd>&c_p;&c_a;&c_s;</trd>,
      <trd>&c_t;&c_a;&c_s;&c_mol;&c_m;&c_a;</trd>
    </trdgrp>
    <trdgrp lng="de">
      <trd>Band</trd>,
      <trd>Zierband</trd>
    </trdgrp>
    <trd lng="en">ribbon</trd>
    <trdgrp lng="fr">
      <trd>ruban</trd>
    </trdgrp>
    <trdgrp lng="hu">
      <trd>szalag</trd>,
      <trd>p&aacute;ntlika</trd>
    </trdgrp>
    <trd lng="nl">lint</trd>
    <trdgrp lng="pt">
      <trd>fita</trd>,
      <trd>tira</trd>,
      <trd>banda</trd>,
      <trd>faixa</trd>
    </trdgrp>
    <trdgrp lng="ru">
      <trd>&c_l;&c_je;&c_n;&c_t;&c_a;</trd>,
      <trd>&c_t;&c_je;&c_s;&c_mol;&c_m;&c_a;</trd>
    </trdgrp>
    <trdgrp lng="zh">
    <trd>&#24102; <pr>d&agrave;i</pr></trd>,
    <trd>&#24118; <pr>d&agrave;i</pr></trd>,
    <trd>&#19997;&#24102; <pr>s&#299;d&agrave;i</pr></trd>,
    <trd>&#32114;&#24118; <pr>s&#299;d&agrave;i</pr></trd>,
    <trd>&#32172;&#24118; <pr>sh&ograve;ud&agrave;i</pr></trd>,
    <trd>&#32502;&#24102; <pr>sh&ograve;ud&agrave;i</pr></trd>,
    <trd>&#32222;&#24118; <pr>du&agrave;nd&agrave;i</pr></trd>,
    <trd>&#32526;&#24102; <pr>du&agrave;nd&agrave;i</pr></trd>,
    <trd>&#33394;&#24102; <pr>s&egrave;d&agrave;i</pr></trd>,
    <trd>&#33394;&#24118; <pr>s&egrave;d&agrave;i</pr></trd>
  </trdgrp>
</snc>
  <snc mrk="ruband.0o.vindo">
    <dif>
      <ref tip="dif" cel="vind.0o">Vindo</ref>:
      <ekz>
        &ccirc;iun manon kaj piedon, &ccirc;iun fingron de l' mortinto oni &ccirc;irka&ubreve;volvis per
        <tld/>oj, sur kiuj estis skribitaj pre&gcirc;oj kaj &jcirc;uroj
        <fnt>
          <bib>Far3</bib>
          <lok>&Ccirc;apitro IV</lok>
        </fnt>.
      </ekz>
    </dif>
    <refgrp tip="vid">
      <ref cel="bandag.0o">banda&gcirc;o</ref>,
      <ref cel="rimen.0o">rimeno</ref>,
    </refgrp>
    <trd lng="be">&c_b;&c_ib;&c_n;&c_t;</trd>
    <trdgrp lng="de">
      <trd>Wickel</trd>,
      <trd>Wickelband</trd>,
      <trd>Windel</trd>
    </trdgrp>
    <trdgrp lng="hu">
      <trd>sz&ouml;vetcs&iacute;k</trd>,
      <trd>k&ouml;t&ouml;z&odblac;szalag</trd>
    </trdgrp>
    <trd lng="nl">zwachtel</trd>
    <trd lng="ru">&c_b;&c_i;&c_n;&c_t;</trd>
    <trd lng="zh">&#23615;&#24067; <pr>ni&agrave;ob&ugrave;</pr></trd>
</snc>
  <snc mrk="ruband.0o.FIG">
    <uzo tip="stl">FIG</uzo>
    <dif>
      Longa vico da a&jcirc;oj senmanke sinsekvaj:
      <ekz>
        senfinaj <tld/>oj da regimentoj fluis en la centron de la
        urbo;
      </ekz>
      <ekz>
        <tld/>oj de fumo
        <fnt>
          <bib>FdO</bib>
        </fnt>;
      </ekz>
      <ekz>
        saltante sur vojo <tld/>a
        <fnt>
          <bib>FK</bib>
        </fnt>;
      </ekz>
    </dif>
    <refgrp tip="sin">
      <ref cel="cxen.0o">&ccirc;eno</ref>,
      <ref cel="girlan.0o">girlando</ref>,
      <ref cel="rozari.0o">rozario</ref>.
    </refgrp>
    <trdgrp lng="be">
      <trd>&c_s;&c_t;&c_u;&c_zh;&c_k;&c_a;</trd>,
      <trd>&c_l;&c_a;&c_n;&c_c;&c_u;&c_g;</trd>,
      <trd>&c_ch;&c_a;&c_r;&c_g;&c_a;</trd>
    </trdgrp>
    <trdgrp lng="de">
      <trd>Kolonne</trd>,
      <trd>Schlange</trd>,
      <trd>Marschs&auml;ule</trd>
    </trdgrp>
    <trd lng="fr">d&eacute;fil&eacute;<klr> (fig.)</klr></trd>
    <trdgrp lng="hu">
      <trd>szalag</trd>,
      <trd>k&iacute;gy&oacute; <klr tip="amb">(&aacute;tv.)</klr></trd>
    </trdgrp>
    <trd lng="nl">lint</trd>
    <trdgrp lng="pl">
      <trd>pas</trd>,
      <trd>ta&sacute;ma</trd>,
      <trd>wst&eogonek;ga</trd>
    </trdgrp>
  </snc>
  <trdgrp lng="ca">
    <trd>cinta</trd>,
    <trd>banda</trd>
  </trdgrp>
  <trdgrp lng="cs">
    <trd>lenta</trd>,
    <trd>p&aacute;s</trd>,
    <trd>pentle</trd>,
    <trd>p&aacute;ska z l&aacute;tky</trd>,
    <trd>stuha</trd>,
    <trd>tkanice</trd>,
    <trd>tkani&ccaron;ka</trd>
  </trdgrp>
  <trdgrp lng="ja">
    <trd>&#12522;&#12508;&#12531;</trd>,
    <trd>&#12486;&#12540;&#12503;  <pr>&#12390;&#12540;&#12407;</pr></trd>,
    <trd>&#12402;&#12418;</trd>,
    <trd>&#24111;&#29366;&#12398;&#12418;&#12398;  <pr>&#12362;&#12403;&#12376;&#12423;&#12358;&#12398;&#12418;&#12398;</pr></trd>,
    <trd>&#32172;  <pr>&#12376;&#12421;</pr></trd>
  </trdgrp>
  <trd lng="ru">&c_l;&c_je;&c_n;&c_t;&c_a;</trd>
  <trdgrp lng="sk">
    <trd>p&aacute;sik</trd>,
    <trd>stuha</trd>,
    <trd>stu&zcaron;ka</trd>
  </trdgrp>
  <trdgrp lng="uk">
    <trd>&c_s;&c_t;&c_r;&c_ib;&c_ch;&c_k;&c_a;</trd>,
    <trd>&c_t;&c_a;&c_s;&c_mol;&c_m;&c_a;</trd>,
    <trd>&c_s;&c_m;&c_u;&c_zh;&c_k;&c_a;</trd>
  </trdgrp>
</drv>

<drv mrk="ruband.brak0o">
  <kap>brak<tld/>o</kap>
  <snc mrk="ruband.brak0o.KOMUNE">
    <dif>
      <tld lit="R"/>o &ccirc;irka&ubreve;anta brakon, pliofte kiel indikilo
      de ia funkcio de la portanto:
      <ekz>
        porti blankan brak<tld/>on
        <fnt>
          <aut>W. Heller, trad. B. Westerhoff</aut>
          <vrk>Lidia, la Vivo de Lidia Zamenhof, Filino de Esperanto</vrk>
          <lok>2007</lok>
        </fnt>.
      </ekz>
    </dif>
    <ref tip="vid" cel="bracel.0o">braceleto</ref>
  </snc>
  <trdgrp lng="be">
    <trd>&c_p;&c_a;&c_v;&c_ja;&c_z;&c_k;&c_a;</trd>,
    <trd>&c_p;&c_o;&c_v;&c_ja;&c_z;&c_mol; <klr>(&c_n;&c_a; &c_r;&c_u;&c_c;&c_e;)</klr></trd>
  </trdgrp>
  <trd lng="ca">bra&ccedil;al</trd>
  <trdgrp lng="de">
    <trd>Armband</trd>,
    <trd>Armbinde</trd>
  </trdgrp>
  <trd lng="en">armband</trd>
  <trd lng="fr">brassard</trd>
  <trd lng="pl">mankiet</trd>
  <trdgrp lng="zh">
    <trd>&#25163;&#33218; <pr>sh&#466;ub&igrave;</pr></trd>,
    <trd>&#34966;&#26631; <pr>xi&ugrave;bi&#257;o</pr></trd>,
    <trd>&#34966;&#27161; <pr>xi&ugrave;bi&#257;o</pr></trd>,
    <trd>&#37351; <pr>chu&agrave;n</pr></trd>,
    <trd>&#38031; <pr>chu&agrave;n</pr></trd>
  </trdgrp>
</drv>

<drv mrk="ruband.sxtrumpa_0o">
  <kap>
    &scirc;trumpa <tld/>o
  </kap>
  <snc>
    <uzo tip="fak">TEKS</uzo>
    <dif>
      <tld lit="R"/>o volvita &ccirc;irka&ubreve; la supra fina&jcirc;o de &scirc;trumpo por fiksi &gcirc;in &ccirc;e la kruro:
      <ekz>
        li &jcirc;us atingis la edzi&gcirc;ota&ubreve;gan a&gcirc;on, kiam li okaze trafis en lavotan tola&jcirc;on
        kune kun &scirc;trumpa <tld/>o
        <fnt>
          <bib>Fab3</bib>
          <lok>Kolumo</lok>
        </fnt>.
      </ekz>
    </dif>
  </snc>
  <trd lng="be">&c_p;&c_a;&c_d;&c_v;&c_ja;&c_z;&c_k;&c_a; <klr>(&c_n;&c_a;
  &c_p;&c_a;&c_n;&c_ch;&c_o;&c_s;&c_je;)</klr></trd>
  <trdgrp lng="ca">
    <trd>lligacama</trd>,
    <trd>camalliga</trd>,
    <trd>lliga</trd>,
    <trd>garrotera</trd>
  </trdgrp>
  <trd lng="de">Strumpfband</trd>
  <trd lng="en">garter</trd>
  <trd lng="fr">jarreti&egrave;re</trd>
  <trd lng="pl">podwi&aogonek;zka</trd>
  <trdgrp lng="zh">
    <trd>&#34972;&#24102; <pr>w&agrave;d&agrave;i</pr></trd>,
    <trd>&#35178;&#24118; <pr>w&agrave;d&agrave;i</pr></trd>
  </trdgrp>
</drv>

</art>
