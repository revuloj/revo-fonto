<!DOCTYPE vortaro SYSTEM "../dtd/vokoxml.dtd">
<vortaro>
<art mrk="$Id: optimi.xml,v 1.30 2026/07/06 10:59:37 revo Exp $">
<kap>
  <ofc>2</ofc>
  <rad>optimism</rad>/o <fnt><bib>PVEF</bib></fnt>
</kap>
<drv mrk="optimi.0o">
  <kap><tld/>o</kap>
  <snc mrk="optimi.0o.KOMUNE">
    <uzo tip="stl">KOMUNE</uzo>
    <dif>
      Fido, firma espero pri feli&ccirc;a estonteco,
      pri la sukceso de iu entrepreno ks:
      <ekz>
        rigardi kun <tld/>o al la nova jaro
        <fnt>
          <bib>Monato</bib>
          <aut>Stefan Maul</aut>
          <vrk><url ref="&Monato;/2007/009366.php"
              >Problemoj ne solvataj</url></vrk>
          <lok>2007</lok>
        </fnt>;
      </ekz>
      <ekz>
        li certe sukcesos, lia timo miksi&gcirc;is kun ekscito de <tld/>o
        <fnt>
          <bib>LGA</bib>
          <lok>III.</lok>
        </fnt>;
      </ekz>
      <ekz>
        nenio estas pli dan&gcirc;era ol blinda <tld/>o
        <fnt>
          <aut>E&ubreve;geno Lanti</aut>
          <vrk><url ref="https://eo.wikisource.org/wiki/El_verkoj_de_E._Lanti/Kompleta_teksto"
              >Absolutismo, parolado, 1934</url></vrk>
          <lok>El Verkoj De E. Lanti, p. 75</lok>
        </fnt>;
      </ekz>
      <ekz>
        e&ccirc; en plej amaraj momentoj aperas <tld/>o
        <fnt>
        <aut>C. Minnaja</aut>,
          <vrk>Meritanta ne nur reeldonon</vrk>,
          <bib>Monato</bib>,
          <lok>2001:7a, p. 28a</lok>
        </fnt>;
      </ekz>
      <ekz>
        vi iomete plenigis mian ofte malgajan kaj malplenan animon per &gcirc;ojo kaj <tld/>o
        <fnt>
          <bib>FSI</bib>
          <lok>IV</lok>
        </fnt>;
      </ekz>
      <ekz>
        rapide evidenti&gcirc;is, ke la komenca <tld/>o ne estis pravigita
        <fnt>
          <bib>Monato</bib>
          <aut>Marc Vanden Bempt</aut>
        </fnt>.
      </ekz>
    </dif>
    <refgrp tip="ant">
      <ref cel="pesimi1.0o.KOMUNE">pesimismo<sncref/></ref>
    </refgrp>
    <refgrp tip="vid">
      <ref cel="esper.0o">espero</ref>,
      <ref cel="fid.0o">fido</ref>,
      <ref cel="seren.0o.anima">sereno<sncref/></ref>
    </refgrp>
    <trdgrp lng="de">
      <trd>Zuversicht</trd>,
      <trd>Lebensbejahung</trd>,
      <trd>Aufbruchstimmung</trd>
    </trdgrp>
    <trd lng="el">&alfa;&jota;&sigma;&jota;&omikron;&delta;&omikron;&xi;&jota_ton;&alfa;</trd>
    <trdgrp lng="hu">
      <trd>der&uuml;l&aacute;t&aacute;s</trd>,
      <trd>optimizmus</trd>
    </trdgrp>
    <trd lng="nl">optimisme</trd>
    <trd lng="pt">o(p)timismo</trd>
    <trd lng="sv">optimism</trd>
  </snc>
  <snc mrk="optimi.0o.FIL">
    <uzo tip="fak">FIL</uzo>
    <dif>
      Doktrino, la&ubreve; kiu la mondo harmonias kaj estas a&ubreve;
      povas i&gcirc;i
      plejeble bona:
      <ekz>
        <tld/>o estas, diris <nom>Kandid</nom>, la obstinego asertadi, ke &ccirc;io
        estas bona, kiam oni malbone statas;
      </ekz>
      <ekz>
        <nom>Keynes</nom> elkreskis en bonhava medio karakterizata per <tld/>o kaj
        kredo ke la mondon povas &scirc;an&gcirc;i la intelekta elito
        <fnt>
          <aut>B. Sandelin</aut>,
          <vrk>Makroekonomiko en la 20a jarcento</vrk>,
          <bib>Monato</bib>,
          <lok>2001:9a, p. 14a</lok>
        </fnt>.
      </ekz>
    </dif>
    <refgrp tip="ant">
      <ref cel="pesimi1.0o.FIL">pesimismo<sncref/></ref>
    </refgrp>
  </snc>
   <trd lng="be">&c_a;&c_p;&c_t;&c_y;&c_m;&c_ib;&c_z;&c_m;</trd>
  <trd lng="bg">&c_o;&c_p;&c_t;&c_i;&c_m;&c_i;&c_z;&c_malmol;&c_m;</trd>
  <trd lng="cs">optimizmus</trd>
  <trd lng="de">Optimismus</trd>
  <trd lng="en">optimism</trd>
  <trd lng="fr">optimisme</trd>
  <trdgrp lng="ja">
    <trd>&#x30AA;&#x30D7;&#x30C6;&#x30A3;&#x30DF;&#x30BA;&#x30E0;</trd>,
    <trd>&#x697D;&#x5929;&#x4E3B;&#x7FA9;  <pr>&#x3089;&#x304F;&#x3066;&#x3093;&#x3057;&#x3085;&#x304E;</pr></trd>,
    <trd>&#x697D;&#x89B3;  <pr>&#x3089;&#x3063;&#x304B;&#x3093;</pr></trd>
  </trdgrp>
  <trd lng="pl">optymizm</trd>
  <trd lng="ro">optimism</trd>
  <trd lng="ru">&c_o;&c_p;&c_t;&c_i;&c_m;&c_i;&c_z;&c_m;</trd>
  <trd lng="sk">optimizmus</trd>
  <trd lng="uk">&c_o;&c_p;&c_t;&c_i;&c_m;&c_ib;&c_z;&c_m;</trd>
  <trdgrp lng="zh">
    <trd>&#x4E50;&#x89C2;&#x4E3B;&#x4E49; <pr>l&egrave;gu&amacron;nzh&#x1D4;y&igrave;</pr></trd>,
    <trd>&#x6A02;&#x89C0;&#x4E3B;&#x7FA9; <pr>l&egrave;gu&amacron;nzh&#x1D4;y&igrave;</pr></trd>
  </trdgrp>
</drv>

<drv mrk="optimi.0a">
  <kap><tld/>a</kap>
  <snc mrk="optimi.0a.KOMUNE">
    <dif>
      Kiu volonte rigardas la situacion bona
      a&ubreve; firme esperas &gcirc;ian pliboni&gcirc;on:
      <ekz>
        li estas tro <tld/>a en tiu takso
        <fnt>
          <bib>Ret</bib>
          <lok>Unua Parto</lok>
        </fnt>;
      </ekz>
      <ekz>
        mokoj &ccirc;e la establita lingvistiko estis la &ccirc;efaj malamikoj de la <tld/>aj
        dis&ccirc;iploj de <nom>Zamenhof</nom>
        <fnt>
          <bib>EeP</bib>
          <lok>Kvina Parto</lok>
        </fnt>;
      </ekz>
      <ekz>
        la &ccirc;efministro ne plu estas <tld/>a pri la tendencoj de la ekonomio
        <fnt>
          <bib>Monato</bib>
          <aut>last</aut>
          <vrk><url ref="&Monato;/2009/009866.php"
              >Litovio fermi&gcirc;as!</url></vrk>
          <lok>2009</lok>
        </fnt>;
      </ekz>
      <ekz>
        temas pri <tld/>a poezio kaj ne hazarde ofti&gcirc;as
        vortoj kiel &leftquot;amo&rightquot;, &leftquot;lumo&rightquot;
        <fnt>
          <aut>A. Iannacone</aut>,
          <vrk><url ref="http://www.edizionieva.com/La%20floroj%20de%20l%27bono.htm">
          La Floroj de l' bono (recenzo)</url></vrk>,
          <lok>[2011?]</lok>
        </fnt>.
      </ekz>
    </dif>
    <refgrp tip="vid">
      <ref cel="plen.esper0a">esperplena</ref>,
      <ref cel="plen.fido0a.optimisma">fidoplena<sncref/></ref>,
      <ref cel="roz.0kolora">rozkolora</ref>,
      <ref cel="seren.0a.anime">serena<sncref/></ref>
    </refgrp>
  </snc>
  <trd lng="be">&c_a;&c_p;&c_t;&c_y;&c_m;&c_ib;&c_s;&c_t;&c_y;&c_ch;&c_n;&c_y;</trd>
  <trd lng="bg">&c_o;&c_p;&c_t;&c_i;&c_m;&c_i;&c_s;&c_t;&c_i;&c_ch;&c_je;&c_n;</trd>
  <trd lng="bo">&t_ga;&t_ta;&t_na;&t_tsheg;&t_kha;&t_drengbu;&t_la;&t_tsheg;&t_pa;&t_naro;&t_tsheg;</trd>
  <trd lng="cs">optimistick&yacute;</trd>
  <trdgrp lng="de">
    <trd>optimistisch</trd>,
    <trd>zuversichtlich</trd>,
    <trd>lebensbejahend</trd>
  </trdgrp>
  <trd lng="en">optimistic</trd>
  <trd lng="fr">optimiste<klr> (adj.)</klr></trd>
  <trdgrp lng="ja">
    <trd>&#x697D;&#x5929;&#x7684;&#x306A;  <pr>&#x3089;&#x304F;&#x3066;&#x3093;&#x3066;&#x304D;&#x306A;</pr></trd>,
    <trd>&#x697D;&#x89B3;&#x7684;&#x306A;  <pr>&#x3089;&#x3063;&#x304B;&#x3093;&#x3066;&#x304D;&#x306A;</pr></trd>
  </trdgrp>
  <trd lng="pl">optymistyczny</trd>
  <trd lng="ro">optimist</trd>
  <trd lng="sk">optimistick&yacute;</trd>
  <trd lng="uk">&c_o;&c_p;&c_t;&c_i;&c_m;&c_ib;&c_s;&c_t;&c_i;&c_ch;&c_n;&c_i;&c_j;</trd>
  <trdgrp lng="zh">
    <trd>&#x4E50;&#x89C2; <pr>l&egrave;gu&amacron;n</pr></trd>,
    <trd>&#x6A02;&#x89C0; <pr>l&egrave;gu&amacron;n</pr></trd>,
    <trd>&#x4E50;&#x5929; <pr>l&egrave;ti&amacron;n</pr></trd>,
    <trd>&#x6A02;&#x5929; <pr>l&egrave;ti&amacron;n</pr></trd>,
    <trd>&#x4E50;&#x5929;&#x6D3E; <pr>l&egrave;ti&amacron;np&agrave;i</pr></trd>,
    <trd>&#x6A02;&#x5929;&#x6D3E; <pr>l&egrave;ti&amacron;np&agrave;i</pr></trd>
  </trdgrp>
</drv>

<drv mrk="optimi.0i">
  <kap><tld/>i</kap>
  <gra><vspec>ntr</vspec></gra>
  <snc mrk="optimi.0i.KOMUNE">
    <dif>
      Sinteni, paroli, pensi la&ubreve; <tld/>a vidpunkto:
      <ekz>
        ne tro <tld/>u, <nom>Stef</nom>
        <fnt><aut>C. Piron</aut>, <vrk>&Ccirc;u li bremsis
        sufi&ccirc;e?</vrk>, <lok>1979</lok></fnt>;
      </ekz>
      <ekz>
        en lando, kie &ccirc;irka&ubreve; 90&#x202F;% de la popolo scipovas nek legi, nek skribi, ne eblas
        <tld/>i pri la rezultoj
        <fnt>
          <bib>Monato</bib>
          <aut>J&eacute;r&eacute;mie Sabiyumva</aut>
          <vrk><url ref="&Monato;/2009/009766.php"
              >Kiam naski&gcirc;os virinaj rajtoj?</url></vrk>
          <lok>2009</lok>
        </fnt>;
      </ekz>
      <ekz>
        oni ne scias, kiom longe la juda komunumo en Irlando travivos, la&ubreve; &ccirc;iuj indikoj
        oni ne povas <tld/>i pri &gcirc;ia estonto
        <fnt>
          <bib>Monato</bib>
          <aut>Garbhan Macaoidh</aut>
          <vrk><url ref="&Monato;/2003/008105.html"
              >Renkonti&gcirc;o kun &scirc;rumpanta komunumo</url></vrk>
          <lok>2003</lok>
        </fnt>.
      </ekz>
    </dif>
    <refgrp tip="vid">
      <ref cel="esper.0i">esperi</ref>,
      <ref cel="fid.0i">fidi</ref>
    </refgrp>
  </snc>
  <trdgrp lng="be">
    <trd>&c_b;&c_y;&c_c;&c_mol; <ind>&c_a;&c_p;&c_t;&c_y;&c_m;&c_ib;&c_s;&c_t;&c_a;&c_m;</ind></trd>,
    <trd>&c_v;&c_y;&c_k;&c_a;&c_z;&c_v;&c_a;&c_c;&c_mol; <ind>&c_a;&c_p;&c_t;&c_y;&c_m;&c_ib;&c_z;&c_m;</ind></trd>
  </trdgrp>
  <trd lng="bg">&c_o;&c_p;&c_t;&c_i;&c_m;&c_i;&c_s;&c_t;&c_i;&c_ch;&c_je;&c_n; &c_s;&c_malmol;&c_m;</trd>
  <trdgrp lng="de">
    <trd><ind>optimistisch</ind> sein</trd>,
    <trd><ind>zuversichtlich</ind> sein</trd>
  </trdgrp>
  <trdgrp lng="fr">
    <trd>&ecirc;tre <ind>optimiste</ind></trd>,
    <trd>voir la vie en <ind>rose</ind></trd>
  </trdgrp>
  <trd lng="pl">optymistycznym by&cacute;</trd>
  <trd lng="ro">fi  <ind>optimist</ind></trd>
</drv>
</art>
