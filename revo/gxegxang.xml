<vortaro>
<art mrk="$Id: gxegxang.xml,v 1.1 2026/07/14 23:11:23 afido Exp $">
<kap>
    <rad>&Gcirc;e&gcirc;ang</rad>/o <fnt><bib>LanLin</bib></fnt>,
    <var><kap><rad var="&gcirc;j">&Gcirc;e&gcirc;jang</rad>/o <fnt><bib>PIV2</bib></fnt></kap></var>
</kap>
<drv mrk="gxegxang.0o">
  <kap><tld/>o,
  <var><kap><tld var="&gcirc;j"/>o</kap></var></kap>
  <snc mrk="gxegxang.0o.GEOG">
    <uzo tip="fak">GEOG</uzo>
    <uzo tip="fak">POL</uzo>
    <dif>
      Provinco en la orienta parto de <ref tip="malprt" cel="cxin.CX0ujo">&Ccirc;inujo</ref> kun la
      &ccirc;efurbo Hang&gcirc;o&ubreve;o:
      <ekz>
        situo de <tld/>o en &Ccirc;inujo
        <fnt>
          <aut>-</aut>
          <vrk><url ref="https://eo.wikinews.org/wiki/Kategorio:%C4%9Ce%C4%9Dango">Kategorio:
          &Gcirc;e&gcirc;ango</url></vrk>
          <lok>Vikinova&jcirc;oj, 2015-01-04</lok>
        </fnt>;
      </ekz>
      <ekz>
        <nom>Ant Financial</nom> <klr>[&#8230;]</klr> fari&gcirc;is <nom>Ant Group</nom>, anka&ubreve; bazita en
        Hang&gcirc;o&ubreve;o, provinco <tld var="&gcirc;j"/>o
        <fnt>
          <aut>J. Pouille, trad. M. Leon</aut>
          <vrk><url ref="https://eo.mondediplo.com/2021/03/article2918">Alibaba, &ccirc;ina
          epopeo</url></vrk>
          <lok>Le Monde diplomatique, 2021-03</lok>
        </fnt>;
      </ekz>
      <ekz>
        en 1988, kiam <nom>Swany China</nom> komencis iri glate, mi vizitis kun s-ro Gao,
        forta en kvar lingvoj, la registaron de la subprefektujo <nom>Jiashan</nom> en la provinco
        <tld var="&gcirc;j"/>o
        <fnt>
          <aut>E. Miyoshi, trad. &Scirc;. Maeda</aut>
          <vrk><url ref="https://fr.scribd.com/document/1000007059/Mia-Poliomjelito-Esperanto">
          Mia poliomjelito mal&scirc;losis pordon al da&ubreve;ripova paco</url></vrk>
          <lok>2022</lok>
        </fnt>.
      </ekz>
    </dif>
  </snc>
  <trd lng="fr">Zhejiang</trd>
</drv>
</art>


