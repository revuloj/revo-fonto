<art mrk="$Id: sutur.xml,v 1.12 2026/05/22 20:00:21 revo Exp $">
<kap>
  <rad>sutur</rad>/i <fnt><bib>PVEF</bib></fnt>
</kap>

<drv mrk="sutur.0i">
  <kap><tld/>i</kap>
  <snc mrk="sutur.0i.MED">
    <uzo tip="fak">MED</uzo>
    <dif>
      Fermi vundon per speciala fadeno kaj kudro:
      <ekz>
        necesis <tld/>i vundojn en diversaj partoj de la korpo
        <fnt>
          <aut>-</aut>,
          <vrk><url ref="">
          Membro de Strik-Komitato...</url></vrk>,
          <lok>2006-09-30</lok>
        </fnt>.
      </ekz>
    </dif>
  </snc>
  <trdgrp lng="be">
    <trd>&c_z;&c_a;&c_sh;&c_y;&c_v;&c_a;&c_c;&c_mol; <klr>(&c_r;&c_a;&c_n;&c_u;)</klr></trd>,
    <trd>&c_n;&c_a;&c_k;&c_l;&c_a;&c_d;&c_v;&c_a;&c_c;&c_mol; <ind>&c_sh;&c_v;&c_o;</ind>
    <klr>(&c_n;&c_a; &c_r;&c_a;&c_n;&c_u;)</klr></trd>
  </trdgrp>
  <trd lng="ca">suturar</trd>
  <trd lng="cs">se&scaron;&iacute;t tk&aacute;&ncaron;</trd>
  <trd lng="de">n&auml;hen <klr>(Wunde)</klr></trd>
  <trdgrp lng="en"><trd>stitch</trd>, <trd>suture</trd></trdgrp>
  <trdgrp lng="fr">
    <trd>suturer</trd>,
    <trd>recoudre<klr> (une plaie)</klr></trd>
  </trdgrp>
  <trdgrp lng="pl">
    <trd>zeszy&cacute;</trd>,
    <trd>zszywa&cacute;</trd>
  </trdgrp>
  <trd lng="sk">zo&scaron;i&tcaron; tkanivo</trd>
  <trd lng="uk">&c_n;&c_a;&c_k;&c_l;&c_a;&c_d;&c_a;&c_t;&c_i; &c_sh;&c_o;&c_v;</trd>
  <trdgrp lng="zh">
    <trd>&#32299;&#37341; <pr>f&eacute;ngzh&#275;n</pr></trd>,
    <trd>&#32541;&#38024; <pr>f&eacute;ngzh&#275;n</pr></trd>,
    <trd>&#32299;&#21512; <pr>f&eacute;ngh&eacute;</pr></trd>,
    <trd>&#32541;&#21512; <pr>f&eacute;ngh&eacute;</pr></trd>
  </trdgrp>
</drv>
</art>

