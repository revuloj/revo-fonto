<?xml version="1.0"?>
<!DOCTYPE vortaro SYSTEM "../dtd/vokoxml.dtd">
<vortaro>
<art mrk="$Id: permanent.xml,v 1.16 2026/06/19 14:57:14 revo Exp $">
<kap>
  <rad>permanent</rad>/a <fnt><bib>PIV2</bib></fnt>
</kap>
<drv mrk="permanent.0a">
  <kap><tld/>a</kap>
  <uzo tip="stl">RAR</uzo>
  <snc mrk="permanent.0a.konstanta">
    <dif>
      Ne <ref tip="ant" cel="proviz1.0a">provizora</ref>:
      <ekz>
        <tld/>a parlamenta komisiono pri la konfesioj
        <fnt>
          <bib>Monato</bib>
          <aut>Dimitar Ha&gcirc;iev</aut>
          <vrk><url ref="&Monato;/2006/008957.php">Religioj en Bulgario</url></vrk>
          <lok>2006</lok>
        </fnt>;
      </ekz>
      <ekz>
        <nom>Trockij</nom> estas konata pro aliaj elementoj de sia pensaro:
        <tld/>a revolucio, malebena kaj kombini&gcirc;a disvolvi&gcirc;o
        <fnt>
          <aut>R. Dumain</aut>,
          <vrk><url ref="http://www.autodidactproject.org/my/espotrot2.html">Trockij
          Pravis!</url></vrk>,
          <lok>Sennaciulo, 1990-09, numero 9a (1023), p. 79-80</lok>
        </fnt>;
      </ekz>
      <ekz>
        la <nom>POP</nom>-servilo devas havi <tld/>an konekton al la Interreto
        <fnt><bib>KompLeks</bib>,
       <lok>artikolo &leftquot;POP&rightquot;</lok></fnt>;
      </ekz>
      <ekz>
        kun iom da malfacilo li sukcesas <tld/>e forpeli &scirc;in
        <fnt>
          <bib>Monato</bib>
          <aut>Donald Broadribb</aut>
          <vrk><url ref="&Monato;/2003/007837.html">Ne al &ccirc;iuj pla&ccirc;os &ccirc;i literatura
          gemeto</url></vrk>
          <lok>2003</lok>
        </fnt>;
      </ekz>
      <ekz>
        la fundamenta doktrino de &Scirc;akja-munio estis la mal<tld/>eco de &ccirc;io, la
        malstabileco de &ccirc;io, la fluanta, &scirc;an&gcirc;i&gcirc;anta karaktero de &ccirc;io
        <fnt>
          <bib>Monato</bib>
          <aut>Donald Broadribb</aut>
          <vrk><url ref="&Monato;/2003/007929.html">Priskribo tre bone
          farita</url></vrk>
          <lok>2003</lok>
        </fnt>;
      </ekz>
      <ekz>
        li konigas al ni iun sperton, kiu markas <tld/>e en lia memoro la etoson de tiu
        lando
        <fnt>
          <bib>Monato</bib>
          <aut>Donald Broadribb</aut>
          <vrk><url ref="&Monato;/2007/009082.php">Majstra verko de a&ubreve;toro preska&ubreve;
          nekonata</url></vrk>
          <lok>2007</lok>
        </fnt>.
      </ekz>
    </dif>
    <refgrp tip="sin">
      <ref cel="dauxr.0a">da&ubreve;ra</ref>,
      <ref cel="defini.0a">definitiva</ref>,
      <ref cel="konsta.0a.dauxra">konstanta<sncref/></ref>,
      <ref cel="kontin3.0a.KOMUNE">kontinua</ref>,
      <ref cel="persis.0a">persista</ref>,
      <ref cel="cxes.sen0a">sen&ccirc;esa</ref>,
      <ref cel="halt.sen0a">senhalta</ref>
    </refgrp>
    <rim>
      Ordinare oni ne bezonas tiun maloftan vorton, sed povas diri <em>da&ubreve;ra</em> a&ubreve; <em>konstanta</em>
      membro, servo ktp. Se oni volas akcenti la ne&scirc;an&gcirc;eblan staton de io, oni diras
      anstata&ubreve;e <em>definitiva</em> &scirc;an&gcirc;o; <em>findecidita</em>, <em>ne&scirc;an&gcirc;ebla</em> solvo ks.

      En iuj tre maloftaj kazoj oni volas doni certan nuancon al sia esprimo:
      alie ol <em>konstanta</em> premo, rapido, kiuj ne varias en sia grado, <em><tld/>a</em> premo, rapido povas
      varii sed ne &ccirc;esas &ccirc;eesti. Tamen, en tiu okazo oni povus ekzemple diri <em>sen&ccirc;esa</em>
      a&ubreve; <em>senhalta</em> premo, rapido ktp.
      <aut>Wolfram Diestel</aut>
    </rim>
  </snc>
  <trdgrp lng="be">
    <trd>&c_n;&c_ja;&c_z;&c_mol;&c_m;&c_je;&c_n;&c_n;&c_y;</trd>,
    <trd>&c_p;&c_a;&c_s;&c_t;&c_a;&c_ja;&c_n;&c_n;&c_y;</trd>,
    <trd>&c_s;&c_t;&c_a;&c_l;&c_y;</trd>,
    <trd>&c_p;&c_e;&c_r;&c_m;&c_a;&c_n;&c_e;&c_n;&c_t;&c_n;&c_y;</trd>
  </trdgrp>
  <trd lng="ca">permanent</trd>
  <trdgrp lng="cs">
    <trd>nem&ecaron;nn&yacute;</trd>,
    <trd>permanentn&iacute;</trd>,
    <trd>st&aacute;l&yacute;</trd>,
    <trd>trval&yacute;</trd>
  </trdgrp>
  <trdgrp lng="de">
    <trd>permanent</trd>,
    <trd>st&auml;ndig</trd>
  </trdgrp>
  <trdgrp lng="en">
    <trd>permanent</trd>,
    <trd>constant</trd>
  </trdgrp>
  <trd lng="fr">permanent</trd>
  <trd lng="nl">permanent<klr tip="ind"> (zeldz.)</klr></trd>
  <trdgrp lng="pl">
    <trd>permanentny</trd>,
    <trd>nieprzerwany</trd>
  </trdgrp>
  <trdgrp lng="ro">
    <trd>permanent</trd>,
    <trd>ne&icirc;ntrerupt</trd>
  </trdgrp>
  <trdgrp lng="sk">
    <trd>st&aacute;ly</trd>,
    <trd>trval&yacute;</trd>
  </trdgrp>
  <trdgrp lng="uk">
    <trd>&c_n;&c_je;&c_v;&c_p;&c_i;&c_n;&c_n;&c_i;&c_j;</trd>,
    <trd>&c_b;&c_je;&c_z;&c_u;&c_p;&c_i;&c_n;&c_n;&c_i;&c_j;</trd>,
    <trd>&c_p;&c_je;&c_r;&c_m;&c_a;&c_n;&c_je;&c_n;&c_t;&c_n;&c_i;&c_j;</trd>
  </trdgrp>
  <trdgrp lng="zh">
    <trd>&#x5E38;&#x4EFB; <pr>ch&aacute;ngr&egrave;n</pr></trd>,
    <trd>&#x6046; <pr>h&eacute;ng</pr></trd>,
    <trd>&#x6052; <pr>h&eacute;ng</pr></trd>,
    <trd>&#x6301;&#x4E45; <pr>ch&iacute;ji&#x1D4;</pr></trd>,
    <trd>&#x6C38;&#x4E45;&#x6027; <pr>y&#x1D2;ngji&#x1D4;x&igrave;ng</pr></trd>,
    <trd>&#x6C38;&#x4E45; <pr>y&#x1D2;ngji&#x1D4;</pr></trd>,
    <trd>&#x5E38;&#x4F4F; <pr>ch&aacute;ngzh&ugrave;</pr></trd>
  </trdgrp>
</drv>
</art>

