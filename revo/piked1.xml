<?xml version="1.0"?>
<!DOCTYPE vortaro SYSTEM "../dtd/vokoxml.dtd">
<vortaro>
  <art mrk="$Id: piked1.xml,v 1.5 2026/03/22 20:44:14 afido Exp $">
    <kap>
      <ofc>*</ofc> <rad>piked</rad>/o
    <fnt><bib>UV</bib></fnt></kap>

<drv mrk="piked1.0o">
  <kap><ofc>*</ofc><tld/>o</kap>
  <snc mrk="piked1.0o.SPO">
    <uzo tip="fak">SPO</uzo>
    <fnt><bib>VdE</bib></fnt>
    <dif>
      Franca <ref tip="super" cel="kart.0ludo.SPO">kartludo</ref>, populari&gcirc;inta en la 17a jc:
      <ekz>
        <tld/>o ekzistas la&ubreve; tri versioj: kun 2, 3, a&ubreve; 4 ludantoj, la baza versio
        <klr>[&#8230;]</klr> kun 2 <klr>[&#8230;]</klr> estas la plej malnova el la francaj
        kartludoj
        <fnt>
          <bib>Viki</bib>
          <lok><url ref="https://eo.wikipedia.org/?curid=18154">Pikedo</url></lok>
        </fnt>.
      </ekz>
    </dif>
    <trd lng="be">&c_p;&c_ib;&c_k;&c_je;&c_t;</trd>
    <trdgrp lng="de">
      <trd>Pikett</trd>,
      <trd>Rummelpikett</trd>,
      <trd>Pickett</trd>,
      <trd><ofc>*</ofc>Piquet</trd>
    </trdgrp>
    <trd lng="en">piquet</trd>
    <trd lng="fr"><ofc>*</ofc>piquet</trd>
    <trd lng="hu">pik&eacute;t<klr tip="ind"> (k&aacute;rtya)</klr></trd>
    <trd lng="it">piquet<klr> (gioco)</klr></trd>
    <trd lng="pl">pikieta <klr>(gra)</klr></trd>
    <trd lng="ru"><ofc>*</ofc>&c_p;&c_i;&c_k;&c_je;&c_t;</trd>
  </snc>
  <ref tip="hom" cel="piked.0o.MIL">pikedo (gardistaro)</ref>
  <trdgrp lng="ja">
    <trd>&#x5C0F;&#x54E8;  <pr>&#12375;&#12423;&#12358;&#x54E8;</pr></trd>,
    <trd>&#x524D;&#x54E8;  <pr>&#x305C;&#12435;&#12375;&#12423;&#12358;</pr></trd>,
    <trd>&#x8B66;&#25106;&#x968A;  <pr>&#12369;&#12356;&#x304B;&#12356;&#x305F;&#12356;</pr></trd>,
    <trd>&#x30D4;&#x30B1;&#x30C3;&#x30C8;</trd>
  </trdgrp>
</drv>

  </art>

