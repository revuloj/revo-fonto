<?xml version="1.0"?>
<!DOCTYPE vortaro SYSTEM "../dtd/vokoxml.dtd">
<vortaro>
<art mrk="$Id: jubile.xml,v 1.31 2026/04/29 14:41:48 revo Exp $">
<kap>
  <ofc>1</ofc>
  <rad>jubile</rad>/o <fnt><bib>JED</bib></fnt>
</kap>
<drv mrk="jubile.0o">
  <kap><tld/>o</kap>
  <snc mrk="jubile.0o.KAL">
    <uzo tip="fak">KAL</uzo>
    <dif>
      Publika <ref tip="lst" lst="voko:festoj" cel="fest.0o.KAL">festo</ref>,
      per kiu oni solenas kvindekan, centan a&ubreve; alian gravan
      <ref tip="super" cel="ven.datre0o">datreveno</ref>n de evento:
      <ekz>
        prifestata estas rondcifera <tld/>o
        <fnt>
          <bib>OIP</bib>
          <lok>Ombro sur interna pejza&gcirc;o</lok>
        </fnt>;
      </ekz>
      <ekz>
        la pacpremio estis unuafoje transdonita en 1985, kadre de la 2000-jara <tld/>o
        de la urbo
        <fnt>
          <bib>Monato</bib>
          <aut>Ipfelkofer Jomo</aut>
          <vrk><url ref="&Monato;/2004/008189.html"
              >Festo unika en la mondo</url></vrk>
          <lok>2004</lok>
        </fnt>;
      </ekz>
      <ekz>
        li parolos &ccirc;e la dudek-kvina <tld/>o de la lingvo Esperanto
        <fnt>
          <bib>VivZam</bib>
          <lok>Vivo de Zamenhof</lok>
        </fnt>;
      </ekz>
      <ekz>
        &ccirc;u en la grava tago de la <tld/>o de la esperantismo, de tiu <tld/>o, kiun ni
        atingis post tiom multe da laboroj kaj suferoj, li nenion pli havis por diri
        al ni
        <fnt>
          <bib>Paroloj</bib>
          <vrk>Parolado anta&ubreve; la Oka Kongreso Esperantista en Krakow en la 11a de a&ubreve;gusto 1912</vrk>
        </fnt>?
      </ekz>
      <ekz>
        Somera Esperanta Universitato <klr>[&#x2026;]</klr> celebris la 10-jaran <tld/>on de
        sia funkciado
        <fnt>
          <bib>EeP</bib>
          <lok>Unua Parto</lok>
        </fnt>.
      </ekz>
    </dif>
    <trd lng="be">&c_ju;&c_b;&c_ib;&c_l;&c_je;&c_j;</trd>
    <trdgrp lng="de">
      <trd>Jubil&auml;um</trd>,
      <trd>Gedenkfeier</trd>,
      <trd>Jahrestag</trd>
    </trdgrp>
    <trdgrp lng="hu">
      <trd>jubileum</trd>,
      <trd>&eacute;vfordul&oacute;</trd>
    </trdgrp>
    <trd lng="nl">jubileum</trd>
    <trd lng="pl">jubileusz</trd>
    <trd lng="ru">&c_ju;&c_b;&c_i;&c_l;&c_je;&c_j;</trd>
    <trd lng="sv">jubileum</trd>
    <trdgrp lng="zh">
      <trd>&#x5468;&#x5E74; <pr>zh&omacron;uni&aacute;n</pr></trd>,
      <trd>&#x5E74;&#x7D00;&#x65E5; <pr>ni&aacute;nj&igrave;r&igrave;</pr></trd>,
      <trd>&#x60BC;&#x5FF5;&#x4EEA;&#x5F0F; <pr>d&agrave;oni&agrave;ny&iacute;sh&igrave;</pr></trd>,
      <trd>&#x7D00;&#x5FF5;&#x6703; <pr>j&igrave;ni&agrave;nhu&igrave;</pr></trd>,
      <trd>&#x7D00;&#x5FF5;&#x7BC0; <pr>j&igrave;ni&agrave;nji&eacute;</pr></trd>
    </trdgrp>
  </snc>
  <snc mrk="jubile.0o.KAT">
    <uzo tip="fak">KAT</uzo>
    <dif>
      Solena pek<ref tip="super" cel="absolv.0o.KAT">absolvo</ref>, kiun la papo konsentis unue
      en &ccirc;iu centa jaro, poste en &ccirc;iu kvindeka kaj nuntempe en &ccirc;iu dudekkvina:
      <ekz>
        sanktigu la kvindekan jaron, kaj proklamu liberecon en la lando por &ccirc;iuj &gcirc;iaj
        lo&gcirc;antoj: <tld/>o &gcirc;i estu por vi
        <fnt>
          <bib>MT</bib>
          <lok>Levidoj 25:10</lok>
        </fnt>;
      </ekz>
    </dif>
    <trd lng="be">&c_ju;&c_b;&c_ib;&c_l;&c_je;&c_j;</trd>
    <trdgrp lng="de">
      <trd>Halljahr</trd>,
      <trd>Erlassjahr</trd>,
      <trd>Heiliges Jahr</trd>,
      <trd>Jubeljahr</trd></trdgrp>
    <trd lng="hu">szent&eacute;v</trd>
    <trd lng="nl">heilig <ind>jaar</ind></trd>
    <trd lng="pl">Rok jubileuszowy</trd>
    <trdgrp lng="sv">
      <trd>heligt <ind>&aring;r</ind></trd>,
      <trd>jubel&aring;r</trd>
    </trdgrp>
    <trd lng="zh">&#x79A7;&#x5E74; <pr>x&#x1D0;ni&aacute;n</pr></trd>
</snc>
  <trd lng="ca">jubileu</trd>
  <trd lng="cs">jubileum</trd>
  <trd lng="es">jubileo</trd>
  <trd lng="fr">jubil&eacute;</trd>
  <trd lng="it">giubileo</trd>
  <trdgrp lng="ja">
    <trd>&#x8A18;&#x5FF5;&#x796D;  <pr>&#x304D;&#x306D;&#x3093;&#x3055;&#x3044;</pr></trd>,
    <trd>&#x8056;&#x5E74;  <pr>&#x305B;&#x3044;&#x306D;&#x3093;</pr></trd>,
    <trd>&#x5927;&#x8D66;  <pr>&#x305F;&#x3044;&#x3057;&#x3083;</pr></trd>
  </trdgrp>
  <trd lng="pt">jubileu</trd>
  <trd lng="sk">jubileum</trd>
  <trdgrp lng="uk">
    <trd>&c_ju;&c_v;&c_ib;&c_l;&c_je;&c_j;</trd>,
    <trd>&c_r;&c_ib;&c_ch;&c_n;&c_i;&c_c;&c_ja;</trd>
  </trdgrp>
</drv>

<drv mrk="jubile.0a">
  <kap><tld/>a</kap>
  <snc mrk="jubile.0a.KAL">
    <dif>
      Rilata al <tld/>o, solenanta la pason de ronda nombro
      de jaroj post evento:
      <ekz>
        <tld/>a telegramo
        <fnt>
          <bib>FK</bib>
          <lok>Fundamenta Krestomatio de la lingvo Esperanto</lok>
        </fnt>;
      </ekz>
      <ekz>
        en tiu <tld/>a jaro &ccirc;iu revenu
        <fnt>
          <bib>MT</bib>
          <lok>Levidoj 25:13</lok>
        </fnt>;
      </ekz>
      <ekz>
        <nom>Lidia</nom> anta&ubreve;enpa&scirc;is por meti teron de la tombo
        de sia patro sur la radikojn de la <tld/>a kverko
        <fnt>
          <aut>W. Heller, trad. B. Westerhoff</aut>
          <vrk>Lidia, la Vivo de Lidia Zamenhof, Filino de Esperanto</vrk>
          <lok>2007</lok>
        </fnt>;
      </ekz>
      <ekz>
        en la <tld/>a momento de la esperantismo mi volus paroli al vi pri tio, kio
        naskis la esperantismon
        <fnt>
          <bib>Paroloj</bib>
          <vrk>Parolado anta&ubreve; la Oka Kongreso Esperantista en Krakow en la 11a de a&ubreve;gusto 1912</vrk>
        </fnt>.
      </ekz>
    </dif>
  </snc>
  <trd lng="be">&c_ju;&c_b;&c_ib;&c_l;&c_je;&c_j;&c_n;&c_y;</trd>
  <trd lng="ca">jubilar <klr tip="amb">(adj.)</klr></trd>
  <trd lng="ja">&#x8A18;&#x5FF5;&#x796D;&#x306E;  <pr>&#x304D;&#x306D;&#x3093;&#x3055;&#x3044;&#x306E;</pr></trd>
  <trd lng="pl">jubileuszowy</trd>
  <trd lng="uk">&c_ju;&c_v;&c_ib;&c_l;&c_je;&c_j;&c_n;&c_i;&c_j;</trd>
</drv>
</art>
