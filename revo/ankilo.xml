<?xml version="1.0"?>
<!DOCTYPE vortaro SYSTEM "../dtd/vokoxml.dtd">
<vortaro>
<art mrk="$Id: ankilo.xml,v 1.23 2026/05/15 09:24:31 revo Exp $">
<kap>
  <rad>ankiloz</rad>/o
  <fnt><bib>JED</bib></fnt>
</kap>
<drv mrk="ankilo.0o">
  <kap><tld/>o</kap>
  <uzo tip="fak">MED</uzo>
  <snc>
    <dif>
      Senmoveco de artiko:
      <ekz>
        suferi je <tld/>o;
      </ekz>
      <ekz>
        <uzo tip="stl">FIG</uzo>
        neologismoj multi&gcirc;is kun la kresko kaj maturi&gcirc;o de Esperanto, kaj se ili &ccirc;esus
        aperi, la lingvo mortus senrimede de anemio kaj <tld/>o
        <fnt>
          <aut>Antoni Val&eacute;n</aut>
          <vrk><url ref="https://dvd.ikso.net/revuo/Revuo_Esperanto/2005/10.pdf"
              >Nekrologo</url></vrk>
          <lok>revuo Esperanto, n-ro 1185, okt. 2005, p. 206</lok>
        </fnt>;
      </ekz>
      <ekz>
        <uzo tip="stl">FIG</uzo>
        kiuj estis tiuj sklavoj, kiujn la &ccirc;efredaktoro <nom>Gaston Waringhien</nom> kurbigis sub
        vipo &gcirc;is cerba <tld/>o
        <fnt>
          <aut> Claude kaj Andr&eacute;e Gacond</aut>
          <vrk><url ref="https://www.esperanto-gacond.ch/SRI/Radiokasedo-159/Radioprelego_SRI_1985_12_26__159_B_994_Claude_kaj_Andree_GACOND_La_lasta_numero_de_La_Nica_Literatura_Revuo.pdf"
              >La lasta numero de La Nica Literatura Revuo</url></vrk>
          <lok>SRI, 1985-12-26, p. 2</lok>
        </fnt>.
      </ekz>
    </dif>
    <trdgrp lng="de">
      <trd>Ankylose</trd>,
      <trd>Gelenkversteifung</trd>
    </trdgrp>
  </snc>
  <trd lng="be">&c_a;&c_n;&c_k;&c_ib;&c_l;&c_o;&c_z;</trd>
  <trd lng="bg">&c_a;&c_n;&c_k;&c_i;&c_l;&c_o;&c_z;</trd>
  <trd lng="cs">ankyl&oacute;za</trd>
  <trdgrp lng="en">
    <trd>ankylosis</trd>,
    <trd>anchylosis</trd>
  </trdgrp>
  <trdgrp lng="fa">
    <trd>&a_j;&a_m;&a_w;&a_d; &a_m;&a_f;&a_S;&a_l;&f_y;</trd>,
    <trd>&a_A_madda;&a_n;&f_k;&f_y;&a_l;&a_w;&a_z;</trd>
  </trdgrp>
  <trd lng="fr">ankylose</trd>
  <trdgrp lng="hu">
    <trd>iz&uuml;leti merevs&eacute;g</trd>
    <trd>ankylosis</trd>
  </trdgrp>
  <trd lng="ja">&#x95A2;&#x7BC0;&#x5F37;&#x76F4;
  <pr>&#x304B;&#x3093;&#x305B;&#x3064;&#x304D;&#x3087;&#x3046;&#x3059;&#x306A;&#x304A;</pr></trd>
  <trdgrp lng="nl">
    <trd>ankylosis</trd>,
    <trd>gewrichtsverstijving</trd>
  </trdgrp>
  <trdgrp lng="ru">
    <trd>&c_a;&c_n;&c_k;&c_i;&c_l;&c_o;&c_z;</trd>,
    <trd>&c_n;&c_je;&c_p;&c_o;&c_d;&c_v;&c_i;&c_zh;&c_n;&c_o;&c_s;&c_t;&c_mol; &c_s;&c_u;&c_s;&c_t;&c_a;&c_v;&c_o;&c_v;</trd>
  </trdgrp><trd lng="ru">&c_a;&c_n;&c_k;&c_i;&c_l;&c_o;&c_z;</trd>
  <trdgrp lng="sk">
    <trd>ankyl&oacute;za</trd>,
    <trd>ankyl&oacute;za</trd>,
    <trd>nehybnos&tcaron; k&lacute;bu</trd>
  </trdgrp>
  <trd lng="uk">&c_a;&c_n;&c_k;&c_ib;&c_l;&c_o;&c_z;</trd>
</drv>

<drv mrk="ankilo.0igxi">
  <kap><tld/>i&gcirc;i</kap>
  <snc>
    <dif>
      Esti trafita de <tld/>o.
    </dif>
    <ref tip="vid" cel="rigid.0igxi.neflekseble">rigidi&gcirc;i</ref>
  </snc>
  <trd lng="be">&c_s;&c_t;&c_r;&c_a;&c_c;&c_ib;&c_c;&c_mol; <ind>&c_r;&c_u;&c_h;&c_o;&c_m;&c_a;&c_s;&c_mol;&c_c;&c_mol;</ind> <klr>(&c_a;&c_b; &c_s;&c_u;&c_s;&c_t;&c_a;&c_v;&c_je;)</klr></trd>
  <trd lng="de">sich <ind>versteifen</ind> <klr>(Gelenk)</klr></trd>
  <trd lng="fr">s'<ind>ankyloser</ind></trd>
  <trd lng="hu">megmerevedik<klr tip="ind"> (iz&uuml;let)</klr>&gt;</trd>
  <trd lng="ja">&#x95A2;&#x7BC0;&#x304C;&#x5F37;&#x76F4;&#x3059;&#x308B;
  <pr>&#x304B;&#x3093;&#x305B;&#x3064;&#x304C;&#x3064;&#x3088;&#x306A;&#x304A;&#x3059;&#x308B;</pr></trd>
  <trd lng="nl">verstijven<klr tip="ind"> (v.gewrichten)</klr></trd>
  <trdgrp lng="ru">
    <trd>&c_o;&c_d;&c_je;&c_r;&c_je;&c_v;&c_je;&c_n;&c_je;&c_t;&c_mol;<klr tip="ind"> (&c_o; &c_s;&c_u;&c_s;&c_t;&c_a;&c_v;&c_a;&c_h;)</klr></trd>,
    <trd>&c_p;&c_o;&c_t;&c_je;&c_r;&c_ja;&c_t;&c_mol; <ind>&c_p;&c_o;&c_d;&c_v;&c_i;&c_zh;&c_n;&c_o;&c_s;&c_t;&c_mol;</ind><klr tip="amb"> (&c_o; &c_s;&c_u;&c_s;&c_t;&c_a;&c_v;&c_a;&c_h;)</klr></trd>
  </trdgrp>
</drv>

<drv mrk="ankilo.0igo">
  <kap><tld/>igo</kap>
  <uzo tip="fak">MED</uzo>
  <snc>
    <dif>
      Operacio a&ubreve; procezo ka&ubreve;zanta <tld/>on.
    </dif>
  </snc>
  <trd lng="be">&c_ib;&c_m;&c_a;&c_b;&c_ib;&c_l;&c_ib;&c_z;&c_a;&c_c;&c_y;&c_ja;</trd>
  <trd lng="cs">zp&uring;soben&iacute; ankyl&oacute;zy</trd>
  <trd lng="de">Ruhigstellung <klr>(Gelenk)</klr></trd>
  <trd lng="hu">m&udblac;vi <ind>ankylosis</ind></trd>
  <trd lng="nl">veroorzaken van <ind>ankylosis</ind></trd>
  <trd lng="ru">&c_i;&c_m;&c_m;&c_o;&c_b;&c_i;&c_l;&c_i;&c_z;&c_a;&c_c;&c_i;&c_ja;</trd>
  <trd lng="sk">znehybnenie k&lacute;bu</trd>
</drv>
</art>
