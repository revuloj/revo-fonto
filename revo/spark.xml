<?xml version="1.0"?>
<!DOCTYPE vortaro SYSTEM "../dtd/vokoxml.dtd">
<vortaro>
<art mrk="$Id: spark.xml,v 1.22 2026/03/30 14:00:23 revo Exp $">
<kap>
  <rad>spark</rad>/o
</kap>
<drv mrk="spark.0o">
  <kap><tld/>o</kap>
  <snc>
  <uzo tip="fak">ELE</uzo>
    <dif>
      Elektra <ref tip="super" cel="fajr.0ero">fajrero</ref>:
      <ekz>
        tiu praa fulmo, kies <tld/>o anta&ubreve; milionoj da jarcentoj sur la Tero unuafoje
        ligis simplajn karbonajn kombina&jcirc;ojn en pli komplikajn molekulojn
        <fnt>
          <aut>Ivan Efremov, trad. Jurij Finkel</aut>
          <vrk><url ref="http://www.esperanto.mv.ru/Efremov/andromedo_07.html">La nebulozo de
          Andromedo</url></vrk>
        </fnt>;
      </ekz>
      <ekz>
        elektra <tld/>o trakuris el mia brako en &scirc;ian brakon
        <fnt>
          <lok><url
          ref="http://corpora.uni-leipzig.de/de/res?corpusId=epo_mixed_2012&amp;word=sparko">esperanto.org</url></lok>
        </fnt>;
      </ekz>
      <ekz>
        oni povis produkti radioondojn per <tld/>omal&scirc;argi&gcirc;o, tio ne estis konvena por
        radiofonio, sed Morsa aparato povis sendi la signojn per <tld/>o en foran
        distancon
        <fnt>
          <bib>Viki</bib>
          <lok><url ref="https://eo.wikipedia.org/?curid=18674">Telegrafo</url></lok>
        </fnt>;
      </ekz>
      <ekz>
        <uzo tip="stl">FIG</uzo>
        neniam anta&ubreve;e li vidis tiajn okulojn <klr>[&#8230;]</klr> en ili ludis diverskoloraj
        briloj, similaj al etaj <tld/>oj
        <fnt>
          <bib>Monato</bib>
          <aut>Julian Modest</aut>
          <vrk><url ref="&Monato;/2013/010914.php">Mi luigas miajn okulojn</url></vrk>
        </fnt>;
      </ekz>
      <ekz>
        <uzo tip="stl">FIG</uzo>
        el unu okulo <klr>[&#8230;]</klr> en la alian, kiam li eksilentis, transflugis akra
        <tld/>o de plezuro
        <fnt>
          <aut>Aleksandro Grin, trad. Jurij Finkel</aut>
          <vrk><url ref="http://www.esperanto.mv.ru/Grin/kuranta_09.html">Kuranta sur
          ondoj</url></vrk>
        </fnt>;
      </ekz>
      <ekz>
        <uzo tip="stl">FIG</uzo>
        tiom longe kiom ekzistas, en ilia menso, la plej eta <tld/>o da espero
        <klr>[&#8230;]</klr> nenia loga promeso igos ilin rezigni je tiu espero
        <fnt>
          <aut>Albin Michel, trad. Dominique Vidal</aut>
          <vrk><url ref="&Mondediplo;article747.html">La palestinanoj sie&gcirc;ataj</url></vrk>
        </fnt>.
      </ekz>
    </dif>
  </snc>
  <trd lng="be">&c_ib;&c_s;&c_k;&c_r;&c_a; <klr
  tip="amb">(&c_e;&c_l;&c_je;&c_k;&c_t;&c_r;&c_y;&c_ch;&c_n;&c_a;&c_ja;)</klr></trd>
  <trdgrp lng="ca">
    <trd>guspira</trd>,
    <trd>espurna el&egrave;ctrica</trd>
  </trdgrp>
  <trd lng="cs">elektrick&aacute; jiskra</trd>
  <trd lng="de">Funke</trd>
  <trd lng="fr">arc &eacute;lectrique</trd>
  <trd lng="hu">szikra<klr tip="ind"> (elektromos)</klr></trd>
  <trdgrp lng="ja">
    <trd>&#12473;&#12497;&#12540;&#12463;</trd>,
    <trd>&#38651;&#27671;&#28779;&#33457;  <pr>&#12391;&#12435;&#12365;&#12402;&#12400;&#12394;</pr></trd>
  </trdgrp>
  <trd lng="nl">vonk</trd>
  <trd lng="pl">iskra elektryczna</trd>
  <trdgrp lng="ru">
    <trd>&c_i;&c_s;&c_k;&c_r;&c_a; <klr
    tip="amb">(&c_e;&c_l;&c_je;&c_k;&c_t;&c_r;&c_i;&c_ch;&c_je;&c_s;&c_k;&c_a;&c_ja;)</klr></trd>,
    <trd>&c_i;&c_s;&c_k;&c_r;&c_o;&c_v;&c_o;&c_j; <ind>&c_r;&c_a;&c_z;&c_r;&c_ja;&c_d;</ind></trd>
  </trdgrp>
  <trd lng="sk">iskra elektrick&aacute;</trd>
  <trd lng="uk">&c_ib;&c_s;&c_k;&c_r;&c_a;</trd>
  <trdgrp lng="zh">
    <trd>&#28779;&#20809; <pr>hu&#466;gu&amacron;ng</pr></trd>,
    <trd>&#28779;&#33457; <pr>hu&#466;hu&amacron;</pr></trd>
  </trdgrp>
</drv>

<drv mrk="spark.0ilo">
  <kap><tld/>ilo</kap>
  <snc>
  <uzo tip="fak">ELE</uzo>
  <uzo tip="fak">TEK</uzo>
    <dif>
      Tiu organo de eksplodmotoro kun elektra eksplodigilo, kiu
      produktas interne de la cilindro la <tld/>on, eksplodigantan la
      gasmiksa&jcirc;on:
      <ekz>
        la miksa&jcirc;o estas enigata en cilindron, premata, kaj poste ekbruligata helpe de
        <tld/>o, aperanta inter elektrodoj de <tld/>ilo
        <fnt>
          <bib>Viki</bib>
          <lok><url ref="https://eo.wikipedia.org/?curid=1129">Eksplodmotoro</url></lok>
        </fnt>;
      </ekz>
      <ekz>
        mi devis halti, &ccirc;ar mia veturilo postulis purigon de la <tld/>ilo
        <fnt>
          <aut>Jan Sadowski</aut>
          <vrk><url ref="http://www.esperokatolika.org/ek19861990/ek1989_10.htm">Ses Misiistaj
          Rakontoj</url></vrk>
        </fnt>.
      </ekz>
    </dif>
  </snc>
  <trd lng="be">&c_s;&c_mol;&c_v;&c_je;&c_ch;&c_k;&c_a; <klr
  tip="amb">(&c_z;&c_a;&c_p;&c_a;&c_l;&c_mol;&c_n;&c_a;&c_ja;)</klr></trd>
  <trd lng="ca">bugia d'encesa</trd>
  <trd lng="cs">sv&iacute;&ccaron;ka motoru</trd>
  <trd lng="de">Z&uuml;ndkerze</trd>
  <trd lng="fr">bougie<klr> (d'allumage)</klr></trd>
  <trdgrp lng="ja">
    <trd>&#28857;&#28779;&#12503;&#12521;&#12464;
    <pr>&#12390;&#12435;&#12363;&#12503;&#12521;&#12464;</pr></trd>,
    <trd>&#28857;&#28779;&#35013;&#32622;  <pr>&#12390;&#12435;&#12363;&#12381;&#12358;&#12385;</pr></trd>
  </trdgrp>
  <trdgrp lng="pl">
    <trd>&sacute;wieca zap&lstroke;onowa</trd>,
    <trd>iskrownik</trd>
  </trdgrp>
  <trd lng="sk">svie&ccaron;ka motora</trd>
  <trdgrp lng="uk">
    <trd>&c_r;&c_o;&c_z;&c_r;&c_ja;&c_d;&c_n;&c_i;&c_k;</trd>,
    <trd>&c_z;&c_a;&c_p;&c_a;&c_l;&c_mol;&c_n;&c_a; &c_s;&c_v;&c_ib;&c_ch;&c_k;&c_a;</trd>
  </trdgrp>
  <trdgrp lng="zh">
    <trd>&#28779;&#21632; <pr>hu&#466;j&#468;</pr></trd>,
    <trd>&#28779;&#22068; <pr>hu&#466;zu&#464;</pr></trd>,
    <trd>&#28779;&#26143;&#22622; <pr>hu&#466;x&#299;ngs&amacron;i</pr></trd>
  </trdgrp>
</drv>
