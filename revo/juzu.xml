<?xml version="1.0"?>
<!DOCTYPE vortaro SYSTEM "../dtd/vokoxml.dtd">
<vortaro>
<art mrk="$Id: juzu.xml,v 1.1 2026/03/30 03:37:53 afido Exp $">
<kap>
    <rad>juzu</rad>/o <fnt><bib>Wiki</bib></fnt>
</kap>
<drv mrk="juzu.0o">
  <kap><tld/>o</kap>
  <snc mrk="juzu.0o.KUI">
    <uzo tip="fak">KUI</uzo>
    <dif>
       <ref tip="vid" cel="citrus.0o">Citrusa</ref> <ref tip="super" cel="frukt.0o.BOT">frukto</ref>
       de la <tld/>arbo, arom&scirc;ela, acidsuka, globforma, kun flava a&ubreve; oran&gcirc;a koloro:
      <ekz>
        en tiu tago oni kutimas bani&gcirc;i en banujo, kun flosantaj <tld/>oj (arom&scirc;elaj oran&gcirc;oj),
        esperante, ke la tuta familio restos tute sana
        <fnt>
          <aut>OKITA Kazumi</aut>
          <vrk>Sezonvorto decembra: Bani&gcirc;o kun juzuo</vrk>
          <lok><url
          ref="https://web.archive.org/web/20260329203926/https://s1d89dd5f9bc1d4bc.jimcontent.com/download/version/1773488726/module/14137727690/name/NT391decembro.pdf">Nova&jcirc;oj
          Tamtamas, n-ro 391</url>, pa&gcirc;o 3, 2023-12</lok>
        </fnt>;
      </ekz>
      <ekz>
        estas leona <tld/>o (speco de cedrato) el &gcirc;ardeno
        <fnt>
          <aut>Etsuo Miyoshi</aut>
          <vrk><url
          ref="https://www.facebook.com/etsuo.miyoshi.5/posts/pfbid02xEevL1bCVjEBqp9vhpFrMXbsVFvNhtZs5CPuEYCW3KwBJ7X6zTJCwRuixZshhUpyl">
            Facebook</url></vrk>
          <lok>2026-01-13</lok>
        </fnt>;
      </ekz>
      <ekz>
        malgrande tran&ccirc;itaj <tld/>oj estas konservitaj en mielo a&ubreve; sukera siropo por fari siropon
        similan al marmelado, kaj oni miksas la siropon kun varmega akvo por fari
        <ind><tld/>-teo</ind>n
        <fnt>
          <bib>Viki</bib>
          <lok><url ref="https://eo.wikipedia.org/?curid=939932">Juzuo</url></lok>
        </fnt>.
        <trd lng="en">yuzu tea</trd>
        <trdgrp lng="ja">
          <trd>&#26586;&#23376;&#33590; <pr>&#12422;&#12378;&#12385;&#12419;</pr></trd>,
          <trd>&#12518;&#12472;&#12515;&#12481;&#12515;</trd>
        </trdgrp>
        <trd lng="ko">&#50976;&#51088;&#52264;<klr tip="amb"> (&#26586;&#23376;&#33590;)</klr></trd>
        <trdgrp lng="zh">
          <trd>&#26586;&#23376;&#33590; <pr>y&ograve;uzich&aacute;</pr></trd>,
          <trd>&#26586;&#23376;&#34588;&#33590; <pr>y&ograve;uzi m&igrave;ch&aacute;</pr></trd>,
          <trd>&#34562;&#34588;&#26586;&#23376;&#33590; <pr>f&emacron;ngm&igrave; y&ograve;uzich&aacute;</pr></trd>
        </trdgrp>
      </ekz>
    </dif>
  </snc>
  <trd lng="de">Yuzu</trd>
  <trdgrp lng="en">
    <trd>yuzu</trd>,
    <trd>yuzu citron</trd>,
    <trd>Japanese citron</trd>
  </trdgrp>
  <trd lng="es">yuzu</trd>
  <trd lng="fr">yuzu</trd>
  <trd lng="ko">&#50976;&#51088;<klr tip="amb"> (&#26586;&#23376;)</klr></trd>
  <trd lng="id">buah yuzu</trd>
  <trdgrp lng="ja">
    <trd>&#26586;&#23376; <pr>&#12422;&#12378;</pr></trd>,
    <trd>&#26586;&#23376;&#12398;&#23455; <pr>&#12422;&#12378;&#12398;&#12415;</pr></trd>,
    <trd>&#26586;&#23376;&#12398;&#26524;&#23455; <pr>&#12422;&#12378;&#12398;&#12363;&#12376;&#12388;</pr></trd>
  </trdgrp>
  <trd lng="nl">yuzu</trd>
  <trd lng="pt">yuzu</trd>
  <trd lng="ru">&c_ju;&c_d;&c_z;&c_u;</trd>
  <trd lng="tr">yuzu</trd>
  <trdgrp lng="zh">
    <trd>&#39321;&#27225; <pr>xi&amacron;ngch&eacute;ng</pr></trd>,
    <trd>&#32645;&#28450;&#27225; <pr>lu&oacute;h&agrave;nch&eacute;ng</pr></trd>,
    <trd>&#26085;&#26412;&#26586;&#23376; <pr>R&igrave;b&ecaron;n y&ograve;uzi</pr></trd>
  </trdgrp>
</drv>

<drv mrk="juzu.0arbo">
  <kap><tld/>arbo, <var><kap><tld/>ujo</kap></var></kap>
  <snc mrk="juzu.0arbo.BOT">
    <uzo tip="fak">BOT</uzo>
    <dif>
      <ref tip="vid" cel="hibrid.0o">Hibrida</ref> specio de <ref tip="super"
      cel="citrus.0o">citruso</ref>
      (<trd lng="la">Citrus &#215; junos</trd>).
    </dif>
    <ekz>
      <tld/>arbo <klr>[...]</klr> estas natura hibrido de mandarinarbo (<nac>Citrus
      reticulata</nac>) kaj papedarbo (<nac>Citrus cavaleriei</nac>)
        <fnt>
          <bib>Viki</bib>
          <lok><url ref="https://eo.wikipedia.org/?curid=939932">Juzuo</url></lok>
        </fnt>.
    </ekz>
  </snc>
  <trd lng="en">yuzu tree</trd>
  <trd lng="id">pohon yuzu</trd>
  <trdgrp lng="ja">
    <trd>&#26586;&#23376; <pr>&#12422;&#12378;</pr></trd>,
    <trd>&#26586;&#23376;&#12398;&#26408; <pr>&#12422;&#12378;&#12398;&#12365;</pr></trd>
  </trdgrp>
  <trd lng="ko">&#50976;&#51088;&#45208;&#47924;</trd>
  <trd lng="nl">yuzuboom</trd>
</drv>

</art>

