      <ref tip="dif" cel="kroat.K0ujo.GEOG">Kroatujo</ref>:
      <ekz>
        la Popola Armeo de eks-Jugoslavio enmar&scirc;is Bosnio-Hercegovinon post la retiro de siaj trupoj
        el Slovenio kaj <tld/>o
        <fnt>
          <aut>Hamza Baksi&cacute;</aut>
          <vrk><url ref="&Monato;/1993/A931001.php">La fino de la mondo komenci&gcirc;as en
          Sarajevo</url></vrk>
          <bib>Monato</bib>
          <lok>1993/10, p. 8</lok>
        </fnt>;
      </ekz>
      <ekz>
        en <tld/>o, kiu havas 4,5 milionojn da lo&gcirc;antoj, vivis anta&ubreve; &ccirc;i tiu lasta milito proksimume
        15&nbsp;% da serboj, do proksimume 700&nbsp;000
        <fnt>
	<aut>Zlatko Ti&scaron;ljar</aut>
	<vrk><url ref="&Monato;/2000/006811.php">Nekredeblaj malveroj</url></vrk>
	<bib>Monato</bib>
	<lok>2000/03, p. 12-13</lok>
        </fnt>.
      </ekz>
    </dif>
  </snc>
