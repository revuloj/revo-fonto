<?xml version="1.0"?>
<!DOCTYPE vortaro SYSTEM "../dtd/vokoxml.dtd">
<vortaro>
<art mrk="$Id: norveg.xml,v 1.29 2026/06/21 16:00:22 revo Exp $">
<kap>
  <ofc>8</ofc>
  <rad>norveg</rad>/o <fnt><bib>JED</bib></fnt>
</kap>

<drv mrk="norveg.0o">
  <kap><tld/>o</kap>
  <snc mrk="norveg.0o.sxtatano">
    <dif>
      <ref tip="super" cel="sxtat.0ano">&Scirc;tatano</ref> de
      <ref tip="malprt" cel="norveg.N0ujo.GEOG"><tld lit="N"/>ujo</ref>:
      <ekz>
        mi lernis ami la <tld lit="N"/>ojn, &scirc;i respondis, kaj mi
        edzini&gcirc;os nur en tia okazo, se mi povos veni <tld lit="N"/>ujon
        <fnt>
          <bib>Fab2</bib>
          <lok>Monteto de elfoj</lok>
        </fnt>.
      </ekz>
    </dif>
  </snc>
  <snc mrk="norveg.0o.naciano">
    <dif>
      Homo kun <tld/>a nacieco:
      <ekz>
        la batalo kontra&ubreve; la <tld lit="N"/>oj
        <fnt>
          <bib>Hamlet</bib>
        </fnt>;
      </ekz>
      <ekz>
        la maljuna estro de l&#8217; <tld/>oj
        <fnt>
          <bib>Hamlet</bib>
        </fnt>.
      </ekz>
    </dif>
  </snc>
  <trd lng="be">&c_n;&c_a;&c_r;&c_v;&c_e;&c_zh;&c_a;&c_c;&c_mol;</trd>
  <trd lng="ca">noruec</trd>
  <trd lng="cs">Nor</trd>
  <trd lng="de">Norweger</trd>
  <trd lng="en">Norwegian<klr> (subst.)</klr></trd>
  <trdgrp lng="fr">
    <trd>Norv&eacute;gien</trd>
    <trd>Norv&eacute;gienne<klr> (subst.)</klr></trd>
  </trdgrp>
  <trd lng="ja">&#12494;&#12523;&#12454;&#12455;&#12540;&#20154; 
  <pr>&#12494;&#12523;&#12454;&#12455;&#12540;&#12376;&#12435;</pr></trd>
  <trd lng="nl">Noor</trd>
  <trd lng="no">nordmann</trd>
  <trdgrp lng="pl">
    <trd>Norweg</trd>,
    <trd>Norwe&zdot;ka</trd>
  </trdgrp>
  <trd lng="ro">norvegian</trd>
  <trd lng="sk">N&oacute;r</trd>
  <trd lng="tok">jan pi ma Nosiki</trd>
  <trd lng="uk">&c_n;&c_o;&c_r;&c_v;&c_je;&c_zh;&c_je;&c_c;&c_mol;</trd>
  <trd lng="vo">Norg&auml;nan</trd>
  <trd lng="zh">&#25386;&#23041;&#20154; <pr>nu&oacute;w&emacron;ir&eacute;n</pr></trd>
</drv>

<drv mrk="norveg.0a">
  <kap><tld/>a</kap>
  <snc>
    <dif>
      Rilatanta al <tld/>oj, ilia nacieco a&ubreve; &scirc;tato:
      <ekz>
        la <tld lit="N"/>a re&gcirc;o <nom>Fortinbras</nom>
        <fnt>
          <bib>Hamlet</bib>
        </fnt>;
      </ekz>
      <ekz>
        mi eka&ubreve;dis fra&ubreve;linan vo&ccirc;on post mi, dirantan en pura <tld/>a
        lingvo: Dio, kion mi faros
        <fnt>
          <bib>FK</bib>
        </fnt>.
      </ekz>
    </dif>
    <trd lng="en">Norwegian<klr> (adj.)</klr></trd>
    <trdgrp lng="fr">
      <trd>norv&eacute;gien</trd>
      <trd>norv&eacute;gienne<klr> (adj.)</klr></trd>
    </trdgrp>
    <trd lng="tok">pi ma Nosiki</trd>
    <trd lng="vo">Norg&auml;nik</trd>
  </snc>
  <snc>
    <dif>
      <klr>(la)</klr> <tld lit="N"/>a <ref tip="super" cel="lingv.0o">lingvo</ref>:
      <ekz>
        li kantis, kaj igis nin kunkanti, plurajn belajn kantojn, kiujn
        li persone tradukis el la <tld/>a
        <fnt>
          <bib>Monato</bib>
          <aut>Garvan Makaj</aut>
          <vrk><url ref="&Monato;/2010/010123.php">Neniam
          plu</url></vrk>
        </fnt>.
      </ekz>
    </dif>
    <trd lng="en">Norwegian<klr> (language)</klr></trd>
    <trd lng="fr">norv&eacute;gien<klr> (langue)</klr></trd>
    <trd lng="tok">toki Nosiki</trd>
    <trd lng="vo">Norg&auml;nap&uuml;k</trd>
  </snc>
  <trd lng="be">&c_n;&c_a;&c_r;&c_v;&c_e;&c_s;&c_k;&c_ib;</trd>
  <trd lng="ca">noruec</trd>
  <trd lng="cs">norsk&yacute;</trd>
  <trd lng="de">norwegisch</trd>
  <trd lng="ja">&#12494;&#12523;&#12454;&#12455;&#12540;&#12398; 
  <pr>&#12398;&#12427;&#12358;&#12359;&#12540;&#12398;</pr></trd>
  <trd lng="nl">Noors</trd>
  <trd lng="no">norsk</trd>
  <trd lng="pl"></trd>
  <trdgrp lng="pl">
    <trd>norweski</trd>,
    <trd>norweska</trd>
  </trdgrp>
  <trd lng="ro">norvegian</trd>
  <trd lng="sk">n&oacute;rsky</trd>
  <trd lng="uk">&c_n;&c_o;&c_r;&c_v;&c_je;&c_z;&c_mol;&c_k;&c_i;&c_j;</trd>
</drv>

<drv mrk="norveg.N0ujo">
  <kap>
    <tld lit="N"/>ujo
  </kap>
  <mlg kod="ISO-3166">NO</mlg>
  <snc mrk="norveg.N0ujo.GEOG">
    <uzo tip="fak">GEOG</uzo>
    <uzo tip="fak">POL</uzo>
    <dif>
      <ref tip="super" cel="sxtat.0o.POL">&Scirc;tato</ref> en la norda E&ubreve;ropo
      sur la Skandinava duoninsulo kun
      <ref tip="lst" lst="voko:&ccirc;efurboj" cel="urb.cxef0o.POL">&ccirc;efurbo</ref>
      <ref tip="prt" cel="osl.0o">Oslo</ref>; teritorio de Regno <tld lit="N"/>ujo;
      &gcirc;i limas kun
      <ref tip="vid" cel="finn.F0lando">Finnlando</ref>,
      <ref tip="vid" cel="rus.R0ujo">Rusujo</ref>,
      <ref tip="vid" cel="sved.S0ujo">Svedujo</ref>
      kaj <ref tip="vid" cel="atlant.A0o.GEOG">Atlantiko</ref>:
      <ekz>
        maljuna gnomo el <tld lit="N"/>ujo, kiu lo&gcirc;as en la malnova roko
        de Dovro kaj posedas multe da rokaj kasteloj kaj orminejon
        <fnt>
          <bib>Fab2</bib>
          <lok>Monteto de elfoj</lok>
        </fnt>;
      </ekz>
      <ekz>
        en Aprilo devis iri &scirc;ipo al <tld lit="N"/>ujo, kaj Georgo estis
        kunveturonta
        <fnt>
          <bib>Fab4</bib>
          <lok>Historio el la dunoj</lok>
        </fnt>.
      </ekz>
    </dif>
    <ref tip="sin" cel="norvegi.N0o">Norvegio</ref>
    <trd lng="de">Norwegen</trd>
  </snc>
  <trd lng="be">&c_N;&c_a;&c_r;&c_v;&c_e;&c_g;&c_ib;&c_ja;</trd>
  <trd lng="ca">Noruega</trd>
  <trd lng="en">Norway</trd>
  <trd lng="es">Noruega</trd>
  <trd lng="fa">&a_n;&a_r;&a_w;&f_zh;</trd>
  <trd lng="fr">Norv&egrave;ge</trd>
  <trd lng="fy">Noarwegen</trd>
  <trd lng="id">Norwegia</trd>
  <trd lng="nl">Noorwegen</trd>
  <trd lng="no">Norge</trd>
  <trdgrp lng="pl">
    <trd>Norwegia</trd>,
    <trd>Kr&oacute;lestwo <ind>Norwegii</ind></trd>
  </trdgrp>
  <trd lng="ro">Norvegia</trd>
  <trd lng="tok">ma Nosiki</trd>
  <trd lng="vo">Norg&auml;n</trd>
  <trd lng="zh">&#25386;&#23041; <pr>Nu&oacute;w&emacron;i</pr></trd>
</drv>
</art>
