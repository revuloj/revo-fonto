<?xml version="1.0"?>
<!DOCTYPE vortaro SYSTEM "../dtd/vokoxml.dtd">
<vortaro>
<art mrk="$Id: auxton.xml,v 1.28 2026/05/19 10:04:31 revo Exp $">
<kap>
  <ofc>4</ofc>
  <rad>a&ubreve;tonom</rad>/a <fnt><bib>PVEF</bib></fnt>
</kap>
<drv mrk="auxton.0a">
  <kap><tld/>a</kap>
  <snc mrk="auxton.0a.POL">
    <dif>
      &Gcirc;uanta <tld/>econ,
      <ref tip="vid" cel="star.mem0a">memstare</ref>,
      <ref tip="vid" cel="pend.sende0a">sendepende</ref>
      decidanta pri iuj politikaj aferoj:
      <ekz>
        Krimeo estas <tld/>a respubliko de Ukrainio
        <fnt><aut>JeZo</aut>, <vrk>Krimoj en Krimeo</vrk>,
        <bib>Monato</bib>, <lok>2002:6, p. 10a</lok></fnt>;
      </ekz>
      <ekz>
        la brita registaro suspendis la <tld/>an parlamenton demokratie elektitan de la
        nordirlanda popolo
        <fnt>
          <bib>Monato</bib>
          <aut>PGubbins</aut>
          <vrk>Irlando: Karuselo de seniluzii&gcirc;o</vrk>
        </fnt>;
      </ekz>
      <ekz>
        slovenaj fe&ubreve;doj, teorie ligitaj al la rom-germana imperio, sed pli-malpli
        <tld/>aj &gcirc;is la 13a jc
        <fnt>
          <bib>Monato</bib>
          <vrk>Reago: Eks-Jugoslavio: kiu kiun mistifikas?</vrk>
        </fnt>.
      </ekz>
    </dif>
    <trdgrp lng="zh">
      <trd>&#x72EC;&#x7ACB; <pr>d&uacute;l&igrave;</pr></trd>,
      <trd>&#x7368;&#x7ACB; <pr>d&uacute;l&igrave;</pr></trd>,
      <trd>&#x81EA;&#x6CBB; <pr>z&igrave;zh&igrave;</pr></trd>
    </trdgrp>
  </snc>
  <snc mrk="auxton.0a.TEK">
    <uzo tip="fak">TEK</uzo>
    <dif>
      Funkcianta sendepende de &ccirc;efa sistemo:
      <ekz>
        <tld/>a energifonto;
      </ekz>
      <ekz>
        lingvoj ne estas objektoj havantaj a&ubreve;tonoman materian ekziston kaj evoluantaj
        per si mem
        <fnt>
          <bib>Ret</bib>
          <lok>Unua Parto</lok>
        </fnt>;
      </ekz>
      <ekz>
        <uzo tip="fak">KOMP</uzo>
        el&scirc;utu la mesa&gcirc;ojn kaj poste legu ilin en la <tld/>a
        <ref tip="super" cel="regxim.0o.TEK">re&gcirc;imo</ref>
        <klr>(t.e.
        <ref tip="sin" cel="konekt.sen0e.KOMP">senkonekte</ref>)</klr>!
      </ekz>
    </dif>
    <trdgrp lng="zh">
      <trd>&#x81EA;&#x52A8;&#x5BFC;&#x5411;&#x7684; <pr>z&igrave;d&ograve;ngd&#x1CE;oxi&agrave;ngde</pr></trd>,
      <trd>&#x81EA;&#x52D5;&#x5C0E;&#x5411;&#x7684; <pr>z&igrave;d&ograve;ngd&#x1CE;oxi&agrave;ngde</pr></trd>,
      <trd>&#x81EA;&#x4E3B;&#x64CD;&#x7E31;&#x7684; <pr>z&igrave;zh&#x1D4;c&amacron;oz&ograve;ngde</pr></trd>,
      <trd>&#x81EA;&#x4E3B;&#x64CD;&#x7EB5;&#x7684; <pr>z&igrave;zh&#x1D4;c&amacron;oz&ograve;ngde</pr></trd>
    </trdgrp>
  </snc>
  <rim>
    La&ubreve; <fnt><bib>BL</bib></fnt>: Anka&ubreve; eblas diri <ke>memstara</ke>, <ke>memrega</ke>.
  </rim>

  <trd lng="be">&c_a;&c_w;&c_t;&c_a;&c_n;&c_o;&c_m;&c_n;&c_y;</trd>
  <trd lng="bo">&t_ra;&t_nga;&t_tsheg;&t_da;&t_ba;&t_nga;&t_tsheg;</trd>
  <trdgrp lng="de">
    <trd>autonom</trd>,
    <trd>selbst&auml;ndig</trd>,
    <trd>unabh&auml;ngig</trd>
  </trdgrp>
  <trd lng="en">autonomous</trd>
  <trdgrp lng="fa">
    <trd>&a_kh;&a_w;&a_d;&a_m;&a_kh;&a_t;&a_A;&a_r;</trd>,
    <trd>&a_kh;&a_w;&a_d;&f_g;&a_r;&a_d;&a_A;&a_n;</trd>
  </trdgrp>
  <trd lng="fr">autonome</trd>
  <trd lng="he">&alef;&vav;&tet;&vav;&nun;&vav;&mem;&yod;</trd>
  <trdgrp lng="nl">
    <trd>autonoom</trd>,
    <trd>onafhankelijk</trd>
  </trdgrp>
  <trdgrp lng="hu">
    <trd>auton&oacute;m</trd>,
    <trd>f&uuml;ggetlen</trd>
  </trdgrp>
  <trd lng="it">autonomo</trd>
  <trd lng="pl">autonomiczny</trd>
  <trdgrp lng="ru">
    <trd>&c_a;&c_v;&c_t;&c_o;&c_n;&c_o;&c_m;&c_n;&c_y;&c_j;</trd>,
    <trd>&c_s;&c_a;&c_m;&c_o;&c_u;&c_p;&c_r;&c_a;&c_v;&c_l;&c_ja;&c_ju;&c_shch;&c_i;&c_j;&c_s;&c_ja;</trd>
  </trdgrp>
  <trdgrp lng="sk">
    <trd>nez&aacute;visl&yacute;</trd>,
    <trd>auton&oacute;mny</trd>
  </trdgrp>
  <trdgrp lng="uk">
    <trd>&c_a;&c_v;&c_t;&c_o;&c_n;&c_o;&c_m;&c_n;&c_i;&c_j;</trd>,
    <trd>&c_s;&c_a;&c_m;&c_o;&c_v;&c_r;&c_ja;&c_d;&c_n;&c_i;&c_j;</trd>
  </trdgrp>
</drv>

<drv mrk="auxton.0eco">
  <kap><tld/>eco</kap>
  <snc mrk="auxton.0eco.POL">
    <uzo tip="fak">POL</uzo>
    <dif>
      Grandparta <ref tip="super" cel="reg.mem0ado.POL">memregeco</ref>
      ekzemple politika a&ubreve; ekonomia; rajto decidi kaj
      fari la proprajn le&gcirc;ojn en difinita kampo;
      <ref tip="sin" cel="auxton1.0o">a&ubreve;tonomio</ref>:
      <ekz>
        la kurdoj ekspluatis la aktualan krizon por havigi al si mem pli grandan
        <tld/>econ
        <fnt>
          <bib>Kon11</bib>
          <lok>&Ccirc;efartikolo</lok>
        </fnt>;
      </ekz>
      <ekz>
        jam fondi&gcirc;is en Kosovo almena&ubreve; 11 novaj pure etnaj serbaj komunumoj
        <klr>[&#x2026;]</klr> posedantaj eksterordinaran <tld/>econ
        <fnt>
          <bib>Monato</bib>
          <aut>Bardhyl Selimi</aut>
          <vrk><url ref="&Monato;/2009/009760.php"
              >Dependa sendependeco</url></vrk>
          <lok>2009</lok>
        </fnt>;
      </ekz>
      <ekz>
        1936 nove elektita hispana registaro restarigas la <tld/>econ de Katalunio
        <fnt>
          <bib>Monato</bib>
          <aut>Donald Broadribb</aut>
          <vrk><url ref="&Monato;/2011/010155.php"
              >Admirinda historilibro</url></vrk>
          <lok>2011</lok>
        </fnt>.
      </ekz>
    </dif>
    <trdgrp lng="zh">
      <trd>&#x81EA;&#x7D66;&#x81EA;&#x8DB3; <pr>z&igrave;j&#x1D0;z&igrave;z&uacute;</pr></trd>,
      <trd>&#x81EA;&#x7ED9;&#x81EA;&#x8DB3; <pr>z&igrave;j&#x1D0;z&igrave;z&uacute;</pr></trd>,
      <trd>&#x81EA;&#x71DF; <pr>z&igrave;y&iacute;ng</pr></trd>,
      <trd>&#x81EA;&#x8425; <pr>z&igrave;y&iacute;ng</pr></trd>,
      <trd>&#x81EA;&#x6CBB; <pr>z&igrave;zh&igrave;</pr></trd>,
      <trd>&#x81EA;&#x6CBB;&#x6743; <pr>z&igrave;zh&igrave;qu&aacute;n</pr></trd>,
      <trd>&#x81EA;&#x6CBB;&#x6B0A; <pr>z&igrave;zh&igrave;qu&aacute;n</pr></trd>,
      <trd>&#x81EA;&#x4E3B; <pr>z&igrave;zh&#x1D4;</pr></trd>
    </trdgrp>
  </snc>
  <trdgrp lng="be">
    <trd>&c_a;&c_w;&c_t;&c_a;&c_n;&c_o;&c_m;&c_ib;&c_ja;</trd>,
    <trd>&c_a;&c_w;&c_t;&c_a;&c_n;&c_o;&c_m;&c_n;&c_a;&c_s;&c_mol;&c_c;&c_mol;</trd>
  </trdgrp>
  <trdgrp lng="de">
    <trd>Autonomie</trd>,
    <trd>Selbst&auml;ndigkeit</trd>,
    <trd>Unabh&auml;ngigkeit</trd>
  </trdgrp>
  <trd lng="en">autonomy</trd>
  <trdgrp lng="fa">
    <trd>&a_kh;&a_w;&a_d;&a_m;&a_kh;&a_t;&a_A;&a_r;&f_y;</trd>,
    <trd>&a_kh;&a_w;&a_d;&f_g;&a_r;&a_d;&a_A;&a_n;&f_y;</trd>
  </trdgrp>
  <trd lng="fr">autonomie</trd>
  <trd lng="he">&alef;&vav;&tet;&vav;&nun;&vav;&mem;&yod;&he;</trd>
  <trdgrp lng="nl">
    <trd>autonomie</trd>,
    <trd>onafhankelijkheid</trd>
  </trdgrp>
  <trdgrp lng="hu">
    <trd>auton&oacute;mia</trd>,
    <trd>f&uuml;ggetlens&eacute;g</trd>
  </trdgrp>
  <trd lng="it">autonomia</trd>
  <trd lng="pl">autonomia</trd>
  <trd lng="ro">autonomie</trd>
  <trdgrp lng="ru">
    <trd>&c_a;&c_v;&c_t;&c_o;&c_n;&c_o;&c_m;&c_i;&c_ja;</trd>,
    <trd>&c_a;&c_v;&c_t;&c_o;&c_n;&c_o;&c_m;&c_n;&c_o;&c_s;&c_t;&c_mol;</trd>,
    <trd>&c_s;&c_a;&c_m;&c_o;&c_u;&c_p;&c_r;&c_a;&c_v;&c_l;&c_je;&c_n;&c_i;&c_je;</trd>
  </trdgrp>
  <trdgrp lng="sk">
    <trd>nez&aacute;vislos&tcaron;</trd>,
    <trd>auton&oacute;mia</trd>
  </trdgrp>
  <trdgrp lng="uk">
    <trd>&c_a;&c_v;&c_t;&c_o;&c_n;&c_o;&c_m;&c_ib;&c_ja;</trd>,
    <trd>&c_a;&c_v;&c_t;&c_o;&c_n;&c_o;&c_m;&c_n;&c_ib;&c_s;&c_t;&c_mol;</trd>
  </trdgrp>
</drv>
</art>
