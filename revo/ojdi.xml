<?xml version="1.0"?>
<!DOCTYPE vortaro SYSTEM "../dtd/vokoxml.dtd">
<vortaro>
<art mrk="$Id: ojdi.xml,v 1.9 2026/03/15 03:31:55 afido Exp $">
<kap>
  <rad>ojdi</rad>/o <fnt><bib>PVEF</bib></fnt>
</kap>

<drv mrk="ojdi.0o">
  <kap><tld/>o</kap>
  <snc mrk="ojdi.0o.AGR">
    <uzo tip="fak">AGR</uzo>
    <dif>
      Iu el <ref tip="super" cel="fung.sak0oj">sakfungoj</ref> de la ordo <nom>Erysiphales</nom>
      ka&ubreve;zantaj malsanon de diversaj vegeta&jcirc;oj, kiu aperas kiel blanka pulvoro sur la folioj;
      la malsano mem:
      <ekz>
        la vinberarbo ne estas ankora&ubreve; liberigita de la <tld/>o
        <fnt>
          <aut>E. About, trad. G. Moch</aut>
          <vrk><url ref="&Gutenberg;files/65835/65835-0.txt">La Re&gcirc;o de la
          Montoj</url></vrk>
          <lok>1909</lok>
        </fnt>;
      </ekz>
      <ekz>
        la <tld/>o, nomata anka&ubreve; blanka malbono, <klr>[&#8230;]</klr> kovras la fragoplantojn per blanka
        &scirc;a&ubreve;mo-polvo
        <fnt>
          <aut>Filomena Canzano</aut>
          <vrk><url ref="https://apetito.ikso.net/artikolo/fragoj">Fragoj</url></vrk>
        </fnt>.
      </ekz>
    </dif>
    <ref tip="super" cel="meldu.0o">melduo</ref>
    <bld lok="&WCU;/thumb/0/0a/Echter_Mehltau_der_Rebe.jpg/330px-Echter_Mehltau_der_Rebe.jpg"
    prm="CC BY 3.0"><tld/>o (Erysiphe necator) sur vinbero
        <fnt>
          <aut>Bauer Karl, propra verko</aut>
          <lok><url
          ref="&WCW;/File:Echter_Mehltau_der_Rebe.jpg">&WCW;/File:Echter_Mehltau_der_Rebe.jpg</url></lok>
        </fnt>
    </bld>
  </snc>
  <trd lng="be">&c_m;&c_u;&c_ch;&c_n;&c_ib;&c_s;&c_t;&c_a;&c_ja; &c_r;&c_a;&c_s;&c_a;</trd>
  <trd lng="de">Echter <ind>Mehltau</ind></trd>
  <trd lng="en">powdery <ind>mildew</ind></trd>
  <trd lng="fr">o&iuml;dium</trd>
  <trd lng="pl">m&aogonek;czniak</trd>
  <trd lng="ru">&c_m;&c_u;&c_ch;&c_n;&c_i;&c_s;&c_t;&c_a;&c_ja; &c_r;&c_o;&c_s;&c_a;</trd>
  <trdgrp lng="uk">
    <trd>&#x43E;&c_ji;&c_d;&c_ib;&c_u;&#x43C;</trd>,
    <trd>&#x43F;&#x43E;&#x43F;&c_je;&#x43B;&#x44E;&c_h;&c_a;</trd>,
    <trd>&c_b;&#x43E;&c_r;&#x43E;&c_sh;&#x43D;&c_i;&c_s;&c_t;&c_a; &c_r;&#x43E;&c_s;&c_a; &c_v;&c_i;&#x43D;&#x43E;&c_g;&c_r;&c_a;&c_d;&c_u;</trd>
  </trdgrp>
  <trdgrp lng="zh">
    <trd>&#x767D;&#x7C89;&#x75C5; <pr>b&#xE1;if&#x11B;nb&#xEC;ng</pr></trd>,
    <trd>&#x7C89;&#x5B62;&#x5B50; <pr>f&#x11B;nb&amacron;oz&#x1D0;</pr></trd>
  </trdgrp>
</drv>
</art>

