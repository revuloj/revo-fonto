<kap>
    <rad>Fu&gcirc;en</rad>/o <fnt><bib>LanLin</bib></fnt>,
    <var><kap><rad var="&gcirc;jan">Fu&gcirc;jan</rad>/o <fnt><bib>PIV2</bib></fnt></kap></var>
