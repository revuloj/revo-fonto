  <var><kap><tld var="&gcirc;jan"/>o</kap></var></kap>
  <snc mrk="fugxen.0o.GEOG">
    <uzo tip="fak">GEOG</uzo>
    <uzo tip="fak">POL</uzo>
    <dif>
      Provinco en la sud-orienta parto de <ref tip="malprt" cel="cxin.CX0ujo">&Ccirc;inujo</ref> kun la
      &ccirc;efurbo Fu&gcirc;o&ubreve;o:
      <ekz>
        nova&jcirc;oj pri la &ccirc;ina ... provinco <tld/>o
        <fnt>
          <aut>-</aut>
          <vrk><url ref="https://eo.wikinews.org/wiki/Kategorio:Fu%C4%9Deno">
          Kategorio: Fu&gcirc;eno</url></vrk>
          <lok>Vikinova&jcirc;oj, 2015-01-04</lok>
        </fnt>;
      </ekz>
      <ekz>
        <tld var="&gcirc;jan"/>o <klr>[&#8230;]</klr> la&ubreve; la loka kutima diro entenas ok partojn de montaro,
        unu parton de akvo kaj unu parton de kamparo
        <fnt>
          <aut>-</aut>
          <vrk><url ref="https://eo.wikipedia.org/wiki/Fu%C4%9Djano">
          Fu&gcirc;jano</url></vrk>
          <lok>Vikipedio, 2025-10-20</lok>
        </fnt>.
      </ekz>
    </dif>
  </snc>
  <trd lng="fr">Fujian</trd>
</drv>
