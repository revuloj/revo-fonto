<?xml version="1.0"?>
<!DOCTYPE vortaro SYSTEM "../dtd/vokoxml.dtd">
<vortaro>
<art mrk="$Id: spinde.xml,v 1.24 2026/03/18 20:00:20 revo Exp $">
<kap>
  <rad>spindel</rad>/o <fnt><bib>JED</bib></fnt>
</kap>
<drv mrk="spinde.0o">
  <kap><tld/>o</kap>
  <snc mrk="spinde.0o.TEKS">
    <uzo tip="fak">TEKS</uzo>
    <uzo tip="fak">TEK</uzo>
    <dif>
      Konuse pintigita <ref tip="super" cel="stang.0eto">stangeto</ref>, &ccirc;irka&ubreve; kiu oni
      volvas la fadenon dum &scirc;pinado, puntoplektado, teksado ktp:
      <ekz>
        tradicia &scirc;pinilo konsistas el <tld/>o kaj &scirc;pinturnilo;
      </ekz>
      <ekz>
        vidis la infanoj la unuan fojon en sia vivo,
        kiel oni &scirc;pinas je <tld/>o
        <fnt>
          <aut>B. N&ecaron;mcov&aacute;, trad. V. Tobek kaj K. Proch&aacute;zka</aut>,
          <vrk><url ref="https://eo.wikisource.org/wiki/Avineto/I.">
          Avineto</url></vrk>,
          <lok>[sen dato]</lok>
        </fnt>;
      </ekz>
      <ekz>
        <tld/>e plektita punto
        <fnt>
          <bib>Monato</bib>
          <aut>Julius Hauser</aut>
          <vrk><url ref="&Monato;/2014/011206.php">Bunte punte</url></vrk>
          <lok>2014</lok>
        </fnt>.
      </ekz>
    </dif>
    <ref tip="sin" cel="boben.0o.KOMUNE">bobeno<sncref/></ref>
    <refgrp tip="malprt">
      <ref cel="naved.0o">navedo</ref>,
      <ref cel="sxpin.0ilo">&scirc;pinilo</ref>
    </refgrp>
    <bld lok="&WCU;/thumb/9/96/Spindel-vereteno.JPG/500px-Spindel-vereteno.JPG" prm="PD"><tld/>o kun
    surmetita &scirc;pinturnilo
        <fnt>
          <aut>VladimirZhV, propra verko</aut>
          <lok><url
          ref="&WCW;/File:Spindel-vereteno.JPG">&WCW;/File:Spindel-vereteno.JPG</url></lok>
        </fnt>
    </bld>

    <trd lng="ca">fus<klr tip="amb"> (de filar)</klr></trd>
    <trdgrp lng="fr">
      <trd>broche<klr> (tissage)</klr></trd>,
      <trd>fuseau<klr> (tissage)</klr></trd>
    </trdgrp>
  </snc>
  <snc mrk="spinde.0o.TEK">
    <uzo tip="fak">TEK</uzo>
    <dif>
      Similforma <ref tip="super" cel="aks.0o.TEK">akso</ref>,
      &ccirc;irka&ubreve; kiu rotacias rado a&ubreve; alia peco:
      <ekz>
        <tld/>o de borilo, glitvalvo, &scirc;ra&ubreve;btenilo.
      </ekz>
    </dif>
    <ref tip="vid" cel="rad.spindel0o"><tld/>rado</ref>
    <trd lng="ca">eix<klr tip="amb"> (d&#8217;una roda, etc.)</klr></trd>
  </snc>
  <trdgrp lng="be">
    <trd>&c_sh;&c_p;&c_ib;&c_n;&c_d;&c_e;&c_l;&c_mol;</trd>,
    <trd>&c_v;&c_je;&c_r;&c_a;&c_c;&c_ja;&c_n;&c_o;</trd>
  </trdgrp>
  <trdgrp lng="cs">
    <trd>krajk&aacute;&rcaron;sk&aacute; pali&ccaron;ka</trd>,
    <trd>v&rcaron;eteno</trd>
  </trdgrp>
  <trd lng="de">Spindel</trd>
  <trd lng="en">spindle</trd>
  <trd lng="hu">ors&oacute;</trd>
  <trd lng="ja">&#12473;&#12500;&#12531;&#12489;&#12523;</trd>
  <trdgrp lng="nl">
    <trd>spoel</trd>,
    <trd>spil</trd>
  </trdgrp>
  <trdgrp lng="pl">
    <trd>wa&lstroke;ek</trd>,
    <trd>wrzeciono</trd>
  </trdgrp>
  <trd lng="ru">&c_sh;&c_p;&c_i;&c_n;&c_d;&c_je;&c_l;&c_mol;</trd>
  <trd lng="sk">vreteno</trd>
  <trdgrp lng="uk">
    <trd>&c_v;&c_je;&c_r;&c_je;&c_t;&c_je;&c_n;&c_o;</trd>,
    <trd>&c_sh;&c_p;&c_i;&c_n;&c_d;&c_je;&c_l;&c_mol;</trd>
  </trdgrp>
  <trdgrp lng="zh">
    <trd>&#31603; <pr>t&iacute;ng</pr></trd>,
    <trd>&#37664; <pr>d&igrave;ng</pr></trd>,
    <trd>&#38189; <pr>d&igrave;ng</pr></trd>,
    <trd>&#24515;&#36600; <pr>x&#299;nzh&oacute;u</pr></trd>,
    <trd>&#24515;&#36724; <pr>x&#299;nzh&oacute;u</pr></trd>,
    <trd>&#32023;&#32187; <pr>sh&amacron;zh&agrave;n</pr></trd>,
    <trd>&#32433;&#32509; <pr>sh&amacron;zh&agrave;n</pr></trd>,
    <trd>&#32033;&#37656; <pr>f&#462;ngchu&iacute;</pr></trd>,
    <trd>&#32442;&#38180; <pr>f&#462;ngchu&iacute;</pr></trd>,
    <trd>&#20013;&#24515;&#26609; <pr>zh&#333;ngx&#299;nzh&ugrave;</pr></trd>,
    <trd>&#26426;&#36724; <pr>j&#299;zh&oacute;u</pr></trd>,
    <trd>&#27231;&#36600; <pr>j&#299;zh&oacute;u</pr></trd>,
    <trd>&#31603;&#23376; <pr>t&iacute;ngz&#464;</pr></trd>,
    <trd>&#32023;&#37664; <pr>sh&amacron;d&igrave;ng</pr></trd>,
    <trd>&#32433;&#38189; <pr>sh&amacron;d&igrave;ng</pr></trd>,
    <trd>&#36600; <pr>zh&oacute;u</pr></trd>,
    <trd>&#36724; <pr>zh&oacute;u</pr></trd>
  </trdgrp>
</drv>
</art>
