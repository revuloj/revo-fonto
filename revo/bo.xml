<?xml version="1.0"?>
<!DOCTYPE vortaro SYSTEM "../dtd/vokoxml.dtd">

<vortaro>
<art mrk="$Id: bo.xml,v 1.19 2026/06/02 05:01:32 revo Exp $">
<kap>
<ofc>*</ofc>
<rad>bo</rad>-</kap>
<subart>
  <drv mrk="bo.0">
    <kap><tld/>-</kap>
    <snc>
      <dif>
        Prefikso montranta la proedzi&gcirc;an parencecon:
        <ekz>
          <tld/>frato <klr>(frato de la edzo rilate al lia edzino, a&ubreve; frato
          de la edzino rilate al &scirc;ia edzo)</klr>;
        </ekz>
        <ekz>
          <tld/>parenci&gcirc;i kun la re&gcirc;o
          <fnt><bib>MT</bib>, <lok>&Sa1; 18:23</lok></fnt>.
        </ekz>
      </dif>
    </snc>
        <rim>
          &Ccirc;e kombino de <tld/>- kaj <ref cel="ge.0">ge-</ref> la
          Fundamento metas la prefikson <tld/>- ekstere (unue):
          <ekz>
            <tld/>gepatroj
            <fnt><bib>F</bib>, <lok>&FE;39.</lok></fnt>;
          </ekz><ekz>
            <tld/>gefratoj
            <fnt><bib>F</bib>, <lok>&FE;36.</lok></fnt>.
          </ekz>
          Tiu ordo estas &gcirc;enerale preferata en Esperanto &mdash; kaj de la
          bonaj a&ubreve;toroj, kaj de la publiko; &gcirc;in preskribas PIV1 (en la
          artikolo <em>bo</em>). Tamen PIV2, malgra&ubreve; la uzado kaj la
          Fundamento, ial preferas la inversan ordon.
        </rim>
    <trd lng="ca">pol&iacute;tic<klr> (adj., dit dels parents sobrevinguts per
    matrimoni)</klr></trd>
    <trd lng="de">Schwieger-</trd>
    <trd lng="en"><klr>-</klr>in-law</trd>
    <trd lng="es">pol&iacute;tico<klr> (denota parentesco por
    matrimonio)</klr></trd>
    <trdgrp lng="fr">
      <trd>beau-</trd>,
      <trd>belle-</trd>
    </trdgrp>
    <trd lng="io">bo-</trd>
    <trd lng="ja">&#32681;&#29702;&#12398; <pr>&#12366;&#12426;&#12398;</pr></trd>
    <trd lng="nl">schoon-<klr> (aangetrouwde familie)</klr></trd>
    <trd lng="no">sviger-</trd>
    <trd lng="pl">przedrostek powinowactwa przez ma&lstroke;&zdot;e&nacute;stwo</trd>
    <trd lng="ro">prefix de afinitate prin c&abreve;s&abreve;torie</trd>
    <trd lng="vo">l&uuml;-</trd>
  </drv>
</subart>

<subart>
  <dif>
    Samsignifa vortero uzata memstare:
  </dif>
  <drv mrk="bo.0a">
    <kap><tld/>a</kap>
    <uzo tip="stl">RAR</uzo>
    <snc>
      <dif>
        Boparenca; apartenanta al la sama familio pro geedzi&gcirc;o:
        <ekz>
          la gvidaj albanaj komunistoj, kiuj havis inter si parencajn kaj <tld/>ajn rilatojn
          <fnt>
	    <aut>Donald Rogers</aut>
	    <vrk><url ref="https://www.planlingvoj.ch/Prago1968.pdf">Prago 1968 kaj &gcirc;ia
	    anta&ubreve;historio</url></vrk>
	    <lok>p. 106</lok>
          </fnt>;
        </ekz>
        <ekz>
          vi ne kredu, ke mi volas profiti de mia <tld/>eco kun vi
          <fnt>
            <bib>ViV</bib>
          </fnt>;
        </ekz>
        <ekz>
          pli preciza nomo por tiu lasta estus <tld/><tld/>frato, &ccirc;ar la parenceco estas duoble
          <tld/>a
          <fnt>
            <bib>LAE</bib>
          </fnt>;
        </ekz>
        <ekz>
          la <tld/>ajn rilatojn estigas la geedzecoj
          <fnt>
            <aut>Bal&aacute;zs Szem&ouml;k</aut>
            <vrk><url ref="https://scienca-revuo.info/article/847">Esprimo de Malproksima Parencaro
            per la Prefiksoj pra- kaj bo-</url></vrk>
            <lok>Scienca Revuo Vol. 45 (1994)(2)- 165, p. 33</lok>
          </fnt>.
        </ekz>
      </dif>
    </snc>
  </drv>
</subart>

</art>
