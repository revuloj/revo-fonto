<kap>
  <rad>&scirc;ampu</rad>/o
</kap>

<drv mrk="sxampu.0o">
  <kap><tld/>o</kap>
  <snc>
    <dif>
      &Scirc;a&ubreve;miga likva&jcirc;o a&ubreve; pulvoro, uzata por lavi 
      la harojn; harlavilo:
      <ekz>
        &ccirc;io alia, inkluzive de boteloj da akvo, <tld/>o, kontaktolensa fluida&jcirc;o, anka&ubreve;
        dentopasto, devis esti tuj repakita
        <fnt>
          <bib>Monato</bib>
          <aut>Paul Gubbins</aut>
          <vrk><url ref="&Monato;/2006/009061.php">Faktoj kaj famoj</url></vrk>
        </fnt>.
      </ekz>
    </dif>
  </snc>
  <trd lng="be">&c_sh;&c_a;&c_m;&c_p;&c_u;&c_n;&c_mol;</trd>
  <trd lng="bg">&c_sh;&c_a;&c_m;&c_p;&c_o;&c_a;&c_n;</trd>
  <trd lng="ca">xamp&uacute;</trd>
  <trdgrp lng="de">
    <trd>Haarwaschmittel</trd>,
    <trd>Schampu</trd>,
    <trd>Shampoo</trd>
  </trdgrp>
  <trd lng="en">shampoo</trd>
  <trd lng="es">champ&uacute;</trd>
  <trd lng="fr">shampoing</trd>
  <trd lng="hu">sampon</trd>
  <trd lng="it">shampoo</trd>
  <trdgrp lng="ja">
    <trd>&#12471;&#12515;&#12531;&#12503;&#12540;  <pr>&#12375;&#12419;&#12435;&#12407;&#12540;</pr></trd>,
    <trd>&#27927;&#39658;&#21092;  <pr>&#12379;&#12435;&#12401;&#12388;&#12374;&#12356;</pr></trd>
  </trdgrp>
  <trd lng="nl">shampoo</trd>
  <trd lng="pl">szampon</trd>
  <trd lng="pt">xampu</trd>
  <trd lng="ru">&c_sh;&c_a;&c_m;&c_p;&c_u;&c_n;&c_mol;</trd>
  <trd lng="sv">schampo</trd>
  <trdgrp lng="uk">
    <trd>&c_sh;&c_a;&c_m;&c_p;&c_u;&c_n;&c_mol;</trd>,
    <trd>&c_r;&c_ib;&c_d;&c_k;&c_je; &c_m;&c_i;&c_l;&c_o;</trd>
  </trdgrp>
  <trdgrp lng="zh">
    <trd>&#27927;&#21457;&#27700; <pr>x&#464;f&agrave;shu&#464;</pr></trd>,
    <trd>&#27927;&#39662;&#27700; <pr>x&#464;f&agrave;shu&#464;</pr></trd>,
    <trd>&#39321;&#27874; <pr>xi&#257;ngb&#333;</pr></trd>,
    <trd>&#27927;&#21457;&#38706; <pr>x&#464;f&agrave;l&ugrave;</pr></trd>,
    <trd>&#27927;&#39662;&#38706; <pr>x&#464;f&agrave;l&ugrave;</pr></trd>,
    <trd>&#27927;&#21457;&#20083; <pr>x&#464;f&#257;r&#468;</pr></trd>,
    <trd>&#27927;&#39662;&#20083; <pr>x&#464;f&#257;r&#468;</pr></trd>,
    <trd>&#27927;&#21457;&#39321;&#27874; <pr>x&#464;f&#257;xi&#257;ngb&#333;</pr></trd>,
    <trd>&#27927;&#30332;&#39321;&#27874; <pr>x&#464;f&#257;xi&#257;ngb&#333;</pr></trd>,
    <trd>&#27927;&#22836;&#27700; <pr>x&#464;t&oacute;ushu&#464;</pr></trd>,
    <trd>&#27927;&#38957;&#27700; <pr>x&#464;t&oacute;ushu&#464;</pr></trd>
  </trdgrp>
</drv>

<drv mrk="sxampu.0i">
  <kap><tld/>i</kap>
  <gra><vspec>tr</vspec></gra>
  <snc>
    <dif>
      Sapumi, lavi kaj masa&gcirc;i ies kapon per <tld/>o.
    </dif>
  </snc>
  <trd lng="be">&c_m;&c_y;&c_c;&c_mol; 
    <ind>&c_sh;&c_a;&c_m;&c_p;&c_u;&c_n;&c_je;&c_m;</ind></trd>
  <trd lng="bg">&c_m;&c_i;&c_ja; &c_s; <ind>&c_sh;&c_a;&c_m;&c_p;&c_o;&c_a;&c_n;</ind></trd>
  <trdgrp lng="de">
    <trd>Haare waschen</trd>,
    <trd>schamponieren</trd>
  </trdgrp>
  <trd lng="en">to shampoo</trd>
  <trd lng="fr">shampouiner</trd>
  <trd lng="hu">besamponoz</trd>
  <trdgrp lng="it">
    <trd><ind>lavare</ind> i capelli<klr> (con shampoo)</klr></trd>,
    <trd>fare lo <ind>shampoo</ind></trd>
  </trdgrp>
  <trd lng="ja">&#12471;&#12515;&#12531;&#12503;&#12540;&#12391;&#27927;&#12358;  <pr>&#12375;&#12419;&#12435;&#12407;&#12540;&#12391;&#12354;&#12425;&#12358;</pr></trd>
  <trd lng="nl">haar wassen</trd>
  <trd lng="pl">my&cacute; <ind>szamponem</ind></trd>
  <trd lng="uk">&c_m;&c_i;&c_t;&c_i; &c_sh;&c_a;&c_m;&c_p;&c_u;&c_n;&c_je;&c_m;</trd>
  <trdgrp lng="zh">
    <trd>&#27927;&#22836; <pr>x&#464;t&oacute;u</pr></trd>,
    <trd>&#27927;&#38957; <pr>x&#464;t&oacute;u</pr></trd>,
    <trd>&#27927;&#22836;&#21457; <pr>x&#464;t&oacute;ufa</pr></trd>,
    <trd>&#27927;&#38957;&#39662; <pr>x&#464;t&oacute;ufa</pr></trd>
  </trdgrp>
</drv>
