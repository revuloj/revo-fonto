<?xml version="1.0"?>
<!DOCTYPE vortaro SYSTEM "../dtd/vokoxml.dtd">

<vortaro>
<art mrk="$Id: kodrant.xml,v 1.10 2026/07/24 14:07:48 revo Exp $">
<kap>
  <rad>kodrant</rad>/o <fnt><bib>NePiv</bib></fnt>,
  <var><kap><rad var="v">kvadrant</rad>/o</kap></var>
</kap>
<drv mrk="kodrant.0o">
  <kap><tld/>o, <var><kap><tld var="v"/>o</kap></var></kap>
  <uzo tip="fak">EKON</uzo>
  <snc mrk="kodrant.0o.monero">
    <dif>
      Antikva roma malgrandvalora <ref tip="lst" lst="voko:monunuoj" cel="mon.0ero">monero</ref> el
      bronzo, egala al <ref cel="kvar.0ono">kvarono</ref> de <ref tip="malprt" cel="asar.0o.EKON">asaro</ref>:
      <ekz>
        vere mi diras al vi, ke vi neniel eliros el tie, &gcirc;is vi pagos
        la
        lastan <tld/>on
        <fnt><bib>NT</bib>, <lok>&Mat; 5:26</lok></fnt>;
      </ekz>
      <ekz>
        li ne eliros el tie &gcirc;is li estos repaginta la lastan <tld var="v"/>on
        <fnt><aut>trad. G. Berveling</aut>, <vrk><url ref="http://www.esperanto.gr/lit/els/did.pdf">la dida&hcirc;eo</url>
        - IABO, 1979</vrk></fnt>.
      </ekz>
    </dif>
    <bld lok="&WCU;/thumb/9/93/Quadrans_Avers.JPG/330px-Quadrans_Avers.JPG" prm="CC BY-SA 3.0"><tld/>o de Kaligulo
        <fnt>
          <aut>Gesa Nehring kaj Hermann Junghans, propra foto</aut>
          <lok><url ref="&WCW;/File:Quadrans_Avers.JPG">&WCW;/File:Quadrans_Avers.JPG</url></lok>
        </fnt>
    </bld>
  </snc>
  <rim mrk="kvadrant.0o.RIM">
    La vorto etime signifas kvaronon.
    <ref tip="hom" cel="kvadra.0o">Kvadranto</ref> do signifas anka&ubreve;
    kvaronon de geometria figuro.
  </rim>
  <trd lng="be">&c_k;&c_v;&c_a;&c_d;&c_r;&c_a;&c_n;&c_t; <klr tip="amb">(&c_m;&c_a;&c_n;&c_e;&c_t;&c_a;)</klr></trd>
  <trd lng="ca">quadrant<klr> (numis.)</klr></trd>
  <trdgrp lng="cs">
    <trd>kvadrant</trd>,
    <trd>&ccaron;tvrtkruh</trd>
  </trdgrp>
  <trd lng="de">Quadrans</trd>
  <trd lng="en">quadrans</trd>
  <trd lng="el">&kappa;&omikron;&delta;&rho;&alfa_ton;&ny;&tau;&eta;&sigma_fina;</trd>
  <trd lng="es">cuadrante<klr tip="ind"> (moneda antigua)</klr></trd>
  <trd lng="fr">quadrant<klr tip="ind"> (monnaie antique)</klr></trd>
  <trd lng="hu">quadrans</trd>
  <trdgrp lng="ja">
    <trd>&#x56DB;&#x5206;&#x5186; <pr>&#x3057;&#x3076;&#x3093;&#x3048;&#x3093;</pr></trd>,
    <trd>&#x8C61;&#x9650; <pr>&#x3057;&#x3087;&#x3046;&#x3052;&#x3093;</pr></trd>
  </trdgrp>
  <trdgrp lng="nl">
    <trd>kwadrant<klr tip="ind"> (munt)</klr></trd>,
    <trd lng="nl">quadrans</trd>
  </trdgrp>
  <trdgrp lng="pl">
    <trd>kodrant</trd>,
    <trd>kwadrant</trd>
  </trdgrp>
  <trd lng="ro">cvadrant</trd>
  <trdgrp lng="sk">
    <trd>kvadrant</trd>,
    <trd>&scaron;tvr&tcaron; kruh</trd>
  </trdgrp>
  <trd lng="uk">&#x43A;&c_v;&c_a;&c_d;&c_r;&c_a;&#x43D;&c_t;</trd>
</drv>
</art>

