<!DOCTYPE vortaro SYSTEM "../dtd/vokoxml.dtd">

<vortaro>
  <art mrk="$Id: bagel.xml,v 1.1 2026/05/05 14:35:12 afido Exp $">
    <kap>
      <rad>bagel</rad>/o
    </kap>

<drv mrk="bagel.0o">
  <kap><tld/>o</kap>
  <uzo tip="fak">KUI</uzo>
  <snc>
    <dif>
      Ringa <ref tip="super" cel="bulk.0o">bulko</ref>, origina el orienta E&ubreve;ropo, tipa en Nordameriko,
      kies tritikan paston oni kuiras anta&ubreve; la bakado:
      <ekz>
        Montreala <tld/>o
        <fnt>
          <vrk><url ref="https://bitoteko.esperanto.es/xmlui/bitstream/handle/11013/5936/Riverego142-144.pdf?"
              >Vi maltrafis virtualajn eventojn</url></vrk>
          <lok>La Riverego, n-ro 142-144, a&ubreve;tuno-vintro 2020 &ndash; printempo 2021p. 29</lok>
        </fnt>;
      </ekz>
      <ekz>
        <nom>Rosillo</nom>, estro de la <tld/>-butiko, kreis la vaste &scirc;atatan &leftquot;&ccirc;ielarkan <tld/>on&rightquot;
        <fnt>
          <vrk><url ref="http://esperanto.china.org.cn/2016-02/18/content_37819229.htm"
              >La plej bela bagelo en la mondo</url></vrk>
          <lok>2016-02-18</lok>
        </fnt>.
      </ekz>
    </dif>
    <refgrp tip="vid">
      <ref cel="kring.0o">kringo</ref>,
      <ref cel="pan.ringo0o">ringopano</ref>
    </refgrp>
    <trd lng="de">Bagel</trd>
    <trd lng="en">bagel</trd>
    <trd lng="fr">bagel</trd>
    <trd lng="ru">&c_b;&c_je;&c_j;&c_g;&c_l;</trd>
    <trd lng="yi">&bet;&#x5F2;&gimel;&lamed;</trd>
  </snc>
</drv>

  </art>

