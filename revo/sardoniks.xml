<!DOCTYPE vortaro SYSTEM "../dtd/vokoxml.dtd">
<vortaro>
<art mrk="$Id: sardoniks.xml,v 1.5 2026/04/10 22:55:34 afido Exp $">
<kap>
    <rad>sardoniks</rad>/o <fnt><bib>PVEF</bib></fnt>
</kap>
<drv mrk="sardoniks.0o">
  <kap><tld/>o</kap>
  <snc mrk="sardoniks.0o.MIN">
    <uzo tip="fak">MIN</uzo>
    <dif>
      Speco de <ref tip="super" cel="kalcedon.0o.MIN">kalcedono</ref> kun ru&gcirc;aj kaj brunaj paralelaj
      strioj:
      <ekz>
        <tld/>o estas ru&gcirc;a onikso, t.e. kalcedono kun ru&gcirc;aj strioj
        <fnt>
          <aut>-</aut>
          <vrk><url ref="https://eo.wikipedia.org/wiki/Sardonikso">
          Sardonikso</url></vrk>
          <lok>Vikipedio, 2023-11-09</lok>
        </fnt>.
      </ekz>
    </dif>
    <ref tip="vid" cel="agat.0o">agato</ref>
  <trd lng="en">sardonyx</trd>
  </snc>
  <trd lng="be">&c_s;&c_a;&c_r;&c_d;&c_a;&c_n;&c_ib;&c_k;&c_s;</trd>
  <trd lng="de">Sardonyx</trd>
  <trd lng="fr">sardonyx</trd>
  <trdgrp lng="pl">
    <trd>sardonik</trd>,
    <trd>sardonyks</trd>
  </trdgrp>
</drv>
</art>

