<!DOCTYPE vortaro SYSTEM "../dtd/vokoxml.dtd">

<vortaro>
  <art mrk="$Id: ic.xml,v 1.1 2026/03/01 13:09:24 afido Exp $">
    <kap>
      <rad>ic</rad>/o
    </kap>

<drv mrk="ic.0o">
  <kap><tld/>o</kap>
  <snc mrk="ic.0o.KOMP">
    <uzo tip="fak">KOMP</uzo>
    <dif>
      <ref tip="dif" cel="cirkvi.integra_0o">Integra cirkvito</ref>:
      <ekz>
        la procezilo en la <tld/>o-karto kontrolas la &gcirc;ustecon de la entajpita numero
        kaj &scirc;losas la karton kontra&ubreve; plua uzo, se tri sinsekvaj provoj estas mal&gcirc;ustaj
        <fnt>
          <aut>Reinhard F&ouml;ssmeier </aut>
          <vrk><url ref="https://www.ais-sanmarino.org/acta/cxifrado/cxif.html"
              >&Ccirc;ifrado kaj &gcirc;ia rolo en la &leftquot;nova komunikado&rightquot; </url></vrk>
        </fnt>;
      </ekz>
      <ekz>
        <nom>ASML</nom> fari&gcirc;is mondfama pro ekstrem-ultraviola litografio <klr>[por]</klr>
        produkti pli potencajn, pli efikajn <tld/>ojn
        <fnt>
          <vrk><url ref="https://esperantaretradio.blogspot.com/2026/01/asml-kaj-la-nevidebla-bazo-de-moderna.html"
              >ASML kaj la nevidebla bazo de moderna teknologio</url></vrk>
          <lok>Esperanta Retradio, 2026-01-16</lok>
        </fnt>.
      </ekz>
    </dif>
    <ref tip="malprt" cel="blat.0o.ic">blato<sncref/></ref>
    <trd lng="de">IC</trd>
    <trd lng="en">IC</trd>
    <trd lng="fr">CI</trd>
  </snc>
</drv>

  </art>

