<?xml version="1.0"?>
<!DOCTYPE vortaro SYSTEM "../dtd/vokoxml.dtd">
<vortaro>
<art mrk="$Id: ornito1.xml,v 1.26 2026/03/15 03:31:46 revo Exp $">
<kap>
  <rad>ornitorink</rad>/o <fnt><bib>PVEF</bib></fnt>
</kap>
<drv mrk="ornito1.0o">
  <kap><tld/>o</kap>
  <snc mrk="ornito1.0o.ZOO">
    <uzo tip="fak">ZOO</uzo>
    <dif>
      <ref tip="lst" cel="mam.pra0ulo" lst="voko:pramamuloj">Pramamulo</ref>
      kun kastorsimila korpoformo, kun plata vosto kaj lar&gcirc;a
      <ref tip="prt" cel="bek.0o">beko</ref>simila
      bu&scirc;o; metanta ovojn kaj vivanta en orienta
      <ref tip="malprt" cel="auxstr1.A0o">A&ubreve;stralio</ref>
      kaj Tasmanio; sola vivanta
      <ref tip="lst" cel="speci.0o.BIO" lst="voko:zoologiaj_specioj">specio</ref> kaj
      <ref tip="lst" cel="genr.0o.BIO" lst="voko:zoologiaj_genroj">genro</ref>
      de sia familio
      (<trd lng="la">Ornithorhynchus anatinus</trd>):
      <ekz>
        ornitorinko <klr>[&#8230;]</klr> &scirc;ajnas esti stranga miksa&jcirc;o de pluraj aliaj bestoj
        <fnt>
          <bib>Monato</bib>
          <aut>Angela Tellier</aut>
          <vrk><url ref="&Monato;/2004/008306.html">La&ubreve;proverbaj fabeloj</url></vrk>
          <lok>2004</lok>
        </fnt>;
      </ekz>
      <ekz>
        la stranga A&ubreve;stralia <tld/>o demetas
        <ref tip="prt" cel="ov.0o">ovojn</ref>
        kaj poste mamnutras la idojn
        <fnt>
        <aut>R. Harry</aut>,
        <vrk>La Diplomato kiu Ridis</vrk>,
        <lok>1997</lok>
        </fnt>.
      </ekz>
    </dif>
    <bld lok="&WCU;/thumb/f/f2/Platypus.jpg/500px-Platypus.jpg" prm="CC-BY-SA-3.0"><tld/>o
        <fnt>
          <aut>Stefan Kraft, propra foto</aut>
          <lok><url ref="&WCW;/File:Platypus.jpg">&WCW;/File:Platypus.jpg</url></lok>
        </fnt>
    </bld>
  </snc>
  <trd lng="be">&c_k;&c_a;&c_ch;&c_k;&c_a;&c_n;&c_o;&c_s;</trd>
  <trd lng="bg">&c_p;&c_t;&c_i;&c_c;&c_je;&c_ch;&c_o;&c_v;&c_k;&c_a;</trd>
  <trd lng="cs">ptakopysk</trd>
  <trd lng="de">Schnabeltier</trd>
  <trd lng="el">&omikron;&rho;&ny;&jota;&theta;&omikron_ton;&rho;&ypsilon;&gamma;&chi;&omikron;&sigma_fina;</trd>
  <trd lng="en">platypus</trd>
  <trd lng="fr">ornithorynque</trd>
  <trd lng="hu">cs&odblac;r&ouml;s <ind>eml&odblac;s</ind></trd>
  <trd lng="ja">&#x30AB;&#x30E2;&#x30CE;&#x30CF;&#x30B7;</trd>
  <trd lng="nl">vogelbekdier</trd>
  <trd lng="pl">dziobak australijski</trd>
  <trd lng="pt">ornitorrinco</trd>
  <trd lng="ru">&c_u;&c_t;&c_k;&c_o;&c_n;&c_o;&c_s;</trd>
  <trd lng="sk">vt&aacute;kopysk</trd>
  <trd lng="uk">&#x43A;&c_a;&c_ch;&#x43A;&#x43E;&#x43D;&c_ib;&c_s;</trd>
  <trdgrp lng="zh">
    <trd>&#x9D28;&#22068;&#29560; <pr>y&amacron;zu&#x1D0;sh&#xF2;u</pr></trd>,
    <trd>&#x9E2D;&#22068;&#x517D; <pr>y&amacron;zu&#x1D0;sh&#xF2;u</pr></trd>
  </trdgrp>
</drv>
</art>
