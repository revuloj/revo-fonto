<?xml version="1.0"?>
<!DOCTYPE vortaro SYSTEM "../dtd/vokoxml.dtd">
<vortaro>
<art mrk="$Id: rimark.xml,v 1.38 2026/07/07 20:00:21 revo Exp $">
<kap>
   <ofc>*</ofc>
   <rad>rimark</rad>/i <fnt><bib>UV</bib></fnt>
</kap>
<drv mrk="rimark.0i">
   <kap><ofc>*</ofc><tld/>i</kap>
   <snc mrk="rimark.0i.mense">
     <gra><vspec>tr</vspec></gra>
     <dif>
       Distingi kaj aparte atenti ion a&ubreve; iun:
       <ekz>
         li foriris ne<tld/>ite;
       </ekz>
       <ekz>
         &ccirc;iuj <tld/>is lian malgajan mienon;
       </ekz>
      <ekz>
        restu &ccirc;i tie kun miaj junulinoj, <tld/>u la kampon, kie ili rikoltas, kaj sekvu
        ilin
        <fnt>
          <bib>MT</bib>
          <lok>Rut 2:9</lok>
        </fnt>;
      </ekz>
      <ekz>
        ili foriris kaj neniu vidis, neniu <tld/>is, kaj neniu veki&gcirc;is, sed &ccirc;iuj dormis
        <fnt>
          <bib>MT</bib>
          <lok>I. Samuel 26:12</lok>
        </fnt>;
      </ekz>
      <ekz>
        la re&gcirc;o de Asirio <tld/>is &ccirc;e <nom>Ho&scirc;ea</nom> perfidon
        <fnt>
          <bib>MT</bib>
          <lok>II. Re&gcirc;oj 17:4</lok>
        </fnt>;
      </ekz>
      <ekz>
        <klr>[kvankam]</klr> vidante, ili ne <tld/>as <klr>[&#8230;]</klr>
        <fnt>
          <bib>NT</bib>
          <lok>Mateo 13:13</lok>
        </fnt>;
      </ekz>
      <ekz>
        mi <tld/>as, ke vi estas &ccirc;iurilate tro servemaj
        <fnt>
          <bib>NT</bib>
          <lok>La agoj 17:22</lok>
        </fnt>;
      </ekz>
      <ekz>
        Johano balda&ubreve; <tld/>is, ke la fremdulo estas pli sa&gcirc;a ol li
        <fnt>
          <bib>Fab1</bib>
          <lok>Vojkamarado</lok>
        </fnt>;
      </ekz>
      <ekz>
        ili ne devis lasi <tld/>i, ke ili nenion vidas
        <fnt>
          <bib>Fab1</bib>
          <lok>La novaj vestoj de la re&gcirc;o</lok>
        </fnt>;
      </ekz>
      <ekz>
        mi sidis tiel absorbita per la notoj, ke mi ne <tld/>is vian eniron
        <fnt>
          <bib>FK</bib>
        </fnt>;
      </ekz>
      <ekz>
        &ccirc;iujn siajn argumentojn ili penadis konformigadi al tiu anta&ubreve;e farita decido, ne
        <tld/>ante la tutan senfundamentecon de tiuj &ccirc;i argumentoj
        <fnt>
          <bib>EE</bib>
        </fnt>;
      </ekz>
      <ekz>
        <klr>[li]</klr> <tld/>is, ke tiu &ccirc;i sistemo postulas tro grandan pripensadon
        <fnt>
          <bib>FK</bib>
        </fnt>.
      </ekz>
    </dif>
     <refgrp tip="sin">
       <ref cel="atent.0i">atenti</ref>,
       <ref cel="not.0i">noti</ref>,
       <ref cel="observ.0i">observi</ref>,
       <ref cel="percep.0i">percepti</ref>
     </refgrp>
     <trdgrp lng="be">
       <trd>&c_z;&c_a;&c_w;&c_v;&c_a;&c_zh;&c_a;&c_c;&c_mol;</trd>,
       <trd>&c_z;&c_a;&c_z;&c_n;&c_a;&c_ch;&c_a;&c_c;&c_mol;</trd>,
       <trd>&c_p;&c_r;&c_y;&c_k;&c_m;&c_ja;&c_ch;&c_a;&c_c;&c_mol;</trd>
     </trdgrp>
     <trdgrp lng="ca">
       <trd>apercebre('s)</trd>,
       <trd>notar</trd>
     </trdgrp>
    <trd lng="en">notice something</trd>
     <trdgrp lng="es">
       <trd>percibir</trd>,
       <trd>notar</trd>
     </trdgrp>
     <trd lng="hu">&eacute;szrevesz</trd>
     <trdgrp lng="nl">
       <trd>opmerken</trd>,
       <trd>bemerken</trd>,
       <trd>merken</trd>
     </trdgrp>
     <trdgrp lng="pl">
       <trd>dostrzega&cacute;</trd>,
       <trd>zauwa&zdot;a&cacute;</trd>,
       <trd>spostrzega&cacute;</trd>
     </trdgrp>
     <trd lng="de">bemerken</trd>
     <trd lng="en"><ind>notice</ind> <klr>(something)</klr></trd>
     <trdgrp lng="zh">
    <trd>&#23519;&#35258; <pr>ch&aacute;ju&eacute;</pr></trd>,
    <trd>&#23519;&#35273; <pr>ch&aacute;ju&eacute;</pr></trd>,
    <trd>&#27880; <pr>zh&ugrave;</pr></trd>,
    <trd>&#35387; <pr>zh&ugrave;</pr></trd>
  </trdgrp>
</snc>
   <snc mrk="rimark.0i.parole">
     <gra><vspec>ntr</vspec></gra>
     <dif>
       Diri atentigante:
       <ekz>
         nu, vi ja nenion diras, <tld/>is unu el la
         teksistoj
        <fnt>
          <bib>Fab1</bib>
          <lok>La novaj vestoj de la re&gcirc;o</lok>
        </fnt>;
       </ekz>
       <ekz>
         la mastro amike <tld/>is: mi donus cent funtojn,
         <klr>[&#8230;]</klr> se...
        <fnt>
          <bib>FK</bib>
        </fnt>.
       </ekz>
     </dif>
    <refgrp tip="sin">
      <ref cel="koment1.0i">komenti, komentarii</ref>,
      <ref cel="atent.0igi">atentigi</ref>
    </refgrp>
     <trd lng="ca">remarcar</trd>
     <trd lng="de">anmerken</trd>
    <trd lng="en">remark <klr>(state as observation)</klr></trd>
     <trd lng="es">remarcar</trd>
     <trdgrp lng="hu">
       <trd>figyelmeztet</trd>,
       <trd>megjegyez</trd>
     </trdgrp>
     <trd lng="nl">een <ind>opmerking</ind> maken</trd>
     <trdgrp lng="pl">
       <trd>zwraca&cacute; <ind>uwag&eogonek;</ind></trd>,
       <trd>spostrzega&cacute;</trd>
     </trdgrp>
   </snc>
  <trdgrp lng="be">
     <trd>&c_z;&c_a;&c_w;&c_v;&c_a;&c_zh;&c_a;&c_c;&c_mol;</trd>,
     <trd>&c_z;&c_a;&c_z;&c_n;&c_a;&c_ch;&c_a;&c_c;&c_mol;</trd>,
     <trd>&c_a;&c_d;&c_z;&c_n;&c_a;&c_ch;&c_a;&c_c;&c_mol;</trd>
   </trdgrp>
  <trdgrp lng="cs">
    <trd>d&aacute;t najevo</trd>,
    <trd>podotknout</trd>,
    <trd>poznamenat</trd>,
    <trd>p&rcaron;ipomenout</trd>,
    <trd>upozornit</trd>,
    <trd>v&scaron;imnout si</trd>
  </trdgrp>
  <trdgrp lng="es">
       <trd>advertir</trd>,
       <trd>hacer notar</trd>
     </trdgrp>
  <trd lng="fr">remarquer</trd>
  <trd lng="id"><baz>hati</baz>memperhatikan</trd>
  <trdgrp lng="ja">
    <trd>&#27671;&#12389;&#12367;  <pr>&#12365;&#12389;&#12367;</pr></trd>,
    <trd>&#27880;&#30446;&#12377;&#12427;  <pr>&#12385;&#12421;&#12358;&#12418;&#12367;&#12377;&#12427;</pr></trd>,
    <trd>&#35328;&#12358;  <pr>&#12356;&#12358;</pr></trd>,
    <trd>&#25351;&#25688;&#12377;&#12427;  <pr>&#12375;&#12390;&#12365;&#12377;&#12427;</pr></trd>
  </trdgrp>
  <trdgrp lng="ru">
     <trd>&c_z;&c_a;&c_m;&c_je;&c_ch;&c_a;&c_t;&c_mol;</trd>,
     <trd>&c_z;&c_a;&c_m;&c_je;&c_t;&c_i;&c_t;&c_mol;</trd>
   </trdgrp>
  <trdgrp lng="sk">
    <trd>podotkn&uacute;&tcaron;</trd>,
    <trd>poznamena&tcaron;</trd>,
    <trd>spozorova&tcaron;</trd>,
    <trd>zbada&tcaron;</trd>
  </trdgrp>
  <trdgrp lng="uk">
    <trd>&c_z;&c_a;&c_u;&c_v;&c_a;&c_zh;&c_u;&c_v;&c_a;&c_t;&c_i;</trd>,
    <trd>&c_p;&c_o;&c_m;&c_ib;&c_ch;&c_a;&c_t;&c_i;</trd>
  </trdgrp>
</drv>

<drv mrk="rimark.0o">
   <kap><tld/>o</kap>
   <snc mrk="rimark.0o.KOMUNE">
     <dif>
       <tld lit="R"/>ita&jcirc;o, penso a&ubreve; diro pri atentinda afero:
      <ekz>
        &ccirc;iuj &ccirc;i <tld/>oj kun rapideco de l' vento traflugis la animon de l' kronprinco
        <fnt>
          <bib>Far1</bib>
          <lok>&Ccirc;apitro XIV</lok>
        </fnt>;
      </ekz>
      <ekz>
        ne tre turnante atenton sur tiujn &ccirc;i <tld/>ojn
        <fnt>
          <bib>BdV</bib>
        </fnt>;
      </ekz>
      <ekz>
        spiritplena <tld/>o
        <fnt>
          <bib>Fab4</bib>
          <lok>Historio el la dunoj</lok>
        </fnt>;
      </ekz>
      <ekz>
        <nom>Goethe</nom> finis sian Fa&ubreve;ston per la <tld/>o: &leftquot;povas esti
        da&ubreve;rigata&rightquot;
        <fnt>
          <bib>Fab3</bib>
          <lok>Bona humoro</lok>
        </fnt>;
      </ekz>
      <ekz>
        mi ne faros longan paroladon, mi faros nur mallongan <tld/>on
        <fnt>
          <bib>Fab4</bib>
          <lok>Kuristoj</lok>
        </fnt>.
      </ekz>
     </dif>
   </snc>
  <trd lng="be">&c_z;&c_a;&c_w;&c_v;&c_a;&c_g;&c_a;</trd>
  <trdgrp lng="ca">
     <trd>remarca</trd>,
     <trd>observaci&oacute;</trd>
   </trdgrp>
  <trdgrp lng="cs">
    <trd>pozn&aacute;mka</trd>,
    <trd>upozorn&ecaron;n&iacute;</trd>
  </trdgrp>
  <trd lng="de">Bemerkung</trd>
  <trdgrp lng="en">
    <trd>remark</trd>,
    <trd>observation</trd>
  </trdgrp>
  <trd lng="es">observaci&oacute;n</trd>
  <trd lng="fr">remarque</trd>
  <trd lng="hu">megjegyz&eacute;s</trd>
  <trdgrp lng="id">
    <trd>tanda</trd>,
    <trd><baz>tanda</baz>penanda</trd>
  </trdgrp>
  <trdgrp lng="ja">
    <trd>&#27880;&#24847;  <pr>&#12385;&#12421;&#12358;&#12356;</pr></trd>,
    <trd>&#25351;&#25688;  <pr>&#12375;&#12390;&#12365;</pr></trd>
  </trdgrp>
  <trd lng="nl">opmerking</trd>
  <trdgrp lng="pl">
     <trd>uwaga</trd>,
     <trd>spostrze&zdot;enie</trd>
  </trdgrp>
  <trdgrp lng="ru">
     <trd>&c_z;&c_a;&c_m;&c_je;&c_ch;&c_a;&c_n;&c_i;&c_je;</trd>,
     <trd>&c_z;&c_a;&c_m;&c_je;&c_t;&c_k;&c_a;</trd>,
     <trd>&c_p;&c_r;&c_i;&c_m;&c_je;&c_ch;&c_a;&c_n;&c_i;&c_je;</trd>
   </trdgrp>
  <trdgrp lng="sk">
    <trd>pozn&aacute;mka</trd>,
    <trd>upozornenie</trd>
  </trdgrp>
  <trdgrp lng="uk">
    <trd>&c_z;&c_a;&c_m;&c_ib;&c_t;&c_k;&c_a; (&c_z;&c_a;&c_p;&c_i;&c_s;)</trd>,
    <trd>&c_z;&c_a;&c_u;&c_v;&c_a;&c_zh;&c_je;&c_n;&c_n;&c_ja;</trd>,
    <trd>&c_p;&c_r;&c_i;&c_m;&c_ib;&c_t;&c_k;&c_a;</trd>
  </trdgrp>
  <trdgrp lng="zh">
    <trd>&#25163;&#35352; <pr>sh&#466;uj&igrave;</pr></trd>,
    <trd>&#25163;&#35760; <pr>sh&#466;uj&igrave;</pr></trd>,
    <trd>&#35413;&#35387; <pr>p&iacute;ngzh&ugrave;</pr></trd>,
    <trd>&#35780;&#27880; <pr>p&iacute;ngzh&ugrave;</pr></trd>,
    <trd>&#35413;&#35486; <pr>p&iacute;ngy&#468;</pr></trd>,
    <trd>&#35780;&#35821; <pr>p&iacute;ngy&#468;</pr></trd>,
    <trd>&#38468;&#27880; <pr>f&ugrave;zh&ugrave;</pr></trd>
  </trdgrp>
</drv>

<drv mrk="rimark.0igi">
  <kap><tld/>igi</kap>
  <gra><vspec>tr</vspec></gra>
  <snc mrk="rimark.0igi.parole">
    <dif>
      Aparte atentigi pri:
      <ekz>
        mi jam anta&ubreve;e volis <tld/>igi vin pri tio, sed mi &ccirc;iam iel forgesadis
        <fnt>
          <bib>Revizoro</bib>
          <lok>Akto unua</lok>
        </fnt>;
      </ekz>
      <ekz>
        ju&gcirc;isto <tld/>igis, ke la&ubreve; la le&gcirc;o la intendanto <klr>[&#8230;]</klr> devus esti
        procesita pro malvera plendo
        <fnt>
          <bib>Far1</bib>
          <lok>&Ccirc;apitro XII</lok>
        </fnt>.
      </ekz>
    </dif>
    <refgrp tip="vid">
      <ref cel="akcent.0i">akcenti</ref>,
      <ref cel="emfaz.0i">emfazi</ref>
    </refgrp>
  </snc>
  <trdgrp lng="be">
    <trd>&c_z;&c_mol;&c_v;&c_ja;&c_r;&c_n;&c_u;&c_c;&c_mol;
    <ind>&c_u;&c_v;&c_a;&c_g;&c_u;</ind></trd>,
    <trd>&c_p;&c_r;&c_y;&c_c;&c_ja;&c_g;&c_n;&c_u;&c_c;&c_mol;
    <ind>&c_u;&c_v;&c_a;&c_g;&c_u;</ind></trd>
  </trdgrp>
  <trdgrp lng="ca">
    <trd>fer <ind>notar</ind></trd>
    <trd>fer <ind>observar</ind></trd>,
    <trd>destacar</trd>,,
    <trd>cridar l'atenci&oacute;<klr tip="amb"> (sobre alg&uacute;, alguna cosa)</klr></trd>
  </trdgrp>
  <trdgrp lng="cs">
    <trd>d&aacute;t najevo</trd>,
    <trd>podotknout</trd>,
    <trd>poznamenat</trd>,
    <trd>p&rcaron;ipomenout</trd>,
    <trd>upozornit</trd>
  </trdgrp>
  <trdgrp lng="de">
    <trd>bemerken</trd>,
    <trd>anmerken</trd>,
    <trd>dazu sagen</trd>
  </trdgrp>
  <trdgrp lng="en">
    <trd>call <ind>attention</ind> to</trd>,
    <trd><ind>point</ind> out</trd>
  </trdgrp>
  <trdgrp lng="es">
    <trd>hacer notar</trd>,
    <trd>llamar la atenci&oacute;n sobre</trd>
  </trdgrp>
  <trd lng="fr">faire <ind>remarquer</ind></trd>
  <trdgrp lng="hu">
    <trd>figyelmeztet</trd>,
    <trd>megjegyez</trd>,
    <trd>felh&iacute;vja a <ind>figyelmet</ind></trd>
  </trdgrp>
  <trdgrp lng="ja">
    <trd>&#27880;&#24847;&#12434;&#20419;&#12377;  <pr>&#12385;&#12421;&#12358;&#12356;&#12434;&#12358;&#12394;&#12364;&#12377;</pr></trd>,
    <trd>&#27671;&#12389;&#12363;&#12379;&#12427;  <pr>&#12365;&#12389;&#12363;&#12379;&#12427;</pr></trd>
  </trdgrp>
  <trd lng="pl">zwraca&cacute; uwag&eogonek; <klr>(czyj&aogonek;&sacute;)</klr></trd>
  <trd lng="ru">&c_o;&c_b;&c_r;&c_a;&c_t;&c_i;&c_t;&c_mol; &c_ch;&c_mol;&c_jo;-&c_l;.
  &c_v;&c_n;&c_i;&c_m;&c_a;&c_n;&c_i;&c_je; <klr>(&c_n;&c_a; &c_ch;&c_t;&c_o;-&c_l;.)</klr></trd>
  <trdgrp lng="sk">
    <trd>pripomen&uacute;&tcaron;</trd>,
    <trd>upozorni&tcaron;</trd>
  </trdgrp>
  <trd lng="uk">&c_z;&c_v;&c_je;&c_r;&c_n;&c_u;&c_t;&c_i; &c_ch;&c_i;&c_ju;-&c_n;.
  &c_u;&c_v;&c_a;&c_g;&c_u; &c_n;&c_a; &c_shch;&c_o;-&c_n;.</trd>
  <trdgrp lng="zh">
    <trd>&#25552;&#31034; <pr>t&iacute;sh&igrave;</pr></trd>,
    <trd>&#27880; <pr>zh&ugrave;</pr></trd>,
    <trd>&#35387; <pr>zh&ugrave;</pr></trd>,
    <trd>&#25163;&#35352; <pr>sh&#466;uj&igrave;</pr></trd>,
    <trd>&#25163;&#35760; <pr>sh&#466;uj&igrave;</pr></trd>,
    <trd>&#25552;&#37266; <pr>t&iacute;x&#464;ng</pr></trd>
  </trdgrp>
</drv>

<drv mrk="rimark.0inda">
  <kap><tld/>inda</kap>
  <snc mrk="rimark.0inda.KOMUNE">
    <dif>
      Kiun indas <tld/>i, kiu estas
      <ref tip="vid" cel="eminen1.0a">eminenta</ref>,
      aparta, kurioza:
      <ekz>
        en la &gcirc;ardeno oni povis vidi la plej <tld/>indajn florojn
        <fnt>
          <bib>Fab2</bib>
          <lok>La najtingalo</lok>
        </fnt>;
      </ekz>
      <ekz>
        la vojo &scirc;ajnis al ili <tld/>inde longa
        <fnt>
          <bib>Fab2</bib>
          <lok>Sonorilo</lok>
        </fnt>;
      </ekz>
      <ekz>
        &gcirc;i estis tre granda kaj <tld/>inde malbela
        <fnt>
          <bib>Fab2</bib>
          <lok>Malbela anasido</lok>
        </fnt>;
      </ekz>
      <ekz>
        &ccirc;iuj volis vidi la <tld/>indan viron, kiu voja&gcirc;is en la stomako de fi&scirc;o
        <fnt>
          <bib>Fab1</bib>
          <lok>Persista stana soldato</lok>
        </fnt>;
      </ekz>
      <ekz>
        estis <tld/>inde vidi, kiel ili &ccirc;iuj sub siaj vestoj zorge ion ka&scirc;as unu anta&ubreve;
        la alia
        <fnt>
          <bib>Fab3</bib>
          <lok>En la lasta tago</lok>
        </fnt>;
      </ekz>
      <ekz>
        &ccirc;ion &ccirc;i tion kunprenis <klr>[li]</klr> kiel <tld/>inda&jcirc;on
        <fnt>
          <bib>Fab1</bib>
          <lok>Sova&gcirc;aj cignoj</lok>
        </fnt>.
      </ekz>
    </dif>
  </snc>
  <trd lng="be">&c_v;&c_a;&c_r;&c_t;&c_y; <ind>&c_w;&c_v;&c_a;&c_g;&c_ib;</ind></trd>
  <trdgrp lng="ca">
    <trd>remarcable</trd>,
    <trd>notable</trd>,
    <trd>apreciable</trd>,
    <trd>considerable</trd>
  </trdgrp>
  <trd lng="cs">pozoruhodn&yacute;</trd>
  <trd lng="de">bemerkenswert</trd>
  <trdgrp lng="en">
    <trd>remarkable</trd>,
    <trd>noteworthy</trd>
  </trdgrp>
  <trd lng="es">remarcable</trd>
  <trd lng="fr">remarquable</trd>
  <trdgrp lng="ja">
    <trd>&#27880;&#30446;&#12377;&#12409;&#12365;  <pr>&#12385;&#12421;&#12358;&#12418;&#12367;&#12377;&#12409;&#12365;</pr></trd>,
    <trd>&#30446;&#31435;&#12388;  <pr>&#12417;&#12384;&#12388;</pr></trd>
  </trdgrp>
  <trd lng="pl">znamienny</trd>
  <trd lng="sk">pozoruhodn&yacute;</trd>
  <trdgrp lng="uk">
    <trd>&c_p;&c_o;&c_m;&c_ib;&c_t;&c_n;&c_i;&c_j;</trd>,
    <trd>&c_v;&c_ib;&c_d;&c_ch;&c_u;&c_t;&c_n;&c_i;&c_j;</trd>
  </trdgrp>
  <trdgrp lng="zh">
    <trd>&#20986;&#33394; <pr>ch&umacron;s&egrave;</pr></trd>,
    <trd>&#21331;&#33879; <pr>zhu&oacute;zh&ugrave;</pr></trd>,
    <trd>&#20524; <pr>zhu&omacron;</pr></trd>
  </trdgrp>
</drv>
</art>
