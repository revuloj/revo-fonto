<?xml version="1.0"?>
<!DOCTYPE vortaro SYSTEM "../dtd/vokoxml.dtd">
<vortaro>
<art mrk="$Id: patolo.xml,v 1.29 2026/06/26 09:50:25 revo Exp $">
<kap>
  <ofc>2</ofc>
  <rad>patologi</rad>/o
<fnt><bib>JED</bib></fnt></kap>
<drv mrk="patolo.0o">
  <kap><tld/>o</kap>
  <uzo tip="fak">MED</uzo>
  <snc mrk="patolo.0o.fako">
    <dif>
      Bran&ccirc;o de <ref tip="malprt" cel="medici.0o.SCI">medicino</ref>,
      <ref tip="lst" cel="scienc.0o.fako" lst="voko:sciencoj">scienco</ref>
      pri la organaj difekti&gcirc;oj ka&ubreve;zitaj de malsano:
      <ekz>
        <nom>John McCrae</nom> rapide avancis kiel kuracisto, laboris pri a&ubreve;topsioj, pri <tld/>o,
        pri konta&gcirc;aj malsanoj
        <fnt>
          <bib>Monato</bib>
          <aut>Gerrit Berveling</aut>
          <vrk><url ref="&Monato;/2015/011504.php">Tre bonvena verko, sed ...</url></vrk>
        </fnt>.
      </ekz>
    </dif>
  </snc>
  <snc mrk="patolo.0o.procezo">
    <dif>
      Malsaneca procezo:
      <ekz>
        viroj trafataj de gravaj dent-<tld/>oj havas ekzakte 3,29-oblan probablon sperti erekti&gcirc;an
        deficiton ol la ceteraj
        <fnt>
          <bib>Monato</bib>
          <aut>Roberto Pigro</aut>
          <vrk><url ref="&Monato;/2013/011056.php">Armitaj &gcirc;is la dentoj kontra&ubreve;
          impotenteco</url></vrk>
        </fnt>.
      </ekz>
    </dif>
    <ref tip="sin" cel="san.mal0o">malsano</ref>
  </snc>
  <rim>
    La&ubreve; <fnt><bib>BL</bib></fnt>: Anka&ubreve; eblas diri <ke>malsanscienco</ke>.
  </rim>

  <trd lng="be">&c_p;&c_a;&c_t;&c_a;&c_l;&c_jo;&c_g;&c_ib;&c_ja;</trd>
  <trd lng="bg">&c_p;&c_a;&c_t;&c_o;&c_l;&c_o;&c_g;&c_i;&c_ja;</trd>
  <trd lng="cs">patologie</trd>
  <trd lng="de">Pathologie</trd>
  <trd lng="en">pathology</trd>
  <trd lng="fr">pathologie</trd>
  <trdgrp lng="hu">
    <trd>k&oacute;rtan</trd>,
    <trd>patol&oacute;gia</trd>
  </trdgrp>
  <trd lng="id">patologi</trd>
  <trd lng="ja">&#x75C5;&#x7406;&#x5B66;  <pr>&#x3073;&#x3087;&#x3046;&#x308A;&#x304C;&#x304F;</pr></trd>
  <trd lng="nl">pathologie</trd>
  <trd lng="pl">patologia</trd>
  <trd lng="pt">patologia</trd>
  <trd lng="ro">patologie</trd>
  <trd lng="ru">&c_p;&c_a;&c_t;&c_o;&c_l;&c_o;&c_g;&c_i;&c_ja;</trd>
  <trd lng="sk">patol&oacute;gia</trd>
  <trd lng="uk">&c_p;&c_a;&c_t;&c_o;&c_l;&c_o;&c_g;&c_ib;&c_ja;</trd>
  <trdgrp lng="zh">
    <trd>&#x75C5;&#x7406; <pr>b&igrave;ngl&#x1D0;</pr></trd>,
    <trd>&#x75C5;&#x7406;&#x5B66; <pr>b&igrave;ngl&#x1D0;xu&eacute;</pr></trd>,
    <trd>&#x75C5;&#x7406;&#x5B78; <pr>b&igrave;ngl&#x1D0;xu&eacute;</pr></trd>
  </trdgrp>
</drv>

<drv mrk="patolo.0a">
  <kap>
    <tld/>a
  </kap>
  <uzo tip="fak">MED</uzo>
  <snc>
    <dif>
      Malsaneca:
      <ekz>
        <tld/>a labileco
        <fnt>
          <bib>LOdE</bib>
          <lok>2003, &#x2116; 5 (103)</lok>
        </fnt>;
      </ekz>
      <ekz>
        io <tld/>a okazis en lia hormona sistemo
        <fnt>
          <bib>ChV</bib>
          <lok>12</lok>
        </fnt>;
      </ekz>
      <ekz>
        postresta&jcirc;oj ostaj de homoj vivintaj anta&ubreve; 500 miloj da jaroj montras <tld/>ajn
        &scirc;an&gcirc;ojn karakterizajn por la tuberkulozo
        <fnt>
          <bib>Monato</bib>
          <aut>Vladimir Lemelev</aut>
          <vrk><url ref="&Monato;/2011/010389.php"
              >Dan&gcirc;era malamiko revenas</url></vrk>
          <lok>2011</lok>
        </fnt>;
      </ekz>
      <ekz>
        ni ne povas ordoni al la <tld/>aj ekmovoj, kiuj havas malsanan kaj nur refleksan
        karakteron
        <fnt>
          <bib>ChL</bib>
          <lok>&Ccirc;apitro Na&ubreve;a</lok>
        </fnt>.
      </ekz>
    </dif>
    <ref tip="vid" cel="perver.0a.MED">perversia<sncref/></ref>
  <trd lng="de">krankhaft</trd>
  </snc>
  <snc>
    <dif>
      <ref tip="dif" cel="san.mal0iga">Malsaniga</ref>:
      <ekz>
        plimulto da prionaj malsanoj aperas rezulte de infektado per <tld/>aj prionoj
        <fnt>
          <bib>Monato</bib>
          <aut>Vladimir Lemelev</aut>
          <vrk><url ref="&Monato;/2006/008861.php"
              >Nova etapo en biologio kaj medicino</url></vrk>
          <lok>2006</lok>
        </fnt>;
      </ekz>
      <ekz>
        kuracistoj diagnozas pne&ubreve;monion, la <tld/>an proceson komplikas diversaj
        bakterioj
        <fnt>
          <bib>Monato</bib>
          <aut>Vladimir Lemelev</aut>
          <vrk>De kie venis kaj kial &ccirc;esis netipa pne&ubreve;monio?</vrk>
          <lok>2005</lok>
        </fnt>.
      </ekz>
    </dif>
  <trd lng="de">krankmachend</trd>
  </snc>
  <snc mrk="patolo.0a.MED">
    <dif>
      <klr>(pri medicina ekzameno)</klr> <ref tip="super" cel="mort.post0a">Postmorta</ref>:
      <ekz>
        la <tld/>an ekzamenon de la re&gcirc;a korpo partoprenis la persona kuracisto de la
        re&gcirc;o
        <fnt>
          <bib>Monato</bib>
          <aut>Jomo Ipfelkofer</aut>
          <vrk><url ref="&Monato;/2006/009006.php"
              >Monar&hcirc;o-mistero: &ccirc;u murdo a&ubreve; sinmortigo?</url></vrk>
          <lok>2006</lok>
        </fnt>.
      </ekz>
    </dif>
  <trd lng="de">die <ind>Leichenschau</ind> betreffend</trd>
  </snc>
  <trd lng="de">pathologisch</trd>
  <trd lng="en">pathological</trd>
</drv>

</art>
