<!DOCTYPE vortaro SYSTEM "../dtd/vokoxml.dtd">
<vortaro>
<art mrk="$Id: injekt.xml,v 1.33 2026/07/22 17:38:43 revo Exp $">
<kap>
  <ofc>8</ofc>
  <rad>injekt</rad>/i
  <fnt><bib>JED</bib></fnt>
</kap>
<drv mrk="injekt.0i">
  <kap><tld/>i</kap>
  <gra><vspec>tr</vspec></gra>
  <snc mrk="injekt.0i.MED">
    <uzo tip="fak">MED</uzo>
    <dif>
      <ref tip="super" cel="sxpruc.en0igi">En&scirc;prucigi</ref> per speciala ilo likva&jcirc;on sub la
      ha&ubreve;ton, en vejnon, muskolon a&ubreve; kavon de la korpo:
      <ekz>
        tuj, kiam mi <tld/>is la fluida&jcirc;on, la paciento je mia grandega hororo rigidi&gcirc;is
        <fnt>
          <bib>VaK</bib>
          <lok>Sesa &Ccirc;apitro</lok>
        </fnt>;
      </ekz>
      <ekz>
        <nom>Shipman</nom> <tld/>is morfinon al siaj viktimoj kaj poste subskribis atestilon pri
        morto
        <fnt>
          <bib>Monato</bib>
          <aut>Paul Gubbins</aut>
          <vrk>Britio: Doktoro Morto</vrk>
        </fnt>;
      </ekz>
      <ekz>
        <uzo tip="stl">FIG</uzo>
        li <tld/>is al ni la viruson de la optimismo
        <fnt>
          <bib>LOdE</bib>
          <lok>2002, &#x2116; 12</lok>
        </fnt>;
      </ekz>
      <ekz>
        pne&ubreve;mokokoj de tipo 1 estas sendan&gcirc;eraj, oni povas <tld/>i la vivantajn
        mikro-organismojn kaj la <tld/>itaj musoj plu vivas
        <fnt>
          <bib>Monato</bib>
          <aut>Ste&ccirc;jo Norvell</aut>
          <vrk><url ref="&Monato;/2003/007987.html"
              >Profeto sen honoro</url></vrk>
          <lok>2003</lok>
        </fnt>;
      </ekz>
      <ekz>
        mi <tld/>is al li buljonon tra la naztruoj, &ccirc;ar liaj dentoj preme tenis
        bastoneton
        <fnt>
          <bib>LOdE</bib>
          <lok>2000, No 2 (64)</lok>
        </fnt>.
      </ekz>
    </dif>
    <refgrp tip="vid">
      <ref cel="inokul.0i.MED">inokuli<sncref/></ref>,
      <ref cel="transfuz.0i">transfuzi</ref>
    </refgrp>
    <trd lng="pl">robi&cacute; <ind>zastrzyk</ind></trd>
  </snc>
  <snc mrk="injekt.0i.TEK">
    <uzo tip="fak">TEK</uzo>
    <dif>
      En&scirc;prucigi likva&jcirc;on.
    </dif>
    <trd lng="pl">wtryskiwa&cacute;</trd>
  </snc>
  <trdgrp lng="be">
    <trd>&c_ib;&c_n;'&c_je;&c_k;&c_t;&c_a;&c_v;&c_a;&c_c;&c_mol;</trd>,
    <trd>&c_u;&c_p;&c_y;&c_r;&c_s;&c_k;&c_v;&c_a;&c_c;&c_mol;</trd>
  </trdgrp>
  <trd lng="ca">injectar</trd>
  <trd lng="cs">vst&rcaron;ikovat injekci</trd>
  <trdgrp lng="de">
    <trd><klr tip="ind">(jmd. etw.)</klr> spritzen</trd>,
    <trd>injizieren</trd>
  </trdgrp>
  <trd lng="en">inject</trd>
  <trd lng="es">inyectar</trd>
  <trd lng="fr">injecter</trd>
  <trdgrp lng="hu">
    <trd>fecsekendez</trd>,
    <trd>injekt&aacute;l</trd>
  </trdgrp>
  <trdgrp lng="ja">
    <trd>&#x6CE8;&#x5C04;&#x3059;&#x308B;  <pr>&#x3061;&#x3085;&#x3046;&#x3057;&#x3083;&#x3059;&#x308B;</pr></trd>,
    <trd>&#x6CE8;&#x5165;&#x3059;&#x308B;  <pr>&#x3061;&#x3085;&#x3046;&#x306B;&#x3085;&#x3046;&#x3059;&#x308B;</pr></trd>
  </trdgrp>
  <trd lng="nl">inspuiten</trd>
  <trd lng="pt">injetar</trd>
  <trdgrp lng="ru">
    <trd>&c_s;&c_d;&c_je;&c_l;&c_a;&c_t;&c_mol;
    <ind>&c_i;&c_n;&c_malmol;&c_je;&c_k;&c_c;&c_i;&c_ju;</ind></trd>,
    <trd>&c_v;&c_p;&c_r;&c_y;&c_s;&c_n;&c_u;&c_t;&c_mol;</trd>,
    <trd>&c_v;&c_p;&c_r;&c_y;&c_s;&c_k;&c_i;&c_v;&c_a;&c_t;&c_mol;</trd>
  </trdgrp>
  <trd lng="sk">vstrekova&tcaron; injekciou</trd>
  <trdgrp lng="uk">
    <trd>&c_v;&c_p;&c_o;&c_r;&c_s;&c_k;&c_u;&c_v;&c_a;&c_t;&c_i;</trd>,
    <trd>&c_r;&c_o;&c_b;&c_i;&c_t;&c_i; &c_ib;&c_n;&#x2019;&c_jeu;&c_k;&c_c;&c_ib;&c_ju;</trd>,
    <trd>&c_ib;&c_n;&#x2019;&c_jeu;&c_k;&c_t;&c_u;&c_v;&c_a;&c_t;&c_i;</trd>,
    <trd>&c_v;&c_l;&c_i;&c_v;&c_a;&c_t;&c_i;</trd>,
    <trd>&c_r;&c_o;&c_b;&c_i;&c_t;&c_i; &c_u;&c_k;&c_o;&c_l;</trd>
  </trdgrp>
  <trdgrp lng="zh">
    <trd>&#x6CE8;&#x5C04; <pr>zh&ugrave;sh&egrave;</pr></trd>,
    <trd>&#x8F38;&#x6CE8; <pr>sh&umacron;zh&ugrave;</pr></trd>,
    <trd>&#x6253;&#x91DD; <pr>d&#x1CE;zh&emacron;n</pr></trd>,
    <trd>&#x65BD;&#x6253; <pr>sh&imacron;d&#x1CE;</pr></trd>
  </trdgrp>
</drv>

<drv mrk="injekt.0o">
  <kap><tld/>o</kap>
  <snc mrk="injekt.0o.MED">
    <uzo tip="fak">MED</uzo>
    <dif>
      Ago, procedo <ref tip="vid" cel="injekt.0i.MED">injekti</ref>
      a&ubreve; la rezulto de tiu ago:
      <ekz>
        post la <tld/>o &ccirc;io &scirc;an&gcirc;i&gcirc;as
        anta&ubreve; la dormanto
        <fnt><bib>MkM</bib><lok>&ccirc;ap. 27</lok></fnt>;
      </ekz>
      <ekz>
        la lerta kuracisto profitis la momenton kaj enpikis
        la <tld/>onadlon en lian brakon
        <fnt><bib>MkM</bib><lok>&ccirc;ap. 27</lok></fnt>.
      </ekz>
    </dif>
    <trd lng="de">Spritzen</trd>
    <trdgrp lng="pl">
      <trd>zastrzyk</trd>,
      <trd>injekcja</trd>
    </trdgrp>
  </snc>
  <snc mrk="injekt.0o.TEK">
    <uzo tip="fak">TEK</uzo>
    <dif>
      Ago, procedo <ref tip="vid" cel="injekt.0i.TEK">injekti</ref>
      a&ubreve; la rezulto de tiu ago:
      <ekz>
        <uzo tip="fak">TEK</uzo>
        <ind><tld/>opumpilo</ind>
        <fnt><bib>PV</bib></fnt>.
        <trd lng="fr">pompe d'injection</trd>
        <trd lng="hu">befecskendez&odblac;szivatty&uacute;</trd>
        <trd lng="pl">pompa <ind>wtryskowa</ind></trd>
      </ekz>
    </dif>
    <trd lng="de">Einspritzen</trd>
    <trd lng="pl">wtrysk</trd>
  </snc>
  <trdgrp lng="be">
    <trd>&c_ib;&c_n;'&c_je;&c_k;&c_c;&c_y;&c_ja; <klr tip="amb">(&c_d;&c_z;&c_je;&c_ja;&c_n;&c_mol;&c_n;&c_je;)</klr></trd>,
    <trd>&c_u;&c_k;&c_o;&c_l;</trd>
  </trdgrp>
  <trd lng="bo">&t_sa;&t_mata;&t_na;&t_tsheg;&t_kha;&t_ba;&t_tsheg;</trd>
  <trd lng="ca">injecci&oacute;</trd>
  <trdgrp lng="cs">
    <trd>injektov&aacute;n&iacute;</trd>,
    <trd>injekt&aacute;&zcaron;</trd>
  </trdgrp>
  <trdgrp lng="de">
    <trd>Injektion</trd>,
    <trd>Injizieren</trd>
  </trdgrp>
  <trd lng="en">injection</trd>
  <trd lng="es">inyecci&oacute;n</trd>
  <trd lng="fr">injection<klr tip="ind"> (acte)</klr></trd>
  <trdgrp lng="hu">
    <trd>befecsekendez&eacute;s</trd>,
    <trd>injekci&oacute;</trd>
  </trdgrp>
  <trdgrp lng="ja">
    <trd>&#x6CE8;&#x5C04;  <pr>&#x3061;&#x3085;&#x3046;&#x3057;&#x3083;</pr></trd>,
    <trd>&#x6CE8;&#x5165;  <pr>&#x3061;&#x3085;&#x3046;&#x306B;&#x3085;&#x3046;</pr></trd>
  </trdgrp>
  <trd lng="nl">injectie</trd>
  <trd lng="pt">inje&ccedil;&atilde;o<klr tip="amb"> (a&ccedil;&atilde;o
  de injetar)</klr></trd>
  <trdgrp lng="ru">
    <trd>&c_i;&c_n;&c_malmol;&c_je;&c_k;&c_c;&c_i;&c_ja;</trd>,
    <trd>&c_v;&c_p;&c_r;&c_y;&c_s;&c_k;&c_i;&c_v;&c_a;&c_n;&c_i;&c_je;</trd>,
    <trd>&c_v;&c_l;&c_i;&c_v;&c_a;&c_n;&c_i;&c_je;</trd>,
    <trd>&c_u;&c_k;&c_o;&c_l;</trd>
  </trdgrp>
  <trdgrp lng="sk">
    <trd>injektovanie</trd>,
    <trd>injekt&aacute;&zcaron;</trd>
  </trdgrp>
  <trdgrp lng="uk">
    <trd>&c_ib;&c_n;&#x2019;&c_jeu;&c_k;&c_c;&c_ib;&c_ja;</trd>,
    <trd>&c_v;&c_p;&c_o;&c_r;&c_s;&c_k;&c_u;&c_v;&c_a;&c_n;&c_n;&c_ja;</trd>,
    <trd>&c_v;&c_l;&c_i;&c_v;&c_a;&c_n;&c_n;&c_ja;</trd>,
    <trd>&c_u;&c_k;&c_o;&c_l;</trd>,
    <trd>&c_z;&c_a;&c_sh;&c_t;&c_r;&c_i;&c_k;</trd>
  </trdgrp>
  <trd lng="zh">&#x6CE8;&#x5C04; <pr>zh&ugrave;sh&egrave;</pr></trd>
</drv>

<drv mrk="injekt.0ajxo">
  <kap><tld/>a&jcirc;o</kap>
  <snc>
    <dif>
      <tld lit="I"/>ata likva&jcirc;o:
      <ekz>
        post kiam &ccirc;esis enlanda produktado <klr>[&#x2026;]</klr>, Kalifornio kaj kvin aliaj
        &scirc;tatoj ser&ccirc;as anestezan <tld/>a&jcirc;on
        <fnt>
          <bib>Monato</bib>
          <aut>Elson B. Snow</aut>
          <vrk><url ref="&Monato;/2011/010384.php"
              >Barbara minoritato</url></vrk>
          <lok>2011</lok>
        </fnt>.
      </ekz>
    </dif>
  </snc>
  <trdgrp lng="be">
    <trd>&c_ib;&c_n;&#x2019;&c_je;&c_k;&c_c;&c_y;&c_ja; <klr tip="amb">(&c_r;&c_e;&c_ch;&c_y;&c_v;&c_a;)</klr></trd>,
    <trd>&c_v;&c_a;&c_d;&c_k;&c_a;&c_s;&c_mol;&c_c;&c_mol; &c_d;&c_l;&c_ja; &c_ib;&c_n;&#x2019;&c_je;&c_k;&c_c;&c_y;&c_ib;</trd>
  </trdgrp>
  <trd lng="ca">injecci&oacute;</trd>
  <trd lng="de">Injektionsfl&uuml;ssigkeit</trd>
  <trd lng="en">injection</trd>
  <trd lng="fr">injection<klr tip="ind"> (ce que l'on
  injecte)</klr></trd>
  <trdgrp lng="hu">
    <trd>injekci&oacute;<klr tip="ind"> (vakcina)</klr></trd>,
    <trd>befecskendezett folyad&eacute;k</trd>
  </trdgrp>
  <trdgrp lng="ja">
    <trd>&#x6CE8;&#x5C04;&#x6DB2;  <pr>&#x3061;&#x3085;&#x3046;&#x3057;&#x3083;&#x3048;&#x304D;</pr></trd>,
    <trd>&#x6CE8;&#x5165;&#x5264;  <pr>&#x3061;&#x3085;&#x3046;&#x306B;&#x3085;&#x3046;&#x3056;&#x3044;</pr></trd>
  </trdgrp>
  <trd lng="pl">zastrzyk</trd>
  <trd lng="pt">inje&ccedil;&atilde;o<klr tip="amb"> (l&iacute;quido
  injetado)</klr></trd>
  <trd lng="ru">&c_v;&c_p;&c_r;&c_y;&c_s;&c_k;&c_i;&c_v;&c_a;&c_je;&c_m;&c_a;&c_ja;
  &c_zh;&c_i;&c_d;&c_k;&c_o;&c_s;&c_t;&c_mol;</trd>
  <trd lng="uk">&c_r;&c_je;&c_ch;&c_o;&c_v;&c_i;&c_n;&c_a; &c_d;&c_l;&c_ja; &c_ib;&c_n;&#x2019;&c_jeu;&c_k;&c_c;&c_ib;&c_ji;</trd>
  <trd lng="zh">&#x6CE8;&#x5C04;&#x5242; <pr>zh&ugrave;sh&egrave;j&igrave;</pr></trd>
</drv>

<drv mrk="injekt.0ilo">
  <kap><tld/>ilo</kap>
  <snc mrk="injekt.0ilo.MED">
    <uzo tip="fak">MED</uzo>
    <dif>
      Pumpilo kun akra tuba nadlo, servanta por <tld/>i,
      a&ubreve; elsu&ccirc;i likvon (ekz. sangon):
      <ekz>
        li alportis <tld/>ilon, su&ccirc;is sangon el mia brako
        <fnt>
          <bib>VaK</bib>
          <lok>Oka &Ccirc;apitro</lok>
        </fnt>;
      </ekz>
      <ekz>
        sub la lampo ku&scirc;as preta <tld/>ilo en alkoholo
        kaj ampolo kun likva&jcirc;o havanta intensan tean koloron
        <fnt><bib>MkM</bib><lok>&ccirc;ap. 27</lok></fnt>.
      </ekz>
    </dif>
    <trdgrp lng="be">
      <trd>&c_sh;&c_p;&c_r;&c_y;&c_c;</trd>,
      <trd>&c_ib;&c_n;'&c_je;&c_k;&c_t;&c_a;&c_r;</trd>
    </trdgrp>
    <trd lng="en">needle <klr>(for injection)</klr></trd>
    <trd lng="es">jeringa</trd>
    <trd lng="fr">seringue<klr tip="ind"> (m&eacute;d.)</klr></trd>
    <trd lng="hu">injekci&oacute;s t&udblac;</trd>
    <trd lng="nl">injectiespuit</trd>
    <trd lng="pl">strzykawka</trd>
    <trd lng="pt">seringa<klr tip="amb"> (de inje&ccedil;&atilde;o;
    medicina)</klr></trd>
    <trdgrp lng="ru">
      <trd>&c_sh;&c_p;&c_r;&c_i;&c_c;</trd>,
      <trd>&c_i;&c_n;&c_malmol;&c_je;&c_k;&c_t;&c_o;&c_r;</trd>
    </trdgrp>
  </snc>
  <snc mrk="injekt.0ilo.TEK">
    <uzo tip="fak">TEK</uzo>
    <dif>
      Aparato por <tld/>i:
      <ekz>
        peraera, perakva, pervapora <tld/>ilo.
      </ekz>
    </dif>
    <trd lng="be">&c_ib;&c_n;&c_zh;&c_e;&c_k;&c_t;&c_a;&c_r;</trd>
    <trd lng="ru">&c_i;&c_n;&c_zh;&c_je;&c_k;&c_t;&c_o;&c_r;</trd>
    <trd lng="fr">injecteur</trd>
    <trdgrp lng="hu">
      <trd>fecskend&odblac;</trd>,
      <trd>injektor</trd>
    </trdgrp>
    <trd lng="pl">wtryskarka</trd>
    <trd lng="pt">injetor<klr tip="amb"> (tecnologia)</klr></trd>
  </snc>
  <trd lng="ca">xeringa</trd>
  <trd lng="cs">injek&ccaron;n&iacute; st&rcaron;&iacute;ka&ccaron;ka</trd>
  <trd lng="de">Spritze <klr>(Medizin)</klr></trd>
  <trd lng="ja">&#x6CE8;&#x5C04;&#x5668;  <pr>&#x3061;&#x3085;&#x3046;&#x3057;&#x3083;&#x304D;</pr></trd>
  <trd lng="sk">injek&ccaron;n&aacute; strieka&ccaron;ka</trd>
  <trdgrp lng="uk">
    <trd>&c_sh;&c_p;&c_r;&c_i;&c_c;</trd>,
    <trd>&c_ib;&c_n;&#x2019;&c_jeu;&c_k;&c_t;&c_o;&c_r;</trd>,
    <trd>&c_ib;&c_n;&c_zh;&c_je;&c_k;&c_t;&c_o;&c_r;</trd>,
    <trd>&c_zh;&c_i;&c_v;&c_i;&c_l;&c_mol;&c_n;&c_i;&c_j; &c_p;&c_r;&c_i;&c_l;&c_a;&c_d;</trd>
  </trdgrp>
  <trd lng="zh">&#x6CE8;&#x5C04;&#x5668; <pr>zh&ugrave;sh&egrave;q&igrave;</pr></trd>
</drv>

<drv mrk="injekt.envejna_0o">
  <kap>
    envejna <tld/>o
  </kap>
  <snc>
    <uzo tip="fak">MED</uzo>
    <dif>
      Enigo de likva kuracilo tra kanulo en la vejnon:
      <ekz>
        li prenis ampolon el la &scirc;ranko kaj transdonis al mi por envejna <tld/>o
        <fnt>
          <bib>VaK</bib>
          <lok>Sesa &Ccirc;apitro</lok>
        </fnt>;
      </ekz>
      <ekz>
        la droguloj estu prizorgataj de spertuloj (flegistoj, kuracistoj), kiuj zorgos
        pri la <klr>[&#x2026;]</klr> envejnaj injektoj
        <fnt>
          <bib>Kon11</bib>
          <lok>&Ccirc;efartikolo</lok>
        </fnt>.
      </ekz>
    </dif>
  </snc>
  <trdgrp lng="de">
    <trd><ind>intraven&ouml;s</ind>e Injektion</trd>,
    <trd>Infusion</trd>
  </trdgrp>
  <trd lng="en">intravenous therapy</trd>
  <trd lng="fr">perfusion intraveineuse</trd>
  <trd lng="ru">&c_v;&c_n;&c_u;&c_t;&c_r;&c_i;&c_v;&c_je;&c_n;&c_n;&c_o;&c_je; &c_v;&c_l;&c_i;&c_v;&c_a;&c_n;&c_i;&c_je;</trd>
  <trd lng="uk">&c_v;&c_n;&c_u;&c_t;&c_r;&c_ib;&c_sh;&c_n;&c_mol;&c_o;&c_v;&c_je;&c_n;&c_n;&c_a; &c_ib;&c_n;'&c_jeu;&c_k;&c_c;&c_ib;&c_ja;</trd>
</drv>

