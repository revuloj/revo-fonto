<vortaro>
  <art mrk="$Id: fotovolta.xml,v 1.1 2026/06/07 14:18:26 afido Exp $">
    <kap>
      <rad>fotovolta</rad>/a
    </kap>

<drv mrk="fotovolta.0a">
  <kap><tld/>a</kap>
  <snc mrk="fotovolta.0a.ELET">
    <uzo tip="fak">ELET</uzo>
    <dif>
      Rilata al speciala lumelektra efiko, &ccirc;e kiu la fotonoj de la lumo
      produktas elektran &scirc;argon &ccirc;e la limo inter du materialoj (lumdiodoj):
      <ekz>
        <tld/>a modulo
        <fnt>
          <aut>Yao Chunyan</aut>
          <vrk><url ref="http://www.espero.com.cn/se/txt/2011-03/07/content_339178.htm"
              >Tibeto plenforte disvolvas purajn energiojn</url></vrk>
          <lok>El Popola &Ccirc;inio, 2011-03-07 </lok>
        </fnt>;
      </ekz>
      <ekz>
        anka&ubreve; la produktado de elektro per <tld/>aj &ccirc;eloj provokas kritikojn
        <fnt>
          <bib>Monato</bib>
          <aut>Roland Rotsaert</aut>
          <vrk><url ref="&Monato;/2007/009344.php"
              >&Ccirc;u biokarbura&jcirc;oj helpas a&ubreve; malhelpas?</url></vrk>
          <lok>2007</lok>
        </fnt>.
      </ekz>
    </dif>
    <trd lng="de">Photovoltaik-</trd>
    <trd lng="en">photovoltaic</trd>
  </snc>
</drv>

  </art>

